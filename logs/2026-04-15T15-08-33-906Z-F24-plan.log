\n56\t  const [loading, setLoading] = useState(false);\n57\t  const [error, setError] = useState<string | null>(null);\n58\t\n59\t  // Controls\n60\t  const [eventName, setEventName] = useState<string | null>(null);\n61\t  const [measure, setMeasure] = useState(\"count\");\n62\t  const [granularity, setGranularity] = useState<\"day\" | \"week\">(\"day\");\n63\t  const [startDate, setStartDate] = useState(daysAgoISO(30));\n64\t  const [endDate, setEndDate] = useState(todayISO);\n65\t  const [breakdown, setBreakdown] = useState<string | null>(null);\n66\t  const [breakdownLimit, setBreakdownLimit] = useState(10);\n67\t\n68\t  // Fetch schema once on mount\n69\t  useEffect(() => {\n70\t    setLoading(true);\n71\t    fetch(\"/api/schema\")\n72\t      .then((res) => res.json() as Promise<SchemaResponse>)\n73\t      .then((data) => {\n74\t        setSchema(data);\n75\t      })\n76\t      .catch(() => {\n77\t        // Schema stays null; controls still work\n78\t      })\n79\t      .finally(() => {\n80\t        setLoading(false);\n81\t      });\n82\t  }, []);\n83\t\n84\t  // Fetch trends whenever relevant controls change (only when eventName is set)\n85\t  const fetchTrends = useCallback(\n86\t    (\n87\t      name: string,\n88\t      opts: {\n89\t        measure: string;\n90\t        granularity: \"day\" | \"week\";\n91\t        startDate: string;\n92\t        endDate: string;\n93\t        breakdown: string | null;\n94\t        breakdownLimit: number;\n95\t      },\n96\t    ) => {\n97\t      const url = new URL(\"/api/trends\", window.location.origin);\n98\t      url.searchParams.set(\"event_name\", name);\n99\t      url.searchParams.set(\"measure\", opts.measure);\n100\t      url.searchParams.set(\"granularity\", opts.granularity);\n101\t      url.searchParams.set(\"start\", opts.startDate);\n102\t      url.searchParams.set(\"end\", opts.endDate);\n103\t      if (opts.breakdown) {\n104\t        url.searchParams.set(\"breakdown\", opts.breakdown);\n105\t        url.search