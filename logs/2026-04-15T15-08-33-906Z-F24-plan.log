=> ({\n46\t    date: `2026-04-${String(i + 1).padStart(2, \"0\")}`,\n47\t    value: i * 10,\n48\t  }));\n49\t  return [\n50\t    { label: \"US\", data },\n51\t    { label: \"UK\", data },\n52\t  ];\n53\t}\n54\t\n55\tafterEach(() => {\n56\t  cleanup();\n57\t  vi.clearAllMocks();\n58\t});\n59\t\n60\t// ─── Tests ────────────────────────────────────────────────────────────────────\n61\t\n62\tdescribe(\"TrendChart\", () => {\n63\t  describe(\"chart type toggle\", () => {\n64\t    it(\"renders chart type toggle with Line option\", () => {\n65\t      render(<TrendChart series={makeSeries(5)} loading={false} />);\n66\t      expect(screen.getByText(\"Line\")).toBeTruthy();\n67\t    });\n68\t\n69\t    it(\"renders chart type toggle with Bar option\", () => {\n70\t      render(<TrendChart series={makeSeries(5)} loading={false} />);\n71\t      expect(screen.getByText(\"Bar\")).toBeTruthy();\n72\t    });\n73\t\n74\t    it(\"renders chart type toggle with Area option\", () => {\n75\t      render(<TrendChart series={makeSeries(5)} loading={false} />);\n76\t      expect(screen.getByText(\"Area\")).toBeTruthy();\n77\t    });\n78\t\n79\t    it(\"renders chart type toggle with Table option\", () => {\n80\t      render(<TrendChart series={makeSeries(5)} loading={false} />);\n81\t      expect(screen.getByText(\"Table\")).toBeTruthy();\n82\t    });\n83\t  });\n84\t\n85\t  describe(\"empty state\", () => {\n86\t    it(\"renders an empty state message when series is empty\", () => {\n87\t      render(<TrendChart series={[]} loading={false} />);\n88\t      // Should show something indicating no data\n89\t      const noDataEl =\n90\t        screen.queryByText(/no data/i) ??\n91\t        screen.queryByTestId(\"trend-chart-empty\");\n92\t      expect(noDataEl).not.toBeNull();\n93\t    });\n94\t\n95\t    it(\"does not render a recharts chart when series is empty\", () => {\n96\t      render(<TrendChart series={[]} loading={false} />);\n97\t      expect(screen.queryByTestId(\"recharts-line-chart\")).toBeNull();\n98\t      expect(screen.queryByTestId(\"recharts-bar-chart\")).toBeNull();\n99\t    });\n100\t  });\n101\t\n102\t  describe(\"loading state\", () => {\n103\t    it(\"shows a loading skeleton when loading is true\", () => {\n104\t      render(<TrendChart series={[]} loading={true} />);\n105\t      // Loading skeleton should be present (MUI Skeleton or data-testid)\n106\t      const skeleton =\n107\t        screen.queryByTestId(\"trend-chart-skeleton\") ??\n108\t        screen.queryByRole(\"progressbar\") ??\n109\t        document.querySelector(\".MuiSkeleton-root\");\n110\t      expect(skeleton).not.toBeNull();\n111\t    });\n112\t\n113\t    it(\"does not render empty state when loading is true\", () => {\n114\t      render(<TrendChart series={[]} loading={true} />);\n115\t      expect(screen.queryByTestId(\"trend-chart-empty\")).toBeNull();\n116\t    });\n117\t  });\n118\t\n119\t  describe(\"auto-switch to Bar\", () => {\n120\t    it(\"defaults to Bar chart type when series has exactly 1 data point\", () => {\n121\t      render(<TrendChart series={makeSeries(1)} loading={false} />);\n122\t      // Bar chart component should be rendered (not line)\n123\t      expect(screen.queryByTestId(\"recharts-bar-chart\")).not.toBeNull();\n124\t      expect(screen.queryByTestId(\"recharts-line-chart\")).toBeNull();\n125\t    });\n126\t\n127\t    it(\"defaults to Line chart type when series has multiple data points\", () => {\n128\t      render(<TrendChart series={makeSeries(5)} loading={false} />);\n129\t      expect(screen.queryByTestId(\"recharts-line-chart\")).not.toBeNull();\n130\t      expect(screen.queryByTestId(\"recharts-bar-chart\")).toBeNull();\n131\t    });\n132\t  });\n133\t\n134\t  describe(\"table mode\", () => {\n135\t    it(\"renders a table when Table chart type is selected\", () => {\n136\t      render(<TrendChart series={makeSeries(3)} loading={false} />);\n137\t      fireEvent.click(screen.getByText(\"Table\"));\n138\t      expect(screen.getByRole(\"table\")).toBeTruthy();\n139\t    });\n140\t\n141\t    it(\"table includes date column data\", () => {\n142\t      render(<TrendChart series={makeSeries(3)} loading={false} />);\n143\t      fireEvent.click(screen.getByText(\"Table\"));\n144\t      // Dates should appear in the table\n145\t      expect(screen.getByText(\"2026-04-01\")).toBeTruthy();\n146\t    });\n147\t\n148\t    it(\"does not render recharts chart when Table mode is active\", () => {\n149\t      render(<TrendChart series={makeSeries(3)} loading={false} />);\n150\t      fireEvent.click(screen.getByText(\"Table\"));\n151\t      expect(screen.queryByTestId(\"recharts-line-chart\")).toBeNull();\n152\t      expect(screen.queryByTestId(\"recharts-bar-chart\")).toBeNull();\n153\t    });\n154\t  });\n155\t\n156\t  describe(\"chart container\", () => {\n157\t    it(\"renders a container with data-testid='trend-chart'\", () => {\n158\t      render(<TrendChart series={makeSeries(3)} loading={false} />);\n159\t      expect(screen.getByTestId(\"trend-chart\")).toBeTruthy();\n160\t    });\n161\t  });\n162\t});\n163\t"}]},"parent_tool_use_id":null,"session_id":"aa824c2e-5629-4921-b9e8-8c0b9af66380","uuid":"16b2152c-04d4-4e1f-a75a-0188d9fd0295","timestamp":"2026-04-15T17:01:40.897Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/__tests__/TrendChart.test.tsx","content":"// @vitest-environment jsdom\nimport { cleanup, fireEvent, render, screen } from \"@testing-library/react\";\nimport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\nimport { TrendChart } from \"@/components/TrendChart\";\nimport type { Series } from \"@/lib/trends\";\n\n// ─── Mock recharts ─────────────────────────────────────────────────────────────\n// Recharts needs ResizeObserver and real DOM dimensions to render.\n// jsdom has zero-size containers, so we stub the chart components.\n\nvi.mock(\"recharts\", () => ({\n  ResponsiveContainer: ({ children }: { children: React.ReactNode }) => (\n    <div>{children}</div>\n  ),\n  LineChart: ({ children }: { children: React.ReactNode }) => (\n    <div data-testid=\"recharts-line-chart\">{children}</div>\n  ),\n  BarChart: ({ children }: { children: React.ReactNode }) => (\n    <div data-testid=\"recharts-bar-chart\">{children}</div>\n  ),\n  AreaChart: ({ children }: { children: React.ReactNode }) => (\n    <div data-testid=\"recharts-area-chart\">{children}</div>\n  ),\n  Line: () => null,\n  Bar: () => null,\n  Area: () => null,\n  XAxis: () => null,\n  YAxis: () => null,\n  CartesianGrid: () => null,\n  Tooltip: () => null,\n  Legend: () => null,\n}));\n\n// ─── Fixtures ─────────────────────────────────────────────────────────────────\n\nfunction makeSeries(numPoints: number): Series[] {\n  const data = Array.from({ length: numPoints }, (_, i) => ({\n    date: `2026-04-${String(i + 1).padStart(2, \"0\")}`,\n    value: i * 10,\n  }));\n  return [{ label: \"Page Viewed\", data }];\n}\n\nfunction makeMultiSeries(numPoints: number): Series[] {\n  const data = Array.from({ length: numPoints }, (_, i) => ({\n    date: `2026-04-${String(i + 1).padStart(2, \"0\")}`,\n    value: i * 10,\n  }));\n  return [\n    { label: \"US\", data },\n    { label: \"UK\", data },\n  ];\n}\n\nafterEach(() => {\n  cleanup();\n  vi.clearAllMocks();\n});\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\ndescribe(\"TrendChart\", () => {\n  describe(\"chart type toggle\", () => {\n    it(\"renders chart type toggle with Line option\", () => {\n      render(<TrendChart series={makeSeries(5)} loading={false} />);\n      expect(screen.getByText(\"Line\")).toBeTruthy();\n    });\n\n    it(\"renders chart type toggle with Bar option\", () => {\n      render(<TrendChart series={makeSeries(5)} loading={false} />);\n      expect(screen.getByText(\"Bar\")).toBeTruthy();\n    });\n\n    it(\"renders chart type toggle with Area option\", () => {\n      render(<TrendChart series={makeSeries(5)} loading={false} />);\n      expect(screen.getByText(\"Area\")).toBeTruthy();\n    });\n\n    it(\"renders chart type toggle with Table option\", () => {\n      render(<TrendChart series={makeSeries(5)} loading={false} />);\n      expect(screen.getByText(\"Table\")).toBeTruthy();\n    });\n  });\n\n  describe(\"empty state\", () => {\n    it(\"renders an empty state message when series is empty\", () => {\n      render(<TrendChart series={[]} loading={false} />);\n      // Should show something indicating no data\n      const noDataEl =\n        screen.queryByText(/no data/i) ??\n        screen.queryByTestId(\"trend-chart-empty\");\n      expect(noDataEl).not.toBeNull();\n    });\n\n    it(\"does not render a recharts chart when series is empty\", () => {\n      render(<TrendChart series={[]} loading={false} />);\n      expect(screen.queryByTestId(\"recharts-line-chart\")).toBeNull();\n      expect(screen.queryByTestId(\"recharts-bar-chart\")).toBeNull();\n    });\n  });\n\n  describe(\"loading state\", () => {\n    it(\"shows a loading skeleton when loading is true\", () => {\n      render(<TrendChart series={[]} loading={true} />);\n      // Loading skeleton should be present (MUI Skeleton or data-testid)\n      const skeleton =\n        screen.queryByTestId(\"trend-chart-skeleton\") ??\n        screen.queryByRole(\"progressbar\") ??\n        document.querySelector(\".MuiSkeleton-root\");\n      expect(skeleton).not.toBeNull();\n    });\n\n    it(\"does not render empty state when loading is true\", () => {\n      render(<TrendChart series={[]} loading={true} />);\n      expect(screen.queryByTestId(\"trend-chart-empty\")).toBeNull();\n    });\n  });\n\n  describe(\"auto-switch to Bar\", () => {\n    it(\"defaults to Bar chart type when series has exactly 1 data point\", () => {\n      render(<TrendChart series={makeSeries(1)} loading={false} />);\n      // Bar chart component should be rendered (not line)\n      expect(screen.queryByTestId(\"recharts-bar-chart\")).not.toBeNull();\n      expect(screen.queryByTestId(\"recharts-line-chart\")).toBeNull();\n    });\n\n    it(\"defaults to Line chart type when series has multiple data points\", () => {\n      render(<TrendChart series={makeSeries(5)} loading={false} />);\n      expect(screen.queryByTestId(\"recharts-line-chart\")).not.toBeNull();\n      expect(screen.queryByTestId(\"recharts-bar-chart\")).toBeNull();\n    });\n  });\n\n  describe(\"table mode\", () => {\n    it(\"renders a table when Table chart type is selected\", () => {\n      render(<TrendChart series={makeSeries(3)} loading={false} />);\n      fireEvent.click(screen.getByText(\"Table\"));\n      expect(screen.getByRole(\"table\")).toBeTruthy();\n    });\n\n    it(\"table includes date column data\", () => {\n      render(<TrendChart series={makeSeries(3)} loading={false} />);\n      fireEvent.click(screen.getByText(\"Table\"));\n      // Dates should appear in the table\n      expect(screen.getByText(\"2026-04-01\")).toBeTruthy();\n    });\n\n    it(\"does not render recharts chart when Table mode is active\", () => {\n      render(<TrendChart series={makeSeries(3)} loading={false} />);\n      fireEvent.click(screen.getByText(\"Table\"));\n      expect(screen.queryByTestId(\"recharts-line-chart\")).toBeNull();\n      expect(screen.queryByTestId(\"recharts-bar-chart\")).toBeNull();\n    });\n  });\n\n  describe(\"chart container\", () => {\n    it(\"renders a container with data-testid='trend-chart'\", () => {\n      render(<TrendChart series={makeSeries(3)} loading={false} />);\n      expect(screen.getByTestId(\"trend-chart\")).toBeTruthy();\n    });\n  });\n});\n","numLines":163,"startLine":1,"totalLines":163}}}
