{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J6bAtXck1dTnqGyiKbrVU3","type":"tool_result","content":"1\timport { queryNewEvents } from \"@/lib/live\";\n2\t\n3\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n4\t\n5\t/**\n6\t * Converts a JS Date to the ClickHouse-compatible datetime string format:\n7\t * \"YYYY-MM-DD HH:MM:SS.mmm\" (no T, no Z).\n8\t */\n9\tfunction toClickHouseDateTime(d: Date): string {\n10\t  return d.toISOString().replace(\"T\", \" \").replace(\"Z\", \"\");\n11\t}\n12\t\n13\t// ─── GET /api/live ────────────────────────────────────────────────────────────\n14\t\n15\texport async function GET(): Promise<Response> {\n16\t  // Watermark: only events ingested after this point will be streamed.\n17\t  // Initialized to the current server time so the feed shows only new events.\n18\t  let lastSeenIngestedAt = toClickHouseDateTime(new Date());\n19\t\n20\t  let intervalId: ReturnType<typeof setInterval> | undefined;\n21\t\n22\t  const encoder = new TextEncoder();\n23\t\n24\t  const stream = new ReadableStream({\n25\t    start(controller) {\n26\t      intervalId = setInterval(async () => {\n27\t        try {\n28\t          const events = await queryNewEvents(lastSeenIngestedAt);\n29\t\n30\t          for (const event of events) {\n31\t            controller.enqueue(\n32\t              encoder.encode(`data: ${JSON.stringify(event)}\\n\\n`),\n33\t            );\n34\t          }\n35\t\n36\t          // Advance watermark to the latest ingested_at in this batch\n37\t          if (events.length > 0) {\n38\t            lastSeenIngestedAt = events[events.length - 1].ingested_at;\n39\t          }\n40\t        } catch {\n41\t          // Swallow errors — keep the stream alive on transient ClickHouse issues\n42\t        }\n43\t      }, 1000);\n44\t    },\n45\t    cancel() {\n46\t      clearInterval(intervalId);\n47\t    },\n48\t  });\n49\t\n50\t  return new Response(stream, {\n51\t    headers: {\n52\t 