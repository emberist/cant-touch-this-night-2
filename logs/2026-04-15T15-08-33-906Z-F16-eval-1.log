{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AfvxULW11hEyq36vEnJFBC","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockSeedData } = vi.hoisted(() => ({\n6\t  mockSeedData: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/seed\", () => ({\n10\t  seedData: mockSeedData,\n11\t}));\n12\t\n13\timport { POST } from \"@/app/api/seed/route\";\n14\t\n15\t// ─── Tests ────────────────────────────────────────────────────────────────────\n16\t\n17\tbeforeEach(() => {\n18\t  mockSeedData.mockResolvedValue({ events: 12000, users: 60 });\n19\t});\n20\t\n21\tafterEach(() => {\n22\t  vi.clearAllMocks();\n23\t});\n24\t\n25\tdescribe(\"POST /api/seed\", () => {\n26\t  describe(\"success — 201\", () => {\n27\t    it(\"returns 201 with ok:true, events, and users when seedData resolves\", async () => {\n28\t      const res = await POST();\n29\t\n30\t      expect(res.status).toBe(201);\n31\t      const body = await res.json();\n32\t      expect(body).toMatchObject({ ok: true, events: 12000, users: 60 });\n33\t    });\n34\t\n35\t    it(\"propagates event and user counts from seedData result\", async () => {\n36\t      mockSeedData.mockResolvedValue({ events: 11800, users: 60 });\n37\t\n38\t      const res = await POST();\n39\t\n40\t      expect(res.status).toBe(201);\n41\t      const body = await res.json();\n42\t      expect(body.events).toBe(11800);\n43\t      expect(body.users).toBe(60);\n44\t    });\n45\t  });\n46\t\n47\t  describe(\"failure — 500\", () => {\n48\t    it(\"returns 500 with error message when seedData rejects with Error\", async () => {\n49\t      mockSeedData.mockRejectedValue(new Error(\"ClickHouse unavailable\"));\n50\t\n51\t      const res = await POST();\n52\t\n53\t      expect(res.status).toBe(500);\n54\t      const body = await res.json();\n55\t      expect(body).toHaveProperty(\"error\");\n56\t      expect(body.error).toBe(\"ClickHouse unavailable\");\n57\t    });\n58\t\n59\t    it(\"returns 500 with generic message when seedData rejects with non-Error\", async () => {\n60\t      mockSeedData.mockRejectedValue(\"something broke\");\n61\t\n62\t      const res = await POST();\n63\t\n64\t      expect(res.status).toBe(500);\n65\t      const body = await res.json();\n66\t      expect(body).toHaveProperty(\"error\");\n67\t      expect(body.error).toBe(\"Internal server error.\");\n68\t    });\n69\t  });\n70\t});\n71\t"}]},"parent_tool_use_id":null,"session_id":"0f944bc9-b5f5-46a3-ab0f-d68158a73110","uuid":"db504baf-1126-4e0a-83a0-8a8a27e07d60","timestamp":"2026-04-15T15:12:03.141Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/seed/__tests__/route.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockSeedData } = vi.hoisted(() => ({\n  mockSeedData: vi.fn(),\n}));\n\nvi.mock(\"@/lib/seed\", () => ({\n  seedData: mockSeedData,\n}));\n\nimport { POST } from \"@/app/api/seed/route\";\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockSeedData.mockResolvedValue({ events: 12000, users: 60 });\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\ndescribe(\"POST /api/seed\", () => {\n  describe(\"success — 201\", () => {\n    it(\"returns 201 with ok:true, events, and users when seedData resolves\", async () => {\n      const res = await POST();\n\n      expect(res.status).toBe(201);\n      const body = await res.json();\n      expect(body).toMatchObject({ ok: true, events: 12000, users: 60 });\n    });\n\n    it(\"propagates event and user counts from seedData result\", async () => {\n      mockSeedData.mockResolvedValue({ events: 11800, users: 60 });\n\n      const res = await POST();\n\n      expect(res.status).toBe(201);\n      const body = await res.json();\n      expect(body.events).toBe(11800);\n      expect(body.users).toBe(60);\n    });\n  });\n\n  describe(\"failure — 500\", () => {\n    it(\"returns 500 with error message when seedData rejects with Error\", async () => {\n      mockSeedData.mockRejectedValue(new Error(\"ClickHouse unavailable\"));\n\n      const res = await POST();\n\n      expect(res.status).toBe(500);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n      expect(body.error).toBe(\"ClickHouse unavailable\");\n    });\n\n    it(\"returns 500 with generic message when seedData rejects with non-Error\", async () => {\n      mockSeedData.mockRejectedValue(\"something broke\");\n\n      const res = await POST();\n\n      expect(res.status).toBe(500);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n      expect(body.error).toBe(\"Internal server error.\");\n    });\n  });\n});\n","numLines":71,"startLine":1,"totalLines":71}}}
