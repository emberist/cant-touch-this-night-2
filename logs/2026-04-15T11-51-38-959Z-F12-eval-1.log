{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012WRqYLsVq1zYpvy5v6T1Cv","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQueryFunnel } = vi.hoisted(() => ({\n6\t  mockQueryFunnel: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/funnels\", () => ({\n10\t  queryFunnel: mockQueryFunnel,\n11\t}));\n12\t\n13\timport { POST } from \"@/app/api/funnels/route\";\n14\t\n15\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n16\t\n17\tfunction makeRequest(body: unknown): Request {\n18\t  return new Request(\"http://localhost/api/funnels\", {\n19\t    method: \"POST\",\n20\t    body: JSON.stringify(body),\n21\t    headers: { \"Content-Type\": \"application/json\" },\n22\t  });\n23\t}\n24\t\n25\tfunction makeMalformedRequest(): Request {\n26\t  return new Request(\"http://localhost/api/funnels\", {\n27\t    method: \"POST\",\n28\t    body: \"{ this is not valid json !!!\",\n29\t    headers: { \"Content-Type\": \"application/json\" },\n30\t  });\n31\t}\n32\t\n33\tconst sampleResponse = {\n34\t  steps: [\n35\t    {\n36\t      name: \"Page Viewed\",\n37\t      users: 1000,\n38\t      conversion_from_prev: null,\n39\t      conversion_overall: 1.0,\n40\t    },\n41\t    {\n42\t      name: \"Signup Completed\",\n43\t      users: 320,\n44\t      conversion_from_prev: 0.32,\n45\t      conversion_overall: 0.32,\n46\t    },\n47\t  ],\n48\t};\n49\t\n50\tconst validBody = {\n51\t  steps: [\"Page Viewed\", \"Signup Completed\"],\n52\t  start: \"2026-04-01\",\n53\t  end: \"2026-04-15\",\n54\t};\n55\t\n56\t// ─── Tests ────────────────────────────────────────────────────────────────────\n57\t\n58\tbeforeEach(() => {\n59\t  mockQueryFunnel.mockResolvedValue(sampleResponse);\n60\t});\n61\t\n62\tafterEach(() => {\n63\t  vi.clearAllMocks();\n64\t});\n65\t\n66\tdescribe(\"PO