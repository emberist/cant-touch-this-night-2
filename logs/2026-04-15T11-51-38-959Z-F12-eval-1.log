{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qi97Z1XJNB2yBpc5Q5gVbg","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\t\n3\t// ─── Types ────────────────────────────────────────────────────────────────────\n4\t\n5\texport interface FunnelParams {\n6\t  steps: string[];\n7\t  /** ISO date string (YYYY-MM-DD) — inclusive lower bound */\n8\t  start: string;\n9\t  /** ISO date string (YYYY-MM-DD) — inclusive upper bound */\n10\t  end: string;\n11\t}\n12\t\n13\texport interface FunnelStepResult {\n14\t  name: string;\n15\t  users: number;\n16\t  conversion_from_prev: number | null;\n17\t  conversion_overall: number;\n18\t}\n19\t\n20\texport interface FunnelResponse {\n21\t  steps: FunnelStepResult[];\n22\t}\n23\t\n24\texport interface FunnelQuerySpec {\n25\t  query: string;\n26\t  query_params: Record<string, string>;\n27\t}\n28\t\n29\t// ─── Type alias for the ClickHouse client ─────────────────────────────────────\n30\t\n31\ttype ClickHouseClientLike = typeof clickhouse;\n32\t\n33\t// ─── Internal helpers ─────────────────────────────────────────────────────────\n34\t\n35\t/** Returns the exclusive upper bound timestamp for the given ISO date.\n36\t *  Returns ClickHouse-compatible format: \"YYYY-MM-DD HH:MM:SS.mmm\" (no T/Z).\n37\t */\n38\tfunction computeEndExclusive(end: string): string {\n39\t  const [y, m, d] = end.split(\"-\").map(Number);\n40\t  const dt = new Date(Date.UTC(y, m - 1, d + 1));\n41\t  const year = dt.getUTCFullYear();\n42\t  const month = String(dt.getUTCMonth() + 1).padStart(2, \"0\");\n43\t  const day = String(dt.getUTCDate()).padStart(2, \"0\");\n44\t  return `${year}-${month}-${day} 00:00:00.000`;\n45\t}\n46\t\n47\t// ─── buildFunnelQuery ─────────────────────────────────────────────────────────\n48\t\n49\t/**\n50\t * Constructs the ClickHouse SQL query and bound parameters for a funnel request.\n51\t * Uses windowFunnel() aggregate to find the max funnel level reached per user,\n52\t * then groups by level to count users at each depth.\n53\t *\n54\t * Exported for unit testing of SQL correctness.\n55\t */\n56\texport function buildFunnelQuery(params: FunnelParams): FunnelQuerySpec {\n57\t  const { steps, start, end } = params;\n58\t\n59\t  const query_params: Record<string, string> = {\n60\t    start: `${start} 00:00:00.000`,\n61\t    end_exclusive: computeEndExclusive(end),\n62\t  };\n63\t\n64\t  for (let i = 0; i < steps.length; i++) {\n65\t    query_params[`step_${i}`] = steps[i];\n66\t  }\n67\t\n68\t  // Build the step conditions: e.event_name = {step_0:String}, etc.\n69\t  const stepConditions = steps\n70\t    .map((_, i) => `e.event_name = {step_${i}:String}`)\n71\t    .join(\",\\n      \");\n72\t\n73\t  const query = `\n74\t    SELECT level, count() AS cnt\n75\t    FROM (\n76\t      SELECT\n77\t        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id,\n78\t        windowFunnel(2147483647)(\n79\t          toUnixTimestamp(e.timestamp),\n80\t          ${stepConditions}\n81\t        ) AS level\n82\t      FROM events e\n83\t      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n84\t        ON e.device_id = m.device_id\n85\t      WHERE e.timestamp >= {start:String}\n86\t        AND e.timestamp < {end_exclusive:String}\n87\t      GROUP BY resolved_id\n88\t    )\n89\t    GROUP BY level\n90\t    ORDER BY level ASC\n91\t  `.trim();\n92\t\n93\t  return { query, query_params };\n94\t}\n95\t\n96\t// ─── queryFunnel ──────────────────────────────────────────────────────────────\n97\t\n98\tinterface FunnelLevelRow {\n99\t  level: number | string;\n100\t  cnt: number | string;\n101\t}\n102\t\n103\t/**\n104\t * Executes the funnel query and transforms raw level counts into per-step\n105\t * user counts with conversion_from_prev and conversion_overall rates.\n106\t *\n107\t * windowFunnel returns the max level each user reached (0 = no step completed,\n108\t * 1 = step 1 completed, etc.). Users at step N = sum of cnt for levels >= N.\n109\t */\n110\texport async function queryFunnel(\n111\t  params: FunnelParams,\n112\t  client: ClickHouseClientLike = clickhouse,\n113\t): Promise<FunnelResponse> {\n114\t  const { steps } = params;\n115\t  const { query, query_params } = buildFunnelQuery(params);\n116\t\n117\t  const result = await client.query({\n118\t    query,\n119\t    query_params,\n120\t    format: \"JSONEachRow\",\n121\t  });\n122\t\n123\t  const rows = await result.json<FunnelLevelRow>();\n124\t\n125\t  if (rows.length === 0) {\n126\t    return { steps: [] };\n127\t  }\n128\t\n129\t  // Build a map of level → user count (coerce strings to numbers)\n130\t  const levelCounts = new Map<number, number>();\n131\t  for (const row of rows) {\n132\t    const level = Number(row.level);\n133\t    const cnt = Number(row.cnt);\n134\t    levelCounts.set(level, (levelCounts.get(level) ?? 0) + cnt);\n135\t  }\n136\t\n137\t  // Compute cumulative user counts: users at step i = sum of cnt for levels >= (i+1)\n138\t  // A user who reached level L is counted in steps 1..L (indices 0..L-1)\n139\t  const userCounts = new Array<number>(steps.length).fill(0);\n140\t  for (const [level, cnt] of levelCounts) {\n141\t    for (let i = 0; i < Math.min(level, steps.length); i++) {\n142\t      userCounts[i] += cnt;\n143\t    }\n144\t  }\n145\t\n146\t  const step1Users = userCounts[0];\n147\t\n148\t  const result_steps: FunnelStepResult[] = steps.map((name, i) => {\n149\t    const users = userCounts[i];\n150\t    const prevUsers = i === 0 ? null : userCounts[i - 1];\n151\t\n152\t    const conversion_from_prev: number | null =\n153\t      i === 0 ? null : prevUsers === 0 ? 0 : users / (prevUsers as number);\n154\t\n155\t    const conversion_overall: number =\n156\t      i === 0 ? 1.0 : step1Users === 0 ? 0 : users / step1Users;\n157\t\n158\t    return { name, users, conversion_from_prev, conversion_overall };\n159\t  });\n160\t\n161\t  return { steps: result_steps };\n162\t}\n163\t"}]},"parent_tool_use_id":null,"session_id":"39cbed89-9497-4111-903f-16ff18e0c764","uuid":"3de94d17-c60e-43ac-8309-aa9afb50b54b","timestamp":"2026-04-15T13:53:17.553Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/funnels.ts","content":"import { clickhouse } from \"@/lib/clickhouse\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface FunnelParams {\n  steps: string[];\n  /** ISO date string (YYYY-MM-DD) — inclusive lower bound */\n  start: string;\n  /** ISO date string (YYYY-MM-DD) — inclusive upper bound */\n  end: string;\n}\n\nexport interface FunnelStepResult {\n  name: string;\n  users: number;\n  conversion_from_prev: number | null;\n  conversion_overall: number;\n}\n\nexport interface FunnelResponse {\n  steps: FunnelStepResult[];\n}\n\nexport interface FunnelQuerySpec {\n  query: string;\n  query_params: Record<string, string>;\n}\n\n// ─── Type alias for the ClickHouse client ─────────────────────────────────────\n\ntype ClickHouseClientLike = typeof clickhouse;\n\n// ─── Internal helpers ─────────────────────────────────────────────────────────\n\n/** Returns the exclusive upper bound timestamp for the given ISO date.\n *  Returns ClickHouse-compatible format: \"YYYY-MM-DD HH:MM:SS.mmm\" (no T/Z).\n */\nfunction computeEndExclusive(end: string): string {\n  const [y, m, d] = end.split(\"-\").map(Number);\n  const dt = new Date(Date.UTC(y, m - 1, d + 1));\n  const year = dt.getUTCFullYear();\n  const month = String(dt.getUTCMonth() + 1).padStart(2, \"0\");\n  const day = String(dt.getUTCDate()).padStart(2, \"0\");\n  return `${year}-${month}-${day} 00:00:00.000`;\n}\n\n// ─── buildFunnelQuery ─────────────────────────────────────────────────────────\n\n/**\n * Constructs the ClickHouse SQL query and bound parameters for a funnel request.\n * Uses windowFunnel() aggregate to find the max funnel level reached per user,\n * then groups by level to count users at each depth.\n *\n * Exported for unit testing of SQL correctness.\n */\nexport function buildFunnelQuery(params: FunnelParams): FunnelQuerySpec {\n  const { steps, start, end } = params;\n\n  const query_params: Record<string, string> = {\n    start: `${start} 00:00:00.000`,\n    end_exclusive: computeEndExclusive(end),\n  };\n\n  for (let i = 0; i < steps.length; i++) {\n    query_params[`step_${i}`] = steps[i];\n  }\n\n  // Build the step conditions: e.event_name = {step_0:String}, etc.\n  const stepConditions = steps\n    .map((_, i) => `e.event_name = {step_${i}:String}`)\n    .join(\",\\n      \");\n\n  const query = `\n    SELECT level, count() AS cnt\n    FROM (\n      SELECT\n        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id,\n        windowFunnel(2147483647)(\n          toUnixTimestamp(e.timestamp),\n          ${stepConditions}\n        ) AS level\n      FROM events e\n      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n        ON e.device_id = m.device_id\n      WHERE e.timestamp >= {start:String}\n        AND e.timestamp < {end_exclusive:String}\n      GROUP BY resolved_id\n    )\n    GROUP BY level\n    ORDER BY level ASC\n  `.trim();\n\n  return { query, query_params };\n}\n\n// ─── queryFunnel ──────────────────────────────────────────────────────────────\n\ninterface FunnelLevelRow {\n  level: number | string;\n  cnt: number | string;\n}\n\n/**\n * Executes the funnel query and transforms raw level counts into per-step\n * user counts with conversion_from_prev and conversion_overall rates.\n *\n * windowFunnel returns the max level each user reached (0 = no step completed,\n * 1 = step 1 completed, etc.). Users at step N = sum of cnt for levels >= N.\n */\nexport async function queryFunnel(\n  params: FunnelParams,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<FunnelResponse> {\n  const { steps } = params;\n  const { query, query_params } = buildFunnelQuery(params);\n\n  const result = await client.query({\n    query,\n    query_params,\n    format: \"JSONEachRow\",\n  });\n\n  const rows = await result.json<FunnelLevelRow>();\n\n  if (rows.length === 0) {\n    return { steps: [] };\n  }\n\n  // Build a map of level → user count (coerce strings to numbers)\n  const levelCounts = new Map<number, number>();\n  for (const row of rows) {\n    const level = Number(row.level);\n    const cnt = Number(row.cnt);\n    levelCounts.set(level, (levelCounts.get(level) ?? 0) + cnt);\n  }\n\n  // Compute cumulative user counts: users at step i = sum of cnt for levels >= (i+1)\n  // A user who reached level L is counted in steps 1..L (indices 0..L-1)\n  const userCounts = new Array<number>(steps.length).fill(0);\n  for (const [level, cnt] of levelCounts) {\n    for (let i = 0; i < Math.min(level, steps.length); i++) {\n      userCounts[i] += cnt;\n    }\n  }\n\n  const step1Users = userCounts[0];\n\n  const result_steps: FunnelStepResult[] = steps.map((name, i) => {\n    const users = userCounts[i];\n    const prevUsers = i === 0 ? null : userCounts[i - 1];\n\n    const conversion_from_prev: number | null =\n      i === 0 ? null : prevUsers === 0 ? 0 : users / (prevUsers as number);\n\n    const conversion_overall: number =\n      i === 0 ? 1.0 : step1Users === 0 ? 0 : users / step1Users;\n\n    return { name, users, conversion_from_prev, conversion_overall };\n  });\n\n  return { steps: result_steps };\n}\n","numLines":163,"startLine":1,"totalLines":163}}}
