{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DCbL2AN63AW9gn4r8BcLrM","type":"tool_result","content":"1\timport { queryFunnel } from \"@/lib/funnels\";\n2\t\n3\t// ─── Route handler ────────────────────────────────────────────────────────────\n4\t\n5\t/**\n6\t * POST /api/funnels\n7\t *\n8\t * Body:\n9\t *   steps  (required) — array of 2–5 event name strings\n10\t *   start  (required) — ISO date YYYY-MM-DD, inclusive lower bound\n11\t *   end    (required) — ISO date YYYY-MM-DD, inclusive upper bound\n12\t */\n13\texport async function POST(request: Request): Promise<Response> {\n14\t  let body: unknown;\n15\t\n16\t  try {\n17\t    body = await request.json();\n18\t  } catch {\n19\t    return Response.json({ error: \"Invalid JSON body.\" }, { status: 400 });\n20\t  }\n21\t\n22\t  if (typeof body !== \"object\" || body === null) {\n23\t    return Response.json(\n24\t      { error: \"Request body must be a JSON object.\" },\n25\t      { status: 400 },\n26\t    );\n27\t  }\n28\t\n29\t  const raw = body as Record<string, unknown>;\n30\t\n31\t  // ── Validate steps ────────────────────────────────────────────────────────\n32\t\n33\t  if (!Array.isArray(raw.steps)) {\n34\t    return Response.json(\n35\t      { error: \"steps is required and must be an array.\" },\n36\t      { status: 400 },\n37\t    );\n38\t  }\n39\t\n40\t  if (raw.steps.length < 2) {\n41\t    return Response.json(\n42\t      { error: \"steps must contain at least 2 entries.\" },\n43\t      { status: 400 },\n44\t    );\n45\t  }\n46\t\n47\t  if (raw.steps.length > 5) {\n48\t    return Response.json(\n49\t      { error: \"steps must contain at most 5 entries.\" },\n50\t      { status: 400 },\n51\t    );\n52\t  }\n53\t\n54\t  for (const step of raw.steps) {\n55\t    if (typeof step !== \"string\" || step.trim() === \"\") {\n56\t      return Response.json(\n57\t        { error: \"Each step must be a non-empty string.\" },\n58\t        { status: 400 },\n59\t      );\n60\t    }\n61\t  }\n62\t\n63\t  const steps = raw.steps as string[];\n64\t\n65\t  // ── Validate start / end ──────────────────────────────────────────────────\n66\t\n67\t  if (typeof raw.start !== \"string\" || raw.start.trim() === \"\") {\n68\t    return Response.json({ error: \"start is required.\" }, { status: 400 });\n69\t  }\n70\t\n71\t  if (typeof raw.end !== \"string\" || raw.end.trim() === \"\") {\n72\t    return Response.json({ error: \"end is required.\" }, { status: 400 });\n73\t  }\n74\t\n75\t  // ── Execute query ─────────────────────────────────────────────────────────\n76\t\n77\t  try {\n78\t    const response = await queryFunnel({\n79\t      steps,\n80\t      start: raw.start,\n81\t      end: raw.end,\n82\t    });\n83\t    return Response.json(response);\n84\t  } catch (err) {\n85\t    const message =\n86\t      err instanceof Error ? err.message : \"Internal server error.\";\n87\t    return Response.json({ error: message }, { status: 500 });\n88\t  }\n89\t}\n90\t"}]},"parent_tool_use_id":null,"session_id":"39cbed89-9497-4111-903f-16ff18e0c764","uuid":"0b8b83e2-2cdc-4204-a3d0-f6da4858691b","timestamp":"2026-04-15T13:53:17.984Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/funnels/route.ts","content":"import { queryFunnel } from \"@/lib/funnels\";\n\n// ─── Route handler ────────────────────────────────────────────────────────────\n\n/**\n * POST /api/funnels\n *\n * Body:\n *   steps  (required) — array of 2–5 event name strings\n *   start  (required) — ISO date YYYY-MM-DD, inclusive lower bound\n *   end    (required) — ISO date YYYY-MM-DD, inclusive upper bound\n */\nexport async function POST(request: Request): Promise<Response> {\n  let body: unknown;\n\n  try {\n    body = await request.json();\n  } catch {\n    return Response.json({ error: \"Invalid JSON body.\" }, { status: 400 });\n  }\n\n  if (typeof body !== \"object\" || body === null) {\n    return Response.json(\n      { error: \"Request body must be a JSON object.\" },\n      { status: 400 },\n    );\n  }\n\n  const raw = body as Record<string, unknown>;\n\n  // ── Validate steps ────────────────────────────────────────────────────────\n\n  if (!Array.isArray(raw.steps)) {\n    return Response.json(\n      { error: \"steps is required and must be an array.\" },\n      { status: 400 },\n    );\n  }\n\n  if (raw.steps.length < 2) {\n    return Response.json(\n      { error: \"steps must contain at least 2 entries.\" },\n      { status: 400 },\n    );\n  }\n\n  if (raw.steps.length > 5) {\n    return Response.json(\n      { error: \"steps must contain at most 5 entries.\" },\n      { status: 400 },\n    );\n  }\n\n  for (const step of raw.steps) {\n    if (typeof step !== \"string\" || step.trim() === \"\") {\n      return Response.json(\n        { error: \"Each step must be a non-empty string.\" },\n        { status: 400 },\n      );\n    }\n  }\n\n  const steps = raw.steps as string[];\n\n  // ── Validate start / end ──────────────────────────────────────────────────\n\n  if (typeof raw.start !== \"string\" || raw.start.trim() === \"\") {\n    return Response.json({ error: \"start is required.\" }, { status: 400 });\n  }\n\n  if (typeof raw.end !== \"string\" || raw.end.trim() === \"\") {\n    return Response.json({ error: \"end is required.\" }, { status: 400 });\n  }\n\n  // ── Execute query ─────────────────────────────────────────────────────────\n\n  try {\n    const response = await queryFunnel({\n      steps,\n      start: raw.start,\n      end: raw.end,\n    });\n    return Response.json(response);\n  } catch (err) {\n    const message =\n      err instanceof Error ? err.message : \"Internal server error.\";\n    return Response.json({ error: message }, { status: 500 });\n  }\n}\n","numLines":90,"startLine":1,"totalLines":90}}}
