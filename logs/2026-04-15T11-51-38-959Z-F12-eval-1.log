{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BNvkctnDGgtzaQS7kaDCKL","type":"tool_result","content":"1\t/**\n2\t * Integration tests for GET /api/trends\n3\t *\n4\t * These tests require:\n5\t *   - A running dev server at http://localhost:3000\n6\t *   - A running ClickHouse instance at http://localhost:8123\n7\t *\n8\t * Run with:\n9\t *   pnpm dev &    # starts ClickHouse + Next.js via concurrently\n10\t *   pnpm test\n11\t */\n12\t\n13\timport { afterAll, beforeAll, describe, expect, it } from \"vitest\";\n14\t\n15\tconst BASE_URL = \"http://localhost:3000\";\n16\tconst ENDPOINT = `${BASE_URL}/api/trends`;\n17\t\n18\t/** Returns true if the dev server is reachable. */\n19\tasync function isServerAvailable(): Promise<boolean> {\n20\t  try {\n21\t    const res = await fetch(BASE_URL, {\n22\t      method: \"HEAD\",\n23\t      signal: AbortSignal.timeout(2000),\n24\t    });\n25\t    return res.status < 600;\n26\t  } catch {\n27\t    return false;\n28\t  }\n29\t}\n30\t\n31\tlet serverAvailable = false;\n32\t\n33\tbeforeAll(async () => {\n34\t  serverAvailable = await isServerAvailable();\n35\t  if (!serverAvailable) {\n36\t    console.warn(\n37\t      \"[integration] Dev server not available at http://localhost:3000 — skipping integration tests.\",\n38\t    );\n39\t  }\n40\t});\n41\t\n42\tafterAll(() => {\n43\t  // Nothing to tear down; we didn't start the server ourselves.\n44\t});\n45\t\n46\tdescribe(\"GET /api/trends — integration\", () => {\n47\t  it(\"valid request returns 200 with series array\", async () => {\n48\t    if (!serverAvailable) {\n49\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n50\t      return;\n51\t    }\n52\t\n53\t    const url = new URL(ENDPOINT);\n54\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n55\t    url.searchParams.set(\"start\", \"2026-01-01\");\n56\t    url.searchParams.set(\"end\", \"2026-04-15\");\n57\t\n58\t    const res = await fetch(url.toString());\n59\t    expect(res.status).toBe(200);\n60\t\n61\t    const body = await res.json();\n62\t    expect(body).toHaveProperty(\"series\");\n63\t    expect(Array.isArray(body.series)).toBe(true);\n64\t  });\n65\t\n66\t  it(\"series items have label string and data array of {date, value}\", async () => {\n67\t    if (!serverAvailable) {\n68\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n69\t      return;\n70\t    }\n71\t\n72\t    const url = new URL(ENDPOINT);\n73\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n74\t    url.searchParams.set(\"start\", \"2026-01-01\");\n75\t    url.searchParams.set(\"end\", \"2026-04-15\");\n76\t\n77\t    const res = await fetch(url.toString());\n78\t    const body = await res.json();\n79\t\n80\t    for (const series of body.series) {\n81\t      expect(typeof series.label).toBe(\"string\");\n82\t      expect(Array.isArray(series.data)).toBe(true);\n83\t      for (const point of series.data) {\n84\t        expect(typeof point.date).toBe(\"string\");\n85\t        expect(typeof point.value).toBe(\"number\");\n86\t      }\n87\t    }\n88\t  });\n89\t\n90\t  it(\"missing event_name returns 400 with error\", async () => {\n91\t    if (!serverAvailable) {\n92\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n93\t      return;\n94\t    }\n95\t\n96\t    const url = new URL(ENDPOINT);\n97\t    url.searchParams.set(\"start\", \"2026-01-01\");\n98\t    url.searchParams.set(\"end\", \"2026-04-15\");\n99\t\n100\t    const res = await fetch(url.toString());\n101\t    expect(res.status).toBe(400);\n102\t\n103\t    const body = await res.json();\n104\t    expect(body).toHaveProperty(\"error\");\n105\t    expect(typeof body.error).toBe(\"string\");\n106\t  });\n107\t\n108\t  it(\"missing start returns 400 with error\", async () => {\n109\t    if (!serverAvailable) {\n110\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n111\t      return;\n112\t    }\n113\t\n114\t    const url = new URL(ENDPOINT);\n115\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n116\t    url.searchParams.set(\"end\", \"2026-04-15\");\n117\t\n118\t    const res = await fetch(url.toString());\n119\t    expect(res.status).toBe(400);\n120\t\n121\t    const body = await res.json();\n122\t    expect(body).toHaveProperty(\"error\");\n123\t  });\n124\t\n125\t  it(\"missing end returns 400 with error\", async () => {\n126\t    if (!serverAvailable) {\n127\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n128\t      return;\n129\t    }\n130\t\n131\t    const url = new URL(ENDPOINT);\n132\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n133\t    url.searchParams.set(\"start\", \"2026-01-01\");\n134\t\n135\t    const res = await fetch(url.toString());\n136\t    expect(res.status).toBe(400);\n137\t\n138\t    const body = await res.json();\n139\t    expect(body).toHaveProperty(\"error\");\n140\t  });\n141\t\n142\t  it(\"invalid measure returns 400 with error\", async () => {\n143\t    if (!serverAvailable) {\n144\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n145\t      return;\n146\t    }\n147\t\n148\t    const url = new URL(ENDPOINT);\n149\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n150\t    url.searchParams.set(\"start\", \"2026-01-01\");\n151\t    url.searchParams.set(\"end\", \"2026-04-15\");\n152\t    url.searchParams.set(\"measure\", \"bogus\");\n153\t\n154\t    const res = await fetch(url.toString());\n155\t    expect(res.status).toBe(400);\n156\t\n157\t    const body = await res.json();\n158\t    expect(body).toHaveProperty(\"error\");\n159\t  });\n160\t\n161\t  it(\"invalid granularity returns 400 with error\", async () => {\n162\t    if (!serverAvailable) {\n163\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n164\t      return;\n165\t    }\n166\t\n167\t    const url = new URL(ENDPOINT);\n168\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n169\t    url.searchParams.set(\"start\", \"2026-01-01\");\n170\t    url.searchParams.set(\"end\", \"2026-04-15\");\n171\t    url.searchParams.set(\"granularity\", \"month\");\n172\t\n173\t    const res = await fetch(url.toString());\n174\t    expect(res.status).toBe(400);\n175\t\n176\t    const body = await res.json();\n177\t    expect(body).toHaveProperty(\"error\");\n178\t  });\n179\t\n180\t  // Integration gap from F11: breakdown + seeded data produces multiple series\n181\t  it(\"breakdown returns 200 with multiple series, each with label and data\", async () => {\n182\t    if (!serverAvailable) {\n183\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n184\t      return;\n185\t    }\n186\t\n187\t    // Seed data first so there are events with page properties\n188\t    const seedRes = await fetch(`${BASE_URL}/api/seed`, {\n189\t      method: \"POST\",\n190\t      signal: AbortSignal.timeout(40000),\n191\t    });\n192\t    expect(seedRes.status).toBe(200);\n193\t\n194\t    const url = new URL(ENDPOINT);\n195\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n196\t    url.searchParams.set(\"start\", \"2026-03-15\");\n197\t    url.searchParams.set(\"end\", \"2026-04-15\");\n198\t    url.searchParams.set(\"breakdown\", \"page\");\n199\t    url.searchParams.set(\"breakdown_limit\", \"3\");\n200\t\n201\t    const res = await fetch(url.toString());\n202\t    expect(res.status).toBe(200);\n203\t\n204\t    const body = await res.json();\n205\t    expect(body).toHaveProperty(\"series\");\n206\t    expect(Array.isArray(body.series)).toBe(true);\n207\t    // With seeded data and breakdown, we expect multiple series\n208\t    expect(body.series.length).toBeGreaterThan(1);\n209\t\n210\t    // Each series must have label (string) and data (array of {date, value})\n211\t    for (const series of body.series) {\n212\t      expect(typeof series.label).toBe(\"string\");\n213\t      expect(Array.isArray(series.data)).toBe(true);\n214\t      for (const point of series.data) {\n215\t        expect(typeof point.date).toBe(\"string\");\n216\t        expect(typeof point.value).toBe(\"number\");\n217\t      }\n218\t    }\n219\t\n220\t    // breakdown_limit=3 means at most 4 series (top 3 + optional \"Other\")\n221\t    expect(body.series.length).toBeLessThanOrEqual(4);\n222\t\n223\t    // Series must be sorted by total value descending (\"Other\" last if present)\n224\t    const nonOther = body.series.filter(\n225\t      (s: { label: string }) => s.label !== \"Other\",\n226\t    );\n227\t    const totals = nonOther.map((s: { data: { value: number }[] }) =>\n228\t      s.data.reduce((sum: number, p: { value: number }) => sum + p.value, 0),\n229\t    );\n230\t    for (let i = 0; i + 1 < totals.length; i++) {\n231\t      expect(totals[i]).toBeGreaterThanOrEqual(totals[i + 1]);\n232\t    }\n233\t  });\n234\t});\n235\t"}]},"parent_tool_use_id":null,"session_id":"39cbed89-9497-4111-903f-16ff18e0c764","uuid":"fc1ee66a-ada3-4add-bafa-d0271fddbc56","timestamp":"2026-04-15T13:53:54.010Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/trends/__tests__/route.integration.test.ts","content":"/**\n * Integration tests for GET /api/trends\n *\n * These tests require:\n *   - A running dev server at http://localhost:3000\n *   - A running ClickHouse instance at http://localhost:8123\n *\n * Run with:\n *   pnpm dev &    # starts ClickHouse + Next.js via concurrently\n *   pnpm test\n */\n\nimport { afterAll, beforeAll, describe, expect, it } from \"vitest\";\n\nconst BASE_URL = \"http://localhost:3000\";\nconst ENDPOINT = `${BASE_URL}/api/trends`;\n\n/** Returns true if the dev server is reachable. */\nasync function isServerAvailable(): Promise<boolean> {\n  try {\n    const res = await fetch(BASE_URL, {\n      method: \"HEAD\",\n      signal: AbortSignal.timeout(2000),\n    });\n    return res.status < 600;\n  } catch {\n    return false;\n  }\n}\n\nlet serverAvailable = false;\n\nbeforeAll(async () => {\n  serverAvailable = await isServerAvailable();\n  if (!serverAvailable) {\n    console.warn(\n      \"[integration] Dev server not available at http://localhost:3000 — skipping integration tests.\",\n    );\n  }\n});\n\nafterAll(() => {\n  // Nothing to tear down; we didn't start the server ourselves.\n});\n\ndescribe(\"GET /api/trends — integration\", () => {\n  it(\"valid request returns 200 with series array\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-01-01\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(200);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"series\");\n    expect(Array.isArray(body.series)).toBe(true);\n  });\n\n  it(\"series items have label string and data array of {date, value}\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-01-01\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n\n    const res = await fetch(url.toString());\n    const body = await res.json();\n\n    for (const series of body.series) {\n      expect(typeof series.label).toBe(\"string\");\n      expect(Array.isArray(series.data)).toBe(true);\n      for (const point of series.data) {\n        expect(typeof point.date).toBe(\"string\");\n        expect(typeof point.value).toBe(\"number\");\n      }\n    }\n  });\n\n  it(\"missing event_name returns 400 with error\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"start\", \"2026-01-01\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n    expect(typeof body.error).toBe(\"string\");\n  });\n\n  it(\"missing start returns 400 with error\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n  });\n\n  it(\"missing end returns 400 with error\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-01-01\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n  });\n\n  it(\"invalid measure returns 400 with error\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-01-01\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n    url.searchParams.set(\"measure\", \"bogus\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n  });\n\n  it(\"invalid granularity returns 400 with error\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-01-01\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n    url.searchParams.set(\"granularity\", \"month\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n  });\n\n  // Integration gap from F11: breakdown + seeded data produces multiple series\n  it(\"breakdown returns 200 with multiple series, each with label and data\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    // Seed data first so there are events with page properties\n    const seedRes = await fetch(`${BASE_URL}/api/seed`, {\n      method: \"POST\",\n      signal: AbortSignal.timeout(40000),\n    });\n    expect(seedRes.status).toBe(200);\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-03-15\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n    url.searchParams.set(\"breakdown\", \"page\");\n    url.searchParams.set(\"breakdown_limit\", \"3\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(200);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"series\");\n    expect(Array.isArray(body.series)).toBe(true);\n    // With seeded data and breakdown, we expect multiple series\n    expect(body.series.length).toBeGreaterThan(1);\n\n    // Each series must have label (string) and data (array of {date, value})\n    for (const series of body.series) {\n      expect(typeof series.label).toBe(\"string\");\n      expect(Array.isArray(series.data)).toBe(true);\n      for (const point of series.data) {\n        expect(typeof point.date).toBe(\"string\");\n        expect(typeof point.value).toBe(\"number\");\n      }\n    }\n\n    // breakdown_limit=3 means at most 4 series (top 3 + optional \"Other\")\n    expect(body.series.length).toBeLessThanOrEqual(4);\n\n    // Series must be sorted by total value descending (\"Other\" last if present)\n    const nonOther = body.series.filter(\n      (s: { label: string }) => s.label !== \"Other\",\n    );\n    const totals = nonOther.map((s: { data: { value: number }[] }) =>\n      s.data.reduce((sum: number, p: { value: number }) => sum + p.value, 0),\n    );\n    for (let i = 0; i + 1 < totals.length; i++) {\n      expect(totals[i]).toBeGreaterThanOrEqual(totals[i + 1]);\n    }\n  });\n});\n","numLines":235,"startLine":1,"totalLines":235}}}
