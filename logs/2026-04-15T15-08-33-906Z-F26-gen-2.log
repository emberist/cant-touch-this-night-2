{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012UZVVDiCNpLiAEfTUJnGM8","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport Box from \"@mui/material/Box\";\n4\timport Chip from \"@mui/material/Chip\";\n5\timport Divider from \"@mui/material/Divider\";\n6\timport Skeleton from \"@mui/material/Skeleton\";\n7\timport Stack from \"@mui/material/Stack\";\n8\timport Typography from \"@mui/material/Typography\";\n9\timport { useParams } from \"next/navigation\";\n10\timport { UserTimeline } from \"@/components/UserTimeline\";\n11\timport { useUserProfile } from \"@/components/users/useUserProfile\";\n12\t\n13\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n14\t\n15\tfunction formatDate(iso: string): string {\n16\t  return new Date(iso).toLocaleString(undefined, {\n17\t    dateStyle: \"medium\",\n18\t    timeStyle: \"short\",\n19\t  });\n20\t}\n21\t\n22\t// ─── Page ─────────────────────────────────────────────────────────────────────\n23\t\n24\texport default function UserProfilePage(): React.JSX.Element {\n25\t  const params = useParams<{ id: string }>();\n26\t  const resolved_id = decodeURIComponent(params.id);\n27\t  const { profile, loading, error } = useUserProfile(resolved_id);\n28\t\n29\t  if (loading) {\n30\t    return (\n31\t      <Box data-testid=\"user-profile\">\n32\t        <Skeleton variant=\"text\" width={300} height={40} sx={{ mb: 2 }} />\n33\t        <Skeleton variant=\"rectangular\" height={80} sx={{ mb: 2 }} />\n34\t        <Skeleton variant=\"rectangular\" height={200} />\n35\t      </Box>\n36\t    );\n37\t  }\n38\t\n39\t  if (error) {\n40\t    return (\n41\t      <Box data-testid=\"user-profile\">\n42\t        <Typography color=\"error\">{error}</Typography>\n43\t      </Box>\n44\t    );\n45\t  }\n46\t\n47\t  if (!profile) {\n48\t    return (\n49\t      <Box data-testid=\"user-profile\">\n50\t        <Typography color=\"text.secondary\">User not found.</Typography>\n51\t      </Box>\n52\t    );\n53\t  }\n54\t\n55\t  return (\n56\t    <Box data-testid=\"user-profile\">\n57\t      <Typography variant=\"h4\" component=\"h1\" gutterBottom>\n58\t        {profile.resolved_id}\n59\t      </Typography>\n60\t\n61\t      <Stack direction=\"row\" spacing={4} sx={{ mb: 3 }}>\n62\t        <Box>\n63\t          <Typography variant=\"caption\" color=\"text.secondary\">\n64\t            First seen\n65\t          </Typography>\n66\t          <Typography variant=\"body2\">\n67\t            {formatDate(profile.first_seen)}\n68\t          </Typography>\n69\t        </Box>\n70\t        <Box>\n71\t          <Typography variant=\"caption\" color=\"text.secondary\">\n72\t            Last seen\n73\t          </Typography>\n74\t          <Typography variant=\"body2\">\n75\t            {formatDate(profile.last_seen)}\n76\t          </Typography>\n77\t        </Box>\n78\t      </Stack>\n79\t\n80\t      <Box data-testid=\"identity-cluster\" sx={{ mb: 3 }}>\n81\t        <Typography variant=\"subtitle1\" gutterBottom>\n82\t          Identity Cluster\n83\t        </Typography>\n84\t\n85\t        {profile.identity_cluster.user_ids.length > 0 && (\n86\t          <Box sx={{ mb: 1 }}>\n87\t            <Typography variant=\"caption\" color=\"text.secondary\" sx={{ mr: 1 }}>\n88\t              User IDs\n89\t            </Typography>\n90\t            <Stack\n91\t              direction=\"row\"\n92\t              sx={{ flexWrap: \"wrap\", gap: 0.5 }}\n93\t              component=\"span\"\n94\t            >\n95\t              {profile.identity_cluster.user_ids.map((uid) => (\n96\t                <Chip\n97\t                  key={uid}\n98\t                  label={uid}\n99\t                  size=\"small\"\n100\t                  color=\"primary\"\n101\t                  variant=\"outlined\"\n102\t                />\n103\t              ))}\n104\t            </Stack>\n105\t          </Box>\n106\t        )}\n107\t\n108\t        {profile.identity_cluster.device_ids.length > 0 && (\