{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A9WraP9ehGwJStfEsjQkvD","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport { useCallback, useEffect, useState } from \"react\";\n4\timport type { FunnelResponse } from \"@/lib/funnels\";\n5\timport type { SchemaResponse } from \"@/lib/schema-cache\";\n6\t\n7\t// ─── Types ────────────────────────────────────────────────────────────────────\n8\t\n9\texport interface UseFunnelsResult {\n10\t  schema: SchemaResponse | null;\n11\t  steps: string[];\n12\t  startDate: string;\n13\t  endDate: string;\n14\t  addStep: () => void;\n15\t  removeStep: (index: number) => void;\n16\t  setStep: (index: number, value: string) => void;\n17\t  setStartDate: (v: string) => void;\n18\t  setEndDate: (v: string) => void;\n19\t  runFunnel: () => void;\n20\t  result: FunnelResponse | null;\n21\t  loading: boolean;\n22\t  error: string | null;\n23\t}\n24\t\n25\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n26\t\n27\tfunction todayISO(): string {\n28\t  return new Date().toISOString().slice(0, 10);\n29\t}\n30\t\n31\tfunction daysAgoISO(days: number): string {\n32\t  const d = new Date();\n33\t  d.setDate(d.getDate() - days);\n34\t  return d.toISOString().slice(0, 10);\n35\t}\n36\t\n37\t// ─── Hook ─────────────────────────────────────────────────────────────────────\n38\t\n39\texport function useFunnels(): UseFunnelsResult {\n40\t  const [schema, setSchema] = useState<SchemaResponse | null>(null);\n41\t  const [steps, setSteps] = useState<string[]>([\"\", \"\"]);\n42\t  const [startDate, setStartDate] = useState(daysAgoISO(30));\n43\t  const [endDate, setEndDate] = useState(todayISO);\n44\t  const [result, setResult] = useState<FunnelResponse | null>(null);\n45\t  const [loading, setLoading] = useState(false);\n46\t  const [error, setError] = useState<string | null>(null);\n47\t\n48\t  // Fetch schema once on mount (for event name autocomplete)\n49\t  useEffect(() => {\n50\t    setLoading(true);\n51\t    fetch(\"/api/schema\")\n52\t      .then((res) => res.json() as Promise<SchemaResponse>)\n53\t      .then((data) => {\n54\t        setSchema(data);\n55\t      })\n56\t      .catch(() => {\n57\t        // Schema stays null; controls still work\n58\t      })\n59\t      .finally(() => {\n60\t        setLoading(false);\n61\t      });\n62\t  }, []);\n63\t\n64\t  const addStep = useCallback(() => {\n65\t    setSteps((prev) => {\n66\t      if (prev.length >= 5) return prev;\n67\t      return [...prev, \"\"];\n68\t    });\n69\t  }, []);\n70\t\n71\t  const removeStep = useCallback((index: number) => {\n72\t    setSteps((prev) => {\n73\t      if (prev.length <= 2) return prev;\n74\t      return prev.filter((_, i) => i !== index);\n75\t    });\n76\t  }, []);\n77\t\n78\t  const setStep = useCallback((index: number, value: string) => {\n79\t    setSteps((prev) => {\n80\t      const next = [...prev];\n81\t      next[index] = value;\n82\t      return next;\n83\t    });\n84\t  }, []);\n85\t\n86\t  const runFunnel = useCallback(() => {\n87\t    // Require at least 2 non-empty steps\n88\t    const nonEmpty = steps.filter((s) => s.trim() !== \"\");\n89\t    if (nonEmpty.length < 2) return;\n90\t\n91\t    setLoading(true);\n92\t    setError(null);\n93\t    setResult(null);\n94\t\n95\t    fetch(\"/api/funnels\", {\n96\t      method: \"POST\",\n97\t      headers: { \"Content-Type\": \"application/json\" },\n98\t      body: JSON.stringify({\n99\t        steps: steps.filter((s) => s.trim() !== \"\"),\n100\t        start: startDate,\n101\t        end: endDate,\n102\t      }),\n103\t    })\n104\t      .then((res) => res.json() as Promise<FunnelResponse>)\n105\t      .then((data) => {\n106\t        setResult(data);\n107\t      })\n108\t      .catch((err: unknown) => {\n109\t        setError(err instanceof Error ? err.message : \"Unknown error\");\n110\t        setResult(null);\n111\t      })\n112\t      .finally(() => {\n113\t        setLoading(false);\n114\t      });\n115\t  }, [steps, startDate, endDate]);\n116\t\n117\t  return {\n118\t    schema,\n119\t    steps,\n120\t    startDate,\n121\t    endDate,\n122\t    addStep,\n123\t    removeStep,\n124\t    setStep,\n125\t    setStartDate,\n126\t    setEndDate,\n127\t    runFunnel,\n128\t    result,\n129\t    loading,\n130\t    error,\n131\t  };\n132\t}\n133\t"}]},"parent_tool_use_id":null,"session_id":"e891fb63-2326-49da-a118-d8f4b8413698","uuid":"29ba75f6-8e61-4b39-a0e3-60145962f2f1","timestamp":"2026-04-15T17:12:45.038Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/funnels/useFunnels.ts","content":"\"use client\";\n\nimport { useCallback, useEffect, useState } from \"react\";\nimport type { FunnelResponse } from \"@/lib/funnels\";\nimport type { SchemaResponse } from \"@/lib/schema-cache\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface UseFunnelsResult {\n  schema: SchemaResponse | null;\n  steps: string[];\n  startDate: string;\n  endDate: string;\n  addStep: () => void;\n  removeStep: (index: number) => void;\n  setStep: (index: number, value: string) => void;\n  setStartDate: (v: string) => void;\n  setEndDate: (v: string) => void;\n  runFunnel: () => void;\n  result: FunnelResponse | null;\n  loading: boolean;\n  error: string | null;\n}\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction todayISO(): string {\n  return new Date().toISOString().slice(0, 10);\n}\n\nfunction daysAgoISO(days: number): string {\n  const d = new Date();\n  d.setDate(d.getDate() - days);\n  return d.toISOString().slice(0, 10);\n}\n\n// ─── Hook ─────────────────────────────────────────────────────────────────────\n\nexport function useFunnels(): UseFunnelsResult {\n  const [schema, setSchema] = useState<SchemaResponse | null>(null);\n  const [steps, setSteps] = useState<string[]>([\"\", \"\"]);\n  const [startDate, setStartDate] = useState(daysAgoISO(30));\n  const [endDate, setEndDate] = useState(todayISO);\n  const [result, setResult] = useState<FunnelResponse | null>(null);\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n\n  // Fetch schema once on mount (for event name autocomplete)\n  useEffect(() => {\n    setLoading(true);\n    fetch(\"/api/schema\")\n      .then((res) => res.json() as Promise<SchemaResponse>)\n      .then((data) => {\n        setSchema(data);\n      })\n      .catch(() => {\n        // Schema stays null; controls still work\n      })\n      .finally(() => {\n        setLoading(false);\n      });\n  }, []);\n\n  const addStep = useCallback(() => {\n    setSteps((prev) => {\n      if (prev.length >= 5) return prev;\n      return [...prev, \"\"];\n    });\n  }, []);\n\n  const removeStep = useCallback((index: number) => {\n    setSteps((prev) => {\n      if (prev.length <= 2) return prev;\n      return prev.filter((_, i) => i !== index);\n    });\n  }, []);\n\n  const setStep = useCallback((index: number, value: string) => {\n    setSteps((prev) => {\n      const next = [...prev];\n      next[index] = value;\n      return next;\n    });\n  }, []);\n\n  const runFunnel = useCallback(() => {\n    // Require at least 2 non-empty steps\n    const nonEmpty = steps.filter((s) => s.trim() !== \"\");\n    if (nonEmpty.length < 2) return;\n\n    setLoading(true);\n    setError(null);\n    setResult(null);\n\n    fetch(\"/api/funnels\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({\n        steps: steps.filter((s) => s.trim() !== \"\"),\n        start: startDate,\n        end: endDate,\n      }),\n    })\n      .then((res) => res.json() as Promise<FunnelResponse>)\n      .then((data) => {\n        setResult(data);\n      })\n      .catch((err: unknown) => {\n        setError(err instanceof Error ? err.message : \"Unknown error\");\n        setResult(null);\n      })\n      .finally(() => {\n        setLoading(false);\n      });\n  }, [steps, startDate, endDate]);\n\n  return {\n    schema,\n    steps,\n    startDate,\n    endDate,\n    addStep,\n    removeStep,\n    setStep,\n    setStartDate,\n    setEndDate,\n    runFunnel,\n    result,\n    loading,\n    error,\n  };\n}\n","numLines":133,"startLine":1,"totalLines":133}}}
