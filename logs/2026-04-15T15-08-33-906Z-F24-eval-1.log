{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M1wyHRaz8gArmq5uCsnnPy","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport Autocomplete from \"@mui/material/Autocomplete\";\n4\timport Box from \"@mui/material/Box\";\n5\timport Button from \"@mui/material/Button\";\n6\timport IconButton from \"@mui/material/IconButton\";\n7\timport Stack from \"@mui/material/Stack\";\n8\timport TextField from \"@mui/material/TextField\";\n9\timport Typography from \"@mui/material/Typography\";\n10\t\n11\t// ─── Types ────────────────────────────────────────────────────────────────────\n12\t\n13\tinterface StepBuilderProps {\n14\t  steps: string[];\n15\t  eventNames: string[];\n16\t  onAddStep: () => void;\n17\t  onRemoveStep: (index: number) => void;\n18\t  onSetStep: (index: number, value: string) => void;\n19\t}\n20\t\n21\t// ─── Component ────────────────────────────────────────────────────────────────\n22\t\n23\texport function StepBuilder({\n24\t  steps,\n25\t  eventNames,\n26\t  onAddStep,\n27\t  onRemoveStep,\n28\t  onSetStep,\n29\t}: StepBuilderProps): React.JSX.Element {\n30\t  const canRemove = steps.length > 2;\n31\t  const canAdd = steps.length < 5;\n32\t\n33\t  return (\n34\t    <Box data-testid=\"step-builder\">\n35\t      <Stack spacing={1.5}>\n36\t        {steps.map((step, i) => (\n37\t          // biome-ignore lint/suspicious/noArrayIndexKey: steps are ordered user inputs that may be empty or identical\n38\t          <Box key={i} sx={{ display: \"flex\", alignItems: \"center\", gap: 1 }}>\n39\t            <Typography\n40\t              variant=\"body2\"\n41\t              color=\"text.secondary\"\n42\t              sx={{ minWidth: 24, textAlign: \"right\" }}\n43\t            >\n44\t              {i + 1}.\n45\t            </Typography>\n46\t            <Autocomplete\n47\t              options={eventNames}\n48\t              value={step || null}\n49\t              onChange={(_, value) => onSetStep(i, value ?? \"\")}\n50\t              renderInput={(params) => (\n51\t                <TextField\n52\t                  {...params}\n53\t                  label={`Step ${i + 1}`}\n54\t                  size=\"small\"\n55\t                  placeholder=\"Select event…\"\n56\t                />\n57\t              )}\n58\t              sx={{ flex: 1, minWidth: 220 }}\n59\t            />\n60\t            <IconButton\n61\t              size=\"small\"\n62\t              aria-label=\"Remove step\"\n63\t              disabled={!canRemove}\n64\t              onClick={() => onRemoveStep(i)}\n65\t            >\n66\t              ✕\n67\t            </IconButton>\n68\t          </Box>\n69\t        ))}\n70\t      </Stack>\n71\t\n72\t      <Box sx={{ mt: 1.5 }}>\n73\t        <Button\n74\t          size=\"small\"\n75\t          variant=\"outlined\"\n76\t          disabled={!canAdd}\n77\t          onClick={onAddStep}\n78\t        >\n79\t          Add Step\n80\t        </Button>\n81\t      </Box>\n82\t    </Box>\n83\t  );\n84\t}\n85\t"}]},"parent_tool_use_id":null,"session_id":"e891fb63-2326-49da-a118-d8f4b8413698","uuid":"7374415b-afee-45ff-97ed-e983d317805d","timestamp":"2026-04-15T17:12:52.106Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/funnels/StepBuilder.tsx","content":"\"use client\";\n\nimport Autocomplete from \"@mui/material/Autocomplete\";\nimport Box from \"@mui/material/Box\";\nimport Button from \"@mui/material/Button\";\nimport IconButton from \"@mui/material/IconButton\";\nimport Stack from \"@mui/material/Stack\";\nimport TextField from \"@mui/material/TextField\";\nimport Typography from \"@mui/material/Typography\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\ninterface StepBuilderProps {\n  steps: string[];\n  eventNames: string[];\n  onAddStep: () => void;\n  onRemoveStep: (index: number) => void;\n  onSetStep: (index: number, value: string) => void;\n}\n\n// ─── Component ────────────────────────────────────────────────────────────────\n\nexport function StepBuilder({\n  steps,\n  eventNames,\n  onAddStep,\n  onRemoveStep,\n  onSetStep,\n}: StepBuilderProps): React.JSX.Element {\n  const canRemove = steps.length > 2;\n  const canAdd = steps.length < 5;\n\n  return (\n    <Box data-testid=\"step-builder\">\n      <Stack spacing={1.5}>\n        {steps.map((step, i) => (\n          // biome-ignore lint/suspicious/noArrayIndexKey: steps are ordered user inputs that may be empty or identical\n          <Box key={i} sx={{ display: \"flex\", alignItems: \"center\", gap: 1 }}>\n            <Typography\n              variant=\"body2\"\n              color=\"text.secondary\"\n              sx={{ minWidth: 24, textAlign: \"right\" }}\n            >\n              {i + 1}.\n            </Typography>\n            <Autocomplete\n              options={eventNames}\n              value={step || null}\n              onChange={(_, value) => onSetStep(i, value ?? \"\")}\n              renderInput={(params) => (\n                <TextField\n                  {...params}\n                  label={`Step ${i + 1}`}\n                  size=\"small\"\n                  placeholder=\"Select event…\"\n                />\n              )}\n              sx={{ flex: 1, minWidth: 220 }}\n            />\n            <IconButton\n              size=\"small\"\n              aria-label=\"Remove step\"\n              disabled={!canRemove}\n              onClick={() => onRemoveStep(i)}\n            >\n              ✕\n            </IconButton>\n          </Box>\n        ))}\n      </Stack>\n\n      <Box sx={{ mt: 1.5 }}>\n        <Button\n          size=\"small\"\n          variant=\"outlined\"\n          disabled={!canAdd}\n          onClick={onAddStep}\n        >\n          Add Step\n        </Button>\n      </Box>\n    </Box>\n  );\n}\n","numLines":85,"startLine":1,"totalLines":85}}}
