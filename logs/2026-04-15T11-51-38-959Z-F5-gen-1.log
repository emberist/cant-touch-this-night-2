{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016t4m3KBQvrcCzgzjRqzv69","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\t\n3\t// ─── Types ────────────────────────────────────────────────────────────────────\n4\t\n5\texport interface EventInput {\n6\t  event_name: string;\n7\t  device_id?: string;\n8\t  user_id?: string;\n9\t  timestamp?: string;\n10\t  properties?: Record<string, unknown>;\n11\t}\n12\t\n13\texport interface EventRow {\n14\t  event_id: string;\n15\t  event_name: string;\n16\t  timestamp: string;\n17\t  device_id: string | null;\n18\t  user_id: string | null;\n19\t  properties: string;\n20\t  ingested_at: string;\n21\t  resolved_id: string;\n22\t}\n23\t\n24\texport interface QueryEventsOptions {\n25\t  event_name?: string;\n26\t  resolved_id?: string;\n27\t  /** ISO timestamp cursor — return events strictly before this time */\n28\t  before?: string;\n29\t  limit?: number;\n30\t}\n31\t\n32\t// ─── Error ────────────────────────────────────────────────────────────────────\n33\t\n34\texport class IdentityConflictError extends Error {\n35\t  readonly status = 409 as const;\n36\t\n37\t  constructor(\n38\t    device_id: string,\n39\t    existing_user_id: string,\n40\t    new_user_id: string,\n41\t  ) {\n42\t    super(\n43\t      `Device \"${device_id}\" is already mapped to user \"${existing_user_id}\". Cannot remap to \"${new_user_id}\".`,\n44\t    );\n45\t    this.name = \"IdentityConflictError\";\n46\t    // Maintain correct prototype chain in transpiled environments\n47\t    Object.setPrototypeOf(this, new.target.prototype);\n48\t  }\n49\t}\n50\t\n51\t// ─── Type alias for the ClickHouse client ─────────────────────────────────────\n52\t\n53\ttype ClickHouseClientLike = typeof clickhouse;\n54\t\n55\t// ─── validateEvent ────────────────────────────────────────────────────────────\n56\t\n57\t/**\n58\t * Validates a raw event input object. Throws an Error if invalid.\n59\t * After this call returns, callers may safely treat the input as EventInput.\n60\t */\n61\texport function validateEvent(input: unknown): asserts input is EventInput {\n62\t  if (typeof input !== \"object\" || input === null) {\n63\t    throw new Error(\"Event must be a non-null object.\");\n64\t  }\n65\t  const evt = input as Record<string, unknown>;\n66\t\n67\t  if (typeof evt.event_name !== \"string\" || evt.event_name.trim() === \"\") {\n68\t    throw new Error(\"event_name is required and must be a non-empty string.\");\n69\t  }\n70\t\n71\t  if (!evt.device_id && !evt.user_id) {\n72\t    throw new Error(\"At least one of device_id or user_id must be present.\");\n73\t  }\n74\t}\n75\t\n76\t// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n77\t\n78\t/**\n79\t * Checks identity_mappings FINAL for an existing device → user mapping and:\n80\t * - Inserts a new mapping if none exists.\n81\t * - No-ops if the same mapping already exists (idempotent).\n82\t * - Throws IdentityConflictError (status 409) if the device is mapped to a\n83\t *   different user.\n84\t */\n85\texport async function resolveIdentityMapping(\n86\t  device_id: string,\n87\t  user_id: string,\n88\t  client: ClickHouseClientLike = clickhouse,\n89\t): Promise<void> {\n90\t  const result = await client.query({\n91\t    query:\n92\t      \"SELECT user_id FROM identity_mappings FINAL WHERE device_id = {device_id:String} LIMIT 1\",\n93\t    query_params: { device_id },\n94\t    format: \"JSONEachRow\",\n95\t  });\n96\t\n97\t  const rows = await result.json<{ user_id: string }>();\n98\t\n99\t  if (rows.length === 0) {\n100\t    // No existing mapping — insert\n101\t    await client.insert({\n102\t      table: \"identity_mappings\",\n103\t      values: [{ device_id, user_id }],\n104\t      format: \"JSONEachRow\",\n105\t    });\n106\t    return;\n107\t  }\n108\t\n109\t  const existingUserId = rows[0].user_id;\n110\t\n111\t  if (existingUserId === user_id) {\n112\t    // Same mapping — no