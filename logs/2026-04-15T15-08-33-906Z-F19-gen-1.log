null,\n  };\n}\n\nexport default async function Dashboard(): Promise<React.JSX.Element> {\n  let metrics = { total_events: 0, total_users: 0, top_event_7d: null } as {\n    total_events: number;\n    total_users: number;\n    top_event_7d: { name: string; count: number } | null;\n  };\n\n  try {\n    metrics = await getMetrics();\n  } catch {\n    // ClickHouse may not be running in CI/build; show zeros\n  }\n\n  return (\n    <Box>\n      <Typography variant=\"h4\" component=\"h1\" gutterBottom>\n        Dashboard\n      </Typography>\n      <Box\n        sx={{\n          display: \"grid\",\n          gridTemplateColumns: { xs: \"1fr\", sm: \"repeat(3, 1fr)\" },\n          gap: 3,\n          mt: 2,\n        }}\n      >\n        <Card data-testid=\"metric-total-events\">\n          <CardContent>\n            <Typography variant=\"h3\" component=\"p\" fontWeight=\"bold\">\n              {metrics.total_events.toLocaleString()}\n            </Typography>\n            <Typography variant=\"body2\" color=\"text.secondary\">\n              Total Events\n            </Typography>\n          </CardContent>\n        </Card>\n\n        <Card data-testid=\"metric-total-users\">\n          <CardContent>\n            <Typography variant=\"h3\" component=\"p\" fontWeight=\"bold\">\n              {metrics.total_users.toLocaleString()}\n            </Typography>\n            <Typography variant=\"body2\" color=\"text.secondary\">\n              Total Users\n            </Typography>\n          </CardContent>\n        </Card>\n\n        <Card data-testid=\"metric-top-event\">\n          <CardContent>\n            <Typography variant=\"h5\" component=\"p\" fontWeight=\"bold\">\n              {metrics.top_event_7d ? metrics.top_event_7d.name : \"No events yet\"}\n            </Typography>\n            {metrics.top_event_7d && (\n              <Typography variant=\"body2\" color=\"text.secondary\">\n                {metrics.top_event_7d.count.toLocaleString()} times\n              </Typography>\n            )}\n            <Typography variant=\"body2\" color=\"text.secondary\">\n              Top Event (last 7 days)\n            </Typography>\n          </CardContent>\n        </Card>\n      </Box>\n    </Box>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":336,"cache_read_input_tokens":40814,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":336},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"999fc03b-da6a-446b-b225-c88c47e72e24","uuid":"0e1272fc-668a-4cc9-a71b-43a8ad1feef9"}
