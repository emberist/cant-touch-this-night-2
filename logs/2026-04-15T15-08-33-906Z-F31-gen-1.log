{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019U1j8rDtspmjyo3SWVMw66","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\timport {\n3\t  buildIdentityMappings,\n4\t  type GeneratedEvent,\n5\t  type GeneratedUser,\n6\t  type IdentityMapping,\n7\t  mulberry32,\n8\t} from \"@/lib/seed\";\n9\t\n10\t// ─── Types ────────────────────────────────────────────────────────────────────\n11\t\n12\texport type JobStatus =\n13\t  | \"queued\"\n14\t  | \"running\"\n15\t  | \"complete\"\n16\t  | \"failed\"\n17\t  | \"cancelled\";\n18\t\n19\texport type NumericVariance = \"low\" | \"medium\" | \"high\";\n20\t\n21\texport interface EventTypeWeight {\n22\t  name: string;\n23\t  weight: number;\n24\t}\n25\t\n26\texport interface JobConfig {\n27\t  total: number;\n28\t  users: number;\n29\t  start: string;\n30\t  end: string;\n31\t  event_types: EventTypeWeight[];\n32\t  identity_resolution: boolean;\n33\t  anonymous_ratio: number;\n34\t  numeric_variance: NumericVariance;\n35\t}\n36\t\n37\texport interface JobConfigInput {\n38\t  total?: number;\n39\t  users?: number;\n40\t  start?: string;\n41\t  end?: string;\n42\t  event_types?: EventTypeWeight[];\n43\t  identity_resolution?: boolean;\n44\t  anonymous_ratio?: number;\n45\t  numeric_variance?: string;\n46\t}\n47\t\n48\texport interface JobState {\n49\t  job_id: string;\n50\t  status: JobStatus;\n51\t  inserted: number;\n52\t  total: number;\n53\t  throughput: number;\n54\t  eta_seconds: number;\n55\t  elapsed_ms: number;\n56\t  error?: string;\n57\t  config: JobConfig;\n58\t  cancelled: boolean;\n59\t  created_at: number;\n60\t}\n61\t\n62\t// ─── Constants ────────────────────────────────────────────────────────────────\n63\t\n64\tconst BATCH_SIZE = 10_000;\n65\t\n66\tconst DEFAULT_EVENT_TYPES: EventTypeWeight[] = [\n67\t  { name: \"Page Viewed\", weight: 0.4 },\n68\t  { name: \"Button Clicked\", weight: 0.15 },\n69\t  { name: \"Signup Completed\", weight: 0.12 },\n70\t  { name: \"Purchase Completed\", weight: 0.13 },\n71\t  { name: \"Subscription Renewed\", weight: 0.12 },\n72\t  { name: \"Support Ticket Opened\", weight: 0.08 },\n73\t];\n74\t\n75\tconst PAGES = [\n76\t  \"/home\",\n77\t  \"/pricing\",\n78\t  \"/features\",\n79\t  \"/about\",\n80\t  \"/signup\",\n81\t  \"/login\",\n82\t  \"/dashboard\",\n83\t];\n84\tconst PLANS = [\"free\", \"starter\", \"pro\", \"enterprise\"];\n85\tconst CURRENCIES = [\"USD\", \"EUR\", \"GBP\", \"BTC\"];\n86\tconst SOURCES = [\"organic\", \"paid\", \"referral\", \"email\", \"social\"];\n87\tconst BUTTON_NAMES = [\n88\t  \"Get Started\",\n89\t  \"Sign Up\",\n90\t  \"Learn More\",\n91\t  \"Buy Now\",\n92\t  \"Upgrade\",\n93\t  \"Try Free\",\n94\t];\n95\t\n96\t// ─── In-memory job store ──────────────────────────────────────────────────────\n97\t\n98\tconst jobs = new Map<string, JobState>();\n99\t\n100\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n101\t\n102\tfunction pickFrom<T>(arr: readonly T[], rand: () => number): T {\n103\t  return arr[Math.floor(rand() * arr.length)];\n104\t}\n105\t\n106\tfunction buildCumulative(weights: readonly number[]): number[] {\n107\t  const cum: number[] = [];\n108\t  let total = 0;\n109\t  for (const w of weights) {\n110\t    total += w;\n111\t    cum.push(total);\n112\t  }\n113\t  return cum;\n114\t}\n115\t\n116\tfunction weightedIndex(cumulative: number[], rand: () => number): number {\n117\t  const r = rand() * cumulative[cumulative.length - 1];\n118\t  for (let i = 0; i < cumulative.length; i++) {\n119\t    if (r <= cumulative[i]) return i;\n120\t  }\n121\t  return cumulative.length - 1;\n122\t}\n123\t\n124\tfunction getVarianceMultiplier(variance: NumericVariance): number {\n125\t  switch (variance) {\n126\t    case \"low\":\n127\t      return 0.2;\n128\t    case \"medium\":\n129\t      return 1.0;\n130\t    case \"high\":\n131\t      return 3.0;\n132\t  }\n133\t}\n134\t\n135\tfunction generateProperties(\n136\t  eventName: string,\n137\t  rand: () => number,\n138\t  variance: NumericVariance,\n139\t): Record<string, unknown> {\n140\t  const vm = getVarianceMultiplier(variance);\n141\t  switch (eventName) {\n142\t    case \"Page Viewed\":\n143\t      return { page: pickFrom(PAGES, rand) };\n144\t    case \"Button Clicked\":\n145\t      return { button_name: pickFrom(BUTTON_NAMES, rand) };\n146\t    case \"Signup Completed\":\n147\t      return {\n148\t        plan: pickFrom(PLANS, rand),\n149\t        source: pickFrom(SOURCES, rand),\n150\t      };\n151\t    case \"Purchase Completed\":\n152\t      return {\n153\t        amount: Math.round(rand() * 500 * vm * 100) / 100,\n154\t        currency: pickFrom(CURRENCIES, rand),\n155\t        plan: pickFrom(PLANS, rand),\n156\t      };\n157\t    case \"Subscription Renewed\":\n158\t      return {\n159\t        amount: Math.round(rand() * 500 * vm * 100) / 100,\n160\t        currency: pickFrom(CURRENCIES, rand),\n161\t        plan: pickFrom(PLANS, rand),\n162\t      };\n163\t    case \"Support Ticket Opened\":\n164\t      return {\n165\t        ticket_count: Math.floor(rand() * 10 * vm) + 1,\n166\t        source: pickFrom(SOURCES, rand),\n167\t      };\n168\t    default:\n169\t      return {};\n170\t  }\n171\t}\n172\t\n173\t/** Converts an ISO 8601 timestamp to the ClickHouse DateTime64 format. */\n174\tfunction toClickHouseTs(iso: string): string {\n175\t  return iso.replace(\"T\", \" \").replace(\"Z\", \"\");\n176\t}\n177\t\n178\t// ─── Config application and validation ───────────────────────────────────────\n179\t\n180\tfunction applyDefaults(input: JobConfigInput): JobConfig {\n181\t  const now = new Date();\n182\t  const thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);\n183\t\n184\t  const total = input.total ?? 10_000;\n185\t  const users = input.users ?? 100;\n186\t  const start = input.start ?? thirtyDaysAgo.toISOString().slice(0, 10);\n187\t  const end = input.end ?? now.toISOString().slice(0, 10);\n188\t  const event_types =\n189\t    input.event_types && input.event_types.length > 0\n190\t      ? input.event_types\n191\t      : DEFAULT_EVENT_TYPES;\n192\t  const identity_resolution = input.identity_resolution ?? true;\n193\t  const anonymous_ratio = input.anonymous_ratio ?? 30;\n194\t  const numeric_variance: NumericVariance =\n195\t    input.numeric_variance === \"low\" ||\n196\t    input.numeric_variance === \"high\" ||\n197\t    input.numeric_variance === \"medium\"\n198\t      ? input.numeric_variance\n199\t      : \"medium\";\n200\t\n201\t  return {\n202\t    total,\n203\t    users,\n204\t    start,\n205\t    end,\n206\t    event_types,\n207\t    identity_resolution,\n208\t    anonymous_ratio,\n209\t    numeric_variance,\n210\t  };\n211\t}\n212\t\n213\tfunction validateConfig(config: JobConfig): void {\n214\t  if (!Number.isInteger(config.total) || config.total < 1) {\n215\t    throw new Error(\"total must be an integer >= 1.\");\n216\t  }\n217\t  if (config.total > 1_000_000) {\n218\t    throw new Error(\"total must be <= 1,000,000.\");\n219\t  }\n220\t  if (!Number.isInteger(config.users) || config.users < 1) {\n221\t    throw new Error(\"users must be an integer >= 1.\");\n222\t  }\n223\t  const startMs = new Date(config.start).getTime();\n224\t  const endMs = new Date(config.end).getTime();\n225\t  if (Number.isNaN(startMs)) {\n226\t    throw new Error(\"start must be a valid date string.\");\n227\t  }\n228\t  if (Number.isNaN(endMs)) {\n229\t    throw new Error(\"end must be a valid date string.\");\n230\t  }\n231\t  if (endMs <= startMs) {\n232\t    throw new Error(\"end must be after start.\");\n233\t  }\n234\t}\n235\t\n236\t// ─── User pool builder ────────────────────────────────────────────────────────\n237\t\n238\tfunction buildUserPool(config: JobConfig, rand: () => number): GeneratedUser[] {\n239\t  const users: GeneratedUser[] = [];\n240\t\n241\t  const anonCount = config.identity_resolution\n242\t    ? Math.round(config.users * (config.anonymous_ratio / 100))\n243\t    : config.users;\n244\t  const resolvedCount = config.users - anonCount;\n245\t\n246\t  for (let i = 0; i < resolvedCount; i++) {\n247\t    users.push({\n248\t      type: \"fully-resolved\",\n249\t      userId: `gen-user-${i}@example.com`,\n250\t      deviceIds: [`gen-device-${i}`],\n251\t    });\n252\t  }\n253\t\n254\t  for (let i = 0; i < anonCount; i++) {\n255\t    users.push({\n256\t      type: \"anonymous\",\n257\t      userId: null,\n258\t      deviceIds: [`gen-anon-${i}`],\n259\t    });\n260\t  }\n261\t\n262\t  // Shuffle so anonymous users aren't always last (affects power-law weighting)\n263\t  for (let i = users.length - 1; i > 0; i--) {\n264\t    const j = Math.floor(rand() * (i + 1));\n265\t    [users[i], users[j]] = [users[j], users[i]];\n266\t  }\n267\t\n268\t  return users;\n269\t}\n270\t\n271\t// ─── Batch event generation ───────────────────────────────────────────────────\n272\t\n273\texport function generateBatchEvents(\n274\t  config: JobConfig,\n275\t  users: GeneratedUser[],\n276\t  startDate: Date,\n277\t  endDate: Date,\n278\t  rand: () => number,\n279\t  batchSize: number,\n280\t): GeneratedEvent[] {\n281\t  const eventCumulative = buildCumulative(\n282\t    config.event_types.map((et) => et.weight),\n283\t  );\n284\t  const userWeights = users.map((_, i) => 1 / (i + 1) ** 1.5);\n285\t  const userCumulative = buildCumulative(userWeights);\n286\t\n287\t  const startMs = startDate.getTime();\n288\t  const rangeMs = endDate.getTime() - startMs;\n289\t\n290\t  const events: GeneratedEvent[] = [];\n291\t\n292\t  for (let i = 0; i < batchSize; i++) {\n293\t    const user = users[weightedIndex(userCumulative, rand)];\n294\t    const eventTypeIdx = weightedIndex(eventCumulative, rand);\n295\t    const eventName = config.event_types[eventTypeIdx].name;\n296\t\n297\t    const deviceId = pickFrom(user.deviceIds, rand);\n298\t    const tsMs = startMs + Math.floor(rand() * rangeMs);\n299\t    const timestamp = new Date(tsMs).toISOString();\n300\t    const properties = JSON.stringify(\n301\t      generateProperties(eventName, rand, config.numeric_variance),\n302\t    );\n303\t\n304\t    events.push({\n305\t      event_name: eventName,\n306\t      timestamp,\n307\t      device_id: deviceId,\n308\t      user_id: user.userId,\n309\t      properties,\n310\t    });\n311\t  }\n312\t\n313\t  return events;\n314\t}\n315\t\n316\t// ─── Generation loop ──────────────────────────────────────────────────────────\n317\t\n318\tasync function runGenerationLoop(job_id: string): Promise<void> {\n319\t  const job = jobs.get(job_id);\n320\t  if (!job) return;\n321\t\n322\t  job.status = \"running\";\n323\t  const startTime = Date.now();\n324\t\n325\t  const { config } = job;\n326\t  const startDate = new Date(config.start);\n327\t  const endDate = new Date(config.end);\n328\t\n329\t  // Use a deterministic seed derived from the job_id's first chars\n330\t  const seed =\n331\t    job_id\n332\t      .replace(/-/g, \"\")\n333\t      .slice(0, 8)\n334\t      .split(\"\")\n335\t      .reduce((acc, c) => acc + c.charCodeAt(0), 0) | 0;\n336\t  const rand = mulberry32(seed);\n337\t\n338\t  const userPool = buildUserPool(config, rand);\n339\t\n340\t  let offset = 0;\n341\t\n342\t  while (offset < config.total) {\n343\t    if (job.cancelled) {\n344\t      job.status = \"cancelled\";\n345\t      job.elapsed_ms = Date.now() - startTime;\n346\t      return;\n347\t    }\n348\t\n349\t    const batchSize = Math.min(BATCH_SIZE, config.total - offset);\n350\t    const events = generateBatchEvents(\n351\t      config,\n352\t      userPool,\n353\t      startDate,\n354\t      endDate,\n355\t      rand,\n356\t      batchSize,\n357\t    );\n358\t\n359\t    await clickhouse.insert({\n360\t      table: \"events\",\n361\t      values: events.map((e) => ({\n362\t        ...e,\n363\t        timestamp: toClickHouseTs(e.timestamp),\n364\t      })),\n365\t      format: \"JSONEachRow\",\n366\t    });\n367\t\n368\t    offset += batchSize;\n369\t    job.inserted = offset;\n370\t\n371\t    const elapsed = Date.now() - startTime;\n372\t    job.elapsed_ms = elapsed;\n373\t    job.throughput = elapsed > 0 ? Math.round((offset / elapsed) * 1000) : 0;\n374\t    const remaining = config.total - offset;\n375\t    job.eta_seconds =\n376\t      job.throughput > 0 ? Math.round(remaining / job.throughput) : 0;\n377\t  }\n378\t\n379\t  // Insert identity mappings after all event batches are complete\n380\t  if (!job.cancelled) {\n381\t    const mappings: IdentityMapping[] = buildIdentityMappings(userPool);\n382\t    if (mappings.length > 0) {\n383\t      await clickhouse.insert({\n384\t        table: \"identity_mappings\",\n385\t        values: mappings,\n386\t        format: \"JSONEachRow\",\n387\t      });\n388\t    }\n389\t\n390\t    job.elapsed_ms = Date.now() - startTime;\n391\t    job.throughput =\n392\t      job.elapsed_ms > 0\n393\t        ? Math.round((config.total / job.elapsed_ms) * 1000)\n394\t        : 0;\n395\t    job.eta_seconds = 0;\n396\t    job.status = \"complete\";\n397\t  }\n398\t}\n399\t\n400\t// ─── Public API ───────────────────────────────────────────────────────────────\n401\t\n402\t/**\n403\t * Validates config, creates a job in the in-memory store, kicks off the async\n404\t * generation loop (fire-and-forget), and returns the job_id synchronously.\n405\t *\n406\t * Throws synchronously if the config is invalid.\n407\t */\n408\texport function startGenerationJob(input: JobConfigInput): string {\n409\t  const config = applyDefaults(input);\n410\t  validateConfig(config);\n411\t\n412\t  const job_id = crypto.randomUUID();\n413\t  const job: JobState = {\n414\t    job_id,\n415\t    status: \"queued\",\n416\t    inserted: 0,\n417\t    total: config.total,\n418\t    throughput: 0,\n419\t    eta_seconds: 0,\n420\t    elapsed_ms: 0,\n421\t    config,\n422\t    cancelled: false,\n423\t    created_at: Date.now(),\n424\t  };\n425\t  jobs.set(job_id, job);\n426\t\n427\t  runGenerationLoop(job_id).catch((err: unknown) => {\n428\t    const j = jobs.get(job_id);\n429\t    if (j && j.status !== \"cancelled\") {\n430\t      j.status = \"failed\";\n431\t      j.error = err instanceof Error ? err.message : String(err);\n432\t    }\n433\t  });\n434\t\n435\t  return job_id;\n436\t}\n437\t\n438\t/** Returns the current JobState for the given job_id, or undefined if not found. */\n439\texport function getJob(id: string): JobState | undefined {\n440\t  return jobs.get(id);\n441\t}\n442\t\n443\t/**\n444\t * Sets the cancellation flag on a job. The generation loop checks this flag\n445\t * between batches and will stop after the current batch completes.\n446\t *\n447\t * Returns true if the job was found, false otherwise.\n448\t */\n449\texport function cancelJob(id: string): boolean {\n450\t  const job = jobs.get(id);\n451\t  if (!job) return false;\n452\t  job.cancelled = true;\n453\t  return true;\n454\t}\n455\t\n456\t/** Returns all jobs in the in-memory store. */\n457\texport function listJobs(): JobState[] {\n458\t  return [...jobs.values()];\n459\t}\n460\t\n461\t// ─── Testing helpers ──────────────────────────────────────────────────────────\n462\t\n463\t/** Clears all jobs from the in-memory store. For use in unit tests only. */\n464\texport function _clearJobs(): void {\n465\t  jobs.clear();\n466\t}\n467\t"}]},"parent_tool_use_id":"toolu_01LqCrFAeC5TM1G8mgQJxKzs","session_id":"4e2b9e14-c306-4c04-b64f-1d0d531c58b6","uuid":"1a18d949-332e-4055-a7cf-a5303d5820ef","timestamp":"2026-04-15T18:39:15.298Z"}
