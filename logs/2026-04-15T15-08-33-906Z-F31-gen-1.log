{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NgMpCN8RmchwwQMn1pzSLW","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { act, renderHook, waitFor } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport { useEventSender } from \"@/components/test/useEventSender\";\n5\t\n6\t// ─── Setup ────────────────────────────────────────────────────────────────────\n7\t\n8\tconst mockFetch = vi.fn();\n9\t\n10\tbeforeEach(() => {\n11\t  vi.stubGlobal(\"fetch\", mockFetch);\n12\t});\n13\t\n14\tafterEach(() => {\n15\t  vi.clearAllMocks();\n16\t  vi.unstubAllGlobals();\n17\t});\n18\t\n19\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n20\t\n21\tfunction makeOkResponse(body: unknown = {}) {\n22\t  return Promise.resolve({\n23\t    ok: true,\n24\t    status: 201,\n25\t    json: () => Promise.resolve(body),\n26\t  });\n27\t}\n28\t\n29\tfunction makeErrorResponse(\n30\t  status: number,\n31\t  body: unknown = { error: \"Something went wrong\" },\n32\t) {\n33\t  return Promise.resolve({\n34\t    ok: false,\n35\t    status,\n36\t    json: () => Promise.resolve(body),\n37\t  });\n38\t}\n39\t\n40\t// ─── Tests ────────────────────────────────────────────────────────────────────\n41\t\n42\tdescribe(\"useEventSender\", () => {\n43\t  describe(\"initial state\", () => {\n44\t    it(\"starts with lastDeviceId null\", () => {\n45\t      const { result } = renderHook(() => useEventSender());\n46\t      expect(result.current.lastDeviceId).toBeNull();\n47\t    });\n48\t\n49\t    it(\"starts with loading false\", () => {\n50\t      const { result } = renderHook(() => useEventSender());\n51\t      expect(result.current.loading).toBe(false);\n52\t    });\n53\t  });\n54\t\n55\t  describe(\"sendEvent\", () => {\n56\t    it(\"calls fetch with POST /api/events and correct JSON body\", async () => {\n57\t      mockFetch.mockReturnValue(makeOkResponse());\n58\t      const { result } = renderHook(() => useEventSender());\n59\t\n60\t      await act(async () => {\n61\t        await result.current.sendEvent({\n62\t          event_name: \"Page Viewed\",\n63\t          device_id: \"dev-1\",\n64\t        });\n65\t      });\n66\t\n67\t      expect(mockFetch).toHaveBeenCalledTimes(1);\n68\t      const [url, init] = mockFetch.mock.calls[0] as [string, RequestInit];\n69\t      expect(url).toBe(\"/api/events\");\n70\t      expect(init.method).toBe(\"POST\");\n71\t      expect((init.headers as Record<string, string>)[\"Content-Type\"]).toBe(\n72\t        \"application/json\",\n73\t      );\n74\t\n75\t      const body = JSON.parse(init.body as string) as Record<string, unknown>;\n76\t      expect(body.event_name).toBe(\"Page Viewed\");\n77\t      expect(body.device_id).toBe(\"dev-1\");\n78\t    });\n79\t\n80\t    it(\"sends full payload including user_id, timestamp, and properties\", async () => {\n81\t      mockFetch.mockReturnValue(makeOkResponse());\n82\t      const { result } = renderHook(() => useEventSender());\n83\t\n84\t      await act(async () => {\n85\t        await result.current.sendEvent({\n86\t          event_name: \"Purchase Completed\",\n87\t          device_id: \"dev-1\",\n88\t          user_id: \"user@example.com\",\n89\t          timestamp: \"2026-04-15T12:00:00.000Z\",\n90\t          properties: { amount: 49.99, currency: \"USD\" },\n91\t        });\n92\t      });\n93\t\n94\t      const body = JSON.parse(\n95\t        (mockFetch.mock.calls[0] as [string, RequestInit])[1].body as string,\n96\t      ) as Record<string, unknown>;\n97\t      expect(body.user_id).toBe(\"user@example.com\");\n98\t      expect(body.timestamp).toBe(\"2026-04-15T12:00:00.000Z\");\n99\t      expect(body.properties).toEqual({ amount: 49.99, currency: \"USD\" });\n100\t    });\n101\t\n102\t    it(\"returns success: true on 201 response\", async () => {\n103\t      mockFetch.mockReturnValue(makeOkResponse());\n104\t      const { result } = renderHook(() => useEventSender());\n105\t\n106\t      let sendResult!: { success: boolean };\n107\t      await act(async () => {\n108\t        sendResult = await result.current.sendEvent({\n109\t          event_name: \"Page Viewed\",\n110\t          device_id: \"dev-1\",\n111\t        });\n112\t      });\n113\t\n114\t      expect(sendResult.success).toBe(true);\n115\t    });\n116\t\n117\t    it(\"returns success: false and error message on 400 response\", async () => {\n118\t      mockFetch.mockReturnValue(\n119\t        makeErrorResponse(400, { error: \"event_name required\" }),\n120\t      );\n121\t      const { result } = renderHook(() => useEventSender());\n122\t\n123\t      let sendResult!: { success: boolean; error?: string };\n124\t      await act(async () => {\n125\t        sendResult = await result.current.sendEvent({ event_name: \"\" });\n126\t      });\n127\t\n128\t      expect(sendResult.success).toBe(false);\n129\t      expect(sendResult.error).toBeTruthy();\n130\t    });\n131\t\n132\t    it(\"returns success: false and error message on 409 response\", async () => {\n133\t      mockFetch.mockReturnValue(makeErrorResponse(409, { error: \"Conflict\" }));\n134\t      const { result } = renderHook(() => useEventSender());\n135\t\n136\t      let sendResult!: { success: boolean; error?: string };\n137\t      await act(async () => {\n138\t        sendResult = await result.current.sendEvent({\n139\t          event_name: \"Page Viewed\",\n140\t          device_id: \"dev-1\",\n141\t          user_id: \"user-2\",\n142\t        });\n143\t      });\n144\t\n145\t      expect(sendResult.success).toBe(false);\n146\t      expect(sendResult.error).toBeTruthy();\n147\t    });\n148\t\n149\t    it(\"returns success: false and error message on 500 response\", async () => {\n150\t      mockFetch.mockReturnValue(\n151\t        makeErrorResponse(500, { error: \"Internal server error\" }),\n152\t      );\n153\t      const { result } = renderHook(() => useEventSender());\n154\t\n155\t      let sendResult!: { success: boolean; error?: string };\n156\t      await act(async () => {\n157\t        sendResult = await result.current.sendEvent({\n158\t          event_name: \"Page Viewed\",\n159\t          device_id: \"dev-1\",\n160\t        });\n161\t      });\n162\t\n163\t      expect(sendResult.success).toBe(false);\n164\t      expect(sendResult.error).toBeTruthy();\n165\t    });\n166\t  });\n167\t\n168\t  describe(\"lastDeviceId tracking\", () => {\n169\t    it(\"updates lastDeviceId after sending an event with device_id (anonymous page view)\", async () => {\n170\t      mockFetch.mockReturnValue(makeOkResponse());\n171\t      const { result } = renderHook(() => useEventSender());\n172\t\n173\t      expect(result.current.lastDeviceId).toBeNull();\n174\t\n175\t      await act(async () => {\n176\t        await result.current.sendEvent({\n177\t          event_name: \"Page Viewed\",\n178\t          device_id: \"dev-123\",\n179\t        });\n180\t      });\n181\t\n182\t      expect(result.current.lastDeviceId).toBe(\"dev-123\");\n183\t    });\n184\t\n185\t    it(\"does not update lastDeviceId when device_id is absent from payload\", async () => {\n186\t      mockFetch.mockReturnValue(makeOkResponse());\n187\t      const { result } = renderHook(() => useEventSender());\n188\t\n189\t      await act(async () => {\n190\t        await result.current.sendEvent({\n191\t          event_name: \"Purchase Completed\",\n192\t          user_id: \"user@example.com\",\n193\t        });\n194\t      });\n195\t\n196\t      expect(result.current.lastDeviceId).toBeNull();\n197\t    });\n198\t\n199\t    it(\"updates lastDeviceId to the most recent device_id sent\", async () => {\n200\t      mockFetch.mockReturnValue(makeOkResponse());\n201\t      const { result } = renderHook(() => useEventSender());\n202\t\n203\t      await act(async () => {\n204\t        await result.current.sendEvent({\n205\t          event_name: \"Page Viewed\",\n206\t          device_id: \"dev-1\",\n207\t        });\n208\t      });\n209\t      expect(result.current.lastDeviceId).toBe(\"dev-1\");\n210\t\n211\t      await act(async () => {\n212\t        await result.current.sendEvent({\n213\t          event_name: \"Page Viewed\",\n214\t          device_id: \"dev-2\",\n215\t        });\n216\t      });\n217\t      expect(result.current.lastDeviceId).toBe(\"dev-2\");\n218\t    });\n219\t  });\n220\t\n221\t  describe(\"sendSeed\", () => {\n222\t    it(\"calls POST /api/seed\", async () => {\n223\t      mockFetch.mockReturnValueOnce(makeOkResponse({})).mockReturnValueOnce(\n224\t        Promise.resolve({\n225\t          ok: true,\n226\t          status: 200,\n227\t          json: () => Promise.resolve({ event_count: 12000, user_count: 70 }),\n228\t        }),\n229\t      );\n230\t      const { result } = renderHook(() => useEventSender());\n231\t\n232\t      await act(async () => {\n233\t        await result.current.sendSeed();\n234\t      });\n235\t\n236\t      const seedCall = mockFetch.mock.calls[0] as [string, RequestInit];\n237\t      expect(seedCall[0]).toBe(\"/api/seed\");\n238\t      expect(seedCall[1].method).toBe(\"POST\");\n239\t    });\n240\t\n241\t    it(\"returns success: true and eventCount on success\", async () => {\n242\t      mockFetch.mockReturnValueOnce(makeOkResponse({})).mockReturnValueOnce(\n243\t        Promise.resolve({\n244\t          ok: true,\n245\t          status: 200,\n246\t          json: () => Promise.resolve({ event_count: 12000, user_count: 70 }),\n247\t        }),\n248\t      );\n249\t      const { result } = renderHook(() => useEventSender());\n250\t\n251\t      let seedResult!: { success: boolean; eventCount?: number };\n252\t      await act(async () => {\n253\t        seedResult = await result.current.sendSeed();\n254\t      });\n255\t\n256\t      expect(seedResult.success).toBe(true);\n257\t      expect(seedResult.eventCount).toBe(12000);\n258\t    });\n259\t\n260\t    it(\"returns success: false and error message when /api/seed returns an error\", async () => {\n261\t      mockFetch.mockReturnValue(\n262\t        makeErrorResponse(500, { error: \"Seed failed\" }),\n263\t      );\n264\t      const { result } = renderHook(() => useEventSender());\n265\t\n266\t      let seedResult!: { success: boolean; error?: string };\n267\t      await act(async () => {\n268\t        seedResult = await result.current.sendSeed();\n269\t      });\n270\t\n271\t      expect(seedResult.success).toBe(false);\n272\t      expect(seedResult.error).toBeTruthy();\n273\t    });\n274\t\n275\t    it(\"returns success: false when fetch throws (network error)\", async () => {\n276\t      mockFetch.mockReturnValue(Promise.reject(new Error(\"Network error\")));\n277\t      const { result } = renderHook(() => useEventSender());\n278\t\n279\t      let seedResult!: { success: boolean; error?: string };\n280\t      await act(async () => {\n281\t        seedResult = await result.current.sendSeed();\n282\t      });\n283\t\n284\t      expect(seedResult.success).toBe(false);\n285\t      expect(seedResult.error).toBeTruthy();\n286\t    });\n287\t  });\n288\t\n289\t  describe(\"loading state\", () => {\n290\t    it(\"is false before any request\", () => {\n291\t      const { result } = renderHook(() => useEventSender());\n292\t      expect(result.current.loading).toBe(false);\n293\t    });\n294\t\n295\t    it(\"is true during an in-flight sendEvent, false after completion\", async () => {\n296\t      let resolveRequest!: (v: unknown) => void;\n297\t      mockFetch.mockReturnValueOnce(\n298\t        new Promise((resolve) => {\n299\t          resolveRequest = resolve;\n300\t        }),\n301\t      );\n302\t\n303\t      const { result } = renderHook(() => useEventSender());\n304\t\n305\t      act(() => {\n306\t        void result.current.sendEvent({\n307\t          event_name: \"Page Viewed\",\n308\t          device_id: \"dev-1\",\n309\t        });\n310\t      });\n311\t\n312\t      await waitFor(() => expect(result.current.loading).toBe(true));\n313\t\n314\t      act(() => {\n315\t        resolveRequest({\n316\t          ok: true,\n317\t          status: 201,\n318\t          json: () => Promise.resolve({}),\n319\t        });\n320\t      });\n321\t\n322\t      await waitFor(() => expect(result.current.loading).toBe(false));\n323\t    });\n324\t\n325\t    it(\"is true during an in-flight sendSeed, false after completion\", async () => {\n326\t      let resolveRequest!: (v: unknown) => void;\n327\t      mockFetch.mockReturnValueOnce(\n328\t        new Promise((resolve) => {\n329\t          resolveRequest = resolve;\n330\t        }),\n331\t      );\n332\t\n333\t      const { result } = renderHook(() => useEventSender());\n334\t\n335\t      act(() => {\n336\t        void result.current.sendSeed();\n337\t      });\n338\t\n339\t      await waitFor(() => expect(result.current.loading).toBe(true));\n340\t\n341\t      act(() => {\n342\t        resolveRequest({\n343\t          ok: true,\n344\t          status: 200,\n345\t          json: () => Promise.resolve({}),\n346\t        });\n347\t      });\n348\t\n349\t      // After seed POST resolves, sendSeed then fetches /api/seed/status — mock that too\n350\t      mockFetch.mockReturnValueOnce(\n351\t        Promise.resolve({\n352\t          ok: true,\n353\t          status: 200,\n354\t          json: () => Promise.resolve({ event_count: 0, user_count: 0 }),\n355\t        }),\n356\t      );\n357\t\n358\t      await waitFor(() => expect(result.current.loading).toBe(false));\n359\t    });\n360\t  });\n361\t});\n362\t"}]},"parent_tool_use_id":"toolu_01LqCrFAeC5TM1G8mgQJxKzs","session_id":"4e2b9e14-c306-4c04-b64f-1d0d531c58b6","uuid":"1a5af768-402c-46ed-a967-e5a371f30146","timestamp":"2026-04-15T18:39:22.049Z"}
