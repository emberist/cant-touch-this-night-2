{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MPWAm7dTVjDhyxdiqjamL1","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\t// Hoist mock refs so vi.mock factory can reference them\n6\tconst { mockQuery, mockInvalidateSchemaCache } = vi.hoisted(() => ({\n7\t  mockQuery: vi.fn(),\n8\t  mockInvalidateSchemaCache: vi.fn(),\n9\t}));\n10\t\n11\tvi.mock(\"@/lib/clickhouse\", () => ({\n12\t  clickhouse: {\n13\t    query: mockQuery,\n14\t  },\n15\t}));\n16\t\n17\t// We need to control the cache for these tests — invalidate before each test\n18\tvi.mock(\"@/lib/schema-cache\", async (importOriginal) => {\n19\t  const actual = await importOriginal<typeof import(\"@/lib/schema-cache\")>();\n20\t  return {\n21\t    ...actual,\n22\t    invalidateSchemaCache: mockInvalidateSchemaCache.mockImplementation(\n23\t      actual.invalidateSchemaCache,\n24\t    ),\n25\t  };\n26\t});\n27\t\n28\timport { GET } from \"@/app/api/schema/route\";\n29\timport { invalidateSchemaCache } from \"@/lib/schema-cache\";\n30\t\n31\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n32\t\n33\tfunction makeRequest(): Request {\n34\t  return new Request(\"http://localhost/api/schema\");\n35\t}\n36\t\n37\t/** Build a ClickHouse query mock that returns the given rows */\n38\tfunction mockQueryReturns(rows: unknown[]) {\n39\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n40\t}\n41\t\n42\t// ─── Tests ────────────────────────────────────────────────────────────────────\n43\t\n44\tbeforeEach(() => {\n45\t  // Clear the real schema cache before every test\n46\t  invalidateSchemaCache();\n47\t  vi.clearAllMocks();\n48\t  // Re-apply default: no rows\n49\t  mockQueryReturns([]);\n50\t});\n51\t\n52\tafterEach(() => {\n53\t  vi.clearAllMocks();\n54\t});\n55\t\n56\tdescribe(\"GET /api/schema\", () => {\n57\t  describe(\"response shape\", () => {\n58\t    it(\"returns 200 with event_names array and properties object\", async () => {\n59\t      mockQueryReturns([]);\n60\t\n61\t      const res = await GET(makeRequest());\n62\t\n63\t      expect(res.status).toBe(200);\n64\t      const body = await res.json();\n65\t      expect(body).toHaveProperty(\"event_names\");\n66\t      expect(body).toHaveProperty(\"properties\");\n67\t      expect(Array.isArray(body.event_names)).toBe(true);\n68\t      expect(typeof body.properties).toBe(\"object\");\n69\t    });\n70\t\n71\t    it(\"returns empty event_names and properties when database has no events\", async () => {\n72\t      mockQueryReturns([]);\n73\t\n74\t      const res = await GET(makeRequest());\n75\t      const body = await res.json();\n76\t\n77\t      expect(body.event_names).toEqual([]);\n78\t      expect(body.properties).toEqual({});\n79\t    });\n80\t  });\n81\t\n82\t  describe(\"event names\", () => {\n83\t    it(\"returns distinct event names from ClickHouse results\", async () => {\n84\t      mockQuery.mockResolvedValueOnce({\n85\t        json: vi.fn().mockResolvedValue([\n86\t          {\n87\t            event_name: \"Page Viewed\",\n88\t            property_key: \"\",\n89\t            is_numeric: 0,\n90\t          },\n91\t          {\n92\t            event_name: \"Purchase Completed\",\n93\t            property_key: \"amount\",\n94\t            is_numeric: 1,\n95\t          },\n96\t        ]),\n97\t      });\n98\t\n99\t      const res = await GET(makeRequest());\n100\t      const body = await res.json();\n101\t\n102\t      expect(body.event_names).toContain(\"Page Viewed\");\n103\t      expect(body.event_names).toContain(\"Purchase Completed\");\n104\t    });\n105\t  });\n106\t\n107\t  describe(\"property type inference\", () => {\n108\t    it(\"infers 'numeric' type when is_numeric is truthy (1)\", async () => {\n109\t      mockQuery.mockResolvedValueOnce({\n110\t        json: vi.fn().mockResolvedValue([\n111\t          {\n112\t            event_name: \"Purchase Completed\",\n113\t            property_key: \"amount\",\n114\t            is_numeric: 1,\n115\t          },\n116\t        ]),\n117\t      });\n118\t\n119\t      const res = await GET(makeRequest());\n120\t      const body = await res.json();\n121\t\n122\t      expect(body.properties[\"Purchase Completed\"].amount).toBe(\"numeric\");\n123\t    });\n124\t\n125\t    it(\"infers 'string' type when is_numeric is falsy (0)\", async () => {\n126\t      mockQuery.mockResolvedValueOnce({\n127\t        json: vi.fn().mockResolvedValue([\n128\t          {\n129\t            event_name: \"Purchase Completed\",\n130\t            property_key: \"currency\",\n131\t            is_numeric: 0,\n132\t          },\n133\t        ]),\n134\t      });\n135\t\n136\t      const res = await GET(makeRequest());\n137\t      const body = await res.json();\n138\t\n139\t      expect(body.properties[\"Purchase Completed\"].currency).toBe(\"string\");\n140\t    });\n141\t\n142\t    it(\"handles mixed property types for the same event\", async () => {\n143\t      mockQuery.mockResolvedValueOnce({\n144\t        json: vi.fn().mockResolvedValue([\n145\t          {\n146\t            event_name: \"Purchase Completed\",\n147\t            property_key: \"amount\",\n148\t            is_numeric: 1,\n149\t          },\n150\t          {\n151\t            event_name: \"Purchase Completed\",\n152\t            property_key: \"currency\",\n153\t            is_numeric: 0,\n154\t          },\n155\t          {\n156\t            event_name: \"Purchase Completed\",\n157\t            property_key: \"plan\",\n158\t            is_numeric: 0,\n159\t          },\n160\t        ]),\n161\t      });\n162\t\n163\t      const res = await GET(makeRequest());\n164\t      const body = await res.json();\n165\t\n166\t      expect(body.properties[\"Purchase Completed\"]).toEqual({\n167\t        amount: \"numeric\",\n168\t        currency: \"string\",\n169\t        plan: \"string\",\n170\t      });\n171\t    });\n172\t  });\n173\t\n174\t  describe(\"caching\", () => {\n175\t    it(\"returns cached response on second call without re-querying ClickHouse\", async () => {\n176\t      mockQuery.mockResolvedValue({\n177\t        json: vi.fn().mockResolvedValue([]),\n178\t      });\n179\t\n180\t      // First call — populates cache\n181\t      await GET(makeRequest());\n182\t      // Second call — should use cache\n183\t      await GET(makeRequest());\n184\t\n185\t      // ClickHouse query should only have been called once\n186\t      expect(mockQuery).toHaveBeenCalledTimes(1);\n187\t    });\n188\t\n189\t    it(\"re-queries ClickHouse after cache is invalidated\", async () => {\n190\t      mockQuery.mockResolvedValue({\n191\t        json: vi.fn().mockResolvedValue([]),\n192\t      });\n193\t\n194\t      await GET(makeRequest());\n195\t      invalidateSchemaCache();\n196\t      await GET(makeRequest());\n197\t\n198\t      expect(mockQuery).toHaveBeenCalledTimes(2);\n199\t    });\n200\t  });\n201\t\n202\t  describe(\"events with no properties\", () => {\n203\t    it(\"includes event in event_names but with empty properties object when property_key is empty\", async () => {\n204\t      mockQuery.mockResolvedValueOnce({\n205\t        json: vi.fn().mockResolvedValue([\n206\t          {\n207\t            event_name: \"Page Viewed\",\n208\t            property_key: \"\",\n209\t            is_numeric: 0,\n210\t          },\n211\t        ]),\n212\t      });\n213\t\n214\t      const res = await GET(makeRequest());\n215\t      const body = await res.json();\n216\t\n217\t      expect(body.event_names).toContain(\"Page Viewed\");\n218\t      // An empty property_key means no properties — should have empty object or no key\n219\t      // The implementation should omit empty property keys\n220\t      if (\"Page Viewed\" in body.properties) {\n221\t        expect(body.properties[\"Page Viewed\"]).toEqual({});\n222\t      }\n223\t    });\n