match(/^(sum|avg|min|max):(.+)$/);\n56\t  if (match) {\n57\t    const fn = match[1];\n58\t    const prop = match[2];\n59\t    return `${fn}(JSONExtractFloat(e.properties, '${prop}'))`;\n60\t  }\n61\t  // Fallback — should be unreachable after route-level validation\n62\t  return \"count()\";\n63\t}\n64\t\n65\t/** Builds the SQL date-bucket expression for the given granularity. */\n66\tfunction buildBucketExpr(granularity: \"day\" | \"week\"): string {\n67\t  return granularity === \"week\"\n68\t    ? \"toMonday(e.timestamp)\"\n69\t    : \"toDate(e.timestamp)\";\n70\t}\n71\t\n72\t// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n73\t\n74\t/**\n75\t * Constructs the ClickHouse SQL query and bound parameters for a trends\n76\t * request. Exported for unit testing of SQL correctness.\n77\t */\n78\texport function buildTrendsQuery(params: TrendsParams): TrendsQuerySpec {\n79\t  const { event_name, measure, granularity, start, end, breakdown } = params;\n80\t\n81\t  const aggregateExpr = buildAggregateExpr(measure);\n82\t  const bucketExpr = buildBucketExpr(granularity);\n83\t  const needsJoin = measure === \"unique_users\";\n84\t\n85\t  const joinClause = needsJoin\n86\t    ? \"LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\\n      ON e.device_id = m.device_id\"\n87\t    : \"\";\n88\t\n89\t  const query_params: Record<string, string> = {\n90\t    event_name,\n91\t    start: `${start}T00:00:00.000Z`,\n92\t    end_exclusive: computeEndExclusive(end),\n93\t  };\n94\t\n95\t  if (breakdown) {\n96\t    const query = `\n97\t      SELECT\n98\t        ${bucketExpr} AS bucket,\n99\t        JSONExtractString(e.properties, '${breakdown}') AS breakdown_val,\n100\t        ${aggregateExpr} AS value\n101\t      FROM events e\n102\t      ${joinClause}\n103\t      WHERE e.event_name = {event_name:String}\n104\t        AND e.timestamp >= {start:String}\n105\t        AND e.timestamp < {end_exclusive:String}\n106\t      GROUP BY bucket, breakdown_val\n107\t      ORDER BY bucket ASC\n108\t    `.trim();\n109\t    return { query, query_params };\n110\t  }\n111\t\n112\t  const query = `\n113\t    SELECT\n114\t      ${bucketExpr} AS bucket,\n115\t      ${aggregateExpr} AS value\n116\t    FROM events e\n117\t    ${joinClause}\n118\t    WHERE e.event_name = {event_name:String}\n119\t      AND e.timestamp >= {start:String}\n120\t      AND e.timestamp < {end_exclusive:String}\n121\t    GROUP BY bucket\n122\t    ORDER BY bucket ASC\n123\t  `.trim();\n124\t\n125\t  return { query, query_params };\n126\t}\n127\t\n128\t// ─── queryTrends ──────────────────────────────────────────────────────────────\n129\t\n130\tinterface TrendsRow {\n131\t  bucket: string;\n132\t  value: number | string;\n133\t  breakdown_val?: string;\n134\t}\n135\t\n136\t/**\n137\t * Executes the trends query and transforms the raw ClickHouse rows into the\n138\t * series response shape.\n139\t *\n140\t * Without breakdown: returns a single series labelled with event_name.\n141\t * With breakdown:    returns one series per top-N breakdown value, with the\n142\t *                    remainder merged into an \"Other\" series.\n143\t */\n144\texport async function queryTrends(\n145\t  params: TrendsParams,\n146\t  client: ClickHouseClientLike = clickhouse,\n147\t): Promise<TrendsResponse> {\n148\t  const { event_name, breakdown, breakdown_limit = 10 } = params;\n149\t  const { query, query_params } = buildTrendsQuery(params);\n150\t\n151\t  const result = await client.query({\n152\t    query,\n153\t    query_params,\n154\t    format: \"JSONEachRow\",\n155\t  });\n156\t\n157\t  const rows = await result.json<TrendsRow>();\n158\t\n159\t  if (rows.length === 0) {\n160\t    return { series: [] };\n161\t  }\n162\t\n163\t  // ── No breakdown: single series ─────────────────────────────────────────────\n164\t\n165\t  if (!breakdown) {\n166\t    const data: SeriesPoint[] = rows.map((r) => ({\n167\t      date: r.bucket,\n168\t      value: Number(r.value),\n169\t    }));\n170\t    return { series: [{ label: event_name, data }] };\n171\t  }\n172\t\n173\t  // ── With breakdown: group rows by breakdown_val ───────────────────────────\n174\t\n175\t  const seriesMap = new Map<string, SeriesPoint[]>();\n176\t  const totalsByLabel = new Map<string, number>();\n177\t\n178\t  for (const row of rows) {\n179\t    const label = row.breakdown_val ?? \"\";\n180\t    const value = Number(row.value);\n181\t\n182\t    let points = seriesMap.get(label);\n183\t    if (points === undefined) {\n184\t      points = [];\n185\t      seriesMap.set(label, points);\n186\t      totalsByLabel.set(label, 0);\n187\t    }\n188\t    points.push({ date: row.bucket, value });\n189\t    totalsByLabel.set(label, (totalsByLabel.get(label) ?? 0) + value);\n190\t  }\n191\t\n192\t  // Sort by total descending to determine top-N\n193\t  const sorted = Array.from(totalsByLabel.entries()).sort(\n194\t    ([, a], [, b]) => b - a,\n195\t  );\n196\t\n197\t  const series: Series[] = [];\n198\t\n199\t  // Add top-N individual series\n200\t  for (const [label] of sorted.slice(0, breakdown_limit)) {\n201\t    series.push({ label, data: seriesMap.get(label) ?? [] });\n202\t  }\n203\t\n204\t  // Merge remaining values into \"Other\"\n205\t  const restEntries = sorted.slice(breakdown_limit);\n206\t  if (restEntries.length > 0) {\n207\t    const otherMap = new Map<string, number>();\n208\t    for (const [otherLabel] of restEntries) {\n209\t      for (const point of seriesMap.get(otherLabel) ?? []) {\n210\t        otherMap.set(point.date, (otherMap.get(point.date) ?? 0) + point.value);\n211\t      }\n212\t    }\n213\t    const otherData = Array.from(otherMap.entries())\n214\t      .sort(([a], [b]) => a.localeCompare(b))\n215\t      .map(([date, value]) => ({ date, value }));\n216\t    series.push({ label: \"Other\", data: otherData });\n217\t  }\n218\t\n219\t  return { series };\n220\t}\n221\t"}]},"parent_tool_use_id":null,"session_id":"13a87e50-7a8a-45d2-945a-473540951