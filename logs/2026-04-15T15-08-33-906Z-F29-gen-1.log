{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015CJrQeCgjZbACiWtrepj5K","type":"tool_result","content":"1\timport {\n2\t  afterEach,\n3\t  beforeAll,\n4\t  beforeEach,\n5\t  describe,\n6\t  expect,\n7\t  it,\n8\t  vi,\n9\t} from \"vitest\";\n10\t\n11\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n12\t\n13\tconst { mockCommand, mockInsert } = vi.hoisted(() => ({\n14\t  mockCommand: vi.fn(),\n15\t  mockInsert: vi.fn(),\n16\t}));\n17\t\n18\tvi.mock(\"@/lib/clickhouse\", () => ({\n19\t  clickhouse: {\n20\t    command: mockCommand,\n21\t    insert: mockInsert,\n22\t  },\n23\t}));\n24\t\n25\timport {\n26\t  buildIdentityMappings,\n27\t  generateEvents,\n28\t  generateUsers,\n29\t  seedData,\n30\t} from \"@/lib/seed\";\n31\t\n32\t// ─── Fixed date range for deterministic tests ─────────────────────────────────\n33\t\n34\tconst END_DATE = new Date(\"2026-04-15T00:00:00.000Z\");\n35\tconst START_DATE = new Date(END_DATE.getTime() - 30 * 24 * 60 * 60 * 1000);\n36\t\n37\t// ─── Global mock reset ────────────────────────────────────────────────────────\n38\t\n39\tbeforeEach(() => {\n40\t  mockCommand.mockResolvedValue(undefined);\n41\t  mockInsert.mockResolvedValue(undefined);\n42\t});\n43\t\n44\tafterEach(() => {\n45\t  vi.clearAllMocks();\n46\t});\n47\t\n48\t// ─── generateUsers ────────────────────────────────────────────────────────────\n49\t\n50\tdescribe(\"generateUsers\", () => {\n51\t  it(\"generates exactly 70 users in total\", () => {\n52\t    const users = generateUsers();\n53\t    expect(users).toHaveLength(70);\n54\t  });\n55\t\n56\t  it(\"generates exactly 50 fully-resolved users\", () => {\n57\t    const users = generateUsers();\n58\t    const fullyResolved = users.filter((u) => u.type === \"fully-resolved\");\n59\t    expect(fullyResolved).toHaveLength(50);\n60\t  });\n61\t\n62\t  it(\"generates exactly 10 multi-device users\", () => {\n63\t    const users = generateUsers();\n64\t    const multiDevice = users.filter((u) => u.type === \"multi-device\");\n65\t    expect(multiDevice).toHaveLength(10);\n66\t  });\n67\t\n68\t  it(\"generates exactly 10 anonymous-only users\", () => {\n69\t    const users = generateUsers();\n70\t    const anonymous = users.filter((u) => u.type === \"anonymous\");\n71\t    expect(anonymous).toHaveLength(10);\n72\t  });\n73\t\n74\t  it(\"multi-device users each have 2–3 device IDs\", () => {\n75\t    const users = generateUsers();\n76\t    const multiDevice = users.filter((u) => u.type === \"multi-device\");\n77\t    for (const user of multiDevice) {\n78\t      expect(user.deviceIds.length).toBeGreaterThanOrEqual(2);\n79\t      expect(user.deviceIds.length).toBeLessThanOrEqual(3);\n80\t    }\n81\t  });\n82\t\n83\t  it(\"anonymous-only users have at least one device_id but no user_id\", () => {\n84\t    const users = generateUsers();\n85\t    const anonymous = users.filter((u) => u.type === \"anonymous\");\n86\t    for (const user of anonymous) {\n87\t      expect(user.deviceIds.length).toBeGreaterThanOrEqual(1);\n88\t      expect(user.userId).toBeNull();\n89\t    }\n90\t  });\n91\t\n92\t  it(\"fully-resolved users have both user_id and device_id\", () => {\n93\t    const users = generateUsers();\n94\t    const fullyResolved = users.filter((u) => u.type === \"fully-resolved\");\n95\t    for (const user of fullyResolved) {\n96\t      expect(user.userId).not.toBeNull();\n97\t      expect(typeof user.userId).toBe(\"string\");\n98\t      expect(user.deviceIds.length).toBe(1);\n99\t    }\n100\t  });\n101\t\n102\t  it(\"multi-device users have a user_id\", () => {\n103\t    const users = generateUsers();\n104\t    const multiDevice = users.filter((u) => u.type === \"multi-device\");\n105\t    for (const user of multiDevice) {\n106\t      expect(user.userId).not.toBeNull();\n107\t      expect(typeof user.userId).toBe(\"string\");\n108\t    }\n109\t  });\n110\t});\n111\t\n112\t// ─── generateEvents ────────────────────────────────────────────────────────────\n113\t\n114\tdescribe(\"generateEvents\", () => {\n115\t  let users: ReturnType<typeof generateUsers>;\n116\t  let events: ReturnType<typeof generateEvents>;\n117\t\n118\t  beforeAll(() => {\n119\t    users = generateUsers();\n120\t    events = generateEvents(users, START_DATE, END_DATE);\n121\t  });\n122\t\n123\t  it(\"generates ~12,000 events (within ±500 of target)\", () => {\n124\t    expect(events.length).toBeGreaterThanOrEqual(11_500);\n125\t    expect(events.length).toBeLessThanOrEqual(12_500);\n126\t  });\n127\t\n128\t  it(\"all 6 event types are present\", () => {\n129\t    const eventNames = new Set(events.map((e) => e.event_name));\n130\t    expect(eventNames).toContain(\"Page Viewed\");\n131\t    expect(eventNames).toContain(\"Button Clicked\");\n132\t    expect(eventNames).toContain(\"Signup Completed\");\n133\t    expect(eventNames).toContain(\"Purchase Completed\");\n134\t    expect(eventNames).toContain(\"Subscription Renewed\");\n135\t    expect(eventNames).toContain(\"Support Ticket Opened\");\n136\t  });\n137\t\n138\t  it(\"Page Viewed constitutes approximately 40% of events (within ±5%)\", () => {\n139\t    const pageViewCount = events.filter(\n140\t      (e) => e.event_name === \"Page Viewed\",\n141\t    ).length;\n142\t    const fraction = pageViewCount / events.length;\n143\t    expect(fraction).toBeGreaterThanOrEqual(0.35);\n144\t    expect(fraction).toBeLessThanOrEqual(0.45);\n145\t  });\n146\t\n147\t  it(\"all event timestamps are within the supplied date range\", () => {\n148\t    const startMs = START_DATE.getTime();\n149\t    const endMs = END_DATE.getTime();\n150\t    for (const event of events) {\n151\t      const ts = new Date(event.timestamp).getTime();\n152\t      expect(ts).toBeGreaterThanOrEqual(startMs);\n153\t      expect(ts).toBeLessThanOrEqual(endMs);\n154\t    }\n155\t  });\n156\t\n157\t  it(\"Purchase Completed events have numeric amount in range 0–500\", () => {\n158\t    const purchases = events.filter(\n159\t      (e) => e.event_name === \"Purchase Completed\",\n160\t    );\n161\t    expect(purchases.length).toBeGreaterThan(0);\n162\t    for (const event of purchases.slice(0, 20)) {\n163\t      const props = JSON.parse(event.properties) as Record<string, unknown>;\n164\t      expect(typeof props.amount).toBe(\"number\");\n165\t      expect(props.amount as number).toBeGreaterThanOrEqual(0);\n166\t      expect(props.amount as number).toBeLessThanOrEqual(500);\n167\t    }\n168\t  });\n169\t\n170\t  it(\"Support Ticket Opened events have numeric ticket_count property\", () => {\n171\t    const tickets = events.filter(\n172\t      (e) => e.event_name === \"Support Ticket Opened\",\n173\t    );\n174\t    expect(tickets.length).toBeGreaterThan(0);\n175\t    for (const event of tickets.slice(0, 20)) {\n176\t      const props = JSON.parse(event.properties) as Record<string, unknown>;\n177\t      expect(typeof props.ticket_count).toBe(\"number\");\n178\t    }\n179\t  });\n180\t\n181\t  it(\"Page Viewed events have a page string property\", () => {\n182\t    const pageViews = events.filter((e) => e.event_name === \"Page Viewed\");\n183\t    expect(pageViews.length).toBeGreaterThan(0);\n184\t    for (const event of pageViews.slice(0, 20)) {\n185\t      const props = JSON.parse(event.properties) as Record<string, unknown>;\n186\t      expect(typeof props.page).toBe(\"string\");\n187\t    }\n188\t  });\n189\t\n190\t  it(\"Button Clicked events have a button_name string property\", () => {\n191\t    const clicks = events.filter((e) => e.event_name === \"Button Clicked\");\n192\t    expect(clicks.length).toBeGreaterThan(0);\n193\t    for (const event of clicks.slice(0, 20)) {\n194\t      const props = JSON.parse(event.properties) as Record<string, unknown>;\n195\t      expect(typeof props.button_name).toBe(\"string\");\n196\t    }\n197\t  });\n198\t\n199\t  it(\"Signup Completed events have plan and source string properties\", () => {\n200\t    const signups = events.filter((e) => e.event_name === \"Signup Completed\");\n201\t    expect(signups.length).toBeGreaterThan(0);\n202\t    for (const event of signups.slice(0, 20)) {\n203\t      const props = JSON.parse(event.properties) as Record<string, unknown>;\n204\t      expect(typeof props.plan).toBe(\"string\");\n205\t      expect(typeof props.source).toBe(\"string\");\n206\t    }\n207\t  });\n208\t\n209\t  it(\"Purchase Completed events have currency and plan string properties\", () => {\n210\t    const purchases = events.filter(\n211\t      (e) => e.event_name === \"Purchase Completed\",\n212\t    );\n213\t    expect(purchases.length).toBeGreaterThan(0);\n214\t    for (const event of purchases.slice(0, 20)) {\n215\t      const props = JSON.parse(event.properties) as Record<string, unknown>;\n216\t      expect(typeof props.currency).toBe(\"string\");\n217\t      expect(typeof props.plan).toBe(\"string\");\n218\t    }\n219\t  });\n220\t});\n221\t\n222\t// ─── buildIdentityMappings ────────────────────────────────────────────────────\n223\t\n224\tdescribe(\"buildIdentityMappings\", () => {\n225\t  it(\"creates exactly 1 mapping per device for fully-resolved users\", () => {\n226\t    const users = generateUsers();\n227\t    const mappings = buildIdentityMappings(users);\n228\t    const fullyResolved = users.filter((u) => u.type === \"fully-resolved\");\n229\t    const frMappings = mappings.filter((m) =>\n230\t      fullyResolved.some((u) => u.userId === m.user_id),\n231\t    );\n232\t    expect(frMappings).toHaveLength(50);\n233\t  });\n234\t\n235\t  it(\"creates mappings for each device of multi-device users\", () => {\n236\t    const users = generateUsers();\n237\t    const mappings = buildIdentityMappings(users);\n238\t    const multiDevice = users.filter((u) => u.type === \"multi-device\");\n239\t    for (const user of multiDevice) {\n240\t      const userMappings = mappings.filter((m) => m.user_id === user.userId);\n241\t      expect(userMappings).toHaveLength(user.deviceIds.length);\n242\t    }\n243\t  });\n244\t\n245\t  it(\"creates no mappings for anonymous-only users\", () => {\n246\t    const users = generateUsers();\n247\t    const mappings = buildIdentityMappings(users);\n248\t    const anonDeviceIds = new Set(\n249\t      users.filter((u) => u.type === \"anonymous\").flatMap((u) => u.deviceIds),\n250\t    );\n251\t    const anonMappings = mappings.filter((m) => anonDeviceIds.has(m.device_id));\n252\t    expect(anonMappings).toHaveLength(0);\n253\t  });\n254\t\n255\t  it(\"total mapping count is in range 70–80 (50 single + 10 × 2-3 multi)\", () => {\n256\t    const users = generateUsers();\n257\t    const mappings = buildIdentityMappings(users);\n258\t    expect(mappings.length).toBeGreaterThanOrEqual(70);\n259\t    expect(mappings.length).toBeLessThanOrEqual(80);\n260\t  });\n261\t});\n262\t\n263\t// ─── seedData ─────────────────────────────────────────────────────────────────\n264\t\n265\tdescribe(\"seedData\", () => {\n266\t  it(\"truncates the events table before inserting\", async () => {\n267\t    await seedData();\n268\t\n269\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n270\t    const eventsCall = mockCommand.mock.calls.find((c: any[]) => {\n271\t      const q: string = c[0].query;\n272\t      return q.toLowerCase().includes(\"truncate\") && q.includes(\"events\");\n273\t    });\n274\t    expect(eventsCall).toBeDefined();\n275\t  });\n276\t\n277\t  it(\"truncates the identity_mappings table before inserting\", async () => {\n278\t    await seedData();\n279\t\n280\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n281\t    const mappingsCall = mockCommand.mock.calls.find((c: any[]) => {\n282\t      const q: string = c[0].query;\n283\t      return (\n284\t        q.toLowerCase().includes(\"truncate\") && q.includes(\"identity_mappings\")\n285\t      );\n286\t    });\n287\t    expect(mappingsCall).toBeDefined();\n288\t  });\n289\t\n290\t  it(\"inserts events into the events table with ~12,000 rows\", async () => {\n291\t    await seedData();\n292\t\n293\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n294\t    const eventsInsert = mockInsert.mock.calls.find(\n295\t      (c: any[]) => c[0].table === \"events\",\n296\t    );\n297\t    expect(eventsInsert).toBeDefined();\n298\t    // biome-ignore lint/style/noNonNullAssertion: guarded by toBeDefined above\n299\t    expect(eventsInsert![0].values.length).toBeGreaterThanOrEqual(11_500);\n300\t    // biome-ignore lint/style/noNonNullAssertion: guarded by toBeDefined above\n301\t    expect(eventsInsert![0].values.length).toBeLessThanOrEqual(12_500);\n302\t  });\n303\t\n304\t  it(\"inserts identity mappings into the identity_mappings table (70–80 rows)\", async () => {\n305\t    await seedData();\n306\t\n307\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n308\t    const mappingsInsert = mockInsert.mock.calls.find(\n309\t      (c: any[]) => c[0].table === \"identity_mappings\",\n310\t    );\n311\t    expect(mappingsInsert).toBeDefined();\n312\t    // biome-ignore lint/style/noNonNullAssertion: guarded by toBeDefined above\n313\t    expect(mappingsInsert![0].values.length).toBeGreaterThanOrEqual(70);\n314\t    // biome-ignore lint/style/noNonNullAssertion: guarded by toBeDefined above\n315\t    expect(mappingsInsert![0].values.length).toBeLessThanOrEqual(80);\n316\t  });\n317\t\n318\t  it(\"returns event count and user count for non-anonymous users\", async () => {\n319\t    const result = await seedData();\n320\t\n321\t    expect(result.events).toBeGreaterThanOrEqual(11_500);\n322\t    expect(result.events).toBeLessThanOrEqual(12_500);\n323\t    expect(result.users).toBe(60); // 50 fully-resolved + 10 multi-device\n324\t  });\n325\t});\n326\t"}]},"parent_tool_use_id":null,"session_id":"52c67b30-c963-4107-9e63-08aed44dfce3","uuid":"95cdf6c8-590a-4e89-8959-176e40ea802d","timestamp":"2026-04-15T18:16:14.049Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/seed.test.ts","content":"import {\n  afterEach,\n  beforeAll,\n  beforeEach,\n  describe,\n  expect,\n  it,\n  vi,\n} from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockCommand, mockInsert } = vi.hoisted(() => ({\n  mockCommand: vi.fn(),\n  mockInsert: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    command: mockCommand,\n    insert: mockInsert,\n  },\n}));\n\nimport {\n  buildIdentityMappings,\n  generateEvents,\n  generateUsers,\n  seedData,\n} from \"@/lib/seed\";\n\n// ─── Fixed date range for deterministic tests ─────────────────────────────────\n\nconst END_DATE = new Date(\"2026-04-15T00:00:00.000Z\");\nconst START_DATE = new Date(END_DATE.getTime() - 30 * 24 * 60 * 60 * 1000);\n\n// ─── Global mock reset ────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockCommand.mockResolvedValue(undefined);\n  mockInsert.mockResolvedValue(undefined);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\n// ─── generateUsers ────────────────────────────────────────────────────────────\n\ndescribe(\"generateUsers\", () => {\n  it(\"generates exactly 70 users in total\", () => {\n    const users = generateUsers();\n    expect(users).toHaveLength(70);\n  });\n\n  it(\"generates exactly 50 fully-resolved users\", () => {\n    const users = generateUsers();\n    const fullyResolved = users.filter((u) => u.type === \"fully-resolved\");\n    expect(fullyResolved).toHaveLength(50);\n  });\n\n  it(\"generates exactly 10 multi-device users\", () => {\n    const users = generateUsers();\n    const multiDevice = users.filter((u) => u.type === \"multi-device\");\n    expect(multiDevice).toHaveLength(10);\n  });\n\n  it(\"generates exactly 10 anonymous-only users\", () => {\n    const users = generateUsers();\n    const anonymous = users.filter((u) => u.type === \"anonymous\");\n    expect(anonymous).toHaveLength(10);\n  });\n\n  it(\"multi-device users each have 2–3 device IDs\", () => {\n    const users = generateUsers();\n    const multiDevice = users.filter((u) => u.type === \"multi-device\");\n    for (const user of multiDevice) {\n      expect(user.deviceIds.length).toBeGreaterThanOrEqual(2);\n      expect(user.deviceIds.length).toBeLessThanOrEqual(3);\n    }\n  });\n\n  it(\"anonymous-only users have at least one device_id but no user_id\", () => {\n    const users = generateUsers();\n    const anonymous = users.filter((u) => u.type === \"anonymous\");\n    for (const user of anonymous) {\n      expect(user.deviceIds.length).toBeGreaterThanOrEqual(1);\n      expect(user.userId).toBeNull();\n    }\n  });\n\n  it(\"fully-resolved users have both user_id and device_id\", () => {\n    const users = generateUsers();\n    const fullyResolved = users.filter((u) => u.type === \"fully-resolved\");\n    for (const user of fullyResolved) {\n      expect(user.userId).not.toBeNull();\n      expect(typeof user.userId).toBe(\"string\");\n      expect(user.deviceIds.length).toBe(1);\n    }\n  });\n\n  it(\"multi-device users have a user_id\", () => {\n    const users = generateUsers();\n    const multiDevice = users.filter((u) => u.type === \"multi-device\");\n    for (const user of multiDevice) {\n      expect(user.userId).not.toBeNull();\n      expect(typeof user.userId).toBe(\"string\");\n    }\n  });\n});\n\n// ─── generateEvents ────────────────────────────────────────────────────────────\n\ndescribe(\"generateEvents\", () => {\n  let users: ReturnType<typeof generateUsers>;\n  let events: ReturnType<typeof generateEvents>;\n\n  beforeAll(() => {\n    users = generateUsers();\n    events = generateEvents(users, START_DATE, END_DATE);\n  });\n\n  it(\"generates ~12,000 events (within ±500 of target)\", () => {\n    expect(events.length).toBeGreaterThanOrEqual(11_500);\n    expect(events.length).toBeLessThanOrEqual(12_500);\n  });\n\n  it(\"all 6 event types are present\", () => {\n    const eventNames = new Set(events.map((e) => e.event_name));\n    expect(eventNames).toContain(\"Page Viewed\");\n    expect(eventNames).toContain(\"Button Clicked\");\n    expect(eventNames).toContain(\"Signup Completed\");\n    expect(eventNames).toContain(\"Purchase Completed\");\n    expect(eventNames).toContain(\"Subscription Renewed\");\n    expect(eventNames).toContain(\"Support Ticket Opened\");\n  });\n\n  it(\"Page Viewed constitutes approximately 40% of events (within ±5%)\", () => {\n    const pageViewCount = events.filter(\n      (e) => e.event_name === \"Page Viewed\",\n    ).length;\n    const fraction = pageViewCount / events.length;\n    expect(fraction).toBeGreaterThanOrEqual(0.35);\n    expect(fraction).toBeLessThanOrEqual(0.45);\n  });\n\n  it(\"all event timestamps are within the supplied date range\", () => {\n    const startMs = START_DATE.getTime();\n    const endMs = END_DATE.getTime();\n    for (const event of events) {\n      const ts = new Date(event.timestamp).getTime();\n      expect(ts).toBeGreaterThanOrEqual(startMs);\n      expect(ts).toBeLessThanOrEqual(endMs);\n    }\n  });\n\n  it(\"Purchase Completed events have numeric amount in range 0–500\", () => {\n    const purchases = events.filter(\n      (e) => e.event_name === \"Purchase Completed\",\n    );\n    expect(purchases.length).toBeGreaterThan(0);\n    for (const event of purchases.slice(0, 20)) {\n      const props = JSON.parse(event.properties) as Record<string, unknown>;\n      expect(typeof props.amount).toBe(\"number\");\n      expect(props.amount as number).toBeGreaterThanOrEqual(0);\n      expect(props.amount as number).toBeLessThanOrEqual(500);\n    }\n  });\n\n  it(\"Support Ticket Opened events have numeric ticket_count property\", () => {\n    const tickets = events.filter(\n      (e) => e.event_name === \"Support Ticket Opened\",\n    );\n    expect(tickets.length).toBeGreaterThan(0);\n    for (const event of tickets.slice(0, 20)) {\n      const props = JSON.parse(event.properties) as Record<string, unknown>;\n      expect(typeof props.ticket_count).toBe(\"number\");\n    }\n  });\n\n  it(\"Page Viewed events have a page string property\", () => {\n    const pageViews = events.filter((e) => e.event_name === \"Page Viewed\");\n    expect(pageViews.length).toBeGreaterThan(0);\n    for (const event of pageViews.slice(0, 20)) {\n      const props = JSON.parse(event.properties) as Record<string, unknown>;\n      expect(typeof props.page).toBe(\"string\");\n    }\n  });\n\n  it(\"Button Clicked events have a button_name string property\", () => {\n    const clicks = events.filter((e) => e.event_name === \"Button Clicked\");\n    expect(clicks.length).toBeGreaterThan(0);\n    for (const event of clicks.slice(0, 20)) {\n      const props = JSON.parse(event.properties) as Record<string, unknown>;\n      expect(typeof props.button_name).toBe(\"string\");\n    }\n  });\n\n  it(\"Signup Completed events have plan and source string properties\", () => {\n    const signups = events.filter((e) => e.event_name === \"Signup Completed\");\n    expect(signups.length).toBeGreaterThan(0);\n    for (const event of signups.slice(0, 20)) {\n      const props = JSON.parse(event.properties) as Record<string, unknown>;\n      expect(typeof props.plan).toBe(\"string\");\n      expect(typeof props.source).toBe(\"string\");\n    }\n  });\n\n  it(\"Purchase Completed events have currency and plan string properties\", () => {\n    const purchases = events.filter(\n      (e) => e.event_name === \"Purchase Completed\",\n    );\n    expect(purchases.length).toBeGreaterThan(0);\n    for (const event of purchases.slice(0, 20)) {\n      const props = JSON.parse(event.properties) as Record<string, unknown>;\n      expect(typeof props.currency).toBe(\"string\");\n      expect(typeof props.plan).toBe(\"string\");\n    }\n  });\n});\n\n// ─── buildIdentityMappings ────────────────────────────────────────────────────\n\ndescribe(\"buildIdentityMappings\", () => {\n  it(\"creates exactly 1 mapping per device for fully-resolved users\", () => {\n    const users = generateUsers();\n    const mappings = buildIdentityMappings(users);\n    const fullyResolved = users.filter((u) => u.type === \"fully-resolved\");\n    const frMappings = mappings.filter((m) =>\n      fullyResolved.some((u) => u.userId === m.user_id),\n    );\n    expect(frMappings).toHaveLength(50);\n  });\n\n  it(\"creates mappings for each device of multi-device users\", () => {\n    const users = generateUsers();\n    const mappings = buildIdentityMappings(users);\n    const multiDevice = users.filter((u) => u.type === \"multi-device\");\n    for (const user of multiDevice) {\n      const userMappings = mappings.filter((m) => m.user_id === user.userId);\n      expect(userMappings).toHaveLength(user.deviceIds.length);\n    }\n  });\n\n  it(\"creates no mappings for anonymous-only users\", () => {\n    const users = generateUsers();\n    const mappings = buildIdentityMappings(users);\n    const anonDeviceIds = new Set(\n      users.filter((u) => u.type === \"anonymous\").flatMap((u) => u.deviceIds),\n    );\n    const anonMappings = mappings.filter((m) => anonDeviceIds.has(m.device_id));\n    expect(anonMappings).toHaveLength(0);\n  });\n\n  it(\"total mapping count is in range 70–80 (50 single + 10 × 2-3 multi)\", () => {\n    const users = generateUsers();\n    const mappings = buildIdentityMappings(users);\n    expect(mappings.length).toBeGreaterThanOrEqual(70);\n    expect(mappings.length).toBeLessThanOrEqual(80);\n  });\n});\n\n// ─── seedData ─────────────────────────────────────────────────────────────────\n\ndescribe(\"seedData\", () => {\n  it(\"truncates the events table before inserting\", async () => {\n    await seedData();\n\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const eventsCall = mockCommand.mock.calls.find((c: any[]) => {\n      const q: string = c[0].query;\n      return q.toLowerCase().includes(\"truncate\") && q.includes(\"events\");\n    });\n    expect(eventsCall).toBeDefined();\n  });\n\n  it(\"truncates the identity_mappings table before inserting\", async () => {\n    await seedData();\n\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const mappingsCall = mockCommand.mock.calls.find((c: any[]) => {\n      const q: string = c[0].query;\n      return (\n        q.toLowerCase().includes(\"truncate\") && q.includes(\"identity_mappings\")\n      );\n    });\n    expect(mappingsCall).toBeDefined();\n  });\n\n  it(\"inserts events into the events table with ~12,000 rows\", async () => {\n    await seedData();\n\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const eventsInsert = mockInsert.mock.calls.find(\n      (c: any[]) => c[0].table === \"events\",\n    );\n    expect(eventsInsert).toBeDefined();\n    // biome-ignore lint/style/noNonNullAssertion: guarded by toBeDefined above\n    expect(eventsInsert![0].values.length).toBeGreaterThanOrEqual(11_500);\n    // biome-ignore lint/style/noNonNullAssertion: guarded by toBeDefined above\n    expect(eventsInsert![0].values.length).toBeLessThanOrEqual(12_500);\n  });\n\n  it(\"inserts identity mappings into the identity_mappings table (70–80 rows)\", async () => {\n    await seedData();\n\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const mappingsInsert = mockInsert.mock.calls.find(\n      (c: any[]) => c[0].table === \"identity_mappings\",\n    );\n    expect(mappingsInsert).toBeDefined();\n    // biome-ignore lint/style/noNonNullAssertion: guarded by toBeDefined above\n    expect(mappingsInsert![0].values.length).toBeGreaterThanOrEqual(70);\n    // biome-ignore lint/style/noNonNullAssertion: guarded by toBeDefined above\n    expect(mappingsInsert![0].values.length).toBeLessThanOrEqual(80);\n  });\n\n  it(\"returns event count and user count for non-anonymous users\", async () => {\n    const result = await seedData();\n\n    expect(result.events).toBeGreaterThanOrEqual(11_500);\n    expect(result.events).toBeLessThanOrEqual(12_500);\n    expect(result.users).toBe(60); // 50 fully-resolved + 10 multi-device\n  });\n});\n","numLines":326,"startLine":1,"totalLines":326}}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01C6WgLmhgMJYHJiH45GZ1QB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017xwyC6wFWYHHRS8mai7Dkv","name":"Read","input":{"file_path":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/identity.test.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1008,"cache_read_input_tokens":39990,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1008},"output_tokens":63,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"52c67b30-c963-4107-9e63-08aed44dfce3","uuid":"304f19c7-2297-4523-9226-cbcb1ebe1a75"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017xwyC6wFWYHHRS8mai7Dkv","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// Hoist mock refs so vi.mock factory can reference them\n4\tconst { mockQuery, mockInsert } = vi.hoisted(() => ({\n5\t  mockQuery: vi.fn(),\n6\t  mockInsert: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: {\n11\t    query: mockQuery,\n12\t    insert: mockInsert,\n13\t  },\n14\t}));\n15\t\n16\timport {\n17\t  IdentityConflictError,\n18\t  insertEvent,\n19\t  resolveIdentityMapping,\n20\t  validateEvent,\n21\t} from \"@/lib/identity\";\n22\t\n23\t// Helper: set up mockQuery to return a given rows array\n24\tfunction mockQueryReturns(rows: unknown[]) {\n25\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n26\t}\n27\t\n28\tbeforeEach(() => {\n29\t  // Default: no existing identity mapping, inserts succeed\n30\t  mockQueryReturns([]);\n31\t  mockInsert.mockResolvedValue(undefined);\n32\t});\n33\t\n34\tafterEach(() => {\n35\t  vi.clearAllMocks();\n36\t});\n37\t\n38\t// ─── validateEvent ────────────────────────────────────────────────────────────\n39\t\n40\tdescribe(\"validateEvent\", () => {\n41\t  it(\"rejects when both device_id and user_id are missing\", () => {\n42\t    expect(() => validateEvent({ event_name: \"Page Viewed\" })).toThrow();\n43\t  });\n44\t\n45\t  it(\"rejects when event_name is missing\", () => {\n46\t    expect(() => validateEvent({ device_id: \"dev-1\" })).toThrow();\n47\t  });\n48\t\n49\t  it(\"rejects when event_name is empty string\", () => {\n50\t    expect(() =>\n51\t      validateEvent({ event_name: \"\", device_id: \"dev-1\" }),\n52\t    ).toThrow();\n53\t  });\n54\t\n55\t  it(\"rejects when event_name is whitespace only\", () => {\n56\t    expect(() =>\n57\t      validateEvent({ event_name: \"  \", device_id: \"dev-1\" }),\n58\t    ).toThrow();\n59\t  });\n60\t\n61\t  it(\"accepts event with only device_id\", () => {\n62\t    expect(() =>\n63\t      validateEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n64\t    ).not.toThrow();\n65\t  });\n66\t\n67\t  it(\"accepts event with only user_id\", () => {\n68\t    expect(() =>\n69\t      validateEvent({ event_name: \"Page Viewed\", user_id: \"user@test.com\" }),\n70\t    ).not.toThrow();\n71\t  });\n72\t\n73\t  it(\"accepts event with both device_id and user_id\", () => {\n74\t    expect(() =>\n75\t      validateEvent({\n76\t        event_name: \"Signup Completed\",\n77\t        device_id: \"dev-1\",\n78\t        user_id: \"user@test.com\",\n79\t      }),\n80\t    ).not.toThrow();\n81\t  });\n82\t});\n83\t\n84\t// ─── insertEvent ──────────────────────────────────────────────────────────────\n85\t\n86\tdescribe(\"insertEvent\", () => {\n87\t  it(\"defaults timestamp to current time when not provided\", async () => {\n88\t    const before = Date.now();\n89\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n90\t    const after = Date.now();\n91\t\n92\t    const insertCall = mockInsert.mock.calls[0][0];\n93\t    const insertedTs = new Date(insertCall.values[0].timestamp).getTime();\n94\t    expect(insertedTs).toBeGreaterThanOrEqual(before);\n95\t    expect(insertedTs).toBeLessThanOrEqual(after);\n96\t  });\n97\t\n98\t  it(\"preserves caller-provided timestamp\", async () => {\n99\t    const ts = \"2026-01-15T10:30:00.000Z\";\n100\t    await insertEvent({\n101\t      event_name: \"Page Viewed\",\n102\t      device_id: \"dev-1\",\n103\t      timestamp: ts,\n104\t    });\n105\t\n106\t    const insertCall = mockInsert.mock.calls[0][0];\n107\t    expect(insertCall.values[0].timestamp).toBe(ts);\n108\t  });\n109\t\n110\t  it(\"inserts event into the events table\", async () => {\n111\t    await insertEvent({\n112\t      event_name: \"Purchase Completed\",\n113\t      user_id: \"user@test.com\",\n114\t      properties: { amount: 49.99 },\n115\t    });\n116\t\n117\t    expect(mockInsert).toHaveBeenCalledWith(\n118\t      expect.objectContaining({ table: \"events\" }),\n119\t    );\n120\t  });\n121\t\n122\t  it(\"stores event_name correctly in the inserted row\", async () => {\n123\t    await insertEvent({ event_name: \"Button Clicked\", device_id: \"dev-2\" });\n124\t\n125\t    const insertCall = mockInsert.mock.calls[0][0];\n126\t    expect(insertCall.values[0].event_name).toBe(\"Button Clicked\");\n127\t  });\n128\t\n129\t  it(\"serialises properties as a JSON string\", async () => {\n130\t    await insertEvent({\n131\t      event_name: \"Page Viewed\",\n132\t      device_id: \"dev-1\",\n133\t      properties: { page: \"/home\", count: 3 },\n134\t    });\n135\t\n136\t    const insertCall = mockInsert.mock.calls[0][0];\n137\t    expect(insertCall.values[0].properties).toBe(\n138\t      JSON.stringify({ page: \"/home\", count: 3 }),\n139\t    );\n140\t  });\n141\t\n142\t  it(\"defaults properties to '{}' when not provided\", async () => {\n143\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n144\t\n145\t    const insertCall = mockInsert.mock.calls[0][0];\n146\t    expect(insertCall.values[0].properties).toBe(\"{}\");\n147\t  });\n148\t\n149\t  it(\"calls resolveIdentityMapping (queries mappings) when both device_id and user_id are present\", async () => {\n150\t    await insertEvent({\n151\t      event_name: \"Signup Completed\",\n152\t      device_id: \"dev-1\",\n153\t      user_id: \"user@test.com\",\n154\t    });\n155\t\n156\t    // resolveIdentityMapping does a SELECT on identity_mappings\n157\t    expect(mockQuery).toHaveBeenCalled();\n158\t  });\n159\t\n160\t  it(\"does NOT call resolveIdentityMapping when only device_id is present\", async () => {\n161\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n162\t\n163\t    expect(mockQuery).not.toHaveBeenCalled();\n164\t  });\n165\t\n166\t  it(\"does NOT call resolveIdentityMapping when only user_id is present\", async () => {\n167\t    await insertEvent({\n168\t      event_name: \"Purchase Completed\",\n169\t      user_id: \"user@test.com\",\n170\t    });\n171\t\n172\t    expect(mockQuery).not.toHaveBeenCalled();\n173\t  });\n174\t\n175\t  it(\"returns an EventRow with resolved_id set to user_id when user_id is present\", async () => {\n176\t    const result = await insertEvent({\n177\t      event_name: \"Purchase Completed\",\n178\t      device_id: \"dev-1\",\n179\t      user_id: \"user@test.com\",\n180\t    });\n181\t\n182\t    expect(result.resolved_id).toBe(\"user@test.com\");\n183\t  });\n184\t\n185\t  it(\"returns an EventRow with resolved_id set to device_id when only device_id is present\", async () => {\n186\t    const result = await insertEvent({\n187\t      event_name: \"Page Viewed\",\n188\t      device_id: \"dev-1\",\n189\t    });\n190\t\n191\t    expect(result.resolved_id).toBe(\"dev-1\");\n192\t  });\n193\t});\n194\t\n195\t// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n196\t\n197\tdescribe(\"resolveIdentityMapping\", () => {\n198\t  it(\"inserts a new mapping when no existing mapping is found\", async () => {\n199\t    mockQueryReturns([]); // no existing mapping\n200\t\n201\t    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n202\t\n203\t    expect(mockInsert).toHaveBeenCalledWith(\n204\t      expect.objectContaining({\n205\t        table: \"identity_mappings\",\n206\t        values: [{ device_id: \"dev-1\", user_id: \"user@test.com\" }],\n207\t      }),\n208\t    );\n209\t  });\n210\t\n211\t  it(\"is a no-op when existing mapping has the same user_id\", async () => {\n212\t    mockQueryReturns([{ user_id: \"user@test.com\" }]); // same user already mapped\n213\t\n214\t    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n215\t\n216\t    expect(mockInsert).not.toHaveBeenCalled();\n217\t  });\n218\t\n219\t  it(\"throws IdentityConflictError when existing mapping has a different user_id\", async () => {\n220\t    mockQueryReturns([{ user_id: \"other@test.com\" }]); // different user already mapped\n221\t\n222\t    await expect(\n223\t      resolveIdentityMapping(\"dev-1\", \"user@test.com\"),\n224\t    ).rejects.toThrow(IdentityConflictError);\n225\t  });\n226\t\n227\t  it(\"IdentityConflictError has status 409\", async () => {\n228\t    mockQueryReturns([{ user_id: \"other@test.com\" }]);\n229\t\n230\t    try {\n231\t      await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n232\t      expect.fail(\"should have thrown\");\n233\t    } catch (err) {\n234\t      expect(err).toBeInstanceOf(IdentityConflictError);\n235\t      expect((err as IdentityConflictError).status).toBe(409);\n236\t    }\n237\t  });\n238\t});\n239\t"}]},"parent_tool_use_id":null,"session_id":"52c67b30-c963-4107-9e63-08aed44dfce3","uuid":"66035ab1-ccce-4707-9490-240b1197ca8a","timestamp":"2026-04-15T18:16:14.300Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/identity.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// Hoist mock refs so vi.mock factory can reference them\nconst { mockQuery, mockInsert } = vi.hoisted(() => ({\n  mockQuery: vi.fn(),\n  mockInsert: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    query: mockQuery,\n    insert: mockInsert,\n  },\n}));\n\nimport {\n  IdentityConflictError,\n  insertEvent,\n  resolveIdentityMapping,\n  validateEvent,\n} from \"@/lib/identity\";\n\n// Helper: set up mockQuery to return a given rows array\nfunction mockQueryReturns(rows: unknown[]) {\n  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n}\n\nbeforeEach(() => {\n  // Default: no existing identity mapping, inserts succeed\n  mockQueryReturns([]);\n  mockInsert.mockResolvedValue(undefined);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\n// ─── validateEvent ────────────────────────────────────────────────────────────\n\ndescribe(\"validateEvent\", () => {\n  it(\"rejects when both device_id and user_id are missing\", () => {\n    expect(() => validateEvent({ event_name: \"Page Viewed\" })).toThrow();\n  });\n\n  it(\"rejects when event_name is missing\", () => {\n    expect(() => validateEvent({ device_id: \"dev-1\" })).toThrow();\n  });\n\n  it(\"rejects when event_name is empty string\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"\", device_id: \"dev-1\" }),\n    ).toThrow();\n  });\n\n  it(\"rejects when event_name is whitespace only\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"  \", device_id: \"dev-1\" }),\n    ).toThrow();\n  });\n\n  it(\"accepts event with only device_id\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n    ).not.toThrow();\n  });\n\n  it(\"accepts event with only user_id\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"Page Viewed\", user_id: \"user@test.com\" }),\n    ).not.toThrow();\n  });\n\n  it(\"accepts event with both device_id and user_id\", () => {\n    expect(() =>\n      validateEvent({\n        event_name: \"Signup Completed\",\n        device_id: \"dev-1\",\n        user_id: \"user@test.com\",\n      }),\n    ).not.toThrow();\n  });\n});\n\n// ─── insertEvent ──────────────────────────────────────────────────────────────\n\ndescribe(\"insertEvent\", () => {\n  it(\"defaults timestamp to current time when not provided\", async () => {\n    const before = Date.now();\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n    const after = Date.now();\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    const insertedTs = new Date(insertCall.values[0].timestamp).getTime();\n    expect(insertedTs).toBeGreaterThanOrEqual(before);\n    expect(insertedTs).toBeLessThanOrEqual(after);\n  });\n\n  it(\"preserves caller-provided timestamp\", async () => {\n    const ts = \"2026-01-15T10:30:00.000Z\";\n    await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n      timestamp: ts,\n    });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].timestamp).toBe(ts);\n  });\n\n  it(\"inserts event into the events table\", async () => {\n    await insertEvent({\n      event_name: \"Purchase Completed\",\n      user_id: \"user@test.com\",\n      properties: { amount: 49.99 },\n    });\n\n    expect(mockInsert).toHaveBeenCalledWith(\n      expect.objectContaining({ table: \"events\" }),\n    );\n  });\n\n  it(\"stores event_name correctly in the inserted row\", async () => {\n    await insertEvent({ event_name: \"Button Clicked\", device_id: \"dev-2\" });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].event_name).toBe(\"Button Clicked\");\n  });\n\n  it(\"serialises properties as a JSON string\", async () => {\n    await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n      properties: { page: \"/home\", count: 3 },\n    });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].properties).toBe(\n      JSON.stringify({ page: \"/home\", count: 3 }),\n    );\n  });\n\n  it(\"defaults properties to '{}' when not provided\", async () => {\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].properties).toBe(\"{}\");\n  });\n\n  it(\"calls resolveIdentityMapping (queries mappings) when both device_id and user_id are present\", async () => {\n    await insertEvent({\n      event_name: \"Signup Completed\",\n      device_id: \"dev-1\",\n      user_id: \"user@test.com\",\n    });\n\n    // resolveIdentityMapping does a SELECT on identity_mappings\n    expect(mockQuery).toHaveBeenCalled();\n  });\n\n  it(\"does NOT call resolveIdentityMapping when only device_id is present\", async () => {\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n\n    expect(mockQuery).not.toHaveBeenCalled();\n  });\n\n  it(\"does NOT call resolveIdentityMapping when only user_id is present\", async () => {\n    await insertEvent({\n      event_name: \"Purchase Completed\",\n      user_id: \"user@test.com\",\n    });\n\n    expect(mockQuery).not.toHaveBeenCalled();\n  });\n\n  it(\"returns an EventRow with resolved_id set to user_id when user_id is present\", async () => {\n    const result = await insertEvent({\n      event_name: \"Purchase Completed\",\n      device_id: \"dev-1\",\n      user_id: \"user@test.com\",\n    });\n\n    expect(result.resolved_id).toBe(\"user@test.com\");\n  });\n\n  it(\"returns an EventRow with resolved_id set to device_id when only device_id is present\", async () => {\n    const result = await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n    });\n\n    expect(result.resolved_id).toBe(\"dev-1\");\n  });\n});\n\n// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n\ndescribe(\"resolveIdentityMapping\", () => {\n  it(\"inserts a new mapping when no existing mapping is found\", async () => {\n    mockQueryReturns([]); // no existing mapping\n\n    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n\n    expect(mockInsert).toHaveBeenCalledWith(\n      expect.objectContaining({\n        table: \"identity_mappings\",\n        values: [{ device_id: \"dev-1\", user_id: \"user@test.com\" }],\n      }),\n    );\n  });\n\n  it(\"is a no-op when existing mapping has the same user_id\", async () => {\n    mockQueryReturns([{ user_id: \"user@test.com\" }]); // same user already mapped\n\n    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n\n    expect(mockInsert).not.toHaveBeenCalled();\n  });\n\n  it(\"throws IdentityConflictError when existing mapping has a different user_id\", async () => {\n    mockQueryReturns([{ user_id: \"other@test.com\" }]); // different user already mapped\n\n    await expect(\n      resolveIdentityMapping(\"dev-1\", \"user@test.com\"),\n    ).rejects.toThrow(IdentityConflictError);\n  });\n\n  it(\"IdentityConflictError has status 409\", async () => {\n    mockQueryReturns([{ user_id: \"other@test.com\" }]);\n\n    try {\n      await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n      expect.fail(\"should have thrown\");\n    } catch (err) {\n      expect(err).toBeInstanceOf(IdentityConflictError);\n      expect((err as IdentityConflictError).status).toBe(409);\n    }\n  });\n});\n","numLines":239,"startLine":1,"totalLines":239}}}
