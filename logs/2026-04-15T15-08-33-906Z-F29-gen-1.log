{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CP7bnmgQ23buNX37eJxitt","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQuery } = vi.hoisted(() => ({\n6\t  mockQuery: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: { query: mockQuery },\n11\t}));\n12\t\n13\timport { queryNewEvents } from \"@/lib/live\";\n14\t\n15\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n16\t\n17\tfunction mockQueryReturns(rows: unknown[]) {\n18\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n19\t}\n20\t\n21\tconst sampleEvents = [\n22\t  {\n23\t    event_id: \"evt-1\",\n24\t    event_name: \"Page Viewed\",\n25\t    timestamp: \"2026-04-15 12:00:00.000\",\n26\t    device_id: \"device-abc\",\n27\t    user_id: null,\n28\t    properties: \"{}\",\n29\t    ingested_at: \"2026-04-15 12:00:01.000\",\n30\t    resolved_id: \"device-abc\",\n31\t  },\n32\t];\n33\t\n34\t// ─── Tests ────────────────────────────────────────────────────────────────────\n35\t\n36\tbeforeEach(() => {\n37\t  mockQueryReturns([]);\n38\t});\n39\t\n40\tafterEach(() => {\n41\t  vi.clearAllMocks();\n42\t});\n43\t\n44\tdescribe(\"queryNewEvents\", () => {\n45\t  it(\"calls ClickHouse with SQL containing ingested_at > {since:String}\", async () => {\n46\t    await queryNewEvents(\"2026-04-15 12:00:00.000\");\n47\t\n48\t    expect(mockQuery).toHaveBeenCalledOnce();\n49\t    const { query } = mockQuery.mock.calls[0][0] as { query: string };\n50\t    expect(query).toContain(\"e.ingested_at > {since:String}\");\n51\t  });\n52\t\n53\t  it(\"queries with a LEFT JOIN on identity_mappings FINAL for resolved_id\", async () => {\n54\t    await queryNewEvents(\"2026-04-15 12:00:00.000\");\n55\t\n56\t    const { query } = mockQuery.mock.calls[0][0] as { query: string };\n57\t    expect(query).toContain(\"identity_mappings FINAL\");\n58\t    expect(query).toContain(\"coalesce(e.user_id, m.user_id, e.device_id)\");\n59\t  });\n60\t\n61\t  it(\"passes the sinceIngestedAt value as the since query_param\", async () => {\n62\t    const since = \"2026-04-15 11:00:00.000\";\n63\t    await queryNewEvents(since);\n64\t\n65\t    const { query_params } = mockQuery.mock.calls[0][0] as {\n66\t      query_params: Record<string, string>;\n67\t    };\n68\t    expect(query_params).toEqual(expect.objectContaining({ since }));\n69\t  });\n70\t\n71\t  it(\"returns the parsed JSON rows from the ClickHouse result\", async () => {\n72\t    mockQueryReturns(sampleEvents);\n73\t\n74\t    const result = await queryNewEvents(\"2026-04-15 12:00:00.000\");\n75\t\n76\t    expect(result).toEqual(sampleEvents);\n77\t  });\n78\t\n79\t  it(\"returns an empty array when no new events exist\", async () => {\n80\t    mockQueryReturns([]);\n81\t\n82\t    const result = await queryNewEvents(\"2026-04-15 12:00:00.000\");\n83\t\n84\t    expect(result).toEqual([]);\n85\t  });\n86\t});\n87\t"}]},"parent_tool_use_id":null,"session_id":"52c67b30-c963-4107-9e63-08aed44dfce3","uuid":"958c2b60-9899-4ec4-8063-c8c919047555","timestamp":"2026-04-15T18:16:24.113Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/live.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockQuery } = vi.hoisted(() => ({\n  mockQuery: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: { query: mockQuery },\n}));\n\nimport { queryNewEvents } from \"@/lib/live\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction mockQueryReturns(rows: unknown[]) {\n  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n}\n\nconst sampleEvents = [\n  {\n    event_id: \"evt-1\",\n    event_name: \"Page Viewed\",\n    timestamp: \"2026-04-15 12:00:00.000\",\n    device_id: \"device-abc\",\n    user_id: null,\n    properties: \"{}\",\n    ingested_at: \"2026-04-15 12:00:01.000\",\n    resolved_id: \"device-abc\",\n  },\n];\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockQueryReturns([]);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\ndescribe(\"queryNewEvents\", () => {\n  it(\"calls ClickHouse with SQL containing ingested_at > {since:String}\", async () => {\n    await queryNewEvents(\"2026-04-15 12:00:00.000\");\n\n    expect(mockQuery).toHaveBeenCalledOnce();\n    const { query } = mockQuery.mock.calls[0][0] as { query: string };\n    expect(query).toContain(\"e.ingested_at > {since:String}\");\n  });\n\n  it(\"queries with a LEFT JOIN on identity_mappings FINAL for resolved_id\", async () => {\n    await queryNewEvents(\"2026-04-15 12:00:00.000\");\n\n    const { query } = mockQuery.mock.calls[0][0] as { query: string };\n    expect(query).toContain(\"identity_mappings FINAL\");\n    expect(query).toContain(\"coalesce(e.user_id, m.user_id, e.device_id)\");\n  });\n\n  it(\"passes the sinceIngestedAt value as the since query_param\", async () => {\n    const since = \"2026-04-15 11:00:00.000\";\n    await queryNewEvents(since);\n\n    const { query_params } = mockQuery.mock.calls[0][0] as {\n      query_params: Record<string, string>;\n    };\n    expect(query_params).toEqual(expect.objectContaining({ since }));\n  });\n\n  it(\"returns the parsed JSON rows from the ClickHouse result\", async () => {\n    mockQueryReturns(sampleEvents);\n\n    const result = await queryNewEvents(\"2026-04-15 12:00:00.000\");\n\n    expect(result).toEqual(sampleEvents);\n  });\n\n  it(\"returns an empty array when no new events exist\", async () => {\n    mockQueryReturns([]);\n\n    const result = await queryNewEvents(\"2026-04-15 12:00:00.000\");\n\n    expect(result).toEqual([]);\n  });\n});\n","numLines":87,"startLine":1,"totalLines":87}}}
