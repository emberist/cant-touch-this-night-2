{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QT2G5mc9t4yzKnxppLYtkR","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQuery } = vi.hoisted(() => ({\n6\t  mockQuery: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: {\n11\t    query: mockQuery,\n12\t  },\n13\t}));\n14\t\n15\timport { buildTrendsQuery, queryTrends } from \"@/lib/trends\";\n16\t\n17\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n18\t\n19\tfunction mockQueryReturns(rows: unknown[]) {\n20\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n21\t}\n22\t\n23\tconst baseParams = {\n24\t  event_name: \"Page Viewed\",\n25\t  measure: \"count\",\n26\t  granularity: \"day\" as const,\n27\t  start: \"2026-04-01\",\n28\t  end: \"2026-04-15\",\n29\t};\n30\t\n31\t// ─── Tests ────────────────────────────────────────────────────────────────────\n32\t\n33\tbeforeEach(() => {\n34\t  mockQueryReturns([]);\n35\t});\n36\t\n37\tafterEach(() => {\n38\t  vi.clearAllMocks();\n39\t});\n40\t\n41\t// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n42\t\n43\tdescribe(\"buildTrendsQuery\", () => {\n44\t  describe(\"measure expressions\", () => {\n45\t    it(\"uses count() for measure=count\", () => {\n46\t      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n47\t      expect(query).toContain(\"count()\");\n48\t    });\n49\t\n50\t    it(\"uses uniqExact and identity_mappings FINAL for measure=unique_users\", () => {"}]},"parent_tool_use_id":null,"session_id":"52c67b30-c963-4107-9e63-08aed44dfce3","uuid":"b6ffa568-08d5-4439-ac69-95d19df8daa8","timestamp":"2026-04-15T18:19:03.703Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/trends.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockQuery } = vi.hoisted(() => ({\n  mockQuery: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    query: mockQuery,\n  },\n}));\n\nimport { buildTrendsQuery, queryTrends } from \"@/lib/trends\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction mockQueryReturns(rows: unknown[]) {\n  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n}\n\nconst baseParams = {\n  event_name: \"Page Viewed\",\n  measure: \"count\",\n  granularity: \"day\" as const,\n  start: \"2026-04-01\",\n  end: \"2026-04-15\",\n};\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockQueryReturns([]);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\n// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n\ndescribe(\"buildTrendsQuery\", () => {\n  describe(\"measure expressions\", () => {\n    it(\"uses count() for measure=count\", () => {\n      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n      expect(query).toContain(\"count()\");\n    });\n\n    it(\"uses uniqExact and identity_mappings FINAL for measure=unique_users\", () => {","numLines":50,"startLine":1,"totalLines":359}}}
