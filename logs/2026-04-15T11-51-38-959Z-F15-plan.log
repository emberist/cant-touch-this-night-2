{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KwQNT14a6MS4AU2UDYcCAP","type":"tool_result","content":"1\timport { IdentityConflictError, insertEvent } from \"@/lib/identity\";\n2\t\n3\tinterface BatchError {\n4\t  index: number;\n5\t  error: string;\n6\t}\n7\t\n8\tinterface BatchResult {\n9\t  ok: number;\n10\t  errors: BatchError[];\n11\t}\n12\t\n13\texport async function POST(request: Request): Promise<Response> {\n14\t  let body: unknown;\n15\t\n16\t  try {\n17\t    body = await request.json();\n18\t  } catch {\n19\t    return Response.json({ error: \"Invalid JSON body.\" }, { status: 400 });\n20\t  }\n21\t\n22\t  if (!Array.isArray(body)) {\n23\t    return Response.json(\n24\t      { error: \"Request body must be an array of events.\" },\n25\t      { status: 400 },\n26\t    );\n27\t  }\n28\t\n29\t  const result: BatchResult = { ok: 0, errors: [] };\n30\t\n31\t  for (let i = 0; i < body.length; i++) {\n32\t    try {\n33\t      await insertEvent(body[i]);\n34\t      result.ok++;\n35\t    } catch (error) {\n36\t      if (error instanceof IdentityConflictError || error instanceof Error) {\n37\t        result.errors.push({ index: i, error: (error as Error).message });\n38\t      } else {\n39\t        result.errors.push({ index: i, error: \"Unexpected error.\" });\n40\t      }\n41\t    }\n42\t  }\n43\t\n44\t  return Response.json(result, { status: 200 });\n45\t}\n46\t"}]},"parent_tool_use_id":null,"session_id":"4be8c427-9bf2-4bd6-a56a-43dcb0374fe5","uuid":"a15495f7-62d4-49e3-b589-37d9b2ac6749","timestamp":"2026-04-15T14:24:27.291Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/events/batch/route.ts","content":"import { IdentityConflictError, insertEvent } from \"@/lib/identity\";\n\ninterface BatchError {\n  index: number;\n  error: string;\n}\n\ninterface BatchResult {\n  ok: number;\n  errors: BatchError[];\n}\n\nexport async function POST(request: Request): Promise<Response> {\n  let body: unknown;\n\n  try {\n    body = await request.json();\n  } catch {\n    return Response.json({ error: \"Invalid JSON body.\" }, { status: 400 });\n  }\n\n  if (!Array.isArray(body)) {\n    return Response.json(\n      { error: \"Request body must be an array of events.\" },\n      { status: 400 },\n    );\n  }\n\n  const result: BatchResult = { ok: 0, errors: [] };\n\n  for (let i = 0; i < body.length; i++) {\n    try {\n      await insertEvent(body[i]);\n      result.ok++;\n    } catch (error) {\n      if (error instanceof IdentityConflictError || error instanceof Error) {\n        result.errors.push({ index: i, error: (error as Error).message });\n      } else {\n        result.errors.push({ index: i, error: \"Unexpected error.\" });\n      }\n    }\n  }\n\n  return Response.json(result, { status: 200 });\n}\n","numLines":46,"startLine":1,"totalLines":46}}}
