ect.any(String),\n58\t        last_seen: expect.any(String),\n59\t        identity_cluster: expect.objectContaining({\n60\t          user_ids: expect.any(Array),\n61\t          device_ids: expect.any(Array),\n62\t        }),\n63\t        events: expect.any(Array),\n64\t      });\n65\t    });\n66\t\n67\t    it(\"passes the id to getUserProfile\", async () => {\n68\t      const [req, ctx] = makeRequest(\"user@test.com\");\n69\t      await GET(req, ctx);\n70\t\n71\t      expect(mockGetUserProfile).toHaveBeenCalledWith(\"user@test.com\");\n72\t    });\n73\t  });\n74\t\n75\t  describe(\"not found — 404\", () => {\n76\t    it(\"returns 404 with error when user not found\", async () => {\n77\t      mockGetUserProfile.mockResolvedValue(null);\n78\t\n79\t      const [req, ctx] = makeRequest(\"nonexistent@test.com\");\n80\t      const res = await GET(req, ctx);\n81\t\n82\t      expect(res.status).toBe(404);\n83\t      const body = await res.json();\n84\t      expect(body).toHaveProperty(\"error\");\n85\t      expect(typeof body.error).toBe(\"string\");\n86\t    });\n87\t  });\n88\t\n89\t  describe(\"error handling — 500\", () => {\n90\t    it(\"returns 500 when getUserProfile throws\", async () => {\n91\t      mockGetUserProfile.mockRejectedValue(\n92\t        new Error(\"ClickHouse connection failed\"),\n93\t      );\n94\t\n95\t      const [req, ctx] = makeRequest(\"user@test.com\");\n96\t      const res = await GET(req, ctx);\n97\t\n98\t      expect(res.status).toBe(500);\n99\t      const body = await res.json();\n100\t      expect(body).toHaveProperty(\"error\");\n101\t    });\n102\t  });\n103\t});\n104\t"}]},"parent_tool_use_id":null,"session_id":"9c234dbc-dbf6-42cf-8033-f4aee2b335fd","uuid":"4d849f9c-3190-4faf-a436-79bf12d99787","timestamp":"2026-04-15T14:19:20.699Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/users/[id]/__tests__/route.test.ts","content":"import { afterEach, beforeEach, descr