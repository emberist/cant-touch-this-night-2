{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Nb2t882ZtTt9NHAcEiv5Nd","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { cleanup, render, screen, waitFor } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport { EventFilterBar } from \"@/components/explore/EventFilterBar\";\n5\t\n6\tconst mockFetch = vi.fn();\n7\t\n8\tbeforeEach(() => {\n9\t  vi.stubGlobal(\"fetch\", mockFetch);\n10\t});\n11\t\n12\tafterEach(() => {\n13\t  cleanup();\n14\t  vi.clearAllMocks();\n15\t  vi.unstubAllGlobals();\n16\t});\n17\t\n18\tfunction makeSchemaResponse(event_names: string[]) {\n19\t  return Promise.resolve({\n20\t    ok: true,\n21\t    json: () => Promise.resolve({ event_names }),\n22\t  });\n23\t}\n24\t\n25\tdescribe(\"EventFilterBar\", () => {\n26\t  it(\"fetches event names from /api/schema on mount\", async () => {\n27\t    mockFetch.mockReturnValue(\n28\t      makeSchemaResponse([\"Page Viewed\", \"Purchase Completed\"]),\n29\t    );\n30\t    render(<EventFilterBar onFilterChange={vi.fn()} />);\n31\t    await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(1));\n32\t    const url = mockFetch.mock.calls[0][0] as string;\n33\t    expect(url).toContain(\"/api/schema\");\n34\t  });\n35\t\n36\t  it(\"renders the filter input\", () => {\n37\t    mockFetch.mockReturnValue(makeSchemaResponse([]));\n38\t    render(<EventFilterBar onFilterChange={vi.fn()} />);\n39\t    // MUI Autocomplete renders a combobox input\n40\t    expect(screen.getByRole(\"combobox\")).toBeTruthy();\n41\t  });\n42\t\n43\t  it(\"does not crash when schema fetch fails\", async () => {\n44\t    mockFetch.mockReturnValue(Promise.reject(new Error(\"network error\")));\n45\t    render(<EventFilterBar onFilterChange={vi.fn()} />);\n46\t    // Should still render a functional input\n47\t    expect(screen.getByRole(\"combobox\")).toBeTruthy();\n48\t  });\n49\t});\n50\t"}]},"parent_tool_use_id