{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T3uvZo7mA5rCDGmihZxvUG","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\t\n3\t// ─── Types ────────────────────────────────────────────────────────────────────\n4\t\n5\texport interface TrendsParams {\n6\t  event_name: string;\n7\t  /** \"count\" | \"unique_users\" | \"sum:<prop>\" | \"avg:<prop>\" | \"min:<prop>\" | \"max:<prop>\" */\n8\t  measure: string;\n9\t  granularity: \"day\" | \"week\";\n10\t  /** ISO date string (YYYY-MM-DD) — inclusive lower bound */\n11\t  start: string;\n12\t  /** ISO date string (YYYY-MM-DD) — inclusive upper bound */\n13\t  end: string;\n14\t  breakdown?: string;\n15\t  breakdown_limit?: number;\n16\t}\n17\t\n18\texport interface SeriesPoint {\n19\t  date: string;\n20\t  value: number;\n21\t}\n22\t\n23\texport interface Series {\n24\t  label: string;\n25\t  data: SeriesPoint[];\n26\t}\n27\t\n28\texport interface TrendsResponse {\n29\t  series: Series[];\n30\t}\n31\t\n32\texport interface TrendsQuerySpec {\n33\t  query: string;\n34\t  query_params: Record<string, string>;\n35\t}\n36\t\n37\t// ─── Type alias for the ClickHouse client ────────────────────────────────────\n38\t\n39\ttype ClickHouseClientLike = typeof clickhouse;\n40\t\n41\t// ─── Internal helpers ─────────────────────────────────────────────────────────\n42\t\n43\t/** Returns the exclusive upper bound timestamp for the given ISO date.\n44\t *  Returns ClickHouse-compatible format: \"YYYY-MM-DD HH:MM:SS.mmm\" (no T/Z).\n45\t */\n46\tfunction computeEndExclusive(end: string): string {\n47\t  const [y, m, d] = end.split(\"-\").map(Number);\n48\t  const dt = new Date(Date.UTC(y, m - 1, d + 1));\n49\t  const year = dt.getUTCFullYear();\n50\t  const month = String(dt.getUTCMonth() + 1).padStart(2, \"0\");\n51\t  const day = String(dt.getUTCDate()).padStart(2, \"0\");\n52\t  return `${year}-${month}-${day} 00:00:00.000`;\n53\t}\n54\t\n55\t/** Builds the SQL aggregate expression for the given measure. */\n56\tfunction buildAggregateExpr(measure: string): string {\n57\t  if (measure === \"count\") return \"count()\";\n58\t  if (measure === \"unique_users\") {\n59\t    return \"uniqExact(coalesce(e.user_id, m.user_id, e.device_id))\";\n60\t  }\n61\t  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n62\t  if (match) {\n63\t    const fn = match[1];\n64\t    const prop = match[2];\n65\t    return `${fn}(JSONExtractFloat(e.properties, '${prop}'))`;\n66\t  }\n67\t  // Fallback — should be unreachable after route-level validation\n68\t  return \"count()\";\n69\t}\n70\t\n71\t/** Builds the SQL date-bucket expression for the given granularity. */\n72\tfunction buildBucketExpr(granularity: \"day\" | \"week\"): string {\n73\t  return granularity === \"week\"\n74\t    ? \"toMonday(e.timestamp)\"\n75\t    : \"toDate(e.timestamp)\";\n76\t}\n77\t\n78\t// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n79\t\n80\t/**\n81\t * Constructs the ClickHouse SQL query and bound parameters for a trends\n82\t * request. Exported for unit testing of SQL correctness.\n83\t */\n84\texport function buildTrendsQuery(params: TrendsParams): TrendsQuerySpec {\n85\t  const { event_name, measure, granularity, start, end, breakdown } = params;\n86\t\n87\t  const aggregateExpr = buildAggregateExpr(measure);\n88\t  const bucketExpr = buildBucketExpr(granularity);\n89\t  const needsJoin = measure === \"unique_users\";\n90\t\n91\t  const joinClause = needsJoin\n92\t    ? \"LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\\n      ON e.device_id = m.device_id\"\n93\t    : \"\";\n94\t\n95\t  const query_params: Record<string, string> = {\n96\t    event_name,\n97\t    start: `${start} 00:00:00.000`,\n98\t    end_exclusive: computeEndExclusive(end),\n99\t  };\n100\t\n101\t  if (breakdown) {\n102\t    const query = `\n103\t      SELECT\n104\t        ${bucketExpr} AS bucket,\n105\t        JSONExtractString(e.properties, '${breakdown}') AS breakdown_val,\n106\t        ${aggregateExpr} AS value\n107\t      FROM events e\n108\t      ${joinClause}\n109\t      WHERE e.event_name = {event_name:String}\n110\t        AND e.timestamp >= {start:String}\n111\t        AND e.timestamp < {end_exclusive:String}\n112\t      GROUP BY bucket, breakdown_val\n113\t      ORDER BY bucket ASC\n114\t    `.trim();\n115\t    return { query, query_params };\n116\t  }\n117\t\n118\t  const query = `\n119\t    SELECT\n120\t      ${bucketExpr} AS bucket,\n121\t      ${aggregateExpr} AS value\n122\t    FROM events e\n123\t    ${joinClause}\n124\t    WHERE e.event_name = {event_name:String}\n125\t      AND e.timestamp >= {start:String}\n126\t      AND e.timestamp < {end_exclusive:String}\n127\t    GROUP BY bucket\n128\t    ORDER BY bucket ASC\n129\t  `.trim();\n130\t\n131\t  return { query, query_params };\n132\t}\n133\t\n134\t// ─── queryTrends ──────────────────────────────────────────────────────────────\n135\t\n136\tinterface TrendsRow {\n137\t  bucket: string;\n138\t  value: number | string;\n139\t  breakdown_val?: string;\n140\t}\n141\t\n142\t/**\n143\t * Executes the trends query and transforms the raw ClickHouse rows into the\n144\t * series response shape.\n145\t *\n146\t * Without breakdown: returns a single series labelled with event_name.\n147\t * With breakdown:    returns one series per top-N breakdown value, with the\n148\t *                    remainder merged into an \"Other\" series.\n149\t */\n150\texport async function queryTrends(\n151\t  params: TrendsParams,\n152\t  client: ClickHouseClientLike = clickhouse,\n153\t): Promise<TrendsResponse> {\n154\t  const { event_name, breakdown, breakdown_limit = 10 } = params;\n155\t  const { query, query_params } = buildTrendsQuery(params);\n156\t\n157\t  const result = await client.query({\n158\t    query,\n159\t    query_params,\n160\t    format: \"JSONEachRow\",\n161\t  });\n162\t\n163\t  const rows = await result.json<TrendsRow>();\n164\t\n165\t  if (rows.length === 0) {\n166\t    return { series: [] };\n167\t  }\n168\t\n169\t  // ── No breakdown: single series ─────────────────────────────────────────────\n170\t\n171\t  if (!breakdown) {\n172\t    const data: SeriesPoint[] = rows.map((r) => ({\n173\t      date: r.bucket,\n174\t      value: Number(r.value),\n175\t    }));\n176\t    return { series: [{ label: event_name, data }] };\n177\t  }\n178\t\n179\t  // ── With breakdown: group rows by breakdown_val ───────────────────────────\n180\t\n181\t  const seriesMap = new Map<string, SeriesPoint[]>();\n182\t  const totalsByLabel = new Map<string, number>();\n183\t\n184\t  for (const row of rows) {\n185\t    const label = row.breakdown_val ?? \"\";\n186\t    const value = Number(row.value);\n187\t\n188\t    let points = seriesMap.get(label);\n189\t    if (points === undefined) {\n190\t      points = [];\n191\t      seriesMap.set(label, points);\n192\t      totalsByLabel.set(label, 0);\n193\t    }\n194\t    points.push({ date: row.bucket, value });\n195\t    totalsByLabel.set(label, (totalsByLabel.get(label) ?? 0) + value);\n196\t  }\n197\t\n198\t  // Sort by total descending to determine top-N\n199\t  const sorted = Array.from(totalsByLabel.entries()).sort(\n200\t    ([, a], [, b]) => b - a,\n201\t  );\n202\t\n203\t  const series: Series[] = [];\n204\t\n205\t  // Add top-N individual series\n206\t  for (const [label] of sorted.slice(0, breakdown_limit)) {\n207\t    series.push({ label, data: seriesMap.get(label) ?? [] });\n208\t  }\n209\t\n210\t  // Merge remaining values into \"Other\"\n211\t  const restEntries = sorted.slice(breakdown_limit);\n212\t  if (restEntries.length > 0) {\n213\t    const otherMap = new Map<string, number>();\n214\t    for (const [otherLabel] of restEntries) {\n215\t      for (const point of seriesMap.get(otherLabel) ?? []) {\n216\t        otherMap.set(point.date, (otherMap.get(point.date) ?? 0) + point.value);\n217\t      }\n218\t    }\n219\t    const otherData = Array.from(otherMap.entries())\n220\t      .sort(([a], [b]) => a.localeCompare(b))\n221\t      .map(([date, value]) => ({ date, value }));\n222\t    series.push({ label: \"Other\", data: otherData });\n223\t  }\n224\t\n225\t  return { series };\n226\t}\n227\t"}]},"parent_tool_use_id":null,"session_id":"a32e35ab-060b-4e2a-a65b-b8a6f50c8790","uuid":"215334ef-3163-46e2-b68d-786a33fb162a","timestamp":"2026-04-15T16:42:42.605Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/trends.ts","content":"import { clickhouse } from \"@/lib/clickhouse\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface TrendsParams {\n  event_name: string;\n  /** \"count\" | \"unique_users\" | \"sum:<prop>\" | \"avg:<prop>\" | \"min:<prop>\" | \"max:<prop>\" */\n  measure: string;\n  granularity: \"day\" | \"week\";\n  /** ISO date string (YYYY-MM-DD) — inclusive lower bound */\n  start: string;\n  /** ISO date string (YYYY-MM-DD) — inclusive upper bound */\n  end: string;\n  breakdown?: string;\n  breakdown_limit?: number;\n}\n\nexport interface SeriesPoint {\n  date: string;\n  value: number;\n}\n\nexport interface Series {\n  label: string;\n  data: SeriesPoint[];\n}\n\nexport interface TrendsResponse {\n  series: Series[];\n}\n\nexport interface TrendsQuerySpec {\n  query: string;\n  query_params: Record<string, string>;\n}\n\n// ─── Type alias for the ClickHouse client ────────────────────────────────────\n\ntype ClickHouseClientLike = typeof clickhouse;\n\n// ─── Internal helpers ─────────────────────────────────────────────────────────\n\n/** Returns the exclusive upper bound timestamp for the given ISO date.\n *  Returns ClickHouse-compatible format: \"YYYY-MM-DD HH:MM:SS.mmm\" (no T/Z).\n */\nfunction computeEndExclusive(end: string): string {\n  const [y, m, d] = end.split(\"-\").map(Number);\n  const dt = new Date(Date.UTC(y, m - 1, d + 1));\n  const year = dt.getUTCFullYear();\n  const month = String(dt.getUTCMonth() + 1).padStart(2, \"0\");\n  const day = String(dt.getUTCDate()).padStart(2, \"0\");\n  return `${year}-${month}-${day} 00:00:00.000`;\n}\n\n/** Builds the SQL aggregate expression for the given measure. */\nfunction buildAggregateExpr(measure: string): string {\n  if (measure === \"count\") return \"count()\";\n  if (measure === \"unique_users\") {\n    return \"uniqExact(coalesce(e.user_id, m.user_id, e.device_id))\";\n  }\n  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n  if (match) {\n    const fn = match[1];\n    const prop = match[2];\n    return `${fn}(JSONExtractFloat(e.properties, '${prop}'))`;\n  }\n  // Fallback — should be unreachable after route-level validation\n  return \"count()\";\n}\n\n/** Builds the SQL date-bucket expression for the given granularity. */\nfunction buildBucketExpr(granularity: \"day\" | \"week\"): string {\n  return granularity === \"week\"\n    ? \"toMonday(e.timestamp)\"\n    : \"toDate(e.timestamp)\";\n}\n\n// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n\n/**\n * Constructs the ClickHouse SQL query and bound parameters for a trends\n * request. Exported for unit testing of SQL correctness.\n */\nexport function buildTrendsQuery(params: TrendsParams): TrendsQuerySpec {\n  const { event_name, measure, granularity, start, end, breakdown } = params;\n\n  const aggregateExpr = buildAggregateExpr(measure);\n  const bucketExpr = buildBucketExpr(granularity);\n  const needsJoin = measure === \"unique_users\";\n\n  const joinClause = needsJoin\n    ? \"LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\\n      ON e.device_id = m.device_id\"\n    : \"\";\n\n  const query_params: Record<string, string> = {\n    event_name,\n    start: `${start} 00:00:00.000`,\n    end_exclusive: computeEndExclusive(end),\n  };\n\n  if (breakdown) {\n    const query = `\n      SELECT\n        ${bucketExpr} AS bucket,\n        JSONExtractString(e.properties, '${breakdown}') AS breakdown_val,\n        ${aggregateExpr} AS value\n      FROM events e\n      ${joinClause}\n      WHERE e.event_name = {event_name:String}\n        AND e.timestamp >= {start:String}\n        AND e.timestamp < {end_exclusive:String}\n      GROUP BY bucket, breakdown_val\n      ORDER BY bucket ASC\n    `.trim();\n    return { query, query_params };\n  }\n\n  const query = `\n    SELECT\n      ${bucketExpr} AS bucket,\n      ${aggregateExpr} AS value\n    FROM events e\n    ${joinClause}\n    WHERE e.event_name = {event_name:String}\n      AND e.timestamp >= {start:String}\n      AND e.timestamp < {end_exclusive:String}\n    GROUP BY bucket\n    ORDER BY bucket ASC\n  `.trim();\n\n  return { query, query_params };\n}\n\n// ─── queryTrends ──────────────────────────────────────────────────────────────\n\ninterface TrendsRow {\n  bucket: string;\n  value: number | string;\n  breakdown_val?: string;\n}\n\n/**\n * Executes the trends query and transforms the raw ClickHouse rows into the\n * series response shape.\n *\n * Without breakdown: returns a single series labelled with event_name.\n * With breakdown:    returns one series per top-N breakdown value, with the\n *                    remainder merged into an \"Other\" series.\n */\nexport async function queryTrends(\n  params: TrendsParams,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<TrendsResponse> {\n  const { event_name, breakdown, breakdown_limit = 10 } = params;\n  const { query, query_params } = buildTrendsQuery(params);\n\n  const result = await client.query({\n    query,\n    query_params,\n    format: \"JSONEachRow\",\n  });\n\n  const rows = await result.json<TrendsRow>();\n\n  if (rows.length === 0) {\n    return { series: [] };\n  }\n\n  // ── No breakdown: single series ─────────────────────────────────────────────\n\n  if (!breakdown) {\n    const data: SeriesPoint[] = rows.map((r) => ({\n      date: r.bucket,\n      value: Number(r.value),\n    }));\n    return { series: [{ label: event_name, data }] };\n  }\n\n  // ── With breakdown: group rows by breakdown_val ───────────────────────────\n\n  const seriesMap = new Map<string, SeriesPoint[]>();\n  const totalsByLabel = new Map<string, number>();\n\n  for (const row of rows) {\n    const label = row.breakdown_val ?? \"\";\n    const value = Number(row.value);\n\n    let points = seriesMap.get(label);\n    if (points === undefined) {\n      points = [];\n      seriesMap.set(label, points);\n      totalsByLabel.set(label, 0);\n    }\n    points.push({ date: row.bucket, value });\n    totalsByLabel.set(label, (totalsByLabel.get(label) ?? 0) + value);\n  }\n\n  // Sort by total descending to determine top-N\n  const sorted = Array.from(totalsByLabel.entries()).sort(\n    ([, a], [, b]) => b - a,\n  );\n\n  const series: Series[] = [];\n\n  // Add top-N individual series\n  for (const [label] of sorted.slice(0, breakdown_limit)) {\n    series.push({ label, data: seriesMap.get(label) ?? [] });\n  }\n\n  // Merge remaining values into \"Other\"\n  const restEntries = sorted.slice(breakdown_limit);\n  if (restEntries.length > 0) {\n    const otherMap = new Map<string, number>();\n    for (const [otherLabel] of restEntries) {\n      for (const point of seriesMap.get(otherLabel) ?? []) {\n        otherMap.set(point.date, (otherMap.get(point.date) ?? 0) + point.value);\n      }\n    }\n    const otherData = Array.from(otherMap.entries())\n      .sort(([a], [b]) => a.localeCompare(b))\n      .map(([date, value]) => ({ date, value }));\n    series.push({ label: \"Other\", data: otherData });\n  }\n\n  return { series };\n}\n","numLines":227,"startLine":1,"totalLines":227}}}
