{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qoit7iahsz5CiK1wy1rqzt","type":"tool_result","content":"1\t/**\n2\t * Integration tests for /api/generate/* routes.\n3\t *\n4\t * These tests require a running dev server at http://localhost:3000.\n5\t * ClickHouse does NOT need to be running — the generate routes use\n6\t * in-memory job state; the background insert loop fails silently if\n7\t * ClickHouse is unavailable.\n8\t *\n9\t * Run with:\n10\t *   next dev &   # start Next.js only (no ClickHouse needed)\n11\t *   pnpm test\n12\t */\n13\t\n14\timport { describe, expect, it } from \"vitest\";\n15\t\n16\tconst BASE_URL = \"http://localhost:3000\";\n17\t\n18\tasync function isServerAvailable(): Promise<boolean> {\n19\t  try {\n20\t    const res = await fetch(BASE_URL, {\n21\t      method: \"HEAD\",\n22\t      signal: AbortSignal.timeout(2000),\n23\t    });\n24\t    return res.status < 600;\n25\t  } catch {\n26\t    return false;\n27\t  }\n28\t}\n29\t\n30\tconst serverAvailable = await isServerAvailable();\n31\tif (!serverAvailable) {\n32\t  console.warn(\n33\t    \"[integration] Dev server not available at http://localhost:3000 — skipping generate integration tests.\",\n34\t  );\n35\t}\n36\t\n37\t// ─── POST /api/generate/start ─────────────────────────────────────────────────\n38\t\n39\tdescribe(\"POST /api/generate/start — integration\", () => {\n40\t  it(\"valid config {total:100, users:10} → 201 with job_id string\", async () => {\n41\t    if (!serverAvailable) return;\n42\t\n43\t    const res = await fetch(`${BASE_URL}/api/generate/start`, {\n44\t      method: \"POST\",\n45\t      headers: { \"Content-Type\": \"application/json\" },\n46\t      body: JSON.stringify({ total: 100, users: 10 }),\n47\t    });\n48\t\n49\t    expect(res.status).toBe(201);\n50\t    const body = await res.json();\n51\t    expect(body).toHaveProperty(\"job_id\");\n52\t    expect(typeof body.job_id).toBe(\"string\");\n53\t    expect(body.job_id.length).toBeGreaterThan(0);\n54\t  });\n55\t\n56\t  it(\"invalid config {total:0} → 400 with error field\", async () => {\n57\t    if (!serverAvailable) return;\n58\t\n59\t    const res = await fetch(`${BASE_URL}/api/generate/start`, {\n60\t      method: \"POST\",\n61\t      headers: { \"Content-Type\": \"application/json\" },\n62\t      body: JSON.stringify({ total: 0, users: 10 }),\n63\t    });\n64\t\n65\t    expect(res.status).toBe(400);\n66\t    const body = await res.json();\n67\t    expect(body).toHaveProperty(\"error\");\n68\t    expect(typeof body.error).toBe(\"string\");\n69\t  });\n70\t\n71\t  it(\"invalid config {total:2000000} → 400 with error field\", async () => {\n72\t    if (!serverAvailable) return;\n73\t\n74\t    const res = await fetch(`${BASE_URL}/api/generate/start`, {\n75\t      method: \"POST\",\n76\t      headers: { \"Content-Type\": \"application/json\" },\n77\t      body: JSON.stringify({ total: 2_000_000, users: 10 }),\n78\t    });\n79\t\n80\t    expect(res.status).toBe(400);\n81\t    const body = await res.json();\n82\t    expect(body).toHaveProperty(\"error\");\n83\t  });\n84\t\n85\t  it(\"invalid JSON body → 400\", async () => {\n86\t    if (!serverAvailable) return;\n87\t\n88\t    const res = await fetch(`${BASE_URL}/api/generate/start`, {\n89\t      method: \"POST\",\n90\t      headers: { \"Content-Type\": \"application/json\" },\n91\t      body: \"not-json\",\n92\t    });\n93\t\n94\t    expect(res.status).toBe(400);\n95\t  });\n96\t});\n97\t\n98\t// ─── GET /api/generate/jobs ───────────────────────────────────────────────────\n99\t\n100\tdescribe(\"GET /api/generate/jobs — integration\", () => {\n101\t  it(\"returns a JSON array (possibly empty)\", async () => {\n102\t    if (!serverAvailable) return;\n103\t\n104\t    const res = await fetch(`${BASE_URL}/api/generate/jobs`);\n105\t\n106\t    expect(res.status).toBe(200);\n107\t    const body = await res.json();\n108\t    expect(Array.isArray(body)).toBe(true);\n109\t  });\n110\t\n111\t  it(\"after POST /api/generate/start, GET /api/generate/jobs includes the new job\", async () => {\n112\t    if (!serverAvailable) return;\n113\t\n114\t    const startRes = await fetch(`${BASE_URL}/api/generate/start`, {\n115\t      method: \"POST\",\n116\t      headers: { \"Content-Type\": \"application/json\" },\n117\t      body: JSON.stringify({ total: 50, users: 5 }),\n118\t    });\n119\t    expect(startRes.status).toBe(201);\n120\t    const { job_id } = await startRes.json();\n121\t\n122\t    const jobsRes = await fetch(`${BASE_URL}/api/generate/jobs`);\n123\t    expect(jobsRes.status).toBe(200);\n124\t    const jobs = await jobsRes.json();\n125\t    expect(Array.isArray(jobs)).toBe(true);\n126\t\n127\t    const found = jobs.find((j: { job_id: string }) => j.job_id === job_id);\n128\t    expect(found).toBeDefined();\n129\t    expect(found.total).toBe(50);\n130\t  });\n131\t});\n132\t\n133\t// ─── POST /api/generate/[job_id]/cancel ──────────────────────────────────────\n134\t\n135\tdescribe(\"POST /api/generate/[job_id]/cancel — integration\", () => {\n136\t  it(\"cancelling an existing job → 200 with {cancelled: true}\", async () => {\n137\t    if (!serverAvailable) return;\n138\t\n139\t    const startRes = await fetch(`${BASE_URL}/api/generate/start`, {\n140\t      method: \"POST\",\n141\t      headers: { \"Content-Type\": \"application/json\" },\n142\t      body: JSON.stringify({ total: 1_000_000, users: 50 }),\n143\t    });\n144\t    expect(startRes.status).toBe(201);\n145\t    const { job_id } = await startRes.json();\n146\t\n147\t    const cancelRes = await fetch(\n148\t      `${BASE_URL}/api/generate/${job_id}/cancel`,\n149\t      { method: \"POST\" },\n150\t    );\n151\t    expect(cancelRes.status).toBe(200);\n152\t    const body = await cancelRes.json();\n153\t    expect(body).toEqual({ cancelled: true });\n154\t  });\n155\t\n156\t  it(\"cancelling a non-existent job → 404\", async () => {\n157\t    if (!serverAvailable) return;\n158\t\n159\t    const res = await fetch(\n160\t      `${BASE_URL}/api/generate/nonexistent-job-id/cancel`,\n161\t      { method: \"POST\" },\n162\t    );\n163\t    expect(res.status).toBe(404);\n164\t  });\n165\t});\n166\t\n167\t// ─── GET /api/generate/[job_id]/status (SSE) ─────────────────────────────────\n168\t\n169\tdescribe(\"GET /api/generate/[job_id]/status — integration\", () => {\n170\t  it(\"non-existent job → 404\", async () => {\n171\t    if (!serverAvailable) return;\n172\t\n173\t    const res = await fetch(\n174\t      `${BASE_URL}/api/generate/nonexistent-job-id/status`,\n175\t    );\n176\t    expect(res.status).toBe(404);\n177\t  });\n178\t\n179\t  it(\"existing job → 200 with Content-Type: text/event-stream\", async () => {\n180\t    if (!serverAvailable) return;\n181\t\n182\t    const startRes = await fetch(`${BASE_URL}/api/generate/start`, {\n183\t      method: \"POST\",\n184\t      headers: { \"Content-Type\": \"application/json\" },\n185\t      body: JSON.stringify({ total: 50, users: 5 }),\n186\t    });\n187\t    expect(startRes.status).toBe(201);\n188\t    const { job_id } = await startRes.json();\n189\t\n190\t    const statusRes = await fetch(\n191\t      `${BASE_URL}/api/generate/${job_id}/status`,\n192\t      { signal: AbortSignal.timeout(5000) },\n193\t    );\n194\t    expect(statusRes.status).toBe(200);\n195\t    expect(statusRes.headers.get(\"content-type\")).toContain(\n196\t      \"text/event-stream\",\n197\t    );\n198\t\n199\t    // Read at least one SSE data event\n200\t    const reader = statusRes.body?.getReader();\n201\t    if (!reader) throw new Error(\"No response body\");\n202\t    const decoder = new TextDecoder();\n203\t    let text = \"\";\n204\t    // Read chunks until we see a `data:` line or the stream closes\n205\t    for (let i = 0; i < 20; i++) {\n206\t      const { done, value } = await reader.read();\n207\t      if (done) break;\n208\t      text += decoder.decode(value);\n209\t      if (text.includes(\"data:\")) break;\n210\t    }\n211\t    reader.cancel();\n212\t    expect(text).toMatch(/data:/);\n213\t  });\n214\t});\n215\t"}]},"parent_tool_use_id":null,"session_id":"ad37df17-7a83-47f0-993e-b421b8843c55","uuid":"1e2b7717-d62f-45de-8446-63c5636b9175","timestamp":"2026-04-15T18:28:39.783Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/generate/__tests__/route.integration.test.ts","content":"/**\n * Integration tests for /api/generate/* routes.\n *\n * These tests require a running dev server at http://localhost:3000.\n * ClickHouse does NOT need to be running — the generate routes use\n * in-memory job state; the background insert loop fails silently if\n * ClickHouse is unavailable.\n *\n * Run with:\n *   next dev &   # start Next.js only (no ClickHouse needed)\n *   pnpm test\n */\n\nimport { describe, expect, it } from \"vitest\";\n\nconst BASE_URL = \"http://localhost:3000\";\n\nasync function isServerAvailable(): Promise<boolean> {\n  try {\n    const res = await fetch(BASE_URL, {\n      method: \"HEAD\",\n      signal: AbortSignal.timeout(2000),\n    });\n    return res.status < 600;\n  } catch {\n    return false;\n  }\n}\n\nconst serverAvailable = await isServerAvailable();\nif (!serverAvailable) {\n  console.warn(\n    \"[integration] Dev server not available at http://localhost:3000 — skipping generate integration tests.\",\n  );\n}\n\n// ─── POST /api/generate/start ─────────────────────────────────────────────────\n\ndescribe(\"POST /api/generate/start — integration\", () => {\n  it(\"valid config {total:100, users:10} → 201 with job_id string\", async () => {\n    if (!serverAvailable) return;\n\n    const res = await fetch(`${BASE_URL}/api/generate/start`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ total: 100, users: 10 }),\n    });\n\n    expect(res.status).toBe(201);\n    const body = await res.json();\n    expect(body).toHaveProperty(\"job_id\");\n    expect(typeof body.job_id).toBe(\"string\");\n    expect(body.job_id.length).toBeGreaterThan(0);\n  });\n\n  it(\"invalid config {total:0} → 400 with error field\", async () => {\n    if (!serverAvailable) return;\n\n    const res = await fetch(`${BASE_URL}/api/generate/start`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ total: 0, users: 10 }),\n    });\n\n    expect(res.status).toBe(400);\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n    expect(typeof body.error).toBe(\"string\");\n  });\n\n  it(\"invalid config {total:2000000} → 400 with error field\", async () => {\n    if (!serverAvailable) return;\n\n    const res = await fetch(`${BASE_URL}/api/generate/start`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ total: 2_000_000, users: 10 }),\n    });\n\n    expect(res.status).toBe(400);\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n  });\n\n  it(\"invalid JSON body → 400\", async () => {\n    if (!serverAvailable) return;\n\n    const res = await fetch(`${BASE_URL}/api/generate/start`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: \"not-json\",\n    });\n\n    expect(res.status).toBe(400);\n  });\n});\n\n// ─── GET /api/generate/jobs ───────────────────────────────────────────────────\n\ndescribe(\"GET /api/generate/jobs — integration\", () => {\n  it(\"returns a JSON array (possibly empty)\", async () => {\n    if (!serverAvailable) return;\n\n    const res = await fetch(`${BASE_URL}/api/generate/jobs`);\n\n    expect(res.status).toBe(200);\n    const body = await res.json();\n    expect(Array.isArray(body)).toBe(true);\n  });\n\n  it(\"after POST /api/generate/start, GET /api/generate/jobs includes the new job\", async () => {\n    if (!serverAvailable) return;\n\n    const startRes = await fetch(`${BASE_URL}/api/generate/start`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ total: 50, users: 5 }),\n    });\n    expect(startRes.status).toBe(201);\n    const { job_id } = await startRes.json();\n\n    const jobsRes = await fetch(`${BASE_URL}/api/generate/jobs`);\n    expect(jobsRes.status).toBe(200);\n    const jobs = await jobsRes.json();\n    expect(Array.isArray(jobs)).toBe(true);\n\n    const found = jobs.find((j: { job_id: string }) => j.job_id === job_id);\n    expect(found).toBeDefined();\n    expect(found.total).toBe(50);\n  });\n});\n\n// ─── POST /api/generate/[job_id]/cancel ──────────────────────────────────────\n\ndescribe(\"POST /api/generate/[job_id]/cancel — integration\", () => {\n  it(\"cancelling an existing job → 200 with {cancelled: true}\", async () => {\n    if (!serverAvailable) return;\n\n    const startRes = await fetch(`${BASE_URL}/api/generate/start`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ total: 1_000_000, users: 50 }),\n    });\n    expect(startRes.status).toBe(201);\n    const { job_id } = await startRes.json();\n\n    const cancelRes = await fetch(\n      `${BASE_URL}/api/generate/${job_id}/cancel`,\n      { method: \"POST\" },\n    );\n    expect(cancelRes.status).toBe(200);\n    const body = await cancelRes.json();\n    expect(body).toEqual({ cancelled: true });\n  });\n\n  it(\"cancelling a non-existent job → 404\", async () => {\n    if (!serverAvailable) return;\n\n    const res = await fetch(\n      `${BASE_URL}/api/generate/nonexistent-job-id/cancel`,\n      { method: \"POST\" },\n    );\n    expect(res.status).toBe(404);\n  });\n});\n\n// ─── GET /api/generate/[job_id]/status (SSE) ─────────────────────────────────\n\ndescribe(\"GET /api/generate/[job_id]/status — integration\", () => {\n  it(\"non-existent job → 404\", async () => {\n    if (!serverAvailable) return;\n\n    const res = await fetch(\n      `${BASE_URL}/api/generate/nonexistent-job-id/status`,\n    );\n    expect(res.status).toBe(404);\n  });\n\n  it(\"existing job → 200 with Content-Type: text/event-stream\", async () => {\n    if (!serverAvailable) return;\n\n    const startRes = await fetch(`${BASE_URL}/api/generate/start`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ total: 50, users: 5 }),\n    });\n    expect(startRes.status).toBe(201);\n    const { job_id } = await startRes.json();\n\n    const statusRes = await fetch(\n      `${BASE_URL}/api/generate/${job_id}/status`,\n      { signal: AbortSignal.timeout(5000) },\n    );\n    expect(statusRes.status).toBe(200);\n    expect(statusRes.headers.get(\"content-type\")).toContain(\n      \"text/event-stream\",\n    );\n\n    // Read at least one SSE data event\n    const reader = statusRes.body?.getReader();\n    if (!reader) throw new Error(\"No response body\");\n    const decoder = new TextDecoder();\n    let text = \"\";\n    // Read chunks until we see a `data:` line or the stream closes\n    for (let i = 0; i < 20; i++) {\n      const { done, value } = await reader.read();\n      if (done) break;\n      text += decoder.decode(value);\n      if (text.includes(\"data:\")) break;\n    }\n    reader.cancel();\n    expect(text).toMatch(/data:/);\n  });\n});\n","numLines":215,"startLine":1,"totalLines":215}}}
