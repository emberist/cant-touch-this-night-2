{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jiv1dBBEirZ1UzC3yme3wQ","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport { useCallback, useEffect, useRef, useState } from \"react\";\n4\timport type { UserListItem, UserSearchResult } from \"@/lib/users\";\n5\t\n6\t// ─── Types ────────────────────────────────────────────────────────────────────\n7\t\n8\texport interface UseUserSearchResult {\n9\t  users: UserListItem[];\n10\t  loading: boolean;\n11\t  hasMore: boolean;\n12\t  query: string;\n13\t  setQuery: (q: string) => void;\n14\t  loadMore: () => void;\n15\t}\n16\t\n17\t// ─── Hook ─────────────────────────────────────────────────────────────────────\n18\t\n19\tconst DEBOUNCE_MS = 300;\n20\t\n21\texport function useUserSearch(): UseUserSearchResult {\n22\t  const [users, setUsers] = useState<UserListItem[]>([]);\n23\t  const [cursor, setCursor] = useState<string | null>(null);\n24\t  const [loading, setLoading] = useState(false);\n25\t  const [hasMore, setHasMore] = useState(false);\n26\t  const [query, setQueryState] = useState(\"\");\n27\t\n28\t  // Holds the current query ref so fetchUsers closure always has the latest value\n29\t  const queryRef = useRef(query);\n30\t  queryRef.current = query;\n31\t\n32\t  const fetchUsers = useCallback(\n33\t    async (opts: { q: string; cursor: string | null; append: boolean }) => {\n34\t      setLoading(true);\n35\t      try {\n36\t        const url = new URL(\"/api/users\", window.location.origin);\n37\t        if (opts.q) url.searchParams.set(\"q\", opts.q);\n38\t        if (opts.cursor) url.searchParams.set(\"cursor\", opts.cursor);\n39\t        url.searchParams.set(\"limit\", \"50\");\n40\t\n41\t        const res = await fetch(url.toString());\n42\t        const data = (await res.json()) as UserSearchResult;\n43\t\n44\t        setUsers((prev) =>\n45\t          opts.append ? [...prev, ...data.users] : data.users,\n46\t        );\n47\t        setCursor(data.next_cursor);\n48\t        setHasMore(data.next_cursor !== null);\n49\t      } finally {\n50\t        setLoading(false);\n51\t      }\n52\t    },\n53\t    [],\n54\t  );\n55\t\n56\t  // Fetch first page on mount (no query filter)\n57\t  useEffect(() => {\n58\t    fetchUsers({ q: \"\", cursor: null, append: false });\n59\t  }, [fetchUsers]);\n60\t\n61\t  const debounceTimer = useRef<ReturnType<typeof setTimeout> | null>(null);\n62\t\n63\t  const setQuery = useCallback(\n64\t    (q: string) => {\n65\t      setQueryState(q);\n66\t\n67\t      if (debounceTimer.current !== null) {\n68\t        clearTimeout(debounceTimer.current);\n69\t      }\n70\t\n71\t      debounceTimer.current = setTimeout(() => {\n72\t        debounceTimer.current = null;\n73\t        setUsers([]);\n74\t        setCursor(null);\n75\t        setHasMore(false);\n76\t        fetchUsers({ q, cursor: null, append: false });\n77\t      }, DEBOUNCE_MS);\n78\t    },\n79\t    [fetchUsers],\n80\t  );\n81\t\n82\t  const loadMore = useCallback(() => {\n83\t    if (loading || !hasMore) return;\n84\t    fetchUsers({ q: queryRef.current, cursor, append: true });\n85\t  }, [loading, hasMore, cursor, fetchUsers]);\n86\t\n87\t  return { users, loading, hasMore, query, setQuery, loadMore };\n88\t}\n89\t"}]},"parent_tool_use_id":null,"session_id":"e42dd551-8e07-4b63-b5f2-5b67266d80ff","uuid":"837d7073-6aa1-4ae4-8877-98b43bbceedc","timestamp":"2026-04-15T17:21:50.601Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/users/useUserSearch.ts","content":"\"use client\";\n\nimport { useCallback, useEffect, useRef, useState } from \"react\";\nimport type { UserListItem, UserSearchResult } from \"@/lib/users\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface UseUserSearchResult {\n  users: UserListItem[];\n  loading: boolean;\n  hasMore: boolean;\n  query: string;\n  setQuery: (q: string) => void;\n  loadMore: () => void;\n}\n\n// ─── Hook ─────────────────────────────────────────────────────────────────────\n\nconst DEBOUNCE_MS = 300;\n\nexport function useUserSearch(): UseUserSearchResult {\n  const [users, setUsers] = useState<UserListItem[]>([]);\n  const [cursor, setCursor] = useState<string | null>(null);\n  const [loading, setLoading] = useState(false);\n  const [hasMore, setHasMore] = useState(false);\n  const [query, setQueryState] = useState(\"\");\n\n  // Holds the current query ref so fetchUsers closure always has the latest value\n  const queryRef = useRef(query);\n  queryRef.current = query;\n\n  const fetchUsers = useCallback(\n    async (opts: { q: string; cursor: string | null; append: boolean }) => {\n      setLoading(true);\n      try {\n        const url = new URL(\"/api/users\", window.location.origin);\n        if (opts.q) url.searchParams.set(\"q\", opts.q);\n        if (opts.cursor) url.searchParams.set(\"cursor\", opts.cursor);\n        url.searchParams.set(\"limit\", \"50\");\n\n        const res = await fetch(url.toString());\n        const data = (await res.json()) as UserSearchResult;\n\n        setUsers((prev) =>\n          opts.append ? [...prev, ...data.users] : data.users,\n        );\n        setCursor(data.next_cursor);\n        setHasMore(data.next_cursor !== null);\n      } finally {\n        setLoading(false);\n      }\n    },\n    [],\n  );\n\n  // Fetch first page on mount (no query filter)\n  useEffect(() => {\n    fetchUsers({ q: \"\", cursor: null, append: false });\n  }, [fetchUsers]);\n\n  const debounceTimer = useRef<ReturnType<typeof setTimeout> | null>(null);\n\n  const setQuery = useCallback(\n    (q: string) => {\n      setQueryState(q);\n\n      if (debounceTimer.current !== null) {\n        clearTimeout(debounceTimer.current);\n      }\n\n      debounceTimer.current = setTimeout(() => {\n        debounceTimer.current = null;\n        setUsers([]);\n        setCursor(null);\n        setHasMore(false);\n        fetchUsers({ q, cursor: null, append: false });\n      }, DEBOUNCE_MS);\n    },\n    [fetchUsers],\n  );\n\n  const loadMore = useCallback(() => {\n    if (loading || !hasMore) return;\n    fetchUsers({ q: queryRef.current, cursor, append: true });\n  }, [loading, hasMore, cursor, fetchUsers]);\n\n  return { users, loading, hasMore, query, setQuery, loadMore };\n}\n","numLines":89,"startLine":1,"totalLines":89}}}
