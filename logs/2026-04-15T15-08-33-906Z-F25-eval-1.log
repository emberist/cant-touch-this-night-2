{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XiKUfvG9fZT5KcPiKooDkU","type":"tool_result","content":"1\timport { expect, test } from \"@playwright/test\";\n2\t\n3\t/**\n4\t * Integration tests for the F22 Trends page.\n5\t *\n6\t * Pre-conditions: Next.js dev or production server running at BASE_URL\n7\t * (default http://localhost:3000). Override with BASE_URL env variable.\n8\t */\n9\t\n10\tconst BASE_URL = process.env.BASE_URL ?? \"http://localhost:3000\";\n11\t\n12\ttest.describe(\"Trends page (/trends)\", () => {\n13\t  test(\"page title contains 'Trends'\", async ({ page }) => {\n14\t    await page.goto(`${BASE_URL}/trends`);\n15\t    await expect(page).toHaveTitle(/Trends/i);\n16\t  });\n17\t\n18\t  test(\"controls container is visible\", async ({ page }) => {\n19\t    await page.goto(`${BASE_URL}/trends`);\n20\t    const controls = page.getByTestId(\"trends-controls\");\n21\t    await expect(controls).toBeVisible();\n22\t  });\n23\t\n24\t  test(\"chart container is visible\", async ({ page }) => {\n25\t    await page.goto(`${BASE_URL}/trends`);\n26\t    const chart = page.getByTestId(\"trend-chart\");\n27\t    await expect(chart).toBeVisible();\n28\t  });\n29\t\n30\t  test(\"page heading shows 'Trends'\", async ({ page }) => {\n31\t    await page.goto(`${BASE_URL}/trends`);\n32\t    const heading = page.getByRole(\"heading\", { name: \"Trends\" });\n33\t    await expect(heading).toBeVisible();\n34\t  });\n35\t});\n36\t"}]},"parent_tool_use_id":null,"session_id":"e42dd551-8e07-4b63-b5f2-5b67266d80ff","uuid":"d00c05b9-96ce-4da6-87b9-60f368157707","timestamp":"2026-04-15T17:25:00.240Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/playwright_tests/trends.spec.ts","content":"import { expect, test } from \"@playwright/test\";\n\n/**\n * Integration tests for the F22 Trends page.\n *\n * Pre-conditions: Next.js dev or production server running at BASE_URL\n * (default http://localhost:3000). Override with BASE_URL env variable.\n */\n\nconst BASE_URL = process.env.BASE_URL ?? \"http://localhost:3000\";\n\ntest.describe(\"Trends page (/trends)\", () => {\n  test(\"page title contains 'Trends'\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/trends`);\n    await expect(page).toHaveTitle(/Trends/i);\n  });\n\n  test(\"controls container is visible\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/trends`);\n    const controls = page.getByTestId(\"trends-controls\");\n    await expect(controls).toBeVisible();\n  });\n\n  test(\"chart container is visible\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/trends`);\n    const chart = page.getByTestId(\"trend-chart\");\n    await expect(chart).toBeVisible();\n  });\n\n  test(\"page heading shows 'Trends'\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/trends`);\n    const heading = page.getByRole(\"heading\", { name: \"Trends\" });\n    await expect(heading).toBeVisible();\n  });\n});\n","numLines":36,"startLine":1,"totalLines":36}}}
