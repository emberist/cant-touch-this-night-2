{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DFGThZHjve3wpzoizJVThN","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { cleanup, render, screen } from \"@testing-library/react\";\n3\timport { afterEach, describe, expect, it, vi } from \"vitest\";\n4\t\n5\t// Mock next/link to avoid Next.js router context requirement in tests\n6\tvi.mock(\"next/link\", () => ({\n7\t  default: ({\n8\t    children,\n9\t    href,\n10\t    style,\n11\t  }: {\n12\t    children: React.ReactNode;\n13\t    href: string;\n14\t    style?: React.CSSProperties;\n15\t  }) => (\n16\t    <a href={href} style={style}>\n17\t      {children}\n18\t    </a>\n19\t  ),\n20\t}));\n21\t\n22\timport { IdentityChip } from \"@/components/ui/IdentityChip\";\n23\t\n24\tafterEach(() => {\n25\t  cleanup();\n26\t  vi.clearAllMocks();\n27\t});\n28\t\n29\tdescribe(\"IdentityChip\", () => {\n30\t  it(\"renders the resolved_id text\", () => {\n31\t    render(<IdentityChip resolved_id=\"user@test.com\" />);\n32\t    expect(screen.getByText(\"user@test.com\")).toBeTruthy();\n33\t  });\n34\t\n35\t  it(\"wraps content in a link element\", () => {\n36\t    render(<IdentityChip resolved_id=\"user@test.com\" />);\n37\t    const link = screen.getByRole(\"link\");\n38\t    expect(link).toBeTruthy();\n39\t  });\n40\t\n41\t  it(\"links to /users/[percent-encoded id]\", () => {\n42\t    render(<IdentityChip resolved_id=\"user@test.com\" />);\n43\t    const link = screen.getByRole(\"link\");\n44\t    // @ must be percent-encoded\n45\t    expect(link.getAttribute(\"href\")).toBe(\n46\t      `/users/${encodeURIComponent(\"user@test.com\")}`,\n47\t    );\n48\t  });\n49\t\n50\t  it(\"handles special characters in resolved_id (URL encoding)\", () => {\n51\t    const id = \"user+special@example.com/path?q=1\";\n52\t    render(<IdentityChip resolved_id={id} />);\n53\t    const link = screen.getByRole(\"link\");\n54\t    expect(link.getAttribute(\"href\")).toBe(`/users/${encodeURIComponent(id)}`);\n55\t  });\n56\t\n57\t  it(\"renders the resolved_id as the chip label\", () => {\n58\t    const id = \"device-abc-123\";\n59\t    render(<IdentityChip resolved_id={id} />);\n60\t    expect(screen.getByText(id)).toBeTruthy();\n61\t  });\n62\t});\n63\t"}]},"parent_tool_use_id":null,"session_id":"19b45d90-1ce0-4130-bc08-6d66becae3e7","uuid":"9cc8db54-888c-4498-97d7-cfc072fd5baf","timestamp":"2026-04-15T16:44:56.187Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/ui/__tests__/IdentityChip.test.tsx","content":"// @vitest-environment jsdom\nimport { cleanup, render, screen } from \"@testing-library/react\";\nimport { afterEach, describe, expect, it, vi } from \"vitest\";\n\n// Mock next/link to avoid Next.js router context requirement in tests\nvi.mock(\"next/link\", () => ({\n  default: ({\n    children,\n    href,\n    style,\n  }: {\n    children: React.ReactNode;\n    href: string;\n    style?: React.CSSProperties;\n  }) => (\n    <a href={href} style={style}>\n      {children}\n    </a>\n  ),\n}));\n\nimport { IdentityChip } from \"@/components/ui/IdentityChip\";\n\nafterEach(() => {\n  cleanup();\n  vi.clearAllMocks();\n});\n\ndescribe(\"IdentityChip\", () => {\n  it(\"renders the resolved_id text\", () => {\n    render(<IdentityChip resolved_id=\"user@test.com\" />);\n    expect(screen.getByText(\"user@test.com\")).toBeTruthy();\n  });\n\n  it(\"wraps content in a link element\", () => {\n    render(<IdentityChip resolved_id=\"user@test.com\" />);\n    const link = screen.getByRole(\"link\");\n    expect(link).toBeTruthy();\n  });\n\n  it(\"links to /users/[percent-encoded id]\", () => {\n    render(<IdentityChip resolved_id=\"user@test.com\" />);\n    const link = screen.getByRole(\"link\");\n    // @ must be percent-encoded\n    expect(link.getAttribute(\"href\")).toBe(\n      `/users/${encodeURIComponent(\"user@test.com\")}`,\n    );\n  });\n\n  it(\"handles special characters in resolved_id (URL encoding)\", () => {\n    const id = \"user+special@example.com/path?q=1\";\n    render(<IdentityChip resolved_id={id} />);\n    const link = screen.getByRole(\"link\");\n    expect(link.getAttribute(\"href\")).toBe(`/users/${encodeURIComponent(id)}`);\n  });\n\n  it(\"renders the resolved_id as the chip label\", () => {\n    const id = \"device-abc-123\";\n    render(<IdentityChip resolved_id={id} />);\n    expect(screen.getByText(id)).toBeTruthy();\n  });\n});\n","numLines":63,"startLine":1,"totalLines":63}}}
