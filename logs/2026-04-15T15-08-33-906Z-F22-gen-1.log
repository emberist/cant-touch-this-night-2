{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jdbr1UqSq1pGYAT16dUVDq","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport Autocomplete from \"@mui/material/Autocomplete\";\n4\timport Box from \"@mui/material/Box\";\n5\timport Chip from \"@mui/material/Chip\";\n6\timport FormControl from \"@mui/material/FormControl\";\n7\timport InputLabel from \"@mui/material/InputLabel\";\n8\timport type { SelectChangeEvent } from \"@mui/material/Select\";\n9\timport Select from \"@mui/material/Select\";\n10\timport Stack from \"@mui/material/Stack\";\n11\timport TextField from \"@mui/material/TextField\";\n12\timport ToggleButton from \"@mui/material/ToggleButton\";\n13\timport ToggleButtonGroup from \"@mui/material/ToggleButtonGroup\";\n14\timport Typography from \"@mui/material/Typography\";\n15\timport type {\n16\t  UseTrendsControls,\n17\t  UseTrendsSetters,\n18\t} from \"@/components/trends/useTrends\";\n19\timport type { SchemaResponse } from \"@/lib/schema-cache\";\n20\t\n21\t// ─── Types ────────────────────────────────────────────────────────────────────\n22\t\n23\tinterface TrendsControlsProps {\n24\t  schema: SchemaResponse | null;\n25\t  controls: UseTrendsControls;\n26\t  setters: UseTrendsSetters;\n27\t  numericProperties: string[];\n28\t}\n29\t\n30\t// ─── Measure helpers ──────────────────────────────────────────────────────────\n31\t\n32\t/** Extract the aggregate function key from the combined measure string. */\n33\tfunction parseMeasureFn(measure: string): string {\n34\t  if (measure === \"count\" || measure === \"unique_users\") return measure;\n35\t  const colon = measure.indexOf(\":\");\n36\t  return colon !== -1 ? measure.slice(0, colon) : measure;\n37\t}\n38\t\n39\t/** Extract the property name from the combined measure string. */\n40\tfunction parseMeasureProp(measure: string): string {\n41\t  const colon = measure.indexOf(\":\");\n42\t  return colon !== -1 ? measure.slice(colon + 1) : \"\";\n43\t}\n44\t\n45\tconst AGGREGATION_FNS = new Set([\"sum\", \"avg\", \"min\", \"max\"]);\n46\t\n47\tfunction isAggregation(measureFn: string): boolean {\n48\t  return AGGREGATION_FNS.has(measureFn);\n49\t}\n50\t\n51\t// ─── Date helpers ─────────────────────────────────────────────────────────────\n52\t\n53\tfunction todayISO(): string {\n54\t  return new Date().toISOString().slice(0, 10);\n55\t}\n56\t\n57\tfunction daysAgoISO(days: number): string {\n58\t  const d = new Date();\n59\t  d.setDate(d.getDate() - days);\n60\t  return d.toISOString().slice(0, 10);\n61\t}\n62\t\n63\t// ─── Component ────────────────────────────────────────────────────────────────\n64\t\n65\texport function TrendsControls({\n66\t  schema,\n67\t  controls,\n68\t  setters,\n69\t  numericProperties,\n70\t}: TrendsControlsProps): React.JSX.Element {\n71\t  const eventNames = schema?.event_names ?? [];\n72\t  const measureFn = parseMeasureFn(controls.measure);\n73\t  const measureProp = parseMeasureProp(controls.measure);\n74\t  const showPropertySelector = isAggregation(measureFn);\n75\t\n76\t  function handleMeasureFnChange(e: SelectChangeEvent) {\n77\t    const fn = e.target.value;\n78\t    if (fn === \"count\" || fn === \"unique_users\") {\n79\t      setters.setMeasure(fn);\n80\t    } else {\n81\t      // Keep current property or default to first numeric property\n82\t      const prop = measureProp || numericProperties[0] || \"\";\n83\t      setters.setMeasure(`${fn}:${prop}`);\n84\t    }\n85\t  }\n86\t\n87\t  function handlePropertyChange(_: React.SyntheticEvent, value: string | null) {\n88\t    if (value) {\n89\t      setters.setMeasure(`${measureFn}:${value}`);\n90\t    }\n91\t  }\n92\t\n93\t  function handlePreset(days: number) {\n94\t    setters.setStartDate(daysAgoISO(days));\n95\t    setters.setEndDate(todayISO());\n96\t  }\n97\t\n98\t  return (\n99\t    <Box data-testid=\"trends-controls\">\n100\t      <Stack spacing={2}>\n101\t        {/* ── Event name ──────────────────────────────────────────────────── */}\n102\t        <Autocomplete\n103\t          options={eventNames}\n104\t          value={controls.eventName}\n105\t          onChange={(_, value) => setters.setEventName(value)}\n106\t          renderInput={(params) => (\n107\t            <TextField {...params} label=\"Event name\" size=\"small\" />\n108\t          )}\n109\t          sx={{ minWidth: 260 }}\n110\t        />\n111\t\n112\t        {/* ── Measure ─────────────────────────────────────────────────────── */}\n113\t        <Stack direction=\"row\" spacing={1} alignItems=\"center\">\n114\t          <FormControl size=\"small\" sx={{ minWidth: 160 }}>\n115\t            <InputLabel id=\"measure-fn-label\">Measure</InputLabel>\n116\t            <Select\n117\t              native\n118\t              labelId=\"measure-fn-label\"\n119\t              label=\"Measure\"\n120\t              value={measureFn}\n121\t              onChange={handleMeasureFnChange}\n122\t              inputProps={{ \"aria-label\": \"Measure\" }}\n123\t            >\n124\t              <option value=\"count\">Count</option>\n125\t              <option value=\"unique_users\">Unique Users</option>\n126\t              <option value=\"sum\">Sum of</option>\n127\t              <option value=\"avg\">Avg of</option>\n128\t              <option value=\"min\">Min of</option>\n129\t              <option value=\"max\">Max of</option>\n130\t            </Select>\n131\t          </FormControl>\n132\t\n133\t          {showPropertySelector && (\n134\t            <Autocomplete\n135\t              options={numericProperties}\n136\t              value={measureProp || null}\n137\t              onChange={handlePropertyChange}\n138\t              renderInput={(params) => (\n139\t                <TextField\n140\t                  {...params}\n141\t                  label=\"Property\"\n142\t                  size=\"small\"\n143\t                  inputProps={{\n144\t                    ...params.inputProps,\n145\t                    \"data-testid\": \"measure-property-select\",\n146\t                  }}\n147\t                />\n148\t              )}\n149\t              sx={{ minWidth: 200 }}\n150\t            />\n151\t          )}\n152\t        </Stack>\n153\t\n154\t        {/* ── Granularity ─────────────────────────────────────────────────── */}\n155\t        <Box>\n156\t          <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n157\t            Granularity\n158\t          </Typography>\n159\t          <ToggleButtonGroup\n160\t            exclusive\n161\t            value={controls.granularity}\n162\t            onChange={(_, v: \"day\" | \"week\" | null) => {\n163\t              if (v) setters.setGranularity(v);\n164\t            }}\n165\t            size=\"small\"\n166\t          >\n167\t            <ToggleButton value=\"day\">Day</ToggleButton>\n168\t            <ToggleButton value=\"week\">Week</ToggleButton>\n169\t          </ToggleButtonGroup>\n170\t        </Box>\n171\t\n172\t        {/* ── Date range ──────────────────────────────────────────────────── */}\n173\t        <Box>\n174\t          <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n175\t            Date range\n176\t          </Typography>\n177\t          <Stack direction=\"row\" spacing={1} sx={{ mb: 1 }}>\n178\t            <Chip\n179\t              label=\"Last 7d\"\n180\t              size=\"small\"\n181\t              clickable\n182\t              onClick={() => handlePreset(7)}\n183\t            />\n184\t            <Chip\n185\t              label=\"Last 30d\"\n186\t              size=\"small\"\n187\t              clickable\n188\t              onClick={() => handlePreset(30)}\n189\t            />\n190\t            <Chip\n191\t              label=\"Last 90d\"\n192\t              size=\"small\"\n193\t              clickable\n194\t              onClick={() => handlePreset(90)}\n195\t            />\n196\t          </Stack>\n197\t          <Stack direction=\"row\" spacing={1}>\n198\t            <TextField\n199\t              label=\"Start\"\n200\t              type=\"date\"\n201\t              size=\"small\"\n202\t              value={controls.startDate}\n203\t              onChange={(e) => setters.setStartDate(e.target.value)}\n204\t              InputLabelProps={{ shrink: true }}\n205\t            />\n206\t            <TextField\n207\t              label=\"End\"\n208\t              type=\"date\"\n209\t              size=\"small\"\n210\t              value={controls.endDate}\n211\t              onChange={(e) => setters.setEndDate(e.target.value)}\n212\t              InputLabelProps={{ shrink: true }}\n213\t            />\n214\t          </Stack>\n215\t        </Box>\n216\t\n217\t        {/* ── Breakdown ───────────────────────────────────────────────────── */}\n218\t        <Stack direction=\"row\" spacing={1} alignItems=\"center\">\n219\t          <Autocomplete\n220\t            options={\n221\t              eventNames.length > 0 && controls.eventName\n222\t                ? Object.keys(schema?.properties[controls.eventName] ?? {})\n223\t                : []\n224\t            }\n225\t            value={controls.breakdown}\n226\t            onChange={(_, value) => setters.setBreakdown(value)}\n227\t            renderInput={(params) => (\n228\t              <TextField {...params} label=\"Breakdown by\" size=\"small\" />\n229\t            )}\n230\t            sx={{ minWidth: 200 }}\n231\t          />\n232\t          {controls.breakdown && (\n233\t            <TextField\n234\t              label=\"Limit\"\n235\t              type=\"number\"\n236\t              size=\"small\"\n237\t              value={controls.breakdownLimit}\n238\t              onChange={(e) =>\n239\t                setters.setBreakdownLimit(Number(e.target.value))\n240\t              }\n241\t              sx={{ width: 80 }}\n242\t              inputProps={{ min: 1, max: 50 }}\n243\t            />\n244\t          )}\n245\t        </Stack>\n246\t      </Stack>\n247\t    </Box>\n248\t  );\n249\t}\n250\t"}]},"parent_tool_use_id":null,"session_id":"19b45d90-1ce0-4130-bc08-6d66becae3e7","uuid":"694fa097-e34a-4504-8ea8-2bdc8b2a5c9d","timestamp":"2026-04-15T16:51:08.055Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/trends/TrendsControls.tsx","content":"\"use client\";\n\nimport Autocomplete from \"@mui/material/Autocomplete\";\nimport Box from \"@mui/material/Box\";\nimport Chip from \"@mui/material/Chip\";\nimport FormControl from \"@mui/material/FormControl\";\nimport InputLabel from \"@mui/material/InputLabel\";\nimport type { SelectChangeEvent } from \"@mui/material/Select\";\nimport Select from \"@mui/material/Select\";\nimport Stack from \"@mui/material/Stack\";\nimport TextField from \"@mui/material/TextField\";\nimport ToggleButton from \"@mui/material/ToggleButton\";\nimport ToggleButtonGroup from \"@mui/material/ToggleButtonGroup\";\nimport Typography from \"@mui/material/Typography\";\nimport type {\n  UseTrendsControls,\n  UseTrendsSetters,\n} from \"@/components/trends/useTrends\";\nimport type { SchemaResponse } from \"@/lib/schema-cache\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\ninterface TrendsControlsProps {\n  schema: SchemaResponse | null;\n  controls: UseTrendsControls;\n  setters: UseTrendsSetters;\n  numericProperties: string[];\n}\n\n// ─── Measure helpers ──────────────────────────────────────────────────────────\n\n/** Extract the aggregate function key from the combined measure string. */\nfunction parseMeasureFn(measure: string): string {\n  if (measure === \"count\" || measure === \"unique_users\") return measure;\n  const colon = measure.indexOf(\":\");\n  return colon !== -1 ? measure.slice(0, colon) : measure;\n}\n\n/** Extract the property name from the combined measure string. */\nfunction parseMeasureProp(measure: string): string {\n  const colon = measure.indexOf(\":\");\n  return colon !== -1 ? measure.slice(colon + 1) : \"\";\n}\n\nconst AGGREGATION_FNS = new Set([\"sum\", \"avg\", \"min\", \"max\"]);\n\nfunction isAggregation(measureFn: string): boolean {\n  return AGGREGATION_FNS.has(measureFn);\n}\n\n// ─── Date helpers ─────────────────────────────────────────────────────────────\n\nfunction todayISO(): string {\n  return new Date().toISOString().slice(0, 10);\n}\n\nfunction daysAgoISO(days: number): string {\n  const d = new Date();\n  d.setDate(d.getDate() - days);\n  return d.toISOString().slice(0, 10);\n}\n\n// ─── Component ────────────────────────────────────────────────────────────────\n\nexport function TrendsControls({\n  schema,\n  controls,\n  setters,\n  numericProperties,\n}: TrendsControlsProps): React.JSX.Element {\n  const eventNames = schema?.event_names ?? [];\n  const measureFn = parseMeasureFn(controls.measure);\n  const measureProp = parseMeasureProp(controls.measure);\n  const showPropertySelector = isAggregation(measureFn);\n\n  function handleMeasureFnChange(e: SelectChangeEvent) {\n    const fn = e.target.value;\n    if (fn === \"count\" || fn === \"unique_users\") {\n      setters.setMeasure(fn);\n    } else {\n      // Keep current property or default to first numeric property\n      const prop = measureProp || numericProperties[0] || \"\";\n      setters.setMeasure(`${fn}:${prop}`);\n    }\n  }\n\n  function handlePropertyChange(_: React.SyntheticEvent, value: string | null) {\n    if (value) {\n      setters.setMeasure(`${measureFn}:${value}`);\n    }\n  }\n\n  function handlePreset(days: number) {\n    setters.setStartDate(daysAgoISO(days));\n    setters.setEndDate(todayISO());\n  }\n\n  return (\n    <Box data-testid=\"trends-controls\">\n      <Stack spacing={2}>\n        {/* ── Event name ──────────────────────────────────────────────────── */}\n        <Autocomplete\n          options={eventNames}\n          value={controls.eventName}\n          onChange={(_, value) => setters.setEventName(value)}\n          renderInput={(params) => (\n            <TextField {...params} label=\"Event name\" size=\"small\" />\n          )}\n          sx={{ minWidth: 260 }}\n        />\n\n        {/* ── Measure ─────────────────────────────────────────────────────── */}\n        <Stack direction=\"row\" spacing={1} alignItems=\"center\">\n          <FormControl size=\"small\" sx={{ minWidth: 160 }}>\n            <InputLabel id=\"measure-fn-label\">Measure</InputLabel>\n            <Select\n              native\n              labelId=\"measure-fn-label\"\n              label=\"Measure\"\n              value={measureFn}\n              onChange={handleMeasureFnChange}\n              inputProps={{ \"aria-label\": \"Measure\" }}\n            >\n              <option value=\"count\">Count</option>\n              <option value=\"unique_users\">Unique Users</option>\n              <option value=\"sum\">Sum of</option>\n              <option value=\"avg\">Avg of</option>\n              <option value=\"min\">Min of</option>\n              <option value=\"max\">Max of</option>\n            </Select>\n          </FormControl>\n\n          {showPropertySelector && (\n            <Autocomplete\n              options={numericProperties}\n              value={measureProp || null}\n              onChange={handlePropertyChange}\n              renderInput={(params) => (\n                <TextField\n                  {...params}\n                  label=\"Property\"\n                  size=\"small\"\n                  inputProps={{\n                    ...params.inputProps,\n                    \"data-testid\": \"measure-property-select\",\n                  }}\n                />\n              )}\n              sx={{ minWidth: 200 }}\n            />\n          )}\n        </Stack>\n\n        {/* ── Granularity ─────────────────────────────────────────────────── */}\n        <Box>\n          <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n            Granularity\n          </Typography>\n          <ToggleButtonGroup\n            exclusive\n            value={controls.granularity}\n            onChange={(_, v: \"day\" | \"week\" | null) => {\n              if (v) setters.setGranularity(v);\n            }}\n            size=\"small\"\n          >\n            <ToggleButton value=\"day\">Day</ToggleButton>\n            <ToggleButton value=\"week\">Week</ToggleButton>\n          </ToggleButtonGroup>\n        </Box>\n\n        {/* ── Date range ──────────────────────────────────────────────────── */}\n        <Box>\n          <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n            Date range\n          </Typography>\n          <Stack direction=\"row\" spacing={1} sx={{ mb: 1 }}>\n            <Chip\n              label=\"Last 7d\"\n              size=\"small\"\n              clickable\n              onClick={() => handlePreset(7)}\n            />\n            <Chip\n              label=\"Last 30d\"\n              size=\"small\"\n              clickable\n              onClick={() => handlePreset(30)}\n            />\n            <Chip\n              label=\"Last 90d\"\n              size=\"small\"\n              clickable\n              onClick={() => handlePreset(90)}\n            />\n          </Stack>\n          <Stack direction=\"row\" spacing={1}>\n            <TextField\n              label=\"Start\"\n              type=\"date\"\n              size=\"small\"\n              value={controls.startDate}\n              onChange={(e) => setters.setStartDate(e.target.value)}\n              InputLabelProps={{ shrink: true }}\n            />\n            <TextField\n              label=\"End\"\n              type=\"date\"\n              size=\"small\"\n              value={controls.endDate}\n              onChange={(e) => setters.setEndDate(e.target.value)}\n              InputLabelProps={{ shrink: true }}\n            />\n          </Stack>\n        </Box>\n\n        {/* ── Breakdown ───────────────────────────────────────────────────── */}\n        <Stack direction=\"row\" spacing={1} alignItems=\"center\">\n          <Autocomplete\n            options={\n              eventNames.length > 0 && controls.eventName\n                ? Object.keys(schema?.properties[controls.eventName] ?? {})\n                : []\n            }\n            value={controls.breakdown}\n            onChange={(_, value) => setters.setBreakdown(value)}\n            renderInput={(params) => (\n              <TextField {...params} label=\"Breakdown by\" size=\"small\" />\n            )}\n            sx={{ minWidth: 200 }}\n          />\n          {controls.breakdown && (\n            <TextField\n              label=\"Limit\"\n              type=\"number\"\n              size=\"small\"\n              value={controls.breakdownLimit}\n              onChange={(e) =>\n                setters.setBreakdownLimit(Number(e.target.value))\n              }\n              sx={{ width: 80 }}\n              inputProps={{ min: 1, max: 50 }}\n            />\n          )}\n        </Stack>\n      </Stack>\n    </Box>\n  );\n}\n","numLines":250,"startLine":1,"totalLines":250}}}
