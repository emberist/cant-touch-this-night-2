ait res.json();\n119\t      expect(body).toHaveProperty(\"error\");\n120\t    });\n121\t\n122\t    it(\"returns 400 for unknown measure\", async () => {\n123\t      const res = await GET(\n124\t        makeRequest({\n125\t          event_name: \"Page Viewed\",\n126\t          start: \"2026-04-01\",\n127\t          end: \"2026-04-15\",\n128\t          measure: \"unknown\",\n129\t        }),\n130\t      );\n131\t\n132\t      expect(res.status).toBe(400);\n133\t      const body = await res.json();\n134\t      expect(body).toHaveProperty(\"error\");\n135\t    });\n136\t\n137\t    it(\"returns 400 for invalid granularity\", async () => {\n138\t      const res = await GET(\n139\t        makeRequest({\n140\t          event_name: \"Page Viewed\",\n141\t          start: \"2026-04-01\",\n142\t          end: \"2026-04-15\",\n143\t          granularity: \"month\",\n144\t        }),\n145\t      );\n146\t\n147\t      expect(res.status).toBe(400);\n148\t      const body = await res.json();\n149\t      expect(body).toHaveProperty(\"error\");\n150\t    });\n151\t  });\n152\t\n153\t  describe(\"defaults\", () => {\n154\t    it(\"defaults measure to count when not provided\", async () => {\n155\t      await GET(\n156\t        makeRequest({\n157\t          event_name: \"Page Viewed\",\n158\t          start: \"2026-04-01\",\n159\t          end: \"2026-04-15\",\n160\t        }),\n161\t      );\n162\t\n163\t      expect(mockQueryTrends).toHaveBeenCalledWith(\n164\t        expect.objectContaining({ measure: \"count\" }),\n165\t      );\n166\t    });\n167\t\n168\t    it(\"defaults granularity to day when not provided\", async () => {\n169\t      await GET(\n170\t        makeRequest({\n171\t          event_name: \"Page Viewed\",\n172\t          start: \"2026-04-01\",\n173\t          end: \"2026-04-15\",\n174\t        }),\n175\t      );\n176\t\n177\t      expect(mockQueryTrends).toHaveBeenCalledWith(\n178\t        expect.objectContaining({ granularity: \"day\" }),\n179\t      );\n180\t    });