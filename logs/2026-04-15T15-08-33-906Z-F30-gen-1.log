{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017bzwYNrkxmZk3z88WnE2mX","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockInsert } = vi.hoisted(() => ({\n6\t  mockInsert: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: {\n11\t    insert: mockInsert,\n12\t  },\n13\t}));\n14\t\n15\timport {\n16\t  _clearJobs,\n17\t  cancelJob,\n18\t  getJob,\n19\t  listJobs,\n20\t  startGenerationJob,\n21\t} from \"@/lib/generator\";\n22\t\n23\t// ─── Constants ────────────────────────────────────────────────────────────────\n24\t\n25\tconst VALID_CONFIG = {\n26\t  total: 100,\n27\t  users: 5,\n28\t  start: \"2026-01-01\",\n29\t  end: \"2026-04-01\",\n30\t};\n31\t\n32\t// ─── Global mock reset ────────────────────────────────────────────────────────\n33\t\n34\tbeforeEach(() => {\n35\t  _clearJobs();\n36\t  mockInsert.mockResolvedValue(undefined);\n37\t});\n38\t\n39\tafterEach(() => {\n40\t  vi.clearAllMocks();\n41\t});\n42\t\n43\t// ─── startGenerationJob — job creation ───────────────────────────────────────\n44\t\n45\tdescribe(\"startGenerationJob — job creation\", () => {\n46\t  it(\"returns a non-empty string job_id\", () => {\n47\t    const jobId = startGenerationJob(VALID_CONFIG);\n48\t    expect(typeof jobId).toBe(\"string\");\n49\t    expect(jobId.length).toBeGreaterThan(0);\n50\t  });\n51\t\n52\t  it(\"getJob retrieves the created job by id\", () => {\n53\t    const jobId = startGenerationJob(VALID_CONFIG);\n54\t    const job = getJob(jobId);\n55\t    expect(job).toBeDefined();\n56\t    expect(job?.job_id).toBe(jobId);\n57\t  });\n58\t\n59\t  it(\"job starts with status 'queued' or 'running'\", () => {\n60\t    const jobId = startGenerationJob(VALID_CONFIG);\n61\t    const job = getJob(jobId);\n62\t    expect([\"queued\", \"running\"]).toContain(job?.status);\n63\t  });\n64\t\n65\t  it(\"job total matches the configured total\", () => {\n66\t    const jobId = startGenerationJob({ total: 250, users: 5 });\n67\t    const job = getJob(jobId);\n68\t    expect(job?.total).toBe(250);\n69\t  });\n70\t\n71\t  it(\"each job gets a unique job_id\", () => {\n72\t    const id1 = startGenerationJob(VALID_CONFIG);\n73\t    const id2 = startGenerationJob(VALID_CONFIG);\n74\t    expect(id1).not.toBe(id2);\n75\t  });\n76\t});\n77\t\n78\t// ─── Config defaults ──────────────────────────────────────────────────────────\n79\t\n80\tdescribe(\"Config defaults\", () => {\n81\t  it(\"defaults total to 10,000 when not provided\", () => {\n82\t    const jobId = startGenerationJob({});\n83\t    const job = getJob(jobId);\n84\t    expect(job?.config.total).toBe(10_000);\n85\t  });\n86\t\n87\t  it(\"defaults users to 100 when not provided\", () => {\n88\t    const jobId = startGenerationJob({});\n89\t    const job = getJob(jobId);\n90\t    expect(job?.config.users).toBe(100);\n91\t  });\n92\t\n93\t  it(\"defaults anonymous_ratio to 30 when not provided\", () => {\n94\t    const jobId = startGenerationJob({});\n95\t    const job = getJob(jobId);\n96\t    expect(job?.config.anonymous_ratio).toBe(30);\n97\t  });\n98\t\n99\t  it(\"defaults identity_resolution to true when not provided\", () => {\n100\t    const jobId = startGenerationJob({});\n101\t    const job = getJob(jobId);\n102\t    expect(job?.config.identity_resolution).toBe(true);\n103\t  });\n104\t\n105\t  it(\"defaults numeric_variance to 'medium' when not provided\", () => {\n106\t    const jobId = startGenerationJob({});\n107\t    const job = getJob(jobId);\n108\t    expect(job?.config.numeric_variance).toBe(\"medium\");\n109\t  });\n110\t\n111\t  it(\"defaults start/end to a valid 30-day window when not provided\", () => {\n112\t    const jobId = startGenerationJob({});\n113\t    const job = getJob(jobId);\n114\t    expect(job?.config.start).toBeTruthy();\n115\t    expect(job?.config.end).toBeTruthy();\n116\t    const startMs = new Date(job!.config.start).getTime();\n117\t    const endMs = new Date(job!.config.end).getTime();\n118\t    // end should be after start\n119\t    expect(endMs).toBeGreaterThan(startMs);\n120\t    // range should be approximately 30 days\n121\t    const rangeMs = endMs - startMs;\n122\t    expect(rangeMs).toBeGreaterThanOrEqual(29 * 24 * 60 * 60 * 1000);\n123\t    expect(rangeMs).toBeLessThanOrEqual(31 * 24 * 60 * 60 * 1000);\n124\t  });\n125\t\n126\t  it(\"defaults event_types to the standard 6 event types when not provided\", () => {\n127\t    const jobId = startGenerationJob({});\n128\t    const job = getJob(jobId);\n129\t    expect(job?.config.event_types.length).toBeGreaterThanOrEqual(1);\n130\t    const names = job!.config.event_types.map((et) => et.name);\n131\t    expect(names).toContain(\"Page Viewed\");\n132\t  });\n133\t});\n134\t\n135\t// ─── Invalid config ───────────────────────────────────────────────────────────\n136\t\n137\tdescribe(\"Invalid config — throws on bad input\", () => {\n138\t  it(\"throws when total < 1\", () => {\n139\t    expect(() => startGenerationJob({ total: 0, users: 10 })).toThrow();\n140\t  });\n141\t\n142\t  it(\"throws when total > 1,000,000\", () => {\n143\t    expect(() => startGenerationJob({ total: 1_000_001, users: 10 })).toThrow();\n144\t  });\n145\t\n146\t  it(\"throws when users < 1\", () => {\n147\t    expect(() => startGenerationJob({ total: 100, users: 0 })).toThrow();\n148\t  });\n149\t\n150\t  it(\"throws when end is before start\", () => {\n151\t    expect(() =>\n152\t      startGenerationJob({ start: \"2026-04-01\", end: \"2026-01-01\" }),\n153\t    ).toThrow();\n154\t  });\n155\t});\n156\t\n157\t// ─── getJob ───────────────────────────────────────────────────────────────────\n158\t\n159\tdescribe(\"getJob\", () => {\n160\t  it(\"returns undefined for a nonexistent job_id\", () => {\n161\t    const result = getJob(\"nonexistent-id\");\n162\t    expect(result).toBeUndefined();\n163\t  });\n164\t});\n165\t\n166\t// ─── cancelJob ────────────────────────────────────────────────────────────────\n167\t\n168\tdescribe(\"cancelJob\", () => {\n169\t  it(\"returns false for a nonexistent job_id\", () => {\n170\t    const result = cancelJob(\"nonexistent-id\");\n171\t    expect(result).toBe(false);\n172\t  });\n173\t\n174\t  it(\"returns true for an existing job_id\", () => {\n175\t    const jobId = startGenerationJob(VALID_CONFIG);\n176\t    const result = cancelJob(jobId);\n177\t    expect(result).toBe(true);\n178\t  });\n179\t\n180\t  it(\"sets the cancelled flag on the job\", () => {\n181\t    const jobId = startGenerationJob(VALID_CONFIG);\n182\t    cancelJob(jobId);\n183\t    const job = getJob(jobId);\n184\t    expect(job?.cancelled).toBe(true);\n185\t  });\n186\t});\n187\t\n188\t// ─── listJobs ─────────────────────────────────────────────────────────────────\n189\t\n190\tdescribe(\"listJobs\", () => {\n191\t  it(\"returns an empty array when no jobs exist\", () => {\n192\t    expect(listJobs()).toEqual([]);\n193\t  });\n194\t\n195\t  it(\"returns all created jobs\", () => {\n196\t    const id1 = startGenerationJob(VALID_CONFIG);\n197\t    const id2 = startGenerationJob(VALID_CONFIG);\n198\t    const jobs = listJobs();\n199\t    const ids = jobs.map((j) => j.job_id);\n200\t    expect(ids).toContain(id1);\n201\t    expect(ids).toContain(id2);\n202\t  });\n203\t\n204\t  it(\"returns jobs with correct status and row counts\", () => {\n205\t    const jobId = startGenerationJob({ total: 50, users: 3 });\n206\t    const jobs = listJobs();\n207\t    const job = jobs.find((j) => j.job_id === jobId);\n208\t    expect(job).toBeDefined();\n209\t    expect(job?.total).toBe(50);\n210\t  });\n211\t});\n212\t\n213\t// ─── Completion ───────────────────────────────────────────────────────────────\n214\t\n215\tdescribe(\"Completion\", () => {\n216\t  it(\"job status becomes 'complete' after all batches insert\", async () => {\n217\t    const jobId = startGenerationJob({ total: 50, users: 3 });\n218\t\n219\t    await vi.waitFor(\n220\t      () => {\n221\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n222\t      },\n223\t      { timeout: 5000 },\n224\t    );\n225\t  });\n226\t\n227\t  it(\"inserted count matches total after completion\", async () => {\n228\t    const jobId = startGenerationJob({ total: 50, users: 3 });\n229\t\n230\t    await vi.waitFor(\n231\t      () => {\n232\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n233\t      },\n234\t      { timeout: 5000 },\n235\t    );\n236\t\n237\t    expect(getJob(jobId)?.inserted).toBe(50);\n238\t  });\n239\t\n240\t  it(\"elapsed_ms is positive after completion\", async () => {\n241\t    const jobId = startGenerationJob({ total: 50, users: 3 });\n242\t\n243\t    await vi.waitFor(\n244\t      () => {\n245\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n246\t      },\n247\t      { timeout: 5000 },\n248\t    );\n249\t\n250\t    expect(getJob(jobId)?.elapsed_ms).toBeGreaterThanOrEqual(0);\n251\t  });\n252\t});\n253\t\n254\t// ─── ClickHouse insert calls ──────────────────────────────────────────────────\n255\t\n256\tdescribe(\"ClickHouse insert calls\", () => {\n257\t  it(\"calls clickhouse.insert with table 'events'\", async () => {\n258\t    const jobId = startGenerationJob({ total: 50, users: 3 });\n259\t\n260\t    await vi.waitFor(\n261\t      () => {\n262\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n263\t      },\n264\t      { timeout: 5000 },\n265\t    );\n266\t\n267\t    const eventsCalls = mockInsert.mock.calls.filter(\n268\t      (c) => c[0].table === \"events\",\n269\t    );\n270\t    expect(eventsCalls.length).toBeGreaterThanOrEqual(1);\n271\t  });\n272\t\n273\t  it(\"calls clickhouse.insert with format 'JSONEachRow'\", async () => {\n274\t    const jobId = startGenerationJob({ total: 50, users: 3 });\n275\t\n276\t    await vi.waitFor(\n277\t      () => {\n278\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n279\t      },\n280\t      { timeout: 5000 },\n281\t    );\n282\t\n283\t    const eventsCalls = mockInsert.mock.calls.filter(\n284\t      (c) => c[0].table === \"events\",\n285\t    );\n286\t    for (const call of eventsCalls) {\n287\t      expect(call[0].format).toBe(\"JSONEachRow\");\n288\t    }\n289\t  });\n290\t\n291\t  it(\"each event batch has at most 10,000 rows\", async () => {\n292\t    // Use 25,000 total to force 3 batches\n293\t    const jobId = startGenerationJob({ total: 25000, users: 10 });\n294\t\n295\t    await vi.waitFor(\n296\t      () => {\n297\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n298\t      },\n299\t      { timeout: 10000 },\n300\t    );\n301\t\n302\t    const eventsCalls = mockInsert.mock.calls.filter(\n303\t      (c) => c[0].table === \"events\",\n304\t    );\n305\t    for (const call of eventsCalls) {\n306\t      expect(call[0].values.length).toBeLessThanOrEqual(10_000);\n307\t    }\n308\t  });\n309\t\n310\t  it(\"calls clickhouse.insert with table 'identity_mappings' after events\", async () => {\n311\t    const jobId = startGenerationJob({\n312\t      total: 50,\n313\t      users: 5,\n314\t      identity_resolution: true,\n315\t      anonymous_ratio: 0, // all resolved users\n316\t    });\n317\t\n318\t    await vi.waitFor(\n319\t      () => {\n320\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n321\t      },\n322\t      { timeout: 5000 },\n323\t    );\n324\t\n325\t    const allCalls = mockInsert.mock.calls.map((c) => c[0].table);\n326\t    const mappingsIdx = allCalls.lastIndexOf(\"identity_mappings\");\n327\t    const lastEventsIdx = allCalls.lastIndexOf(\"events\");\n328\t\n329\t    expect(mappingsIdx).toBeGreaterThan(-1);\n330\t    expect(mappingsIdx).toBeGreaterThan(lastEventsIdx);\n331\t  });\n332\t\n333\t  it(\"splits 25,000 events into 3 batches (10k + 10k + 5k)\", async () => {\n334\t    const jobId = startGenerationJob({ total: 25000, users: 10 });\n335\t\n336\t    await vi.waitFor(\n337\t      () => {\n338\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n339\t      },\n340\t      { timeout: 10000 },\n341\t    );\n342\t\n343\t    const eventsCalls = mockInsert.mock.calls.filter(\n344\t      (c) => c[0].table === \"events\",\n345\t    );\n346\t    expect(eventsCalls).toHaveLength(3);\n347\t    expect(eventsCalls[0][0].values.length).toBe(10_000);\n348\t    expect(eventsCalls[1][0].values.length).toBe(10_000);\n349\t    expect(eventsCalls[2][0].values.length).toBe(5_000);\n350\t  });\n351\t});\n352\t\n353\t// ─── Batch event generation ───────────────────────────────────────────────────\n354\t\n355\tdescribe(\"Batch event generation\", () => {\n356\t  it(\"all generated events have an event_name from the configured event_types\", async () => {\n357\t    const eventTypes = [\n358\t      { name: \"Page Viewed\", weight: 0.6 },\n359\t      { name: \"Button Clicked\", weight: 0.4 },\n360\t    ];\n361\t    const jobId = startGenerationJob({\n362\t      total: 200,\n363\t      users: 5,\n364\t      event_types: eventTypes,\n365\t    });\n366\t\n367\t    await vi.waitFor(\n368\t      () => {\n369\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n370\t      },\n371\t      { timeout: 5000 },\n372\t    );\n373\t\n374\t    const eventsCall = mockInsert.mock.calls.find(\n375\t      (c) => c[0].table === \"events\",\n376\t    );\n377\t    expect(eventsCall).toBeDefined();\n378\t    const allowedNames = new Set(eventTypes.map((et) => et.name));\n379\t    for (const event of eventsCall![0].values) {\n380\t      expect(allowedNames.has(event.event_name)).toBe(true);\n381\t    }\n382\t  });\n383\t\n384\t  it(\"all event timestamps fall within the configured date range\", async () => {\n385\t    const start = \"2026-01-01\";\n386\t    const end = \"2026-04-01\";\n387\t    const jobId = startGenerationJob({ total: 100, users: 5, start, end });\n388\t\n389\t    await vi.waitFor(\n390\t      () => {\n391\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n392\t      },\n393\t      { timeout: 5000 },\n394\t    );\n395\t\n396\t    const eventsCall = mockInsert.mock.calls.find(\n397\t      (c) => c[0].table === \"events\",\n398\t    );\n399\t    expect(eventsCall).toBeDefined();\n400\t\n401\t    const startMs = new Date(start).getTime();\n402\t    const endMs = new Date(end).getTime();\n403\t\n404\t    for (const event of eventsCall![0].values) {\n405\t      // Timestamps are in ClickHouse format: \"YYYY-MM-DD HH:MM:SS.mmm\"\n406\t      const ts = new Date(\n407\t        (event.timestamp as string).replace(\" \", \"T\") + \"Z\",\n408\t      ).getTime();\n409\t      expect(ts).toBeGreaterThanOrEqual(startMs);\n410\t      expect(ts).toBeLessThanOrEqual(endMs);\n411\t    }\n412\t  });\n413\t\n414\t  it(\"all event properties are valid JSON strings\", async () => {\n415\t    const jobId = startGenerationJob({ total: 100, users: 5 });\n416\t\n417\t    await vi.waitFor(\n418\t      () => {\n419\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n420\t      },\n421\t      { timeout: 5000 },\n422\t    );\n423\t\n424\t    const eventsCall = mockInsert.mock.calls.find(\n425\t      (c) => c[0].table === \"events\",\n426\t    );\n427\t    expect(eventsCall).toBeDefined();\n428\t\n429\t    for (const event of eventsCall![0].values) {\n430\t      expect(() => JSON.parse(event.properties as string)).not.toThrow();\n431\t    }\n432\t  });\n433\t\n434\t  it(\"anonymous users have no user_id (null)\", async () => {\n435\t    const jobId = startGenerationJob({\n436\t      total: 200,\n437\t      users: 4,\n438\t      identity_resolution: true,\n439\t      anonymous_ratio: 100, // all anonymous\n440\t    });\n441\t\n442\t    await vi.waitFor(\n443\t      () => {\n444\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n445\t      },\n446\t      { timeout: 5000 },\n447\t    );\n448\t\n449\t    const eventsCall = mockInsert.mock.calls.find(\n450\t      (c) => c[0].table === \"events\",\n451\t    );\n452\t    expect(eventsCall).toBeDefined();\n453\t\n454\t    for (const event of eventsCall![0].values) {\n455\t      expect(event.user_id).toBeNull();\n456\t    }\n457\t  });\n458\t\n459\t  it(\"non-anonymous users have both device_id and user_id\", async () => {\n460\t    const jobId = startGenerationJob({\n461\t      total: 200,\n462\t      users: 4,\n463\t      identity_resolution: true,\n464\t      anonymous_ratio: 0, // all resolved\n465\t    });\n466\t\n467\t    await vi.waitFor(\n468\t      () => {\n469\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n470\t      },\n471\t      { timeout: 5000 },\n472\t    );\n473\t\n474\t    const eventsCall = mockInsert.mock.calls.find(\n475\t      (c) => c[0].table === \"events\",\n476\t    );\n477\t    expect(eventsCall).toBeDefined();\n478\t\n479\t    for (const event of eventsCall![0].values) {\n480\t      expect(event.device_id).toBeTruthy();\n481\t      expect(event.user_id).toBeTruthy();\n482\t    }\n483\t  });\n484\t});\n485\t\n486\t// ─── Identity mappings ────────────────────────────────────────────────────────\n487\t\n488\tdescribe(\"Identity mappings\", () => {\n489\t  it(\"inserts no identity_mappings when anonymous_ratio is 100%\", async () => {\n490\t    const jobId = startGenerationJob({\n491\t      total: 50,\n492\t      users: 4,\n493\t      identity_resolution: true,\n494\t      anonymous_ratio: 100,\n495\t    });\n496\t\n497\t    await vi.waitFor(\n498\t      () => {\n499\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n500\t      },\n501\t      { timeout: 5000 },\n502\t    );\n503\t\n504\t    const mappingsCalls = mockInsert.mock.calls.filter(\n505\t      (c) => c[0].table === \"identity_mappings\",\n506\t    );\n507\t    expect(mappingsCalls.length).toBe(0);\n508\t  });\n509\t\n510\t  it(\"inserts identity_mappings for fully-resolved users\", async () => {\n511\t    const jobId = startGenerationJob({\n512\t      total: 50,\n513\t      users: 4,\n514\t      identity_resolution: true,\n515\t      anonymous_ratio: 0,\n516\t    });\n517\t\n518\t    await vi.waitFor(\n519\t      () => {\n520\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n521\t      },\n522\t      { timeout: 5000 },\n523\t    );\n524\t\n525\t    const mappingsCall = mockInsert.mock.calls.find(\n526\t      (c) => c[0].table === \"identity_mappings\",\n527\t    );\n528\t    expect(mappingsCall).toBeDefined();\n529\t    const mappings = mappingsCall![0].values;\n530\t    expect(mappings.length).toBeGreaterThan(0);\n531\t    for (const m of mappings) {\n532\t      expect(m.device_id).toBeTruthy();\n533\t      expect(m.user_id).toBeTruthy();\n534\t    }\n535\t  });\n536\t});\n537\t\n538\t// ─── Cancellation ─────────────────────────────────────────────────────────────\n539\t\n540\tdescribe(\"Cancellation\", () => {\n541\t  it(\"job reaches a terminal state after cancellation\", async () => {\n542\t    // Use a large enough job that it would take multiple batches\n543\t    const jobId = startGenerationJob({ total: 50000, users: 10 });\n544\t    cancelJob(jobId);\n545\t\n546\t    await vi.waitFor(\n547\t      () => {\n548\t        const status = getJob(jobId)?.status;\n549\t        expect(status === \"cancelled\" || status === \"complete\").toBe(true);\n550\t      },\n551\t      { timeout: 10000 },\n552\t    );\n553\t  });\n554\t\n555\t  it(\"cancelled job inserts fewer batches than the full job would\", async () => {\n556\t    // 50,000 events = 5 batches; cancelling early should stop before all 5\n557\t    const jobId = startGenerationJob({ total: 50000, users: 10 });\n558\t    cancelJob(jobId);\n559\t\n560\t    await vi.waitFor(\n561\t      () => {\n562\t        const status = getJob(jobId)?.status;\n563\t        expect(status === \"cancelled\" || status === \"complete\").toBe(true);\n564\t      },\n565\t      { timeout: 10000 },\n566\t    );\n567\t\n568\t    const eventsCalls = mockInsert.mock.calls.filter(\n569\t      (c) => c[0].table === \"events\",\n570\t    );\n571\t    // Should have fewer than all 5 batches (cancelled before completion)\n572\t    expect(eventsCalls.length).toBeLessThan(5);\n573\t  });\n574\t});\n575\t\n576\t// ─── Throughput calculation ───────────────────────────────────────────────────\n577\t\n578\tdescribe(\"Throughput calculation\", () => {\n579\t  it(\"throughput is a non-negative number after completion\", async () => {\n580\t    const jobId = startGenerationJob({ total: 50, users: 3 });\n581\t\n582\t    await vi.waitFor(\n583\t      () => {\n584\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n585\t      },\n586\t      { timeout: 5000 },\n587\t    );\n588\t\n589\t    expect(getJob(jobId)?.throughput).toBeGreaterThanOrEqual(0);\n590\t  });\n591\t\n592\t  it(\"eta_seconds is 0 after completion (all events inserted)\", async () => {\n593\t    const jobId = startGenerationJob({ total: 50, users: 3 });\n594\t\n595\t    await vi.waitFor(\n596\t      () => {\n597\t        expect(getJob(jobId)?.status).toBe(\"complete\");\n598\t      },\n599\t      { timeout: 5000 },\n600\t    );\n601\t\n602\t    expect(getJob(jobId)?.eta_seconds).toBe(0);\n603\t  });\n604\t});\n605\t"}]},"parent_tool_use_id":null,"session_id":"e860d76c-8b26-422a-9d31-1b5873ceeb41","uuid":"0dbc7b30-6636-4a61-bb1d-5fba43864124","timestamp":"2026-04-15T18:30:24.002Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/generator.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockInsert } = vi.hoisted(() => ({\n  mockInsert: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    insert: mockInsert,\n  },\n}));\n\nimport {\n  _clearJobs,\n  cancelJob,\n  getJob,\n  listJobs,\n  startGenerationJob,\n} from \"@/lib/generator\";\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst VALID_CONFIG = {\n  total: 100,\n  users: 5,\n  start: \"2026-01-01\",\n  end: \"2026-04-01\",\n};\n\n// ─── Global mock reset ────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  _clearJobs();\n  mockInsert.mockResolvedValue(undefined);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\n// ─── startGenerationJob — job creation ───────────────────────────────────────\n\ndescribe(\"startGenerationJob — job creation\", () => {\n  it(\"returns a non-empty string job_id\", () => {\n    const jobId = startGenerationJob(VALID_CONFIG);\n    expect(typeof jobId).toBe(\"string\");\n    expect(jobId.length).toBeGreaterThan(0);\n  });\n\n  it(\"getJob retrieves the created job by id\", () => {\n    const jobId = startGenerationJob(VALID_CONFIG);\n    const job = getJob(jobId);\n    expect(job).toBeDefined();\n    expect(job?.job_id).toBe(jobId);\n  });\n\n  it(\"job starts with status 'queued' or 'running'\", () => {\n    const jobId = startGenerationJob(VALID_CONFIG);\n    const job = getJob(jobId);\n    expect([\"queued\", \"running\"]).toContain(job?.status);\n  });\n\n  it(\"job total matches the configured total\", () => {\n    const jobId = startGenerationJob({ total: 250, users: 5 });\n    const job = getJob(jobId);\n    expect(job?.total).toBe(250);\n  });\n\n  it(\"each job gets a unique job_id\", () => {\n    const id1 = startGenerationJob(VALID_CONFIG);\n    const id2 = startGenerationJob(VALID_CONFIG);\n    expect(id1).not.toBe(id2);\n  });\n});\n\n// ─── Config defaults ──────────────────────────────────────────────────────────\n\ndescribe(\"Config defaults\", () => {\n  it(\"defaults total to 10,000 when not provided\", () => {\n    const jobId = startGenerationJob({});\n    const job = getJob(jobId);\n    expect(job?.config.total).toBe(10_000);\n  });\n\n  it(\"defaults users to 100 when not provided\", () => {\n    const jobId = startGenerationJob({});\n    const job = getJob(jobId);\n    expect(job?.config.users).toBe(100);\n  });\n\n  it(\"defaults anonymous_ratio to 30 when not provided\", () => {\n    const jobId = startGenerationJob({});\n    const job = getJob(jobId);\n    expect(job?.config.anonymous_ratio).toBe(30);\n  });\n\n  it(\"defaults identity_resolution to true when not provided\", () => {\n    const jobId = startGenerationJob({});\n    const job = getJob(jobId);\n    expect(job?.config.identity_resolution).toBe(true);\n  });\n\n  it(\"defaults numeric_variance to 'medium' when not provided\", () => {\n    const jobId = startGenerationJob({});\n    const job = getJob(jobId);\n    expect(job?.config.numeric_variance).toBe(\"medium\");\n  });\n\n  it(\"defaults start/end to a valid 30-day window when not provided\", () => {\n    const jobId = startGenerationJob({});\n    const job = getJob(jobId);\n    expect(job?.config.start).toBeTruthy();\n    expect(job?.config.end).toBeTruthy();\n    const startMs = new Date(job!.config.start).getTime();\n    const endMs = new Date(job!.config.end).getTime();\n    // end should be after start\n    expect(endMs).toBeGreaterThan(startMs);\n    // range should be approximately 30 days\n    const rangeMs = endMs - startMs;\n    expect(rangeMs).toBeGreaterThanOrEqual(29 * 24 * 60 * 60 * 1000);\n    expect(rangeMs).toBeLessThanOrEqual(31 * 24 * 60 * 60 * 1000);\n  });\n\n  it(\"defaults event_types to the standard 6 event types when not provided\", () => {\n    const jobId = startGenerationJob({});\n    const job = getJob(jobId);\n    expect(job?.config.event_types.length).toBeGreaterThanOrEqual(1);\n    const names = job!.config.event_types.map((et) => et.name);\n    expect(names).toContain(\"Page Viewed\");\n  });\n});\n\n// ─── Invalid config ───────────────────────────────────────────────────────────\n\ndescribe(\"Invalid config — throws on bad input\", () => {\n  it(\"throws when total < 1\", () => {\n    expect(() => startGenerationJob({ total: 0, users: 10 })).toThrow();\n  });\n\n  it(\"throws when total > 1,000,000\", () => {\n    expect(() => startGenerationJob({ total: 1_000_001, users: 10 })).toThrow();\n  });\n\n  it(\"throws when users < 1\", () => {\n    expect(() => startGenerationJob({ total: 100, users: 0 })).toThrow();\n  });\n\n  it(\"throws when end is before start\", () => {\n    expect(() =>\n      startGenerationJob({ start: \"2026-04-01\", end: \"2026-01-01\" }),\n    ).toThrow();\n  });\n});\n\n// ─── getJob ───────────────────────────────────────────────────────────────────\n\ndescribe(\"getJob\", () => {\n  it(\"returns undefined for a nonexistent job_id\", () => {\n    const result = getJob(\"nonexistent-id\");\n    expect(result).toBeUndefined();\n  });\n});\n\n// ─── cancelJob ────────────────────────────────────────────────────────────────\n\ndescribe(\"cancelJob\", () => {\n  it(\"returns false for a nonexistent job_id\", () => {\n    const result = cancelJob(\"nonexistent-id\");\n    expect(result).toBe(false);\n  });\n\n  it(\"returns true for an existing job_id\", () => {\n    const jobId = startGenerationJob(VALID_CONFIG);\n    const result = cancelJob(jobId);\n    expect(result).toBe(true);\n  });\n\n  it(\"sets the cancelled flag on the job\", () => {\n    const jobId = startGenerationJob(VALID_CONFIG);\n    cancelJob(jobId);\n    const job = getJob(jobId);\n    expect(job?.cancelled).toBe(true);\n  });\n});\n\n// ─── listJobs ─────────────────────────────────────────────────────────────────\n\ndescribe(\"listJobs\", () => {\n  it(\"returns an empty array when no jobs exist\", () => {\n    expect(listJobs()).toEqual([]);\n  });\n\n  it(\"returns all created jobs\", () => {\n    const id1 = startGenerationJob(VALID_CONFIG);\n    const id2 = startGenerationJob(VALID_CONFIG);\n    const jobs = listJobs();\n    const ids = jobs.map((j) => j.job_id);\n    expect(ids).toContain(id1);\n    expect(ids).toContain(id2);\n  });\n\n  it(\"returns jobs with correct status and row counts\", () => {\n    const jobId = startGenerationJob({ total: 50, users: 3 });\n    const jobs = listJobs();\n    const job = jobs.find((j) => j.job_id === jobId);\n    expect(job).toBeDefined();\n    expect(job?.total).toBe(50);\n  });\n});\n\n// ─── Completion ───────────────────────────────────────────────────────────────\n\ndescribe(\"Completion\", () => {\n  it(\"job status becomes 'complete' after all batches insert\", async () => {\n    const jobId = startGenerationJob({ total: 50, users: 3 });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n  });\n\n  it(\"inserted count matches total after completion\", async () => {\n    const jobId = startGenerationJob({ total: 50, users: 3 });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    expect(getJob(jobId)?.inserted).toBe(50);\n  });\n\n  it(\"elapsed_ms is positive after completion\", async () => {\n    const jobId = startGenerationJob({ total: 50, users: 3 });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    expect(getJob(jobId)?.elapsed_ms).toBeGreaterThanOrEqual(0);\n  });\n});\n\n// ─── ClickHouse insert calls ──────────────────────────────────────────────────\n\ndescribe(\"ClickHouse insert calls\", () => {\n  it(\"calls clickhouse.insert with table 'events'\", async () => {\n    const jobId = startGenerationJob({ total: 50, users: 3 });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    const eventsCalls = mockInsert.mock.calls.filter(\n      (c) => c[0].table === \"events\",\n    );\n    expect(eventsCalls.length).toBeGreaterThanOrEqual(1);\n  });\n\n  it(\"calls clickhouse.insert with format 'JSONEachRow'\", async () => {\n    const jobId = startGenerationJob({ total: 50, users: 3 });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    const eventsCalls = mockInsert.mock.calls.filter(\n      (c) => c[0].table === \"events\",\n    );\n    for (const call of eventsCalls) {\n      expect(call[0].format).toBe(\"JSONEachRow\");\n    }\n  });\n\n  it(\"each event batch has at most 10,000 rows\", async () => {\n    // Use 25,000 total to force 3 batches\n    const jobId = startGenerationJob({ total: 25000, users: 10 });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 10000 },\n    );\n\n    const eventsCalls = mockInsert.mock.calls.filter(\n      (c) => c[0].table === \"events\",\n    );\n    for (const call of eventsCalls) {\n      expect(call[0].values.length).toBeLessThanOrEqual(10_000);\n    }\n  });\n\n  it(\"calls clickhouse.insert with table 'identity_mappings' after events\", async () => {\n    const jobId = startGenerationJob({\n      total: 50,\n      users: 5,\n      identity_resolution: true,\n      anonymous_ratio: 0, // all resolved users\n    });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    const allCalls = mockInsert.mock.calls.map((c) => c[0].table);\n    const mappingsIdx = allCalls.lastIndexOf(\"identity_mappings\");\n    const lastEventsIdx = allCalls.lastIndexOf(\"events\");\n\n    expect(mappingsIdx).toBeGreaterThan(-1);\n    expect(mappingsIdx).toBeGreaterThan(lastEventsIdx);\n  });\n\n  it(\"splits 25,000 events into 3 batches (10k + 10k + 5k)\", async () => {\n    const jobId = startGenerationJob({ total: 25000, users: 10 });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 10000 },\n    );\n\n    const eventsCalls = mockInsert.mock.calls.filter(\n      (c) => c[0].table === \"events\",\n    );\n    expect(eventsCalls).toHaveLength(3);\n    expect(eventsCalls[0][0].values.length).toBe(10_000);\n    expect(eventsCalls[1][0].values.length).toBe(10_000);\n    expect(eventsCalls[2][0].values.length).toBe(5_000);\n  });\n});\n\n// ─── Batch event generation ───────────────────────────────────────────────────\n\ndescribe(\"Batch event generation\", () => {\n  it(\"all generated events have an event_name from the configured event_types\", async () => {\n    const eventTypes = [\n      { name: \"Page Viewed\", weight: 0.6 },\n      { name: \"Button Clicked\", weight: 0.4 },\n    ];\n    const jobId = startGenerationJob({\n      total: 200,\n      users: 5,\n      event_types: eventTypes,\n    });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    const eventsCall = mockInsert.mock.calls.find(\n      (c) => c[0].table === \"events\",\n    );\n    expect(eventsCall).toBeDefined();\n    const allowedNames = new Set(eventTypes.map((et) => et.name));\n    for (const event of eventsCall![0].values) {\n      expect(allowedNames.has(event.event_name)).toBe(true);\n    }\n  });\n\n  it(\"all event timestamps fall within the configured date range\", async () => {\n    const start = \"2026-01-01\";\n    const end = \"2026-04-01\";\n    const jobId = startGenerationJob({ total: 100, users: 5, start, end });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    const eventsCall = mockInsert.mock.calls.find(\n      (c) => c[0].table === \"events\",\n    );\n    expect(eventsCall).toBeDefined();\n\n    const startMs = new Date(start).getTime();\n    const endMs = new Date(end).getTime();\n\n    for (const event of eventsCall![0].values) {\n      // Timestamps are in ClickHouse format: \"YYYY-MM-DD HH:MM:SS.mmm\"\n      const ts = new Date(\n        (event.timestamp as string).replace(\" \", \"T\") + \"Z\",\n      ).getTime();\n      expect(ts).toBeGreaterThanOrEqual(startMs);\n      expect(ts).toBeLessThanOrEqual(endMs);\n    }\n  });\n\n  it(\"all event properties are valid JSON strings\", async () => {\n    const jobId = startGenerationJob({ total: 100, users: 5 });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    const eventsCall = mockInsert.mock.calls.find(\n      (c) => c[0].table === \"events\",\n    );\n    expect(eventsCall).toBeDefined();\n\n    for (const event of eventsCall![0].values) {\n      expect(() => JSON.parse(event.properties as string)).not.toThrow();\n    }\n  });\n\n  it(\"anonymous users have no user_id (null)\", async () => {\n    const jobId = startGenerationJob({\n      total: 200,\n      users: 4,\n      identity_resolution: true,\n      anonymous_ratio: 100, // all anonymous\n    });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    const eventsCall = mockInsert.mock.calls.find(\n      (c) => c[0].table === \"events\",\n    );\n    expect(eventsCall).toBeDefined();\n\n    for (const event of eventsCall![0].values) {\n      expect(event.user_id).toBeNull();\n    }\n  });\n\n  it(\"non-anonymous users have both device_id and user_id\", async () => {\n    const jobId = startGenerationJob({\n      total: 200,\n      users: 4,\n      identity_resolution: true,\n      anonymous_ratio: 0, // all resolved\n    });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    const eventsCall = mockInsert.mock.calls.find(\n      (c) => c[0].table === \"events\",\n    );\n    expect(eventsCall).toBeDefined();\n\n    for (const event of eventsCall![0].values) {\n      expect(event.device_id).toBeTruthy();\n      expect(event.user_id).toBeTruthy();\n    }\n  });\n});\n\n// ─── Identity mappings ────────────────────────────────────────────────────────\n\ndescribe(\"Identity mappings\", () => {\n  it(\"inserts no identity_mappings when anonymous_ratio is 100%\", async () => {\n    const jobId = startGenerationJob({\n      total: 50,\n      users: 4,\n      identity_resolution: true,\n      anonymous_ratio: 100,\n    });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    const mappingsCalls = mockInsert.mock.calls.filter(\n      (c) => c[0].table === \"identity_mappings\",\n    );\n    expect(mappingsCalls.length).toBe(0);\n  });\n\n  it(\"inserts identity_mappings for fully-resolved users\", async () => {\n    const jobId = startGenerationJob({\n      total: 50,\n      users: 4,\n      identity_resolution: true,\n      anonymous_ratio: 0,\n    });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    const mappingsCall = mockInsert.mock.calls.find(\n      (c) => c[0].table === \"identity_mappings\",\n    );\n    expect(mappingsCall).toBeDefined();\n    const mappings = mappingsCall![0].values;\n    expect(mappings.length).toBeGreaterThan(0);\n    for (const m of mappings) {\n      expect(m.device_id).toBeTruthy();\n      expect(m.user_id).toBeTruthy();\n    }\n  });\n});\n\n// ─── Cancellation ─────────────────────────────────────────────────────────────\n\ndescribe(\"Cancellation\", () => {\n  it(\"job reaches a terminal state after cancellation\", async () => {\n    // Use a large enough job that it would take multiple batches\n    const jobId = startGenerationJob({ total: 50000, users: 10 });\n    cancelJob(jobId);\n\n    await vi.waitFor(\n      () => {\n        const status = getJob(jobId)?.status;\n        expect(status === \"cancelled\" || status === \"complete\").toBe(true);\n      },\n      { timeout: 10000 },\n    );\n  });\n\n  it(\"cancelled job inserts fewer batches than the full job would\", async () => {\n    // 50,000 events = 5 batches; cancelling early should stop before all 5\n    const jobId = startGenerationJob({ total: 50000, users: 10 });\n    cancelJob(jobId);\n\n    await vi.waitFor(\n      () => {\n        const status = getJob(jobId)?.status;\n        expect(status === \"cancelled\" || status === \"complete\").toBe(true);\n      },\n      { timeout: 10000 },\n    );\n\n    const eventsCalls = mockInsert.mock.calls.filter(\n      (c) => c[0].table === \"events\",\n    );\n    // Should have fewer than all 5 batches (cancelled before completion)\n    expect(eventsCalls.length).toBeLessThan(5);\n  });\n});\n\n// ─── Throughput calculation ───────────────────────────────────────────────────\n\ndescribe(\"Throughput calculation\", () => {\n  it(\"throughput is a non-negative number after completion\", async () => {\n    const jobId = startGenerationJob({ total: 50, users: 3 });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    expect(getJob(jobId)?.throughput).toBeGreaterThanOrEqual(0);\n  });\n\n  it(\"eta_seconds is 0 after completion (all events inserted)\", async () => {\n    const jobId = startGenerationJob({ total: 50, users: 3 });\n\n    await vi.waitFor(\n      () => {\n        expect(getJob(jobId)?.status).toBe(\"complete\");\n      },\n      { timeout: 5000 },\n    );\n\n    expect(getJob(jobId)?.eta_seconds).toBe(0);\n  });\n});\n","numLines":605,"startLine":1,"totalLines":605}}}
