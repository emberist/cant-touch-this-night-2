 const res = await GET();\n61\t    expect(res.body).not.toBeNull();\n62\t    res.body?.cancel();\n63\t  });\n64\t\n65\t  it(\"immediately enqueues a keep-alive SSE comment on connect before any timer fires\", async () => {\n66\t    const res = await GET();\n67\t    expect(res.body).not.toBeNull();\n68\t    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n69\t    const decoder = new TextDecoder();\n70\t\n71\t    // No timer advancement — the keep-alive comment should already be queued\n72\t    const { value } = await reader.read();\n73\t    expect(decoder.decode(value)).toBe(\":\\n\\n\");\n74\t\n75\t    reader.cancel();\n76\t  });\n77\t\n78\t  it(\"emits data: <JSON>\\\\n\\\\n for each event returned by queryNewEvents\", async () => {\n79\t    mockQueryNewEvents\n80\t      .mockResolvedValueOnce([sampleEvent])\n81\t      .mockResolvedValue([]);\n82\t\n83\t    const res = await GET();\n84\t    expect(res.body).not.toBeNull();\n85\t    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n86\t    const decoder = new TextDecoder();\n87\t\n88\t    // Consume the initial keep-alive comment that is sent on connect\n89\t    const { value: keepAliveValue } = await reader.read();\n90\t    expect(decoder.decode(keepAliveValue)).toBe(\":\\n\\n\");\n91\t\n92\t    // Advance clock 1 second to trigger the first polling tick\n93\t    await vi.advanceTimersByTimeAsync(1000);\n94\t\n95\t    const { value } = await reader.read();\n96\t    const text = decoder.decode(value);\n97\t\n98\t    expect(text).toContain(`data: ${JSON.stringify(sampleEvent)}\\n\\n`);\n99\t\n100\t    reader.cancel();\n101\t  });\n102\t\n103\t  it(\"does not emit data: lines when queryNewEvents returns an empty array\", async () => {\n104\t    mockQueryNewEvents.mockResolvedValue([]);\n105\t\n106\t    const res = await GET();\n107\t    expect(res.body).not.toBeNull();\n108\t    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n109\t    const decoder = new TextDecoder();\n110\t\n111\t    // Consume the initial keep-alive comment that is sent on connect\n112\t    const { value: keepAliveValue } = await reader.read();\n113\t    expect(decoder.decode(keepAliveValue)).toBe(\":\\n\\n\");\n114\t\n115\t    // Advance clock to trigger the polling tick\n116\t    await vi.advanceTimersByTimeAsync(1000);\n117\t\n118\t    // Confirm the tick ran\n119\t    expect(mockQueryNewEvents).toHaveBeenCalledOnce();\n120\t\n121\t    // Start a read — it should stay pending since no data events were enqueued\n122\t    let didResolve = false;\n123\t    const readPromise = reader.read().then(() => {\n124\t      didResolve = true;\n125\t    });\n126\t\n127\t    // Flush microtasks — any immediately-enqueued data would resolve here\n128\t    await Promise.resolve();\n129\t    await Promise.resolve();\n130\t\n131\t    expect(didResolve).toBe(false);\n132\t\n133\t    // Cleanup: cancel the stream (this will eventually resolve the pending read)\n134\t    reader.cancel();\n135\t    await readPromise.catch(() => {});\n136\t  });\n137\t});\n138\t"}]},"parent_tool_use_id":null,"session_id":"e860d76c-8b26-422a-9d31-1b5873ceeb41","uuid":"14930e51-27f4-4b6c-bec1-0e7e4f8d3ee4","timestamp":"2026-04-15T18:31:43.832Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/live/__tests__/route.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockQueryNewEvents } = vi.hoisted(() => ({\n  mockQueryNewEvents: vi.fn(),\n}));\n\nvi.mock(\"@/lib/live\", () => ({\n  queryNewEvents: mockQueryNewEvents,\n}));\n\nimport { GET } from \"@/app/api/live/route\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nconst sampleEvent = {\n  event_id: \"evt-1\",\n  event_name: \"Page Viewed\",\n  timestamp: \"2026-04-15 12:00:00.000\",\n  device_id: \"device-abc\",\n  user_id: null,\n  properties: \"{}\",\n  ingested_at: \"2026-04-15 12:00:01.000\",\n  resolved_id: \"device-abc\",\n};\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockQueryNewEvents.mockResolvedValue([]);\n  vi.useFakeTimers();\n});\n\nafterEach(() => {\n  vi.useRealTimers();\n  vi.clearAllMocks();\n});\n\ndescribe(\"GET /api/live\", () => {\n  it(\"returns status 200\", async () => {\n    const res = await GET();\n    expect(res.status).toBe(200);\n    res.body?.cancel();\n  });\n\n  it(\"returns Content-Type: text/event-stream\", async () => {\n    const res = await GET();\n    expect(res.headers.get(\"Content-Type\")).toContain(\"text/event-stream\");\n    res.body?.cancel();\n  });\n\n  it(\"returns Cache-Control: no-cache\", async () => {\n    const res = await GET();\n    expect(res.headers.get(\"Cache-Control\")).toBe(\"no-cache\");\n    res.body?.cancel();\n  });\n\n  it(\"returns a non-null body stream\", async () => {\n    const res = await GET();\n    expect(res.body).not.toBeNull();\n    res.body?.cancel();\n  });\n\n  it(\"immediately enqueues a keep-alive SSE comment on connect before any timer fires\", async () => {\n    const res = await GET();\n    expect(res.body).not.toBeNull();\n    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n    const decoder = new TextDecoder();\n\n    // No timer advancement — the keep-alive comment should already be queued\n    const { value } = await reader.read();\n    expect(decoder.decode(value)).toBe(\":\\n\\n\");\n\n    reader.cancel();\n  });\n\n  it(\"emits data: <JSON>\\\\n\\\\n for each event returned by queryNewEvents\", async () => {\n    mockQueryNewEvents\n      .mockResolvedValueOnce([sampleEvent])\n      .mockResolvedValue([]);\n\n    const res = await GET();\n    expect(res.body).not.toBeNull();\n    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n    const decoder = new TextDecoder();\n\n    // Consume the initial keep-alive comment that is sent on connect\n    const { value: keepAliveValue } = await reader.read();\n    expect(decoder.decode(keepAliveValue)).toBe(\":\\n\\n\");\n\n    // Advance clock 1 second to trigger the first polling tick\n    await vi.advanceTimersByTimeAsync(1000);\n\n    const { value } = await reader.read();\n    const text = decoder.decode(value);\n\n    expect(text).toContain(`data: ${JSON.stringify(sampleEvent)}\\n\\n`);\n\n    reader.cancel();\n  });\n\n  it(\"does not emit data: lines when queryNewEvents returns an empty array\", async () => {\n    mockQueryNewEvents.mockResolvedValue([]);\n\n    const res = await GET();\n    expect(res.body).not.toBeNull();\n    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n    const decoder = new TextDecoder();\n\n    // Consume the initial keep-alive comment that is sent on connect\n    const { value: keepAliveValue } = await reader.read();\n    expect(decoder.decode(keepAliveValue)).toBe(\":\\n\\n\");\n\n    // Advance clock to trigger the polling tick\n    await vi.advanceTimersByTimeAsync(1000);\n\n    // Confirm the tick ran\n    expect(mockQueryNewEvents).toHaveBeenCalledOnce();\n\n    // Start a read — it should stay pending since no data events were enqueued\n    let didResolve = false;\n    const readPromise = reader.read().then(() => {\n      didResolve = true;\n    });\n\n    // Flush microtasks — any immediately-enqueued data would resolve here\n    await Promise.resolve();\n    await Promise.resolve();\n\n    expect(didResolve).toBe(false);\n\n    // Cleanup: cancel the stream (this will eventually resolve the pending read)\n    reader.cancel();\n    await readPromise.catch(() => {});\n  });\n});\n","numLines":138,"startLine":1,"totalLines":138}}}
