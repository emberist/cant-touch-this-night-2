onst breakdownLimitRaw = searchParams.get(\"breakdown_limit\");\n44\t\n45\t  // ── Required param checks ─────────────────────────────────────────────────\n46\t\n47\t  if (!event_name) {\n48\t    return Response.json({ error: \"event_name is required.\" }, { status: 400 });\n49\t  }\n50\t\n51\t  if (!start) {\n52\t    return Response.json({ error: \"start is required.\" }, { status: 400 });\n53\t  }\n54\t\n55\t  if (!end) {\n56\t    return Response.json({ error: \"end is required.\" }, { status: 400 });\n57\t  }\n58\t\n59\t  // ── Optional param validation ─────────────────────────────────────────────\n60\t\n61\t  const measureError = validateMeasure(measure);\n62\t  if (measureError) {\n63\t    return Response.json({ error: measureError }, { status: 400 });\n64\t  }\n65\t\n66\t  if (!VALID_GRANULARITIES.has(granularity)) {\n67\t    return Response.json(\n68\t      {\n69\t        error: `Invalid granularity \"${granularity}\". Must be \"day\" or \"week\".`,\n70\t      },\n71\t      { status: 400 },\n72\t    );\n73\t  }\n74\t\n75\t  let breakdown_limit = 10;\n76\t  if (breakdownLimitRaw !== null) {\n77\t    const parsed = Number(breakdownLimitRaw);\n78\t    if (Number.isFinite(parsed) && parsed > 0) {\n79\t      breakdown_limit = Math.floor(parsed);\n80\t    }\n81\t  }\n82\t\n83\t  // ── Execute query ─────────────────────────────────────────────────────────\n84\t\n85\t  try {\n86\t    const response = await queryTrends({\n87\t      event_name,\n88\t      measure,\n89\t      granularity: granularity as \"day\" | \"week\",\n90\t      start,\n91\t      end,\n92\t      breakdown,\n93\t      breakdown_limit,\n94\t    });\n95\t    return Response.json(response);\n96\t  } catch (err) {\n97\t    const message =\n98\t      err instanceof Error ? err.message : \"Internal server error.\";\n99\t    return Response.json({ error: message }, { status: 500 });\n100\t  }\n101\t}\n102\t"}]},"parent_tool_use_id":null,"session_id":"7487c004-0d87-49f1-84d9-27e324e21aa2","uuid":"53b9c7fd-8487-4ba9-ab6a-6dc8991c7ca2","timestamp":"2026-04-15T13:22:43.895Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/trends/route.ts","content":"import { queryTrends } from \"@/lib/trends\";\n\n// ─── Validation helpers ───────────────────────────────────────────────────────\n\nconst VALID_MEASURES = new Set([\"count\", \"unique_users\"]);\nconst VALID_GRANULARITIES = new Set([\"day\", \"week\"]);\n\n/**\n * Returns an error string if the measure is invalid, otherwise null.\n * Valid forms: \"count\", \"unique_users\", \"sum:<prop>\", \"avg:<prop>\",\n * \"min:<prop>\", \"max:<prop>\" where <prop> is a non-empty string.\n */\nfunction validateMeasure(measure: string): string | null {\n  if (VALID_MEASURES.has(measure)) return null;\n  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n  if (match) return null;\n  return `Invalid measure \"${measure}\". Must be count, unique_users, sum:<prop>, avg:<prop>, min:<prop>, or max:<prop>.`;\n}\n\n// ─── Route handler ────────────────────────────────────────────────────────────\n\n/**\n * GET /api/trends\n *\n * Query params:\n *   event_name   (required)\n *   measure      default \"count\"\n *   granularity  default \"day\"\n *   start        (required) ISO date YYYY-MM-DD\n *   end          (required) ISO date YYYY-MM-DD\n *   breakdown    (optional) property name\n *   breakdown_limit (optional) default 10\n */\nexport async function GET(request: Request): Promise<Response> {\n  const { searchParams } = new URL(request.url);\n\n  const event_name = searchParams.get(\"event_name\");\n  const measure = searchParams.get(\"measure\") ?? \"count\";\n  const granularity = searchParams.get(\"granularity\") ?? \"day\";\n  const start = searchParams.get(\"start\");\n  const end = searchParams.get(\"end\");\n  const breakdown = searchParams.get(\"breakdown\") ?? undefined;\n  const breakdownLimitRaw = searchParams.get(\"breakdown_limit\");\n\n  // ── Required param checks ─────────────────────────────────────────────────\n\n  if (!event_name) {\n    return Response.json({ error: \"event_name is required.\" }, { status: 400 });\n  }\n\n  if (!start) {\n    return Response.json({ error: \"start is required.\" }, { status: 400 });\n  }\n\n  if (!end) {\n    return Response.json({ error: \"end is required.\" }, { status: 400 });\n  }\n\n  // ── Optional param validation ─────────────────────────────────────────────\n\n  const measureError = validateMeasure(measure);\n  if (measureError) {\n    return Response.json({ error: measureError }, { status: 400 });\n  }\n\n  if (!VALID_GRANULARITIES.has(granularity)) {\n    return Response.json(\n      {\n        error: `Invalid granularity \"${granularity}\". Must be \"day\" or \"week\".`,\n      },\n      { status: 400 },\n    );\n  }\n\n  let breakdown_limit = 10;\n  if (breakdownLimitRaw !== null) {\n    const parsed = Number(breakdownLimitRaw);\n    if (Number.isFinite(parsed) && parsed > 0) {\n      breakdown_limit = Math.floor(parsed);\n    }\n  }\n\n  // ── Execute query ─────────────────────────────────────────────────────────\n\n  try {\n    const response = await queryTrends({\n      event_name,\n      measure,\n      granularity: granularity as \"day\" | \"week\",\n      start,\n      end,\n      breakdown,\n      breakdown_limit,\n    });\n    return Response.json(response);\n  } catch (err) {\n    const message =\n      err instanceof Error ? err.message : \"Internal server error.\";\n    return Response.json({ error: message }, { status: 500 });\n  }\n}\n","numLines":102,"startLine":1,"totalLines":102}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FFjf4oA7Lj9iYz47KziwAz","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQuery } = vi.hoisted(() => ({\n6\t  mockQuery: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: {\n11\t    query: mockQuery,\n12\t  },\n13\t}));\n14\t\n15\timport { buildTrendsQuery, queryTrends } from \"@/lib/trends\";\n16\t\n17\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n18\t\n19\tfunction mockQueryReturns(rows: unknown[]) {\n20\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n21\t}\n22\t\n23\tconst baseParams = {\n24\t  event_name: \"Page Viewed\",\n25\t  measure: \"count\",\n26\t  granularity: \"day\" as const,\n27\t  start: \"2026-04-01\",\n28\t  end: \"2026-04-15\",\n29\t};\n30\t\n31\t// ─── Tests ────────────────────────────────────────────────────────────────────\n32\t\n33\tbeforeEach(() => {\n34\t  mockQueryReturns([]);\n35\t});\n36\t\n37\tafterEach(() => {\n38\t  vi.clearAllMocks();\n39\t});\n40\t\n41\t// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n42\t\n43\tdescribe(\"buildTrendsQuery\", () => {\n44\t  describe(\"measure expressions\", () => {\n45\t    it(\"uses count() for measure=count\", () => {\n46\t      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n47\t      expect(query).toContain(\"count()\");\n48\t    });\n49\t\n50\t    it(\"uses uniqExact and identity_mappings FINAL for measure=unique_users\", () => {\n51\t      const { query } = buildTrendsQuery({\n52\t        ...baseParams,\n53\t        measure: \"unique_users\",\n54\t      });\n55\t      expect(query).toContain(\"uniqExact\");\n56\t      expect(query).toContain(\"identity_mappings FINAL\");\n57\t    });\n58\t\n59\t    it(\"does not include identity_mappings JOIN for measure=count\", () => {\n60\t      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n61\t      expect(query).not.toContain(\"identity_mappings\");\n62\t    });\n63\t\n64\t    it(\"uses sum(JSONExtractFloat) for measure=sum:amount\", () => {\n65\t      const { query } = buildTrendsQuery({\n66\t        ...baseParams,\n67\t        measure: \"sum:amount\",\n68\t      });\n69\t      expect(query).toContain(\"sum(JSONExtractFloat\");\n70\t      expect(query).toContain(\"'amount'\");\n71\t    });\n72\t\n73\t    it(\"uses avg(JSONExtractFloat) for measure=avg:amount\", () => {\n74\t      const { query } = buildTrendsQuery({\n75\t        ...baseParams,\n76\t        measure: \"avg:amount\",\n77\t      });\n78\t      expect(query).toContain(\"avg(JSONExtractFloat\");\n79\t      expect(query).toContain(\"'amount'\");\n80\t    });\n81\t\n82\t    it(\"uses min(JSONExtractFloat) for measure=min:amount\", () => {\n83\t      const { query } = buildTrendsQuery({\n84\t        ...baseParams,\n85\t        measure: \"min:amount\",\n86\t      });\n87\t      expect(query).toContain(\"min(JSONExtractFloat\");\n88\t    });\n89\t\n90\t    it(\"uses max(JSONExtractFloat) for measure=max:amount\", () => {\n91\t      const { query } = buildTrendsQuery({\n92\t        ...baseParams,\n93\t        measure: \"max:amount\",\n94\t      });\n95\t      expect(query).toContain(\"max(JSONExtractFloat\");\n96\t    });\n97\t  });\n98\t\n99\t  describe(\"granularity\", () => {\n100\t    it(\"groups by toDate for granularity=day\", () => {\n101\t      const { query } = buildTrendsQuery({\n102\t        ...baseParams,\n103\t        granularity: \"day\",\n104\t      });\n105\t      expect(query).toContain(\"toDate(\");\n106\t    });\n107\t\n108\t    it(\"groups by toMonday for granularity=week\", () => {\n109\t      const { query } = buildTrendsQuery({\n110\t        ...baseParams,\n111\t        granularity: \"week\",\n112\t      });\n113\t      expect(query).toContain(\"toMonday(\");\n114\t    });\n115\t  });\n116\t\n117\t  describe(\"date range\", () => {\n118\t    it(\"includes start and end_exclusive in query params\", () => {\n119\t      const { query_params } = buildTrendsQuery({\n120\t        ...baseParams,\n121\t        start: \"2026-04-01\",\n122\t        end: \"2026-04-15\",\n123\t      });\n124\t      expect(query_params).toHaveProperty(\"start\");\n125\t      expect(query_params).toHaveProperty(\"end_exclusive\");\n126\t      expect(query_params.start).toContain(\"2026-04-01\");\n127\t      expect(query_params.end_exclusive).toContain(\"2026-04-16\");\n128\t    });\n129\t\n130\t    it(\"references start and end_exclusive params in the WHERE clause\", () => {\n131\t      const { query } = buildTrendsQuery(baseParams);\n132\t      expect(query).toContain(\"{start:String}\");\n133\t      expect(query).toContain(\"{end_exclusive:String}\");\n134\t    });\n135\t\n136\t    it(\"includes event_name in query params\", () => {\n137\t      const { query_params } = buildTrendsQuery({\n138\t        ...baseParams,\n139\t        event_name: \"Purchase Completed\",\n140\t      });\n141\t      expect(query_params.event_name).toBe(\"Purchase Completed\");\n142\t    });\n143\t  });\n144\t\n145\t  describe(\"breakdown\", () => {\n146\t    it(\"does not include breakdown_val column when no breakdown is given\", () => {\n147\t      const { query } = buildTrendsQuery(baseParams);\n148\t      expect(query).not.toContain(\"breakdown_val\");\n149\t    });\n150\t\n151\t    it(\"includes JSONExtractString and breakdown_val when breakdown is provided\", () => {\n152\t      const { query } = buildTrendsQuery({\n153\t        ...baseParams,\n154\t        breakdown: \"country\",\n155\t      });\n156\t      expect(query).toContain(\"JSONExtractString\");\n157\t      expect(query).toContain(\"breakdown_val\");\n158\t      expect(query).toContain(\"'country'\");\n159\t    });\n160\t\n161\t    it(\"groups by breakdown_val in addition to bucket when breakdown is provided\", () => {\n162\t      const { query } = buildTrendsQuery({\n163\t        ...baseParams,\n164\t        breakdown: \"country\",\n165\t      });\n166\t      expect(query).toContain(\"GROUP BY bucket, breakdown_val\");\n167\t    });\n168\t  });\n169\t});\n170\t\n171\t// ─── queryTrends ──────────────────────────────────────────────────────────────\n172\t\n173\tdescribe(\"queryTrends\", () => {\n174\t  describe(\"without breakdown\", () => {\n175\t    it(\"returns a single series with label = event_name\", async () => {\n176\t      mockQueryReturns([\n177\t        { bucket: \"2026-04-01\", value: 5 },\n178\t        { bucket: \"2026-04-02\", value: 3 },\n179\t      ]);\n180\t\n181\t      const result = await queryTrends({\n182\t        ...baseParams,\n183\t        event_name: \"Page Viewed\",\n184\t      });\n185\t\n186\t      expect(result.series).toHaveLength(1);\n187\t      expect(result.series[0].label).toBe(\"Page Viewed\");\n188\t    });\n189\t\n190\t    it(\"maps rows to { date, value } data points\", async () => {\n191\t      mockQueryReturns([\n192\t        { bucket: \"2026-04-01\", value: 5 },\n193\t        { bucket: \"2026-04-02\", value: 3 },\n194\t      ]);\n195\t\n196\t      const result = await queryTrends(baseParams);\n197\t\n198\t      expect(result.series[0].data).toEqual([\n199\t        { date: \"2026-04-01\", value: 5 },\n200\t        { date: \"2026-04-02\", value: 3 },\n201\t      ]);\n202\t    });\n203\t\n204\t    it(\"coerces string values returned by ClickHouse to numbers\", async () => {\n205\t      mockQueryReturns([{ bucket: \"2026-04-01\", value: \"42\" }]);\n206\t\n207\t      const result = await queryTrends(baseParams);\n208\t\n209\t      expect(result.series[0].data[0].value).toBe(42);\n210\t      expect(typeof result.series[0].data[0].value).toBe(\"number\");\n211\t    });\n212\t\n213\t    it(\"returns { series: [] } when ClickHouse returns no rows\", async () => {\n214\t      mockQueryReturns([]);\n215\t\n216\t      const result = await queryTrends(baseParams);\n217\t\n218\t      expect(result.series).toEqual([]);\n219\t    });\n220\t  });\n221\t\n222\t  describe(\"with breakdown\", () => {\n223\t    it(\"returns one series per distinct breakdown value\", async () => {\n224\t      mockQueryReturns([\n225\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n226\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n227\t        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n228\t      ]);\n229\t\n230\t      const result = await queryTrends({\n231\t        ...baseParams,\n232\t        breakdown: \"country\",\n233\t      });\n234\t\n235\t      const labels = result.series.map((s) => s.label);\n236\t      expect(labels).toContain(\"US\");\n237\t      expect(labels).toContain(\"DE\");\n238\t    });\n239\t\n240\t    it(\"orders data points within each series chronologically\", async () => {\n241\t      mockQueryReturns([\n242\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n243\t        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n244\t      ]);\n245\t\n246\t      const result = await queryTrends({\n247\t        ...baseParams,\n248\t        breakdown: \"country\",\n249\t      });\n250\t\n251\t      const usSeries = result.series.find((s) => s.label === \"US\");\n252\t      expect(usSeries?.data[0].date).toBe(\"2026-04-01\");\n253\t      expect(usSeries?.data[1].date).toBe(\"2026-04-02\");\n254\t    });\n255\t\n256\t    it(\"respects breakdown_limit and groups remaining values as Other\", async () => {\n257\t      mockQueryReturns([\n258\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n259\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n260\t        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n261\t      ]);\n262\t\n263\t      const result = await queryTrends({\n264\t        ...baseParams,\n265\t        breakdown: \"country\",\n266\t        breakdown_limit: 2,\n267\t      });\n268\t\n269\t      expect(result.series).toHaveLength(3); // US, DE, Other\n270\t      const labels = result.series.map((s) => s.label);\n271\t      expect(labels).toContain(\"US\");\n272\t      expect(labels).toContain(\"DE\");\n273\t      expect(labels).toContain(\"Other\");\n274\t      expect(labels).not.toContain(\"FR\");\n275\t    });\n276\t\n277\t    it(\"Other series aggregates values of non-top breakdown values by date\", async () => {\n278\t      mockQueryReturns([\n279\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n280\t        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n281\t        { bucket: \"2026-04-01\", breakdown_val: \"JP\", value: 7 },\n282\t      ]);\n283\t\n284\t      const result = await queryTrends({\n285\t        ...baseParams,\n286\t        breakdown: \"country\",\n287\t        breakdown_limit: 1,\n288\t      });\n289\t\n290\t      const otherSeries = result.series.find((s) => s.label === \"Other\");\n291\t      expect(otherSeries).toBeDefined();\n292\t      // FR (10) + JP (7) = 17\n293\t      expect(otherSeries?.data[0].value).toBe(17);\n294\t    });\n295\t\n296\t    it(\"does not add Other series when all values are within the limit\", async () => {\n297\t      mockQueryReturns([\n298\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n299\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n300\t      ]);\n301\t\n302\t      const result = await queryTrends({\n303\t        ...baseParams,\n304\t        breakdown: \"country\",\n305\t        breakdown_limit: 10,\n306\t      });\n307\t\n308\t      const labels = result.series.map((s) => s.label);\n309\t      expect(labels).not.toContain(\"Other\");\n310\t    });\n311\t\n312\t    it(\"sorts series by total value descending (top values first)\", async () => {\n313\t      mockQueryReturns([\n314\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n315\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n316\t        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 25 },\n317\t      ]);\n318\t\n319\t      const result = await queryTrends({\n320\t        ...baseParams,\n321\t        breakdown: \"country\",\n322\t        breakdown_limit: 10,\n323\t      });\n324\t\n325\t      expect(result.series[0].label).toBe(\"US\");\n326\t      expect(result.series[1].label).toBe(\"DE\");\n327\t      expect(result.series[2].label).toBe(\"FR\");\n328\t    });\n329\t  });\n330\t});\n331\t"}]},"parent_tool_use_id":null,"session_id":"7487c004-0d87-49f1-84d9-27e324e21aa2","uuid":"39ef4194-704c-45b8-8c93-a58e790a93ef","timestamp":"2026-04-15T13:22:43.985Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/trends.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockQuery } = vi.hoisted(() => ({\n  mockQuery: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    query: mockQuery,\n  },\n}));\n\nimport { buildTrendsQuery, queryTrends } from \"@/lib/trends\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction mockQueryReturns(rows: unknown[]) {\n  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n}\n\nconst baseParams = {\n  event_name: \"Page Viewed\",\n  measure: \"count\",\n  granularity: \"day\" as const,\n  start: \"2026-04-01\",\n  end: \"2026-04-15\",\n};\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockQueryReturns([]);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\n// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n\ndescribe(\"buildTrendsQuery\", () => {\n  describe(\"measure expressions\", () => {\n    it(\"uses count() for measure=count\", () => {\n      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n      expect(query).toContain(\"count()\");\n    });\n\n    it(\"uses uniqExact and identity_mappings FINAL for measure=unique_users\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"unique_users\",\n      });\n      expect(query).toContain(\"uniqExact\");\n      expect(query).toContain(\"identity_mappings FINAL\");\n    });\n\n    it(\"does not include identity_mappings JOIN for measure=count\", () => {\n      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n      expect(query).not.toContain(\"identity_mappings\");\n    });\n\n    it(\"uses sum(JSONExtractFloat) for measure=sum:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"sum:amount\",\n      });\n      expect(query).toContain(\"sum(JSONExtractFloat\");\n      expect(query).toContain(\"'amount'\");\n    });\n\n    it(\"uses avg(JSONExtractFloat) for measure=avg:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"avg:amount\",\n      });\n      expect(query).toContain(\"avg(JSONExtractFloat\");\n      expect(query).toContain(\"'amount'\");\n    });\n\n    it(\"uses min(JSONExtractFloat) for measure=min:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"min:amount\",\n      });\n      expect(query).toContain(\"min(JSONExtractFloat\");\n    });\n\n    it(\"uses max(JSONExtractFloat) for measure=max:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"max:amount\",\n      });\n      expect(query).toContain(\"max(JSONExtractFloat\");\n    });\n  });\n\n  describe(\"granularity\", () => {\n    it(\"groups by toDate for granularity=day\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        granularity: \"day\",\n      });\n      expect(query).toContain(\"toDate(\");\n    });\n\n    it(\"groups by toMonday for granularity=week\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        granularity: \"week\",\n      });\n      expect(query).toContain(\"toMonday(\");\n    });\n  });\n\n  describe(\"date range\", () => {\n    it(\"includes start and end_exclusive in query params\", () => {\n      const { query_params } = buildTrendsQuery({\n        ...baseParams,\n        start: \"2026-04-01\",\n        end: \"2026-04-15\",\n      });\n      expect(query_params).toHaveProperty(\"start\");\n      expect(query_params).toHaveProperty(\"end_exclusive\");\n      expect(query_params.start).toContain(\"2026-04-01\");\n      expect(query_params.end_exclusive).toContain(\"2026-04-16\");\n    });\n\n    it(\"references start and end_exclusive params in the WHERE clause\", () => {\n      const { query } = buildTrendsQuery(baseParams);\n      expect(query).toContain(\"{start:String}\");\n      expect(query).toContain(\"{end_exclusive:String}\");\n    });\n\n    it(\"includes event_name in query params\", () => {\n      const { query_params } = buildTrendsQuery({\n        ...baseParams,\n        event_name: \"Purchase Completed\",\n      });\n      expect(query_params.event_name).toBe(\"Purchase Completed\");\n    });\n  });\n\n  describe(\"breakdown\", () => {\n    it(\"does not include breakdown_val column when no breakdown is given\", () => {\n      const { query } = buildTrendsQuery(baseParams);\n      expect(query).not.toContain(\"breakdown_val\");\n    });\n\n    it(\"includes JSONExtractString and breakdown_val when breakdown is provided\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n      expect(query).toContain(\"JSONExtractString\");\n      expect(query).toContain(\"breakdown_val\");\n      expect(query).toContain(\"'country'\");\n    });\n\n    it(\"groups by breakdown_val in addition to bucket when breakdown is provided\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n      expect(query).toContain(\"GROUP BY bucket, breakdown_val\");\n    });\n  });\n});\n\n// ─── queryTrends ──────────────────────────────────────────────────────────────\n\ndescribe(\"queryTrends\", () => {\n  describe(\"without breakdown\", () => {\n    it(\"returns a single series with label = event_name\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", value: 5 },\n        { bucket: \"2026-04-02\", value: 3 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        event_name: \"Page Viewed\",\n      });\n\n      expect(result.series).toHaveLength(1);\n      expect(result.series[0].label).toBe(\"Page Viewed\");\n    });\n\n    it(\"maps rows to { date, value } data points\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", value: 5 },\n        { bucket: \"2026-04-02\", value: 3 },\n      ]);\n\n      const result = await queryTrends(baseParams);\n\n      expect(result.series[0].data).toEqual([\n        { date: \"2026-04-01\", value: 5 },\n        { date: \"2026-04-02\", value: 3 },\n      ]);\n    });\n\n    it(\"coerces string values returned by ClickHouse to numbers\", async () => {\n      mockQueryReturns([{ bucket: \"2026-04-01\", value: \"42\" }]);\n\n      const result = await queryTrends(baseParams);\n\n      expect(result.series[0].data[0].value).toBe(42);\n      expect(typeof result.series[0].data[0].value).toBe(\"number\");\n    });\n\n    it(\"returns { series: [] } when ClickHouse returns no rows\", async () => {\n      mockQueryReturns([]);\n\n      const result = await queryTrends(baseParams);\n\n      expect(result.series).toEqual([]);\n    });\n  });\n\n  describe(\"with breakdown\", () => {\n    it(\"returns one series per distinct breakdown value\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n\n      const labels = result.series.map((s) => s.label);\n      expect(labels).toContain(\"US\");\n      expect(labels).toContain(\"DE\");\n    });\n\n    it(\"orders data points within each series chronologically\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n\n      const usSeries = result.series.find((s) => s.label === \"US\");\n      expect(usSeries?.data[0].date).toBe(\"2026-04-01\");\n      expect(usSeries?.data[1].date).toBe(\"2026-04-02\");\n    });\n\n    it(\"respects breakdown_limit and groups remaining values as Other\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 2,\n      });\n\n      expect(result.series).toHaveLength(3); // US, DE, Other\n      const labels = result.series.map((s) => s.label);\n      expect(labels).toContain(\"US\");\n      expect(labels).toContain(\"DE\");\n      expect(labels).toContain(\"Other\");\n      expect(labels).not.toContain(\"FR\");\n    });\n\n    it(\"Other series aggregates values of non-top breakdown values by date\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n        { bucket: \"2026-04-01\", breakdown_val: \"JP\", value: 7 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 1,\n      });\n\n      const otherSeries = result.series.find((s) => s.label === \"Other\");\n      expect(otherSeries).toBeDefined();\n      // FR (10) + JP (7) = 17\n      expect(otherSeries?.data[0].value).toBe(17);\n    });\n\n    it(\"does not add Other series when all values are within the limit\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 10,\n      });\n\n      const labels = result.series.map((s) => s.label);\n      expect(labels).not.toContain(\"Other\");\n    });\n\n    it(\"sorts series by total value descending (top values first)\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 25 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 10,\n      });\n\n      expect(result.series[0].label).toBe(\"US\");\n      expect(result.series[1].label).toBe(\"DE\");\n      expect(result.series[2].label).toBe(\"FR\");\n    });\n  });\n});\n","numLines":331,"startLine":1,"totalLines":331}}}
