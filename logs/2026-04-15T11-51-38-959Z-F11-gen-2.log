{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PHib8igUVE915wGRv9jpZs","type":"tool_result","content":"1\t/**\n2\t * Integration tests for GET /api/trends\n3\t *\n4\t * These tests require:\n5\t *   - A running dev server at http://localhost:3000\n6\t *   - A running ClickHouse instance at http://localhost:8123\n7\t *\n8\t * Run with:\n9\t *   pnpm dev &    # starts ClickHouse + Next.js via concurrently\n10\t *   pnpm test\n11\t */\n12\t\n13\timport { afterAll, beforeAll, describe, expect, it } from \"vitest\";\n14\t\n15\tconst BASE_URL = \"http://localhost:3000\";\n16\tconst ENDPOINT = `${BASE_URL}/api/trends`;\n17\t\n18\t/** Returns true if the dev server is reachable. */\n19\tasync function isServerAvailable(): Promise<boolean> {\n20\t  try {\n21\t    const res = await fetch(BASE_URL, {\n22\t      method: \"HEAD\",\n23\t      signal: AbortSignal.timeout(2000),\n24\t    });\n25\t    return res.status < 600;\n26\t  } catch {\n27\t    return false;\n28\t  }\n29\t}\n30\t\n31\tlet serverAvailable = false;\n32\t\n33\tbeforeAll(async () => {\n34\t  serverAvailable = await isServerAvailable();\n35\t  if (!serverAvailable) {\n36\t    console.warn(\n37\t      \"[integration] Dev server not available at http://localhost:3000 — skipping integration tests.\",\n38\t    );\n39\t  }\n40\t});\n41\t\n42\tafterAll(() => {\n43\t  // Nothing to tear down; we didn't start the server ourselves.\n44\t});\n45\t\n46\tdescribe(\"GET /api/trends — integration\", () => {\n47\t  it(\"valid request returns 200 with series array\", async () => {\n48\t    if (!serverAvailable) {\n49\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n50\t      return;\n51\t    }\n52\t\n53\t    const url = new URL(ENDPOINT);\n54\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n55\t    url.searchParams.set(\"start\", \"2026-01-01\");\n56\t    url.searchParams.set(\"end\", \"2026-04-15\");\n57\t\n58\t    const res = await fetch(url.toString());\n59\t    expect(res.status).toBe(200);\n60\t\n61\t    const body = await res.json();\n62\t    expect(body).toHaveProperty(\"series\");\n63\t    expect(Array.isArray(body.series)).toBe(true);\n64\t  });\n65\t\n66\t  it(\"series items have label string and data array of {date, value}\", async () => {\n67\t    if (!serverAvailable) {\n68\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n69\t      return;\n70\t    }\n71\t\n72\t    const url = new URL(ENDPOINT);\n73\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n74\t    url.searchParams.set(\"start\", \"2026-01-01\");\n75\t    url.searchParams.set(\"end\", \"2026-04-15\");\n76\t\n77\t    const res = await fetch(url.toString());\n78\t    const body = await res.json();\n79\t\n80\t    for (const series of body.series) {\n81\t      expect(typeof series.label).toBe(\"string\");\n82\t      expect(Array.isArray(series.data)).toBe(true);\n83\t      for (const point of series.data) {\n84\t        expect(typeof point.date).toBe(\"string\");\n85\t        expect(typeof point.value).toBe(\"number\");\n86\t      }\n87\t    }\n88\t  });\n89\t\n90\t  it(\"missing event_name returns 400 with error\", async () => {\n91\t    if (!serverAvailable) {\n92\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n93\t      return;\n94\t    }\n95\t\n96\t    const url = new URL(ENDPOINT);\n97\t    url.searchParams.set(\"start\", \"2026-01-01\");\n98\t    url.searchParams.set(\"end\", \"2026-04-15\");\n99\t\n100\t    const res = await fetch(url.toString());\n101\t    expect(res.status).toBe(400);\n102\t\n103\t    const body = await res.json();\n104\t    expect(body).toHaveProperty(\"error\");\n105\t    expect(typeof body.error).toBe(\"string\");\n106\t  });\n107\t\n108\t  it(\"missing start returns 400 with error\", async () => {\n109\t    if (!serverAvailable) {\n110\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n111\t      return;\n112\t    }\n113\t\n114\t    const url = new URL(ENDPOINT);\n115\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n116\t    url.searchParams.set(\"end\", \"2026-04-15\");\n117\t\n118\t    const res = await fetch(url.toString());\n119\t    expect(res.status).toBe(400);\n120\t\n121\t    const body = await res.json();\n122\t    expect(body).toHaveProperty(\"error\");\n123\t  });\n124\t\n125\t  it(\"missing end returns 400 with error\", async () => {\n126\t    if (!serverAvailable) {\n127\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n128\t      return;\n129\t    }\n130\t\n131\t    const url = new URL(ENDPOINT);\n132\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n133\t    url.searchParams.set(\"start\", \"2026-01-01\");\n134\t\n135\t    const res = await fetch(url.toString());\n136\t    expect(res.status).toBe(400);\n137\t\n138\t    const body = await res.json();\n139\t    expect(body).toHaveProperty(\"error\");\n140\t  });\n141\t\n142\t  it(\"invalid measure returns 400 with error\", async () => {\n143\t    if (!serverAvailable) {\n144\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n145\t      return;\n146\t    }\n147\t\n148\t    const url = new URL(ENDPOINT);\n149\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n150\t    url.searchParams.set(\"start\", \"2026-01-01\");\n151\t    url.searchParams.set(\"end\", \"2026-04-15\");\n152\t    url.searchParams.set(\"measure\", \"bogus\");\n153\t\n154\t    const res = await fetch(url.toString());\n155\t    expect(res.status).toBe(400);\n156\t\n157\t    const body = await res.json();\n158\t    expect(body).toHaveProperty(\"error\");\n159\t  });\n160\t\n161\t  it(\"invalid granularity returns 400 with error\", async () => {\n162\t    if (!serverAvailable) {\n163\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n164\t      return;\n165\t    }\n166\t\n167\t    const url = new URL(ENDPOINT);\n168\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n169\t    url.searchParams.set(\"start\", \"2026-01-01\");\n170\t    url.searchParams.set(\"end\", \"2026-04-15\");\n171\t    url.searchParams.set(\"granularity\", \"month\");\n172\t\n173\t    const res = await fetch(url.toString());\n174\t    expect(res.status).toBe(400);\n175\t\n176\t    const body = await res.json();\n177\t    expect(body).toHaveProperty(\"error\");\n178\t  });\n179\t\n180\t  // Integration gap from F11: breakdown + seeded data produces multiple series\n181\t  it(\"breakdown returns 200 with multiple series, each with label and data\", async () => {\n182\t    if (!serverAvailable) {\n183\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n184\t      return;\n185\t    }\n186\t\n187\t    // Seed data first so there are events with page properties\n188\t    const seedRes = await fetch(`${BASE_URL}/api/seed`, {\n189\t      method: \"POST\",\n190\t      signal: AbortSignal.timeout(40000),\n191\t    });\n192\t    expect(seedRes.status).toBe(200);\n193\t\n194\t    const url = new URL(ENDPOINT);\n195\t    url.searchParams.set(\"event_name\", \"Page Viewed\");\n196\t    url.searchParams.set(\"start\", \"2026-03-15\");\n197\t    url.searchParams.set(\"end\", \"2026-04-15\");\n198\t    url.searchParams.set(\"breakdown\", \"page\");\n199\t    url.searchParams.set(\"breakdown_limit\", \"3\");\n200\t\n201\t    const res = await fetch(url.toString());\n202\t    expect(res.status).toBe(200);\n203\t\n204\t    const body = await res.json();\n205\t    expect(body).toHaveProperty(\"series\");\n206\t    expect(Array.isArray(body.series)).toBe(true);\n207\t    // With seeded data and breakdown, we expect multiple series\n208\t    expect(body.series.length).toBeGreaterThan(1);\n209\t\n210\t    // Each series must have label (string) and data (array of {date, value})\n211\t    for (const series of body.series) {\n212\t      expect(typeof series.label).toBe(\"string\");\n213\t      expect(Array.isArray(series.data)).toBe(true);\n214\t      for (const point of series.data) {\n215\t        expect(typeof point.date).toBe(\"string\");\n216\t        expect(typeof point.value).toBe(\"number\");\n217\t      }\n218\t    }\n219\t\n220\t    // breakdown_limit=3 means at most 4 series (top 3 + optional \"Other\")\n221\t    expect(body.series.length).toBeLessThanOrEqual(4);\n222\t\n223\t    // Series must be sorted by total value descending (\"Other\" last if present)\n224\t    const nonOther = body.series.filter((s: { label: string }) => s.label !== \"Other\");\n225\t    const totals = nonOther.map((s: { data: { value: number }[] }) =>\n226\t      s.data.reduce((sum: number, p: { value: number }) => sum + p.value, 0)\n227\t    );\n228\t    for (let i = 0; i + 1 < totals.length; i++) {\n229\t      expect(totals[i]).toBeGreaterThanOrEqual(totals[i + 1]);\n230\t    }\n231\t  });\n232\t});\n233\t"}]},"parent_tool_use_id":null,"session_id":"7487c004-0d87-49f1-84d9-27e324e21aa2","uuid":"0d3ee2f7-62bb-4436-8020-05025b6bc173","timestamp":"2026-04-15T13:22:37.208Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/trends/__tests__/route.integration.test.ts","content":"/**\n * Integration tests for GET /api/trends\n *\n * These tests require:\n *   - A running dev server at http://localhost:3000\n *   - A running ClickHouse instance at http://localhost:8123\n *\n * Run with:\n *   pnpm dev &    # starts ClickHouse + Next.js via concurrently\n *   pnpm test\n */\n\nimport { afterAll, beforeAll, describe, expect, it } from \"vitest\";\n\nconst BASE_URL = \"http://localhost:3000\";\nconst ENDPOINT = `${BASE_URL}/api/trends`;\n\n/** Returns true if the dev server is reachable. */\nasync function isServerAvailable(): Promise<boolean> {\n  try {\n    const res = await fetch(BASE_URL, {\n      method: \"HEAD\",\n      signal: AbortSignal.timeout(2000),\n    });\n    return res.status < 600;\n  } catch {\n    return false;\n  }\n}\n\nlet serverAvailable = false;\n\nbeforeAll(async () => {\n  serverAvailable = await isServerAvailable();\n  if (!serverAvailable) {\n    console.warn(\n      \"[integration] Dev server not available at http://localhost:3000 — skipping integration tests.\",\n    );\n  }\n});\n\nafterAll(() => {\n  // Nothing to tear down; we didn't start the server ourselves.\n});\n\ndescribe(\"GET /api/trends — integration\", () => {\n  it(\"valid request returns 200 with series array\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-01-01\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(200);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"series\");\n    expect(Array.isArray(body.series)).toBe(true);\n  });\n\n  it(\"series items have label string and data array of {date, value}\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-01-01\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n\n    const res = await fetch(url.toString());\n    const body = await res.json();\n\n    for (const series of body.series) {\n      expect(typeof series.label).toBe(\"string\");\n      expect(Array.isArray(series.data)).toBe(true);\n      for (const point of series.data) {\n        expect(typeof point.date).toBe(\"string\");\n        expect(typeof point.value).toBe(\"number\");\n      }\n    }\n  });\n\n  it(\"missing event_name returns 400 with error\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"start\", \"2026-01-01\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n    expect(typeof body.error).toBe(\"string\");\n  });\n\n  it(\"missing start returns 400 with error\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n  });\n\n  it(\"missing end returns 400 with error\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-01-01\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n  });\n\n  it(\"invalid measure returns 400 with error\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-01-01\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n    url.searchParams.set(\"measure\", \"bogus\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n  });\n\n  it(\"invalid granularity returns 400 with error\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-01-01\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n    url.searchParams.set(\"granularity\", \"month\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n  });\n\n  // Integration gap from F11: breakdown + seeded data produces multiple series\n  it(\"breakdown returns 200 with multiple series, each with label and data\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    // Seed data first so there are events with page properties\n    const seedRes = await fetch(`${BASE_URL}/api/seed`, {\n      method: \"POST\",\n      signal: AbortSignal.timeout(40000),\n    });\n    expect(seedRes.status).toBe(200);\n\n    const url = new URL(ENDPOINT);\n    url.searchParams.set(\"event_name\", \"Page Viewed\");\n    url.searchParams.set(\"start\", \"2026-03-15\");\n    url.searchParams.set(\"end\", \"2026-04-15\");\n    url.searchParams.set(\"breakdown\", \"page\");\n    url.searchParams.set(\"breakdown_limit\", \"3\");\n\n    const res = await fetch(url.toString());\n    expect(res.status).toBe(200);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"series\");\n    expect(Array.isArray(body.series)).toBe(true);\n    // With seeded data and breakdown, we expect multiple series\n    expect(body.series.length).toBeGreaterThan(1);\n\n    // Each series must have label (string) and data (array of {date, value})\n    for (const series of body.series) {\n      expect(typeof series.label).toBe(\"string\");\n      expect(Array.isArray(series.data)).toBe(true);\n      for (const point of series.data) {\n        expect(typeof point.date).toBe(\"string\");\n        expect(typeof point.value).toBe(\"number\");\n      }\n    }\n\n    // breakdown_limit=3 means at most 4 series (top 3 + optional \"Other\")\n    expect(body.series.length).toBeLessThanOrEqual(4);\n\n    // Series must be sorted by total value descending (\"Other\" last if present)\n    const nonOther = body.series.filter((s: { label: string }) => s.label !== \"Other\");\n    const totals = nonOther.map((s: { data: { value: number }[] }) =>\n      s.data.reduce((sum: number, p: { value: number }) => sum + p.value, 0)\n    );\n    for (let i = 0; i + 1 < totals.length; i++) {\n      expect(totals[i]).toBeGreaterThanOrEqual(totals[i + 1]);\n    }\n  });\n});\n","numLines":233,"startLine":1,"totalLines":233}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K96cz57DJMPMQ6uDDTSAQA","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\t\n3\t// ─── Types ────────────────────────────────────────────────────────────────────\n4\t\n5\texport interface TrendsParams {\n6\t  event_name: string;\n7\t  /** \"count\" | \"unique_users\" | \"sum:<prop>\" | \"avg:<prop>\" | \"min:<prop>\" | \"max:<prop>\" */\n8\t  measure: string;\n9\t  granularity: \"day\" | \"week\";\n10\t  /** ISO date string (YYYY-MM-DD) — inclusive lower bound */\n11\t  start: string;\n12\t  /** ISO date string (YYYY-MM-DD) — inclusive upper bound */\n13\t  end: string;\n14\t  breakdown?: string;\n15\t  breakdown_limit?: number;\n16\t}\n17\t\n18\texport interface SeriesPoint {\n19\t  date: string;\n20\t  value: number;\n21\t}\n22\t\n23\texport interface Series {\n24\t  label: string;\n25\t  data: SeriesPoint[];\n26\t}\n27\t\n28\texport interface TrendsResponse {\n29\t  series: Series[];\n30\t}\n31\t\n32\texport interface TrendsQuerySpec {\n33\t  query: string;\n34\t  query_params: Record<string, string>;\n35\t}\n36\t\n37\t// ─── Type alias for the ClickHouse client ────────────────────────────────────\n38\t\n39\ttype ClickHouseClientLike = typeof clickhouse;\n40\t\n41\t// ─── Internal helpers ─────────────────────────────────────────────────────────\n42\t\n43\t/** Returns the exclusive upper bound timestamp for the given ISO date. */\n44\tfunction computeEndExclusive(end: string): string {\n45\t  const [y, m, d] = end.split(\"-\").map(Number);\n46\t  return new Date(Date.UTC(y, m - 1, d + 1)).toISOString();\n47\t}\n48\t\n49\t/** Builds the SQL aggregate expression for the given measure. */\n50\tfunction buildAggregateExpr(measure: string): string {\n51\t  if (measure === \"count\") return \"count()\";\n52\t  if (measure === \"unique_users\") {\n53\t    return \"uniqExact(coalesce(e.user_id, m.user_id, e.device_id))\";\n54\t  }\n55\t  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n56\t  if (match) {\n57\t    const fn = match[1];\n58\t    const prop = match[2];\n59\t    return `${fn}(JSONExtractFloat(e.properties, '${prop}'))`;\n60\t  }\n61\t  // Fallback — should be unreachable after route-level validation\n62\t  return \"count()\";\n63\t}\n64\t\n65\t/** Builds the SQL date-bucket expression for the given granularity. */\n66\tfunction buildBucketExpr(granularity: \"day\" | \"week\"): string {\n67\t  return granularity === \"week\"\n68\t    ? \"toMonday(e.timestamp)\"\n69\t    : \"toDate(e.timestamp)\";\n70\t}\n71\t\n72\t// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n73\t\n74\t/**\n75\t * Constructs the ClickHouse SQL query and bound parameters for a trends\n76\t * request. Exported for unit testing of SQL correctness.\n77\t */\n78\texport function buildTrendsQuery(params: TrendsParams): TrendsQuerySpec {\n79\t  const { event_name, measure, granularity, start, end, breakdown } = params;\n80\t\n81\t  const aggregateExpr = buildAggregateExpr(measure);\n82\t  const bucketExpr = buildBucketExpr(granularity);\n83\t  const needsJoin = measure === \"unique_users\";\n84\t\n85\t  const joinClause = needsJoin\n86\t    ? \"LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\\n      ON e.device_id = m.device_id\"\n87\t    : \"\";\n88\t\n89\t  const query_params: Record<string, string> = {\n90\t    event_name,\n91\t    start: `${start}T00:00:00.000Z`,\n92\t    end_exclusive: computeEndExclusive(end),\n93\t  };\n94\t\n95\t  if (breakdown) {\n96\t    const query = `\n97\t      SELECT\n98\t        ${bucketExpr} AS bucket,\n99\t        JSONExtractString(e.properties, '${breakdown}') AS breakdown_val,\n100\t        ${aggregateExpr} AS value\n101\t      FROM events e\n102\t      ${joinClause}\n103\t      WHERE e.event_name = {event_name:String}\n104\t        AND e.timestamp >= {start:String}\n105\t        AND e.timestamp < {end_exclusive:String}\n106\t      GROUP BY bucket, breakdown_val\n107\t      ORDER BY bucket ASC\n108\t    `.trim();\n109\t    return { query, query_params };\n110\t  }\n111\t\n112\t  const query = `\n113\t    SELECT\n114\t      ${bucketExpr} AS bucket,\n115\t      ${aggregateExpr} AS value\n116\t    FROM events e\n117\t    ${joinClause}\n118\t    WHERE e.event_name = {event_name:String}\n119\t      AND e.timestamp >= {start:String}\n120\t      AND e.timestamp < {end_exclusive:String}\n121\t    GROUP BY bucket\n122\t    ORDER BY bucket ASC\n123\t  `.trim();\n124\t\n125\t  return { query, query_params };\n126\t}\n127\t\n128\t// ─── queryTrends ──────────────────────────────────────────────────────────────\n129\t\n130\tinterface TrendsRow {\n131\t  bucket: string;\n132\t  value: number | string;\n133\t  breakdown_val?: string;\n134\t}\n135\t\n136\t/**\n137\t * Executes the trends query and transforms the raw ClickHouse rows into the\n138\t * series response shape.\n139\t *\n140\t * Without breakdown: returns a single series labelled with event_name.\n141\t * With breakdown:    returns one series per top-N breakdown value, with the\n142\t *                    remainder merged into an \"Other\" series.\n143\t */\n144\texport async function queryTrends(\n145\t  params: TrendsParams,\n146\t  client: ClickHouseClientLike = clickhouse,\n147\t): Promise<TrendsResponse> {\n148\t  const { event_name, breakdown, breakdown_limit = 10 } = params;\n149\t  const { query, query_params } = buildTrendsQuery(params);\n150\t\n151\t  const result = await client.query({\n152\t    query,\n153\t    query_params,\n154\t    format: \"JSONEachRow\",\n155\t  });\n156\t\n157\t  const rows = await result.json<TrendsRow>();\n158\t\n159\t  if (rows.length === 0) {\n160\t    return { series: [] };\n161\t  }\n162\t\n163\t  // ── No breakdown: single series ─────────────────────────────────────────────\n164\t\n165\t  if (!breakdown) {\n166\t    const data: SeriesPoint[] = rows.map((r) => ({\n167\t      date: r.bucket,\n168\t      value: Number(r.value),\n169\t    }));\n170\t    return { series: [{ label: event_name, data }] };\n171\t  }\n172\t\n173\t  // ── With breakdown: group rows by breakdown_val ───────────────────────────\n174\t\n175\t  const seriesMap = new Map<string, SeriesPoint[]>();\n176\t  const totalsByLabel = new Map<string, number>();\n177\t\n178\t  for (const row of rows) {\n179\t    const label = row.breakdown_val ?? \"\";\n180\t    const value = Number(row.value);\n181\t\n182\t    let points = seriesMap.get(label);\n183\t    if (points === undefined) {\n184\t      points = [];\n185\t      seriesMap.set(label, points);\n186\t      totalsByLabel.set(label, 0);\n187\t    }\n188\t    points.push({ date: row.bucket, value });\n189\t    totalsByLabel.set(label, (totalsByLabel.get(label) ?? 0) + value);\n190\t  }\n191\t\n192\t  // Sort by total descending to determine top-N\n193\t  const sorted = Array.from(totalsByLabel.entries()).sort(\n194\t    ([, a], [, b]) => b - a,\n195\t  );\n196\t\n197\t  const series: Series[] = [];\n198\t\n199\t  // Add top-N individual series\n200\t  for (const [label] of sorted.slice(0, breakdown_limit)) {\n201\t    series.push({ label, data: seriesMap.get(label) ?? [] });\n202\t  }\n203\t\n204\t  // Merge remaining values into \"Other\"\n205\t  const restEntries = sorted.slice(breakdown_limit);\n206\t  if (restEntries.length > 0) {\n207\t    const otherMap = new Map<string, number>();\n208\t    for (const [otherLabel] of restEntries) {\n209\t      for (const point of seriesMap.get(otherLabel) ?? []) {\n210\t        otherMap.set(point.date, (otherMap.get(point.date) ?? 0) + point.value);\n211\t      }\n212\t    }\n213\t    const otherData = Array.from(otherMap.entries())\n214\t      .sort(([a], [b]) => a.localeCompare(b))\n215\t      .map(([date, value]) => ({ date, value }));\n216\t    series.push({ label: \"Other\", data: otherData });\n217\t  }\n218\t\n219\t  return { series };\n220\t}\n221\t"}]},"parent_tool_use_id":null,"session_id":"7487c004-0d87-49f1-84d9-27e324e21aa2","uuid":"f5b9f5d2-77a1-400a-83aa-822817e18730","timestamp":"2026-04-15T13:22:37.209Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/trends.ts","content":"import { clickhouse } from \"@/lib/clickhouse\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface TrendsParams {\n  event_name: string;\n  /** \"count\" | \"unique_users\" | \"sum:<prop>\" | \"avg:<prop>\" | \"min:<prop>\" | \"max:<prop>\" */\n  measure: string;\n  granularity: \"day\" | \"week\";\n  /** ISO date string (YYYY-MM-DD) — inclusive lower bound */\n  start: string;\n  /** ISO date string (YYYY-MM-DD) — inclusive upper bound */\n  end: string;\n  breakdown?: string;\n  breakdown_limit?: number;\n}\n\nexport interface SeriesPoint {\n  date: string;\n  value: number;\n}\n\nexport interface Series {\n  label: string;\n  data: SeriesPoint[];\n}\n\nexport interface TrendsResponse {\n  series: Series[];\n}\n\nexport interface TrendsQuerySpec {\n  query: string;\n  query_params: Record<string, string>;\n}\n\n// ─── Type alias for the ClickHouse client ────────────────────────────────────\n\ntype ClickHouseClientLike = typeof clickhouse;\n\n// ─── Internal helpers ─────────────────────────────────────────────────────────\n\n/** Returns the exclusive upper bound timestamp for the given ISO date. */\nfunction computeEndExclusive(end: string): string {\n  const [y, m, d] = end.split(\"-\").map(Number);\n  return new Date(Date.UTC(y, m - 1, d + 1)).toISOString();\n}\n\n/** Builds the SQL aggregate expression for the given measure. */\nfunction buildAggregateExpr(measure: string): string {\n  if (measure === \"count\") return \"count()\";\n  if (measure === \"unique_users\") {\n    return \"uniqExact(coalesce(e.user_id, m.user_id, e.device_id))\";\n  }\n  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n  if (match) {\n    const fn = match[1];\n    const prop = match[2];\n    return `${fn}(JSONExtractFloat(e.properties, '${prop}'))`;\n  }\n  // Fallback — should be unreachable after route-level validation\n  return \"count()\";\n}\n\n/** Builds the SQL date-bucket expression for the given granularity. */\nfunction buildBucketExpr(granularity: \"day\" | \"week\"): string {\n  return granularity === \"week\"\n    ? \"toMonday(e.timestamp)\"\n    : \"toDate(e.timestamp)\";\n}\n\n// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n\n/**\n * Constructs the ClickHouse SQL query and bound parameters for a trends\n * request. Exported for unit testing of SQL correctness.\n */\nexport function buildTrendsQuery(params: TrendsParams): TrendsQuerySpec {\n  const { event_name, measure, granularity, start, end, breakdown } = params;\n\n  const aggregateExpr = buildAggregateExpr(measure);\n  const bucketExpr = buildBucketExpr(granularity);\n  const needsJoin = measure === \"unique_users\";\n\n  const joinClause = needsJoin\n    ? \"LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\\n      ON e.device_id = m.device_id\"\n    : \"\";\n\n  const query_params: Record<string, string> = {\n    event_name,\n    start: `${start}T00:00:00.000Z`,\n    end_exclusive: computeEndExclusive(end),\n  };\n\n  if (breakdown) {\n    const query = `\n      SELECT\n        ${bucketExpr} AS bucket,\n        JSONExtractString(e.properties, '${breakdown}') AS breakdown_val,\n        ${aggregateExpr} AS value\n      FROM events e\n      ${joinClause}\n      WHERE e.event_name = {event_name:String}\n        AND e.timestamp >= {start:String}\n        AND e.timestamp < {end_exclusive:String}\n      GROUP BY bucket, breakdown_val\n      ORDER BY bucket ASC\n    `.trim();\n    return { query, query_params };\n  }\n\n  const query = `\n    SELECT\n      ${bucketExpr} AS bucket,\n      ${aggregateExpr} AS value\n    FROM events e\n    ${joinClause}\n    WHERE e.event_name = {event_name:String}\n      AND e.timestamp >= {start:String}\n      AND e.timestamp < {end_exclusive:String}\n    GROUP BY bucket\n    ORDER BY bucket ASC\n  `.trim();\n\n  return { query, query_params };\n}\n\n// ─── queryTrends ──────────────────────────────────────────────────────────────\n\ninterface TrendsRow {\n  bucket: string;\n  value: number | string;\n  breakdown_val?: string;\n}\n\n/**\n * Executes the trends query and transforms the raw ClickHouse rows into the\n * series response shape.\n *\n * Without breakdown: returns a single series labelled with event_name.\n * With breakdown:    returns one series per top-N breakdown value, with the\n *                    remainder merged into an \"Other\" series.\n */\nexport async function queryTrends(\n  params: TrendsParams,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<TrendsResponse> {\n  const { event_name, breakdown, breakdown_limit = 10 } = params;\n  const { query, query_params } = buildTrendsQuery(params);\n\n  const result = await client.query({\n    query,\n    query_params,\n    format: \"JSONEachRow\",\n  });\n\n  const rows = await result.json<TrendsRow>();\n\n  if (rows.length === 0) {\n    return { series: [] };\n  }\n\n  // ── No breakdown: single series ─────────────────────────────────────────────\n\n  if (!breakdown) {\n    const data: SeriesPoint[] = rows.map((r) => ({\n      date: r.bucket,\n      value: Number(r.value),\n    }));\n    return { series: [{ label: event_name, data }] };\n  }\n\n  // ── With breakdown: group rows by breakdown_val ───────────────────────────\n\n  const seriesMap = new Map<string, SeriesPoint[]>();\n  const totalsByLabel = new Map<string, number>();\n\n  for (const row of rows) {\n    const label = row.breakdown_val ?? \"\";\n    const value = Number(row.value);\n\n    let points = seriesMap.get(label);\n    if (points === undefined) {\n      points = [];\n      seriesMap.set(label, points);\n      totalsByLabel.set(label, 0);\n    }\n    points.push({ date: row.bucket, value });\n    totalsByLabel.set(label, (totalsByLabel.get(label) ?? 0) + value);\n  }\n\n  // Sort by total descending to determine top-N\n  const sorted = Array.from(totalsByLabel.entries()).sort(\n    ([, a], [, b]) => b - a,\n  );\n\n  const series: Series[] = [];\n\n  // Add top-N individual series\n  for (const [label] of sorted.slice(0, breakdown_limit)) {\n    series.push({ label, data: seriesMap.get(label) ?? [] });\n  }\n\n  // Merge remaining values into \"Other\"\n  const restEntries = sorted.slice(breakdown_limit);\n  if (restEntries.length > 0) {\n    const otherMap = new Map<string, number>();\n    for (const [otherLabel] of restEntries) {\n      for (const point of seriesMap.get(otherLabel) ?? []) {\n        otherMap.set(point.date, (otherMap.get(point.date) ?? 0) + point.value);\n      }\n    }\n    const otherData = Array.from(otherMap.entries())\n      .sort(([a], [b]) => a.localeCompare(b))\n      .map(([date, value]) => ({ date, value }));\n    series.push({ label: \"Other\", data: otherData });\n  }\n\n  return { series };\n}\n","numLines":221,"startLine":1,"totalLines":221}}}
