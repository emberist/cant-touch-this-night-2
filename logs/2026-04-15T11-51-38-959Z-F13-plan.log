esolvedId(\n  resolved_id: string,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<EventRow[]> {\n  return queryEventsWithResolvedId({ resolved_id, limit: 200 }, client);\n}\n","numLines":249,"startLine":1,"totalLines":249}}}
