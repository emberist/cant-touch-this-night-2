{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SVYorHVLxw2hZQZQANvVNw","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { cleanup, fireEvent, render, screen } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport type { EventRow } from \"@/lib/identity\";\n5\t\n6\t// ─── Module mocks (hoisted by vitest) ────────────────────────────────────────\n7\t\n8\t// Mock Next.js Link to avoid router context requirement in jsdom\n9\tvi.mock(\"next/link\", () => ({\n10\t  default: ({\n11\t    href,\n12\t    children,\n13\t    style,\n14\t  }: {\n15\t    href: string;\n16\t    children: React.ReactNode;\n17\t    style?: React.CSSProperties;\n18\t  }) => (\n19\t    <a href={href} style={style}>\n20\t      {children}\n21\t    </a>\n22\t  ),\n23\t}));\n24\t\n25\t// Mock useLiveFeed so the component tests don't need EventSource\n26\tvi.mock(\"@/components/test/useLiveFeed\", () => ({\n27\t  useLiveFeed: vi.fn(),\n28\t}));\n29\t\n30\timport { LiveFeed } from \"@/components/test/LiveFeed\";\n31\timport { useLiveFeed } from \"@/components/test/useLiveFeed\";\n32\t\n33\tconst mockUseLiveFeed = vi.mocked(useLiveFeed);\n34\t\n35\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n36\t\n37\tfunction makeEventRow(id: string, overrides: Partial<EventRow> = {}): EventRow {\n38\t  return {\n39\t    event_id: id,\n40\t    event_name: \"Page Viewed\",\n41\t    timestamp: \"2026-04-15T12:00:00.000Z\",\n42\t    device_id: \"device-abc\",\n43\t    user_id: null,\n44\t    properties: '{\"page\":\"/home\"}',\n45\t    ingested_at: \"2026-04-15T12:00:00.000Z\",\n46\t    resolved_id: \"device-abc\",\n47\t    ...overrides,\n48\t  };\n49\t}\n50\t\n51\tfunction defaultHookState(\n52\t  overrides: Partial<ReturnType<typeof useLiveFeed>> = {},\n53\t): ReturnType<typeof useLiveFeed> {\n54\t  return {\n55\t    events: [],\n56\t    paused: false,\n57\t    connectionStatus: \"disconnected\",\n58\t    togglePause: vi.fn(),\n59\t    clearEvents: vi.fn(),\n60\t    ...overrides,\n61\t  };\n62\t}\n63\t\n64\t// ─── Setup / Teardown ─────────────────────────────────────────────────────────\n65\t\n66\tbeforeEach(() => {\n67\t  mockUseLiveFeed.mockReturnValue(defaultHookState());\n68\t});\n69\t\n70\tafterEach(() => {\n71\t  cleanup();\n72\t  vi.clearAllMocks();\n73\t});\n74\t\n75\t// ─── Tests ────────────────────────────────────────────────────────────────────\n76\t\n77\tdescribe(\"LiveFeed\", () => {\n78\t  describe(\"connection status indicator\", () => {\n79\t    it(\"renders 'Disconnected' text when connectionStatus is 'disconnected'\", () => {\n80\t      mockUseLiveFeed.mockReturnValue(\n81\t        defaultHookState({ connectionStatus: \"disconnected\" }),\n82\t      );\n83\t      render(<LiveFeed />);\n84\t      expect(screen.getByText(/disconnected/i)).toBeTruthy();\n85\t    });\n86\t\n87\t    it(\"renders 'Live' text when connectionStatus is 'live'\", () => {\n88\t      mockUseLiveFeed.mockReturnValue(\n89\t        defaultHookState({ connectionStatus: \"live\" }),\n90\t      );\n91\t      render(<LiveFeed />);\n92\t      expect(screen.getByText(/^live$/i)).toBeTruthy();\n93\t    });\n94\t  });\n95\t\n96\t  describe(\"toolbar buttons\", () => {\n97\t    it(\"renders a Pause button when not paused\", () => {\n98\t      mockUseLiveFeed.mockReturnValue(defaultHookState({ paused: false }));\n99\t      render(<LiveFeed />);\n100\t      expect(screen.getByRole(\"button\", { name: /pause/i })).toBeTruthy();\n101\t    });\n102\t\n103\t    it(\"renders a Resume button when paused\", () => {\n104\t      mockUseLiveFeed.mockReturnValue(defaultHookState({ paused: true }));\n105\t      render(<LiveFeed />);\n106\t      expect(screen.getByRole(\"button\", { name: /resume/i })).toBeTruthy();\n107\t    });\n108\t\n109\t    it(\"renders a Clear button\", () => {\n110\t      render(<LiveFeed />);\n111\t      expect(screen.getByRole(\"button\", { name: /clear/i })).toBeTruthy();\n112\t    });\n113\t  });\n114\t\n115\t  describe(\"empty state\", () => {\n116\t    it(\"shows 'No events yet' when events array is empty\", () => {\n117\t      mockUseLiveFeed.mockReturnValue(defaultHookState({ events: [] }));\n118\t      render(<LiveFeed />);\n119\t      expect(screen.getByText(/no events yet/i)).toBeTruthy();\n120\t    });\n121\t  });\n122\t\n123\t  describe(\"event cards\", () => {\n124\t    it(\"renders an event card with event name when events exist\", () => {\n125\t      const event = makeEventRow(\"ev-1\", { event_name: \"Purchase Completed\" });\n126\t      mockUseLiveFeed.mockReturnValue(defaultHookState({ events: [event] }));\n127\t      render(<LiveFeed />);\n128\t      expect(screen.getByText(\"Purchase Completed\")).toBeTruthy();\n129\t    });\n130\t\n131\t    it(\"renders an event card with resolved identity\", () => {\n132\t      const event = makeEventRow(\"ev-1\", { resolved_id: \"user@example.com\" });\n133\t      mockUseLiveFeed.mockReturnValue(defaultHookState({ events: [event] }));\n134\t      render(<LiveFeed />);\n135\t      expect(screen.getByText(\"user@example.com\")).toBeTruthy();\n136\t    });\n137\t\n138\t    it(\"does not show 'No events yet' when events exist\", () => {\n139\t      const event = makeEventRow(\"ev-1\");\n140\t      mockUseLiveFeed.mockReturnValue(defaultHookState({ events: [event] }));\n141\t      render(<LiveFeed />);\n142\t      expect(screen.queryByText(/no events yet/i)).toBeNull();\n143\t    });\n144\t\n145\t    it(\"renders multiple event cards\", () => {\n146\t      const events = [\n147\t        makeEventRow(\"ev-1\", { event_name: \"Page Viewed\" }),\n148\t        makeEventRow(\"ev-2\", { event_name: \"Button Clicked\" }),\n149\t      ];\n150\t      mockUseLiveFeed.mockReturnValue(defaultHookState({ events }));\n151\t      render(<LiveFeed />);\n152\t      expect(screen.getByText(\"Page Viewed\")).toBeTruthy();\n153\t      expect(screen.getByText(\"Butt