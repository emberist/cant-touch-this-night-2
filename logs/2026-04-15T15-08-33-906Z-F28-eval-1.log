{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QkCd1cHDX2J6fbubamKpG4","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport { useCallback, useEffect, useRef, useState } from \"react\";\n4\timport type { EventRow } from \"@/lib/identity\";\n5\t\n6\t// ─── Types ────────────────────────────────────────────────────────────────────\n7\t\n8\texport type ConnectionStatus = \"live\" | \"disconnected\";\n9\t\n10\texport interface UseLiveFeedResult {\n11\t  events: EventRow[];\n12\t  paused: boolean;\n13\t  connectionStatus: ConnectionStatus;\n14\t  togglePause: () => void;\n15\t  clearEvents: () => void;\n16\t}\n17\t\n18\t// ─── Constants ────────────────────────────────────────────────────────────────\n19\t\n20\tconst MAX_EVENTS = 200;\n21\t\n22\t// ─── Hook ─────────────────────────────────────────────────────────────────────\n23\t\n24\texport function useLiveFeed(): UseLiveFeedResult {\n25\t  const [events, setEvents] = useState<EventRow[]>([]);\n26\t  const [paused, setPaused] = useState(false);\n27\t  const [connectionStatus, setConnectionStatus] =\n28\t    useState<ConnectionStatus>(\"disconnected\");\n29\t\n30\t  // Refs to avoid stale closures inside the EventSource handlers\n31\t  const pausedRef = useRef(false);\n32\t  const bufferRef = useRef<EventRow[]>([]);\n33\t\n34\t  useEffect(() => {\n35\t    const es = new EventSource(\"/api/live\");\n36\t\n37\t    es.onopen = () => {\n38\t      setConnectionStatus(\"live\");\n39\t    };\n40\t\n41\t    es.onmessage = (e: MessageEvent) => {\n42\t      try {\n43\t        const row = JSON.parse(e.data as string) as EventRow;\n44\t        if (pausedRef.current) {\n45\t          // Buffer newest-first: prepend\n46\t          bufferRef.current = [row, ...bufferRef.current];\n47\t        } else {\n48\t          setEvents((prev) => {\n49\t            const next = [row, ...prev];\n50\t            return next.length > MAX_EVENTS ? next.slice(0, MAX_EVENTS) : next;\n51\t          });\n52\t        }\n53\t      } catch {\n54\t        // ignore malformed SSE payloads\n55\t      }\n56\t    };\n57\t\n58\t    es.onerror = () => {\n59\t      setConnectionStatus(\"disconnected\");\n60\t    };\n61\t\n62\t    return () => {\n63\t      es.close();\n64\t    };\n65\t  }, []);\n66\t\n67\t  const togglePause = useCallback(() => {\n68\t    setPaused((prevPaused) => {\n69\t      const nextPaused = !prevPaused;\n70\t      pausedRef.current = nextPaused;\n71\t\n72\t      if (!nextPaused) {\n73\t        // Resuming — flush buffered events (newest first) into state\n74\t        const buffered = bufferRef.current;\n75\t        bufferRef.current = [];\n76\t        if (buffered.length > 0) {\n77\t          setEvents((prevEvents) => {\n78\t            const merged = [...buffered, ...prevEvents];\n79\t            return merged.length > MAX_EVENTS\n80\t              ? merged.slice(0, MAX_EVENTS)\n81\t              : merged;\n82\t          });\n83\t        }\n84\t      }\n85\t\n86\t      return nextPaused;\n87\t    });\n88\t  }, []);\n89\t\n90\t  const clearEvents = useCallback(() => {\n91\t    setEvents([]);\n92\t    bufferRef.current = [];\n93\t  }, []);\n94\t\n95\t  return { events, paused, connectionStatus, togglePause, clearEvents };\n96\t}\n97\t"}]},"parent_tool_use_id":null,"session_id":"c812aeed-5155-4f1f-9439-97c2d6d6a53c","uuid":"a4d05332-f300-4791-82b4-cc5d15ff1c27","timestamp":"2026-04-15T18:11:22.314Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/test/useLiveFeed.ts","content":"\"use client\";\n\nimport { useCallback, useEffect, useRef, useState } from \"react\";\nimport type { EventRow } from \"@/lib/identity\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport type ConnectionStatus = \"live\" | \"disconnected\";\n\nexport interface UseLiveFeedResult {\n  events: EventRow[];\n  paused: boolean;\n  connectionStatus: ConnectionStatus;\n  togglePause: () => void;\n  clearEvents: () => void;\n}\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst MAX_EVENTS = 200;\n\n// ─── Hook ─────────────────────────────────────────────────────────────────────\n\nexport function useLiveFeed(): UseLiveFeedResult {\n  const [events, setEvents] = useState<EventRow[]>([]);\n  const [paused, setPaused] = useState(false);\n  const [connectionStatus, setConnectionStatus] =\n    useState<ConnectionStatus>(\"disconnected\");\n\n  // Refs to avoid stale closures inside the EventSource handlers\n  const pausedRef = useRef(false);\n  const bufferRef = useRef<EventRow[]>([]);\n\n  useEffect(() => {\n    const es = new EventSource(\"/api/live\");\n\n    es.onopen = () => {\n      setConnectionStatus(\"live\");\n    };\n\n    es.onmessage = (e: MessageEvent) => {\n      try {\n        const row = JSON.parse(e.data as string) as EventRow;\n        if (pausedRef.current) {\n          // Buffer newest-first: prepend\n          bufferRef.current = [row, ...bufferRef.current];\n        } else {\n          setEvents((prev) => {\n            const next = [row, ...prev];\n            return next.length > MAX_EVENTS ? next.slice(0, MAX_EVENTS) : next;\n          });\n        }\n      } catch {\n        // ignore malformed SSE payloads\n      }\n    };\n\n    es.onerror = () => {\n      setConnectionStatus(\"disconnected\");\n    };\n\n    return () => {\n      es.close();\n    };\n  }, []);\n\n  const togglePause = useCallback(() => {\n    setPaused((prevPaused) => {\n      const nextPaused = !prevPaused;\n      pausedRef.current = nextPaused;\n\n      if (!nextPaused) {\n        // Resuming — flush buffered events (newest first) into state\n        const buffered = bufferRef.current;\n        bufferRef.current = [];\n        if (buffered.length > 0) {\n          setEvents((prevEvents) => {\n            const merged = [...buffered, ...prevEvents];\n            return merged.length > MAX_EVENTS\n              ? merged.slice(0, MAX_EVENTS)\n              : merged;\n          });\n        }\n      }\n\n      return nextPaused;\n    });\n  }, []);\n\n  const clearEvents = useCallback(() => {\n    setEvents([]);\n    bufferRef.current = [];\n  }, []);\n\n  return { events, paused, connectionStatus, togglePause, clearEvents };\n}\n","numLines":97,"startLine":1,"totalLines":97}}}
