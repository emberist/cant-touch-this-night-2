{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B7vZmsvSbK3nCx1m9fN9Zt","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { act, renderHook } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport { useLiveFeed } from \"@/components/test/useLiveFeed\";\n5\timport type { EventRow } from \"@/lib/identity\";\n6\t\n7\t// ─── Mock EventSource ─────────────────────────────────────────────────────────\n8\t\n9\tclass MockEventSource {\n10\t  static lastInstance: MockEventSource | null = null;\n11\t\n12\t  url: string;\n13\t  onopen: ((e: Event) => void) | null = null;\n14\t  onmessage: ((e: MessageEvent) => void) | null = null;\n15\t  onerror: ((e: Event) => void) | null = null;\n16\t  readyState = 0;\n17\t  close = vi.fn();\n18\t\n19\t  constructor(url: string) {\n20\t    this.url = url;\n21\t    MockEventSource.lastInstance = this;\n22\t  }\n23\t\n24\t  simulateOpen(): void {\n25\t    this.readyState = 1;\n26\t    this.onopen?.(new Event(\"open\"));\n27\t  }\n28\t\n29\t  simulateMessage(data: string): void {\n30\t    this.onmessage?.(new MessageEvent(\"message\", { data }));\n31\t  }\n32\t\n33\t  simulateError(): void {\n34\t    this.readyState = 2;\n35\t    this.onerror?.(new Event(\"error\"));\n36\t  }\n37\t}\n38\t\n39\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n40\t\n41\tfunction makeEventRow(id: string, overrides: Partial<EventRow> = {}): EventRow {\n42\t  return {\n43\t    event_id: id,\n44\t    event_name: \"Page Viewed\",\n45\t    timestamp: \"2026-04-15T12:00:00.000Z\",\n46\t    device_id: \"device-abc\",\n47\t    user_id: null,\n48\t    properties: '{\"page\":\"/home\"}',\n49\t    ingested_at: \"2026-04-15T12:00:00.000Z\",\n50\t    resolved_id: \"device-abc\",\n51\t    ...overrides,\n52\t  };\n53\t}\n54\t\n55\t// ─── Setup / Teardown ─────────────────────────────────────────────────────────\n56\t\n57\tbeforeEach(() => {\n58\t  vi.stubGlobal(\"EventSource\", MockEventSource);\n59\t  MockEventSource.lastInstance = null;\n60\t});\n61\t\n62\tafterEach(() => {\n63\t  vi.unstubAllGlobals();\n64\t  vi.clearAllMocks();\n65\t});\n66\t\n67\t// ─── Tests ────────────────────────────────────────────────────────────────────\n68\t\n69\tdescribe(\"useLiveFeed\", () => {\n70\t  describe(\"initial state\", () => {\n71\t    it(\"starts with empty events array, disconnected status, and paused false\", () => {\n72\t      const { result } = renderHook(() => useLiveFeed());\n73\t      expect(result.current.events).toEqual([]);\n74\t      expect(result.current.connectionStatus).toBe(\"disconnected\");\n75\t      expect(result.current.paused).toBe(false);\n76\t    });\n77\t  });\n78\t\n79\t  describe(\"EventSource lifecycle\", () => {\n80\t    it(\"opens an EventSource to /api/live on mount\", () => {\n81\t      renderHook(() => useLiveFeed());\n82\t      expect(MockEventSource.lastInstance).not.toBeNull();\n83\t      expect(MockEventSource.lastInstance!.url).toBe(\"/api/live\");\n84\t    });\n85\t\n86\t    it(\"closes the EventSource when the hook unmounts\", () => {\n87\t      const { unmount } = renderHook(() => useLiveFeed());\n88\t      const es = MockEventSource.lastInstance!;\n89\t      unmount();\n90\t      expect(es.close).toHaveBeenCalledOnce();\n91\t    });\n92\t  });\n93\t\n94\t  describe(\"connection status\", () => {\n95\t    it(\"transitions to 'live' when EventSource opens\", () => {\n96\t      const { result } = renderHook(() => useLiveFeed());\n97\t      const es = MockEventSource.lastInstance!;\n98\t\n99\t      act(() => {\n100\t        es.simulateOpen();\n101\t      });\n102\t\n103\t      expect(result.current.connectionStatus).toBe(\"live\");\n104\t    });\n105\t\n106\t    it(\"transitions to 'disconnected' when EventSource fires error\", () => {\n107\t      const { result } = renderHook(() => useLiveFeed());\n108\t      const es = MockEventSource.lastInstance!;\n109\t\n110\t      act(() => {\n111\t        es.simulateOpen();\n112\t      });\n113\t      expect(result.current.connectionStatus).toBe(\"live\");\n114\t\n115\t      act(() => {\n116\t        es.simulateError();\n117\t      });\n118\t      expect(result.current.connectionStatus).toBe(\"disconnected\");\n119\t    });\n120\t  });\n121\t\n122\t  describe(\"receiving messages\", () => {\n123\t    it(\"prepends incoming SSE messages to the list (newest first)\", () => {\n124\t      const { result } = renderHook(() => useLiveFeed());\n125\t      const es = MockEventSource.lastInstance!;\n126\t\n127\t      act(() => {\n128\t        es.simulateMessage(JSON.stringify(makeEventRow(\"ev-1\")));\n129\t      });\n130\t      act(() => {\n131\t        es.simulateMessage(JSON.stringify(makeEventRow(\"ev-2\")));\n132\t      });\n133\t\n134\t      expect(result.current.events).toHaveLength(2);\n135\t      // ev-2 arrived last → newest → index 0\n136\t      expect(result.current.events[0].event_id).toBe(\"ev-2\");\n137\t      expect(result.current.events[1].event_id).toBe(\"ev-1\");\n138\t    });\n139\t\n140\t    it(\"caps the list at 200 events; when a 201st arrives the oldest is dropped\", () => {\n141\t      const { result } = renderHook(() => useLiveFeed());\n142\t      const es = MockEventSource.lastInstance!;\n143\t\n144\t      // Fill with 200 events\n145\t      act(() => {\n146\t        for (let i = 0; i < 200; i++) {\n147\t          es.simulateMessage(JSON.stringify(makeEventRow(`ev-${i}`)));\n148\t        }\n149\t      });\n150\t      expect(result.current.events).toHaveLength(200);\n151\t      // Newest is ev-199 at index 0, oldest is ev-0 at index 199\n152\t      expect(result.current.events[0].event_id).toBe(\"ev-199\");\n153\t      expect(result.current.events[199].event_id).toBe(\"ev-0\");\n154\t\n155\t      // Add 201st event\n156\t      act(() => {\n157\t        es.simulateMessage(JSON.stringify(makeEventRow(\"ev-200\")));\n158\t      });\n159\t\n160\t      expect(result.current.events).toHaveLength(200);\n161\t      // Newest is still at index 0\n162\t      expect(result.current.events[0].event_id).toBe(\"ev-200\");\n163\t      // Oldest (ev-0) was dropped\n164\t      expect(\n165\t        result.current.events.find((e) => e.event_id === \"ev-0\"),\n166\t      ).toBeUndefined();\n167\t    });\n168\t  });\n169\t\n170\t  describe(\"pause / resume\", () => {\n171\t    it(\"togglePause sets paused to true; incoming events during pause go to buffer, not state\", () => {\n172\t      const { result } = renderHook(() => useLiveFeed());\n173\t      const es = MockEventSource.lastInstance!;\n174\t\n175\t      act(() => {\n176\t        result.current.togglePause();\n177\t      });\n178\t      expect(result.current.paused).toBe(true);\n179\t\n180\t      // Message arrives while paused — should NOT appear in events\n181\t      act(() => {\n182\t        es.simulateMessage(JSON.stringify(makeEventRow(\"buffered\")));\n183\t      });\n184\t      expect(result.current.events).toHaveLength(0);\n185\t    });\n186\t\n187\t    it(\"resuming flushes buffered events into state (newest first, prepended before existing)\", () => {\n188\t      const { result } = renderHook(() => useLiveFeed());\n189\t      const es = MockEventSource.lastInstance!;\n190\t\n191\t      // One event before pause\n192\t      act(() => {\n193\t        es.simulateMessage(JSON.stringify(makeEventRow(\"pre-pause\")));\n194\t      });\n195\t      expect(result.current.events).toHaveLength(1);\n196\t\n197\t      // Pause\n198\t      act(() => {\n199\t        result.current.togglePause();\n200\t      });\n201\t\n202\t      // Two events while paused\n203\t      act(() => {\n204\t        es.simulateMessage(JSON.stringify(makeEventRow(\"buf-1\")));\n205\t        es.simulateMessage(JSON.stringify(makeEventRow(\"buf-2\")));\n206\t      });\n207\t      // State should still hold only the 1 pre-pause event\n208\t      expect(result.current.events).toHaveLength(1);\n209\t\n210\t      // Resume — buffer should flush\n211\t      act(() => {\n212\t        result.current.togglePause();\n213\t      });\n214\t\n215\t      expect(result.current.paused).toBe(false);\n216\t      expect(result.current.events).toHaveLength(3);\n217\t      // Buffered events (buf-2 is newest) should be prepended\n218\t      expect(result.current.events[0].event_id).toBe(\"buf-2\");\n219\t      expect(result.current.events[1].event_id).toBe(\"buf-1\");\n220\t      expect(result.current.events[2].event_id).toBe(\"pre-pause\");\n221\t    });\n222\t  });\n223\t\n224\t  describe(\"clearEvents\", () => {\n225\t    it(\"resets the events array to empty\", () => {\n226\t      const { result } = renderHook(() => useLiveFeed());\n227\t      const es = MockEventSource.lastInstance!;\n228\t\n229\t      act(() => {\n230\t        es.simulateMessage(JSON.stringify(makeEventRow(\"ev-1\")));\n231\t        es.simulateMessage(JSON.stringify(makeEventRow(\"ev-2\")));\n232\t      });\n233\t      expect(result.current.events).toHaveLength(2);\n234\t\n235\t      act(() => {\n236\t        result.current.clearEvents();\n237\t      });\n238\t\n239\t      expect(result.current.events).toHaveLength(0);\n240\t    });\n241\t\n242\t    it(\"also clears events buffered during pause\", () => {\n243\t      const { result } = renderHook(() => useLiveFeed());\n244\t      const es = MockEventSource.lastInstance!;\n245\t\n246\t      act(() => {\n247\t        result.current.togglePause();\n248\t      });\n249\t      act(() => {\n250\t        es.simulateMessage(JSON.stringify(makeEventRow(\"buf-1\")));\n251\t      });\n252\t\n253\t      act(() => {\n254\t        result.current.clearEvents();\n255\t      });\n256\t\n257\t      // Resume — nothing should be flushed\n258\t      act(() => {\n259\t        result.current.togglePause();\n260\t      });\n261\t\n262\t      expect(result.current.events).toHaveLength(0);\n263\t    });\n264\t  });\n265\t});\n266\t"}]},"parent_tool_use_id":null,"session_id":"c812aeed-5155-4f1f-9439-97c2d6d6a53c","uuid":"64596376-cb6d-4140-a192-e91bf027e855","timestamp":"2026-04-15T18:11:23.230Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/test/__tests__/useLiveFeed.test.ts","content":"// @vitest-environment jsdom\nimport { act, renderHook } from \"@testing-library/react\";\nimport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\nimport { useLiveFeed } from \"@/components/test/useLiveFeed\";\nimport type { EventRow } from \"@/lib/identity\";\n\n// ─── Mock EventSource ─────────────────────────────────────────────────────────\n\nclass MockEventSource {\n  static lastInstance: MockEventSource | null = null;\n\n  url: string;\n  onopen: ((e: Event) => void) | null = null;\n  onmessage: ((e: MessageEvent) => void) | null = null;\n  onerror: ((e: Event) => void) | null = null;\n  readyState = 0;\n  close = vi.fn();\n\n  constructor(url: string) {\n    this.url = url;\n    MockEventSource.lastInstance = this;\n  }\n\n  simulateOpen(): void {\n    this.readyState = 1;\n    this.onopen?.(new Event(\"open\"));\n  }\n\n  simulateMessage(data: string): void {\n    this.onmessage?.(new MessageEvent(\"message\", { data }));\n  }\n\n  simulateError(): void {\n    this.readyState = 2;\n    this.onerror?.(new Event(\"error\"));\n  }\n}\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction makeEventRow(id: string, overrides: Partial<EventRow> = {}): EventRow {\n  return {\n    event_id: id,\n    event_name: \"Page Viewed\",\n    timestamp: \"2026-04-15T12:00:00.000Z\",\n    device_id: \"device-abc\",\n    user_id: null,\n    properties: '{\"page\":\"/home\"}',\n    ingested_at: \"2026-04-15T12:00:00.000Z\",\n    resolved_id: \"device-abc\",\n    ...overrides,\n  };\n}\n\n// ─── Setup / Teardown ─────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  vi.stubGlobal(\"EventSource\", MockEventSource);\n  MockEventSource.lastInstance = null;\n});\n\nafterEach(() => {\n  vi.unstubAllGlobals();\n  vi.clearAllMocks();\n});\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\ndescribe(\"useLiveFeed\", () => {\n  describe(\"initial state\", () => {\n    it(\"starts with empty events array, disconnected status, and paused false\", () => {\n      const { result } = renderHook(() => useLiveFeed());\n      expect(result.current.events).toEqual([]);\n      expect(result.current.connectionStatus).toBe(\"disconnected\");\n      expect(result.current.paused).toBe(false);\n    });\n  });\n\n  describe(\"EventSource lifecycle\", () => {\n    it(\"opens an EventSource to /api/live on mount\", () => {\n      renderHook(() => useLiveFeed());\n      expect(MockEventSource.lastInstance).not.toBeNull();\n      expect(MockEventSource.lastInstance!.url).toBe(\"/api/live\");\n    });\n\n    it(\"closes the EventSource when the hook unmounts\", () => {\n      const { unmount } = renderHook(() => useLiveFeed());\n      const es = MockEventSource.lastInstance!;\n      unmount();\n      expect(es.close).toHaveBeenCalledOnce();\n    });\n  });\n\n  describe(\"connection status\", () => {\n    it(\"transitions to 'live' when EventSource opens\", () => {\n      const { result } = renderHook(() => useLiveFeed());\n      const es = MockEventSource.lastInstance!;\n\n      act(() => {\n        es.simulateOpen();\n      });\n\n      expect(result.current.connectionStatus).toBe(\"live\");\n    });\n\n    it(\"transitions to 'disconnected' when EventSource fires error\", () => {\n      const { result } = renderHook(() => useLiveFeed());\n      const es = MockEventSource.lastInstance!;\n\n      act(() => {\n        es.simulateOpen();\n      });\n      expect(result.current.connectionStatus).toBe(\"live\");\n\n      act(() => {\n        es.simulateError();\n      });\n      expect(result.current.connectionStatus).toBe(\"disconnected\");\n    });\n  });\n\n  describe(\"receiving messages\", () => {\n    it(\"prepends incoming SSE messages to the list (newest first)\", () => {\n      const { result } = renderHook(() => useLiveFeed());\n      const es = MockEventSource.lastInstance!;\n\n      act(() => {\n        es.simulateMessage(JSON.stringify(makeEventRow(\"ev-1\")));\n      });\n      act(() => {\n        es.simulateMessage(JSON.stringify(makeEventRow(\"ev-2\")));\n      });\n\n      expect(result.current.events).toHaveLength(2);\n      // ev-2 arrived last → newest → index 0\n      expect(result.current.events[0].event_id).toBe(\"ev-2\");\n      expect(result.current.events[1].event_id).toBe(\"ev-1\");\n    });\n\n    it(\"caps the list at 200 events; when a 201st arrives the oldest is dropped\", () => {\n      const { result } = renderHook(() => useLiveFeed());\n      const es = MockEventSource.lastInstance!;\n\n      // Fill with 200 events\n      act(() => {\n        for (let i = 0; i < 200; i++) {\n          es.simulateMessage(JSON.stringify(makeEventRow(`ev-${i}`)));\n        }\n      });\n      expect(result.current.events).toHaveLength(200);\n      // Newest is ev-199 at index 0, oldest is ev-0 at index 199\n      expect(result.current.events[0].event_id).toBe(\"ev-199\");\n      expect(result.current.events[199].event_id).toBe(\"ev-0\");\n\n      // Add 201st event\n      act(() => {\n        es.simulateMessage(JSON.stringify(makeEventRow(\"ev-200\")));\n      });\n\n      expect(result.current.events).toHaveLength(200);\n      // Newest is still at index 0\n      expect(result.current.events[0].event_id).toBe(\"ev-200\");\n      // Oldest (ev-0) was dropped\n      expect(\n        result.current.events.find((e) => e.event_id === \"ev-0\"),\n      ).toBeUndefined();\n    });\n  });\n\n  describe(\"pause / resume\", () => {\n    it(\"togglePause sets paused to true; incoming events during pause go to buffer, not state\", () => {\n      const { result } = renderHook(() => useLiveFeed());\n      const es = MockEventSource.lastInstance!;\n\n      act(() => {\n        result.current.togglePause();\n      });\n      expect(result.current.paused).toBe(true);\n\n      // Message arrives while paused — should NOT appear in events\n      act(() => {\n        es.simulateMessage(JSON.stringify(makeEventRow(\"buffered\")));\n      });\n      expect(result.current.events).toHaveLength(0);\n    });\n\n    it(\"resuming flushes buffered events into state (newest first, prepended before existing)\", () => {\n      const { result } = renderHook(() => useLiveFeed());\n      const es = MockEventSource.lastInstance!;\n\n      // One event before pause\n      act(() => {\n        es.simulateMessage(JSON.stringify(makeEventRow(\"pre-pause\")));\n      });\n      expect(result.current.events).toHaveLength(1);\n\n      // Pause\n      act(() => {\n        result.current.togglePause();\n      });\n\n      // Two events while paused\n      act(() => {\n        es.simulateMessage(JSON.stringify(makeEventRow(\"buf-1\")));\n        es.simulateMessage(JSON.stringify(makeEventRow(\"buf-2\")));\n      });\n      // State should still hold only the 1 pre-pause event\n      expect(result.current.events).toHaveLength(1);\n\n      // Resume — buffer should flush\n      act(() => {\n        result.current.togglePause();\n      });\n\n      expect(result.current.paused).toBe(false);\n      expect(result.current.events).toHaveLength(3);\n      // Buffered events (buf-2 is newest) should be prepended\n      expect(result.current.events[0].event_id).toBe(\"buf-2\");\n      expect(result.current.events[1].event_id).toBe(\"buf-1\");\n      expect(result.current.events[2].event_id).toBe(\"pre-pause\");\n    });\n  });\n\n  describe(\"clearEvents\", () => {\n    it(\"resets the events array to empty\", () => {\n      const { result } = renderHook(() => useLiveFeed());\n      const es = MockEventSource.lastInstance!;\n\n      act(() => {\n        es.simulateMessage(JSON.stringify(makeEventRow(\"ev-1\")));\n        es.simulateMessage(JSON.stringify(makeEventRow(\"ev-2\")));\n      });\n      expect(result.current.events).toHaveLength(2);\n\n      act(() => {\n        result.current.clearEvents();\n      });\n\n      expect(result.current.events).toHaveLength(0);\n    });\n\n    it(\"also clears events buffered during pause\", () => {\n      const { result } = renderHook(() => useLiveFeed());\n      const es = MockEventSource.lastInstance!;\n\n      act(() => {\n        result.current.togglePause();\n      });\n      act(() => {\n        es.simulateMessage(JSON.stringify(makeEventRow(\"buf-1\")));\n      });\n\n      act(() => {\n        result.current.clearEvents();\n      });\n\n      // Resume — nothing should be flushed\n      act(() => {\n        result.current.togglePause();\n      });\n\n      expect(result.current.events).toHaveLength(0);\n    });\n  });\n});\n","numLines":266,"startLine":1,"totalLines":266}}}
