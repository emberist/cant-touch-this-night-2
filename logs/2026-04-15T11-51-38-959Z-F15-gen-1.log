{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UwETq6TMX9BpLFQqEiBdMg","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQuery } = vi.hoisted(() => ({\n6\t  mockQuery: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: {\n11\t    query: mockQuery,\n12\t  },\n13\t}));\n14\t\n15\timport { buildFunnelQuery, queryFunnel } from \"@/lib/funnels\";\n16\t\n17\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n18\t\n19\tfunction mockQueryReturns(rows: unknown[]) {\n20\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n21\t}\n22\t\n23\tconst baseParams = {\n24\t  steps: [\"Page Viewed\", \"Signup Completed\", \"Purchase Completed\"],\n25\t  start: \"2026-04-01\",\n26\t  end: \"2026-04-15\",\n27\t};\n28\t\n29\t// ─── Tests ────────────────────────────────────────────────────────────────────\n30\t\n31\tbeforeEach(() => {\n32\t  mockQueryReturns([]);\n33\t});\n34\t\n35\tafterEach(() => {\n36\t  vi.clearAllMocks();\n37\t});\n38\t\n39\t// ─── buildFunnelQuery ─────────────────────────────────────────────────────────\n40\t\n41\tdescribe(\"buildFunnelQuery\", () => {\n42\t  it(\"generates SQL containing windowFunnel aggregate function\", () => {\n43\t    const { query } = buildFunnelQuery(baseParams);\n44\t    expect(query).toContain(\"windowFunnel\");\n45\t  });\n46\t\n47\t  it(\"includes identity_mappings FINAL JOIN for resolved identity\", () => {\n48\t    const { query } = buildFunnelQuery(baseParams);\n49\t    expect(query).toContain(\"identity_mappings FINAL\");\n50\t  });\n51\t\n52\t  it(\"generates one step condition parameter per step\", () => {\n53\t    const { query } = buildFunnelQuery(baseParams);\n54\t    expect(query).toContain(\"{step_0:String}\");\n55\t    expect(query).toContain(\"{step_1:String}\");\n56\t    expect(query).toContain(\"{step_2:String}\");\n57\t  });\n58\t\n59\t  it(\"correctly populates query_params with step names, start, and end_exclusive\", () => {\n60\t    const { query_params } = buildFunnelQuery(baseParams);\n61\t    expect(query_params.step_0).toBe(\"Page Viewed\");\n62\t    expect(query_params.step_1).toBe(\"Signup Completed\");\n63\t    expect(query_params.step_2).toBe(\"Purchase Completed\");\n64\t    expect(query_params).toHaveProperty(\"start\");\n65\t    expect(query_params).toHaveProperty(\"end_exclusive\");\n66\t  });\n67\t\n68\t  it(\"works with 2 steps (minimum)\", () => {\n69\t    const { query, query_params } = buildFunnelQuery({\n70\t      ...baseParams,\n71\t      steps: [\"Page Viewed\", \"Signup Completed\"],\n72\t    });\n73\t    expect(query).toContain(\"{step_0:String}\");\n74\t    expect(query).toContain(\"{step_1:String}\");\n75\t    expect(query).not.toContain(\"{step_2:String}\");\n76\t    expect(query_params.step_0).toBe(\"Page Viewed\");\n77\t    expect(query_params.step_1).toBe(\"Signup Completed\");\n78\t  });\n79\t\n80\t  it(\"works with 5 steps (maximum)\", () => {\n81\t    const steps = [\"A\", \"B\", \"C\", \"D\", \"E\"];\n82\t    const { query, query_params } = buildFunnelQuery({ ...baseParams, steps });\n83\t    for (let i = 0; i < 5; i++) {\n84\t      expect(query).toContain(`{step_${i}:String}`);\n85\t      expect(query_params[`step_${i}`]).toBe(steps[i]);\n86\t    }\n87\t  });\n88\t\n89\t  it(\"start param uses ClickHouse-compatible space-separated format (no T or Z)\", () => {\n90\t    const { query_params } = buildFunnelQuery(baseParams);\n91\t    expect(query_params.start).toBe(\"2026-04-01 00:00:00.000\");\n92\t    expect(query_params.start).not.toContain(\"T\");\n93\t    expect(query_params.start).not.toContain(\"Z\");\n94\t  });\n95\t\n96\t  it(\"end_exclusive is computed correctly (day after end date)\", () => {\n97\t    const { query_params } = buildFunnelQuery(baseParams);\n98\t    expect(query_params.end_exclusive).toBe(\"2026-04-16 00:00:00.000\");\n99\t    expect(query_params.end_exclusive).not.toContain(\"T\");\n100\t    expect(query_params.end_exclusive).not.toContain(\"Z\");\n101\t  });\n102\t\n103\t  it(\"end_exclusive correctly handles month rollover (April 30 → May 1)\", () => {\n104\t    const { query_params } = buildFunnelQuery({\n105\t      ...baseParams,\n106\t      end: \"2026-04-30\",\n107\t    });\n108\t    expect(query_params.end_exclusive).toBe(\"2026-05-01 00:00:00.000\");\n109\t  });\n110\t\n111\t  it(\"filters events by date range in WHERE clause\", () => {\n112\t    const { query } = buildFunnelQuery(baseParams);\n113\t    expect(query).toContain(\"{start:String}\");\n114\t    expect(query).toContain(\"{end_exclusive:String}\");\n115\t  });\n116\t\n117\t  it(\"groups by resolved identity using coalesce\", () => {\n118\t    const { query } = buildFunnelQuery(baseParams);\n119\t    expect(query).toContain(\"coalesce(e.user_id, m.user_id, e.device_id)\");\n120\t  });\n121\t});\n122\t\n123\t// ─── queryFunnel ──────────────────────────────────────────────────────────────\n124\t\n125\tdescribe(\"queryFunnel\", () => {\n126\t  it(\"returns correct step names in order from params\", async () => {\n127\t    mockQueryReturns([\n128\t      { level: 1, cnt: 1000 },\n129\t      { level: 2, cnt: 320 },\n130\t      { level: 3, cnt: 88 },\n131\t    ]);\n132\t\n133\t    const result = await queryFunnel(baseParams);\n134\t    expect(result.steps.map((s) => s.name)).toEqual([\n135\t      \"Page Viewed\",\n136\t      \"Signup Completed\",\n137\t      \"Purchase Completed\",\n138\t    ]);\n139\t  });\n140\t\n141\t  it(\"computes cumulative user counts (level >= N for step N)\", async () => {\n142\t    mockQueryReturns([\n143\t      { level: 1, cnt: 680 },\n144\t      { level: 2, cnt: 232 },\n145\t      { level: 3, cnt: 88 },\n146\t    ]);\n147\t\n148\t    const result = await queryFunnel(baseParams);\n149\t    expect(result.steps