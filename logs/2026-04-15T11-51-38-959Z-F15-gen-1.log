)\", async () => {\n300\t    await seedData();\n301\t\n302\t    const mappingsInsert = mockInsert.mock.calls.find(\n303\t      (c: [{ table: string; values: unknown[] }]) =>\n304\t        c[0].table === \"identity_mappings\",\n305\t    );\n306\t    expect(mappingsInsert).toBeDefined();\n307\t    expect(mappingsInsert[0].values.length).toBeGreaterThanOrEqual(70);\n308\t    expect(mappingsInsert[0].values.length).toBeLessThanOrEqual(80);\n309\t  });\n310\t\n311\t  it(\"returns event count and user count for non-anonymous users\", async () => {\n312\t    const result = await seedData();\n313\t\n314\t    expect(result.events).toBeGreaterThanOrEqual(11_500);\n315\t    expect(result.events).toBeLessThanOrEqual(12_500);\n316\t    expect(result.users).toBe(60); // 50 fully-resolved + 10 multi-device\n317\t  });\n318\t});\n319\t"}]},"parent_tool_use_id":null,"session_id":"c72eb9a7-df03-4abb-9f50-785b299289e4","uuid":"c034cf2a-e892-419c-9f1f-4ece96608bb0","timestamp":"2026-04-15T14:34:33.940Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/seed.test.ts","content":"  it(\"total mapping count is in range 70–80 (50 single + 10 × 2-3 multi)\", () => {\n    const users = generateUsers();\n    const mappings = buildIdentityMappings(users);\n    expect(mappings.length).toBeGreaterThanOrEqual(70);\n    expect(mappings.length).toBeLessThanOrEqual(80);\n  });\n});\n\n// ─── seedData ─────────────────────────────────────────────────────────────────\n\ndescribe(\"seedData\", () => {\n  it(\"truncates the events table before inserting\", async () => {\n    await seedData();\n\n    const eventsCall = mockCommand.mock.calls.find(\n      (c: [{ query: string }]) =>\n        c[0].query.toLowerCase().includes(\"truncate\") &&\n        c[0].query.includes(\"events\"),\n    );\n    expect(eventsCall).toBeDefined();\n  });\n\n  it(\"truncates the identity_mappings table before inserting\", async () => {\n    await seedData();\n\n    const mappingsCall = mockCommand.mock.calls.find(\n      (c: [{ query: string }]) =>\n        c[0].query.toLowerCase().includes(\"truncate\") &&\n        c[0].query.includes(\"identity_mappings\"),\n    );\n    expect(mappingsCall).toBeDefined();\n  });\n\n  it(\"inserts events into the events table with ~12,000 rows\", async () => {\n    await seedData();\n\n    const eventsInsert = mockInsert.mock.calls.find(\n      (c: [{ table: string; values: unknown[] }]) => c[0].table === \"events\",\n    );\n    expect(eventsInsert).toBeDefined();\n    expect(eventsInsert[0].values.length).toBeGreaterThanOrEqual(11_500);\n    expect(eventsInsert[0].values.length).toBeLessThanOrEqual(12_500);\n  });\n\n  it(\"inserts identity mappings into the identity_mappings table (70–80 rows)\", async () => {\n    await seedData();\n\n    const mappingsInsert = mockInsert.mock.calls.find(\n      (c: [{ table: string; values: unknown[] }]) =>\n        c[0].table === \"identity_mappings\",\n    );\n    expect(mappingsInsert).toBeDefined();\n    expect(mappingsInsert[0].values.length).toBeGreaterThanOrEqual(70);\n    expect(mappingsInsert[0].values.length).toBeLessThanOrEqual(80);\n  });\n\n  it(\"returns event count and user count for non-anonymous users\", async () => {\n    const result = await seedData();\n\n    expect(result.events).toBeGreaterThanOrEqual(11_500);\n    expect(result.events).toBeLessThanOrEqual(12_500);\n    expect(result.users).toBe(60); // 50 fully-resolved + 10 multi-device\n  });\n});\n","numLines":65,"startLine":255,"totalLines":319}}}
