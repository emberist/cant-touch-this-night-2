{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ESJM17N3VX6c1pSj2acc8Y","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport { useEffect, useState } from \"react\";\n4\timport type { UserProfile } from \"@/lib/users\";\n5\t\n6\t// ─── Types ────────────────────────────────────────────────────────────────────\n7\t\n8\texport interface UseUserProfileResult {\n9\t  profile: UserProfile | null;\n10\t  loading: boolean;\n11\t  error: string | null;\n12\t}\n13\t\n14\t// ─── Hook ─────────────────────────────────────────────────────────────────────\n15\t\n16\texport function useUserProfile(resolved_id: string): UseUserProfileResult {\n17\t  const [profile, setProfile] = useState<UserProfile | null>(null);\n18\t  const [loading, setLoading] = useState(false);\n19\t  const [error, setError] = useState<string | null>(null);\n20\t\n21\t  useEffect(() => {\n22\t    let cancelled = false;\n23\t\n24\t    async function fetchProfile(): Promise<void> {\n25\t      setLoading(true);\n26\t      setError(null);\n27\t      setProfile(null);\n28\t\n29\t      try {\n30\t        const url = `/api/users/${encodeURIComponent(resolved_id)}`;\n31\t        const res = await fetch(url);\n32\t\n33\t        if (cancelled) return;\n34\t\n35\t        if (!res.ok) {\n36\t          setError(`Failed to load profile (HTTP ${res.status})`);\n37\t          return;\n38\t        }\n39\t\n40\t        const data = (await res.json()) as UserProfile;\n41\t\n42\t        if (cancelled) return;\n43\t\n44\t        setProfile(data);\n45\t      } catch (err) {\n46\t        if (cancelled) return;\n47\t        setError(err instanceof Error ? err.message : \"Unknown error\");\n48\t      } finally {\n49\t        if (!cancelled) {\n50\t          setLoading(false);\n51\t        }\n52\t      }\n53\t    }\n54\t\n55\t    fetchProfile();\n56\t\n57\t    return () => {\n58\t      cancelled = true;\n59\t    };\n60\t  }, [resolved_id]);\n61\t\n62\t  return { profile, loading, error };\n63\t}\n64\t"}]},"parent_tool_use_id":null,"session_id":"c0c6e330-1db1-48b7-b235-690b82a1cb67","uuid":"bbb4772f-2f37-48b9-ac64-8aef6de8ebfc","timestamp":"2026-04-15T17:32:34.257Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/users/useUserProfile.ts","content":"\"use client\";\n\nimport { useEffect, useState } from \"react\";\nimport type { UserProfile } from \"@/lib/users\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface UseUserProfileResult {\n  profile: UserProfile | null;\n  loading: boolean;\n  error: string | null;\n}\n\n// ─── Hook ─────────────────────────────────────────────────────────────────────\n\nexport function useUserProfile(resolved_id: string): UseUserProfileResult {\n  const [profile, setProfile] = useState<UserProfile | null>(null);\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n\n  useEffect(() => {\n    let cancelled = false;\n\n    async function fetchProfile(): Promise<void> {\n      setLoading(true);\n      setError(null);\n      setProfile(null);\n\n      try {\n        const url = `/api/users/${encodeURIComponent(resolved_id)}`;\n        const res = await fetch(url);\n\n        if (cancelled) return;\n\n        if (!res.ok) {\n          setError(`Failed to load profile (HTTP ${res.status})`);\n          return;\n        }\n\n        const data = (await res.json()) as UserProfile;\n\n        if (cancelled) return;\n\n        setProfile(data);\n      } catch (err) {\n        if (cancelled) return;\n        setError(err instanceof Error ? err.message : \"Unknown error\");\n      } finally {\n        if (!cancelled) {\n          setLoading(false);\n        }\n      }\n    }\n\n    fetchProfile();\n\n    return () => {\n      cancelled = true;\n    };\n  }, [resolved_id]);\n\n  return { profile, loading, error };\n}\n","numLines":64,"startLine":1,"tot