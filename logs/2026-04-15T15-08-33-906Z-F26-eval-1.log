{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AMmTtuTtkUDpjhLmKqc91o","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport Box from \"@mui/material/Box\";\n4\timport Chip from \"@mui/material/Chip\";\n5\timport Divider from \"@mui/material/Divider\";\n6\timport Skeleton from \"@mui/material/Skeleton\";\n7\timport Stack from \"@mui/material/Stack\";\n8\timport Typography from \"@mui/material/Typography\";\n9\timport { useParams } from \"next/navigation\";\n10\timport { UserTimeline } from \"@/components/UserTimeline\";\n11\timport { useUserProfile } from \"@/components/users/useUserProfile\";\n12\t\n13\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n14\t\n15\tfunction formatDate(iso: string): string {\n16\t  return new Date(iso).toLocaleString(undefined, {\n17\t    dateStyle: \"medium\",\n18\t    timeStyle: \"short\",\n19\t  });\n20\t}\n21\t\n22\t// ─── Page ─────────────────────────────────────────────────────────────────────\n23\t\n24\texport default function UserProfilePage(): React.JSX.Element {\n25\t  const params = useParams<{ id: string }>();\n26\t  const resolved_id = decodeURIComponent(params.id);\n27\t  const { profile, loading, error } = useUserProfile(resolved_id);\n28\t\n29\t  if (loading) {\n30\t    return (\n31\t      <Box data-testid=\"user-profile\">\n32\t        <Skeleton variant=\"text\" width={300} height={40} sx={{ mb: 2 }} />\n33\t        <Skeleton variant=\"rectangular\" height={80} sx={{ mb: 2 }} />\n34\t        <Skeleton variant=\"rectangular\" height={200} />\n35\t      </Box>\n36\t    );\n37\t  }\n38\t\n39\t  if (error) {\n40\t    return (\n41\t      <Box data-testid=\"user-profile\">\n42\t        <Typography color=\"error\">{error}</Typography>\n43\t      </Box>\n44\t    );\n45\t  }\n46\t\n47\t  if (!profile) {\n48\t    return (\n49\t      <Box data-testid=\"user-profile\">\n50\t        <Typography color=\"text.secondary\">User not found.</Typography>\n51\t     