{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RxvGYPyb8pvLcGH8bXobmp","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { cleanup, fireEvent, render, screen } from \"@testing-library/react\";\n3\timport { afterEach, describe, expect, it, vi } from \"vitest\";\n4\timport { StepBuilder } from \"@/components/funnels/StepBuilder\";\n5\t\n6\tafterEach(() => {\n7\t  cleanup();\n8\t  vi.clearAllMocks();\n9\t});\n10\t\n11\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n12\t\n13\tfunction renderStepBuilder(\n14\t  steps: string[],\n15\t  overrides: {\n16\t    onAddStep?: () => void;\n17\t    onRemoveStep?: (index: number) => void;\n18\t    onSetStep?: (index: number, value: string) => void;\n19\t  } = {},\n20\t) {\n21\t  const props = {\n22\t    steps,\n23\t    eventNames: [\"Page Viewed\", \"Signup Completed\", \"Purchase Completed\"],\n24\t    onAddStep: overrides.onAddStep ?? vi.fn(),\n25\t    onRemoveStep: overrides.onRemoveStep ?? vi.fn(),\n26\t    onSetStep: overrides.onSetStep ?? vi.fn(),\n27\t  };\n28\t  render(<StepBuilder {...props} />);\n29\t  return props;\n30\t}\n31\t\n32\t// ─── Tests ────────────────────────────────────────────────────────────────────\n33\t\n34\tdescribe(\"StepBuilder\", () => {\n35\t  describe(\"container\", () => {\n36\t    it(\"renders data-testid='step-builder' container\", () => {\n37\t      renderStepBuilder([\"\", \"\"]);\n38\t      expect(screen.getByTestId(\"step-builder\")).toBeTruthy();\n39\t    });\n40\t  });\n41\t\n42\t  describe(\"step inputs\", () => {\n43\t    it(\"renders the correct number of comboboxes matching steps length\", () => {\n44\t      renderStepBuilder([\"Page Viewed\", \"Purchase Completed\"]);\n45\t      const combos = screen.getAllByRole(\"combobox\");\n46\t      expect(combos).toHaveLength(2);\n47\t    });\n48\t\n49\t    it(\"renders 3 comboboxes when steps has 3 items\", () => {\n50\t      renderStepBuilder([\n51\t        \"Page Viewed\",\n52\t        \"Signup Completed\",\n53\t        \"Purchase Completed\",\n54\t      ]);\n55\t      const combos = screen.getAllByRole(\"combobox\");\n56\t      expect(combos).toHaveLength(3);\n57\t    });\n58\t  });\n59\t\n60\t  describe(\"Add Step button\", () => {\n61\t    it(\"renders the Add Step button\", () => {\n62\t      renderStepBuilder([\"\", \"\"]);\n63\t      expect(screen.getByRole(\"button\", { name: /add step/i })).toBeTruthy();\n64\t    });\n65\t\n66\t    it(\"calls onAddStep when the button is clicked\", () => {\n67\t      const onAddStep = vi.fn();\n68\t      renderStepBuilder([\"\", \"\"], { onAddStep });\n69\t      fireEvent.click(screen.getByRole(\"button\", { name: /add step/i }));\n70\t      expect(onAddStep).toHaveBeenCalledTimes(1);\n71\t    });\n72\t\n73\t    it(\"is disabled when steps.length === 5\", () => {\n74\t      renderStepBuilder([\"A\", \"B\", \"C\", \"D\", \"E\"]);\n75\t      const btn = screen.getByRole(\"button\", { name: /add step/i });\n76\t      expect(btn).toHaveProperty(\"disabled\", true);\n77\t    });\n78\t\n79\t    it(\"is not disabled when steps.length < 5\", () => {\n80\t      renderStepBuilder([\"A\", \"B\"]);\n81\t      const btn = screen.getByRole(\"button\", { name: /add step/i });\n82\t      expect(btn).toHaveProperty(\"disabled\", false);\n83\t    });\n84\t  });\n85\t\n86\t  describe(\"Remove buttons\", () => {\n87\t    it(\"renders a remove button for each step\", () => {\n88\t      renderStepBuilder([\n89\t        \"Page Viewed\",\n90\t        \"Purchase Completed\",\n91\t        \"Signup Completed\",\n92\t      ]);\n93\t      const removeBtns = screen.getAllByRole(\"button\", {\n94\t        name: /remove step/i,\n95\t      });\n96\t      expect(removeBtns).toHaveLength(3);\n97\t    });\n98\t\n99\t    it(\"calls onRemoveStep with the correct index when clicked\", () => {\n100\t      const onRemoveStep = vi.fn();\n101\t      renderStepBuilder(\n102\t        [\"Page Viewed\", \"Purchase Completed\", \"Signup Completed\"],\n103\t        {\n104\t          onRemoveStep,\n105\t        },\n106\t      );\n107\t      const removeBtns = screen.getAllByRole(\"button\", {\n108\t        name: /remove step/i,\n109\t      });\n110\t      fireEvent.click(removeBtns[1]);\n111\t      expect(onRemoveStep).toHaveBeenCalledWith(1);\n112\t    });\n113\t\n114\t    it(\"remove buttons are disabled when steps.length === 2\", () => {\n115\t      renderStepBuilder([\"\", \"\"]);\n116\t      const removeBtns = screen.getAllByRole(\"button\", {\n117\t        name: /remove step/i,\n118\t      });\n119\t      for (const btn of removeBtns) {\n120\t        expect(btn).toHaveProperty(\"disabled\", true);\n121\t      }\n122\t    });\n123\t\n124\t    it(\"remove buttons are not disabled when steps.length > 2\", () => {\n125\t      renderStepBuilder([\"A\", \"B\", \"C\"]);\n126\t      const removeBtns = screen.getAllByRole(\"button\", {\n127\t        name: /remove step/i,\n128\t      });\n129\t      for (const btn of removeBtns) {\n130\t        expect(btn).toHaveProperty(\"disabled\", false);\n131\t      }\n132\t    });\n133\t  });\n134\t});\n135\t"}]},"parent_tool_use_id":null,"session_id":"3ede4574-d28a-41bf-9f8d-fc7392620cec","uuid":"79818012-a072-4f3e-b60a-e45bafe3407b","timestamp":"2026-04-15T17:45:08.101Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/funnels/__tests__/StepBuilder.test.tsx","content":"// @vitest-environment jsdom\nimport { cleanup, fireEvent, render, screen } from \"@testing-library/react\";\nimport { afterEach, describe, expect, it, vi } from \"vitest\";\nimport { StepBuilder } from \"@/components/funnels/StepBuilder\";\n\nafterEach(() => {\n  cleanup();\n  vi.clearAllMocks();\n});\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction renderStepBuilder(\n  steps: string[],\n  overrides: {\n    onAddStep?: () => void;\n    onRemoveStep?: (index: number) => void;\n    onSetStep?: (index: number, value: string) => void;\n  } = {},\n) {\n  const props = {\n    steps,\n    eventNames: [\"Page Viewed\", \"Signup Completed\", \"Purchase Completed\"],\n    onAddStep: overrides.onAddStep ?? vi.fn(),\n    onRemoveStep: overrides.onRemoveStep ?? vi.fn(),\n    onSetStep: overrides.onSetStep ?? vi.fn(),\n  };\n  render(<StepBuilder {...props} />);\n  return props;\n}\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\ndescribe(\"StepBuilder\", () => {\n  describe(\"container\", () => {\n    it(\"renders data-testid='step-builder' container\", () => {\n      renderStepBuilder([\"\", \"\"]);\n      expect(screen.getByTestId(\"step-builder\")).toBeTruthy();\n    });\n  });\n\n  describe(\"step inputs\", () => {\n    it(\"renders the correct number of comboboxes matching steps length\", () => {\n      renderStepBuilder([\"Page Viewed\", \"Purchase Completed\"]);\n      const combos = screen.getAllByRole(\"combobox\");\n      expect(combos).toHaveLength(2);\n    });\n\n    it(\"renders 3 comboboxes when steps has 3 items\", () => {\n      renderStepBuilder([\n        \"Page Viewed\",\n        \"Signup Completed\",\n        \"Purchase Completed\",\n      ]);\n      const combos = screen.getAllByRole(\"combobox\");\n      expect(combos).toHaveLength(3);\n    });\n  });\n\n  describe(\"Add Step button\", () => {\n    it(\"renders the Add Step button\", () => {\n      renderStepBuilder([\"\", \"\"]);\n      expect(screen.getByRole(\"button\", { name: /add step/i })).toBeTruthy();\n    });\n\n    it(\"calls onAddStep when the button is clicked\", () => {\n      const onAddStep = vi.fn();\n      renderStepBuilder([\"\", \"\"], { onAddStep });\n      fireEvent.click(screen.getByRole(\"button\", { name: /add step/i }));\n      expect(onAddStep).toHaveBeenCalledTimes(1);\n    });\n\n    it(\"is disabled when steps.length === 5\", () => {\n      renderStepBuilder([\"A\", \"B\", \"C\", \"D\", \"E\"]);\n      const btn = screen.getByRole(\"button\", { name: /add step/i });\n      expect(btn).toHaveProperty(\"disabled\", true);\n    });\n\n    it(\"is not disabled when steps.length < 5\", () => {\n      renderStepBuilder([\"A\", \"B\"]);\n      const btn = screen.getByRole(\"button\", { name: /add step/i });\n      expect(btn).toHaveProperty(\"disabled\", false);\n    });\n  });\n\n  describe(\"Remove buttons\", () => {\n    it(\"renders a remove button for each step\", () => {\n      renderStepBuilder([\n        \"Page Viewed\",\n        \"Purchase Completed\",\n        \"Signup Completed\",\n      ]);\n      const removeBtns = screen.getAllByRole(\"button\", {\n        name: /remove step/i,\n      });\n      expect(removeBtns).toHaveLength(3);\n    });\n\n    it(\"calls onRemoveStep with the correct index when clicked\", () => {\n      const onRemoveStep = vi.fn();\n      renderStepBuilder(\n        [\"Page Viewed\", \"Purchase Completed\", \"Signup Completed\"],\n        {\n          onRemoveStep,\n        },\n      );\n      const removeBtns = screen.getAllByRole(\"button\", {\n        name: /remove step/i,\n      });\n      fireEvent.click(removeBtns[1]);\n      expect(onRemoveStep).toHaveBeenCalledWith(1);\n    });\n\n    it(\"remove buttons are disabled when steps.length === 2\", () => {\n      renderStepBuilder([\"\", \"\"]);\n      const removeBtns = screen.getAllByRole(\"button\", {\n        name: /remove step/i,\n      });\n      for (const btn of removeBtns) {\n        expect(btn).toHaveProperty(\"disabled\", true);\n      }\n    });\n\n    it(\"remove buttons are not disabled when steps.length > 2\", () => {\n      renderStepBuilder([\"A\", \"B\", \"C\"]);\n      const removeBtns = screen.getAllByRole(\"button\", {\n        name: /remove step/i,\n      });\n      for (const btn of removeBtns) {\n        expect(btn).toHaveProperty(\"disabled\", false);\n      }\n    });\n  });\n});\n","numLines":135,"startLine":1,"totalLines":135}}}
