{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VZixcpiNXQiBwPDvjtG4Gb","type":"tool_result","content":"1\timport { queryNewEvents } from \"@/lib/live\";\n2\t\n3\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n4\t\n5\t/**\n6\t * Converts a JS Date to the ClickHouse-compatible datetime string format:\n7\t * \"YYYY-MM-DD HH:MM:SS.mmm\" (no T, no Z).\n8\t */\n9\tfunction toClickHouseDateTime(d: Date): string {\n10\t  return d.toISOString().replace(\"T\", \" \").replace(\"Z\", \"\");\n11\t}\n12\t\n13\t// ─── GET /api/live ────────────────────────────────────────────────────────────\n14\t\n15\texport async function GET(): Promise<Response> {\n16\t  // Watermark: only events ingested after this point will be streamed.\n17\t  // Initialized to the current server time so the feed shows only new events.\n18\t  let lastSeenIngestedAt = toClickHouseDateTime(new Date());\n19\t\n20\t  let intervalId: ReturnType<typeof setInterval> | undefined;\n21\t\n22\t  const encoder = new TextEncoder();\n23\t\n24\t  const stream = new ReadableStream({\n25\t    start(controller) {\n26\t      // Immediately enqueue a keep-alive comment so that the HTTP status line\n27\t      // and headers are flushed to the client on connect, even when no events\n28\t      // exist yet.  SSE clients treat lines beginning with \":\" as comments and\n29\t      // ignore them.\n30\t      controller.enqueue(encoder.encode(\":\\n\\n\"));\n31\t\n32\t      intervalId = setInterval(async () => {\n33\t        try {\n34\t          const events = await queryNewEvents(lastSeenIngestedAt);\n35\t\n36\t          for (const event of events) {\n37\t            controller.enqueue(\n38\t              encoder.encode(`data: ${JSON.stringify(event)}\\n\\n`),\n39\t            );\n40\t          }\n41\t\n42\t          // Advance watermark to the latest ingested_at in this batch\n43\t          if (events.length > 0) {\n44\t            lastSeenIngestedAt = events[events.length - 1].ingested_at;\n45\t          }\n46\t        } catch {\n47\t          // Swallow errors — keep the stream alive on transient ClickHouse issues\n48\t        }\n49\t      }, 1000);\n50\t    },\n51\t    cancel() {\n52\t      clearInterval(intervalId);\n53\t    },\n54\t  });\n55\t\n56\t  return new Response(stream, {\n57\t    headers: {\n58\t      \"Content-Type\": \"text/event-stream\",\n59\t      \"Cache-Control\": \"no-cache\",\n60\t      Connection: \"keep-alive\",\n61\t    },\n62\t  });\n63\t}\n64\t"}]},"parent_tool_use_id":null,"session_id":"3ede4574-d28a-41bf-9f8d-fc7392620cec","uuid":"81c84fc8-1c4f-4e4a-bb71-5d4b7f1f83f9","timestamp":"2026-04-15T17:44:49.103Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/live/route.ts","content":"import { queryNewEvents } from \"@/lib/live\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\n/**\n * Converts a JS Date to the ClickHouse-compatible datetime string format:\n * \"YYYY-MM-DD HH:MM:SS.mmm\" (no T, no Z).\n */\nfunction toClickHouseDateTime(d: Date): string {\n  return d.toISOString().replace(\"T\", \" \").replace(\"Z\", \"\");\n}\n\n// ─── GET /api/live ────────────────────────────────────────────────────────────\n\nexport async function GET(): Promise<Response> {\n  // Watermark: only events ingested after this point will be streamed.\n  // Initialized to the current server time so the feed shows only new events.\n  let lastSeenIngestedAt = toClickHouseDateTime(new Date());\n\n  let intervalId: ReturnType<typeof setInterval> | undefined;\n\n  const encoder = new TextEncoder();\n\n  const stream = new ReadableStream({\n    start(controller) {\n      // Immediately enqueue a keep-alive comment so that the HTTP status line\n      // and headers are flushed to the client on connect, even when no events\n      // exist yet.  SSE clients treat lines beginning with \":\" as comments and\n      // ignore them.\n      controller.enqueue(encoder.encode(\":\\n\\n\"));\n\n      intervalId = setInterval(async () => {\n        try {\n          const events = await queryNewEvents(lastSeenIngestedAt);\n\n          for (const event of events) {\n            controller.enqueue(\n              encoder.encode(`data: ${JSON.stringify(event)}\\n\\n`),\n            );\n          }\n\n          // Advance watermark to the latest ingested_at in this batch\n          if (events.length > 0) {\n            lastSeenIngestedAt = events[events.length - 1].ingested_at;\n          }\n        } catch {\n          // Swallow errors — keep the stream alive on transient ClickHouse issues\n        }\n      }, 1000);\n    },\n    cancel() {\n      clearInterval(intervalId);\n    },\n  });\n\n  return new Response(stream, {\n    headers: {\n      \"Content-Type\": \"text/event-stream\",\n      \"Cache-Control\": \"no-cache\",\n      Connection: \"keep-alive\",\n    },\n  });\n}\n","numLines":64,"startLine":1,"totalLines":64}}}
