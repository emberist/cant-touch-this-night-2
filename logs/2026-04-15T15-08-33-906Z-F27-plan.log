{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014bcWN3g9n7DZuKrGDGZLEj","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { act, renderHook, waitFor } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport { useUserSearch } from \"@/components/users/useUserSearch\";\n5\t\n6\t// ─── Fixtures ─────────────────────────────────────────────────────────────────\n7\t\n8\tconst sampleUser = {\n9\t  resolved_id: \"user@example.com\",\n10\t  first_seen: \"2026-03-01T10:00:00.000Z\",\n11\t  last_seen: \"2026-04-10T15:30:00.000Z\",\n12\t  event_count: 42,\n13\t};\n14\t\n15\tconst sampleUser2 = {\n16\t  resolved_id: \"device-abc\",\n17\t  first_seen: \"2026-03-05T08:00:00.000Z\",\n18\t  last_seen: \"2026-04-09T12:00:00.000Z\",\n19\t  event_count: 7,\n20\t};\n21\t\n22\tfunction makeFetchResponse(\n23\t  users: unknown[],\n24\t  next_cursor: string | null = null,\n25\t) {\n26\t  return Promise.resolve({\n27\t    ok: true,\n28\t    json: () => Promise.resolve({ users, next_cursor }),\n29\t  });\n30\t}\n31\t\n32\t// ─── Setup ────────────────────────────────────────────────────────────────────\n33\t\n34\tconst mockFetch = vi.fn();\n35\t\n36\tbeforeEach(() => {\n37\t  vi.stubGlobal(\"fetch\", mockFetch);\n38\t  mockFetch.mockReturnValue(makeFetchResponse([sampleUser], null));\n39\t});\n40\t\n41\tafterEach(() => {\n42\t  vi.clearAllMocks();\n43\t  vi.unstubAllGlobals();\n44\t  vi.useRealTimers();\n45\t});\n46\t\n47\t// ─── Tests ────────────────────────────────────────────────────────────────────\n48\t\n49\tdescribe(\"useUserSearch\", () => {\n50\t  describe(\"initial fetch\", () => {\n51\t    it(\"fetches users from /api/users on mount\", async () => {\n52\t      renderHook(() => useUserSearch());\n53\t      await waitFor(() => expect(mockFetch).toHaveBeenCalled());\n54\t      const url = new URL(mockFetch.mock.calls[0][0] as string);\n55\t      expect(url.pathname).toBe(\"/api/users\");\n56\t    });\n57\t\n58\t    it(\"populates users array after initial fetch\", async () => {\n59\t      const { result } = renderHook(() => useUserSearch());\n60\t      await waitFor(() => expect(result.current.users).toHaveLength(1));\n61\t      expect(result.current.users[0].resolved_id).toBe(\"user@example.com\");\n62\t    });\n63\t\n64\t    it(\"does not include a q param on initial mount\", async () => {\n65\t      renderHook(() => useUserSearch());\n66\t      await waitFor(() => expect(mockFetch).toHaveBeenCalled());\n67\t      const url = new URL(mockFetch.mock.calls[0][0] as string);\n68\t      expect(url.searchParams.get(\"q\")).toBeNull();\n69\t    });\n70\t  });\n71\t\n72\t  describe(\"loading state\", () => {\n73\t    it(\"sets loading to true during fetch\", async () => {\n74\t      let resolveFetch!: (v: unknown) => void;\n75\t      mockFetch.mockReturnValueOnce(\n76\t        new Promise((resolve) => {\n77\t          resolveFetch = resolve;\n78\t        }),\n79\t      );\n80\t\n81\t      const { result } = renderHook(() => useUserSearch());\n82\t      await waitFor(() => expect(result.current.loading).toBe(true));\n83\t\n84\t      act(() => {\n85\t        resolveFetch({\n86\t          ok: true,\n87\t          json: () => Promise.resolve({ users: [], next_cursor: null }),\n88\t        });\n89\t      });\n90\t      await waitFor(() => expect(result.current.loading).toBe(false));\n91\t    });\n92\t\n93\t    it(\"sets loading to false after fetch completes\", async () => {\n94\t      const { result } = renderHook(() => useUserSearch());\n95\t      await waitFor(() => expect(result.current.loading).toBe(false));\n96\t      expect(result.current.users).toHaveLength(1);\n97\t    });\n98\t  });\n99\t\n100\t  describe(\"hasMore\", () => {\n101\t    it(\"hasMore is false when API returns next_cursor: null\", async () => {\n102\t      mockFetch.mockReturnValue(makeFetchResponse([sampleUser], null));\n103\t      const { result } = renderHook(() => useUserSearch());\n104\t      await waitFor(() => expect(result.current.loading).toBe(false));\n105\t      expect(result.current.hasMore).toBe(false);\n106\t    });\n107\t\n108\t    it(\"hasMore is true when API returns a next_cursor\", async () => {\n109\t      mockFetch.mockReturnValue(\n110\t        makeFetchResponse([sampleUser], \"user@example.com\"),\n111\t      );\n112\t      const { result } = renderHook(() => useUserSearch());\n113\t      await waitFor(() => expect(result.current.loading).toBe(false));\n114\t      expect(result.current.hasMore).toBe(true);\n115\t    });\n116\t  });\n117\t\n118\t  describe(\"loadMore\", () => {\n119\t    it(\"appends the next page using the cursor\", async () => {\n120\t      mockFetch\n121\t        .mockReturnValueOnce(\n122\t          makeFetchResponse([sampleUser], \"user@example.com\"),\n123\t        )\n124\t        .mockReturnValueOnce(makeFetchResponse([sampleUser2], null));\n125\t\n126\t      const { result } = renderHook(() => useUserSearch());\n127\t      await waitFor(() => expect(result.current.loading).toBe(false));\n128\t\n129\t      act(() => {\n130\t        result.current.loadMore();\n131\t      });\n132\t      await waitFor(() => expect(result.current.users).toHaveLength(2));\n133\t\n134\t      const url = new URL(mockFetch.mock.calls[1][0] as string);\n135\t      expect(url.searchParams.get(\"cursor\")).toBe(\"user@example.com\");\n136\t    });\n137\t\n138\t    it(\"is a no-op when hasMore is false\", async () => {\n139\t      mockFetch.mockReturnValue(makeFetchResponse([sampleUser], null));\n140\t      const { result } = renderHook(() => useUserSearch());\n141\t      await waitFor(() => expect(result.current.loading).toBe(false));\n142\t\n143\t      act(() => {\n144\t        result.current.loadMore();\n145\t      });\n146\t\n147\t      expect(mockFetch).toHaveBeenCalledTimes(1);\n148\t    });\n149\t\n150\t    it(\"is a no-op when loading is true\", async () => {\n151\t      let resolveFetch!: (v: unknown) => void;\n152\t      mockFetch\n153\t        .mockReturnValueOnce(\n154\t          makeFetchResponse([sampleUser], \"user@example.com\"),\n155\t        )\n156\t        .mockReturnValueOnce(\n157\t          new Promise((resolve) => {\n158\t            resolveFetch = resolve;\n159\t          }),\n160\t        );\n161\t\n162\t      const { result } = renderHook(() => useUserSearch());\n163\t      await waitFor(() => expect(result.current.loading).toBe(false));\n164\t\n165\t      // Trigger loadMore, which will start loading\n166\t      act(() => {\n167\t        result.current.loadMore();\n168\t      });\n169\t\n170\t      await waitFor(() => expect(result.current.loading).toBe(true));\n171\t\n172\t      // Call loadMore again while still loading — should be a no-op\n173\t      act(() => {\n174\t        result.current.loadMore();\n175\t      });\n176\t\n177\t      // Only 2 calls: initial + first loadMore\n178\t      expect(mockFetch).toHaveBeenCalledTimes(2);\n179\t\n180\t      act(() => {\n181\t        resolveFetch({\n182\t          ok: true,\n183\t          json: () =>\n184\t            Promise.resolve({ users: [sampleUser2], next_cursor: null }),\n185\t        });\n186\t      });\n187\t      await waitFor(() => expect(result.current.loading).toBe(false));\n188\t    });\n189\t  });\n190\t\n191\t  describe(\"setQuery\", () => {\n192\t    it(\"re-fetches with q param when query is set\", async () => {\n193\t      const { result } = renderHook(() => useUserSearch());\n194\t\n195\t      // Let the initial mount fetch complete with real timers\n196\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(1));\n197\t\n198\t      // Switch to fake timers for debounce control\n199\t      vi.useFakeTimers({ toFake: [\"setTimeout\", \"clearTimeout\"] });\n200\t\n201\t      act(() => {\n202\t        result.current.setQuery(\"test@\");\n203\t      });\n204\t\n205\t      // Fire the debounce timer and flush the resulting async fetch\n206\t      await act(async () => {\n207\t        vi.advanceTimersByTime(400);\n208\t      });\n209\t\n210\t      expect(mockFetch).toHaveBeenCalledTimes(2);\n211\t      const url = new URL(mockFetch.mock.calls[1][0] as string);\n212\t      expect(url.searchParams.get(\"q\")).toBe(\"test@\");\n213\t    });\n214\t\n215\t    it(\"resets users list and cursor when query changes\", async () => {\n216\t      const filteredUser = {\n217\t        ...sampleUser,\n218\t        resolved_id: \"filtered@example.com\",\n219\t      };\n220\t\n221\t      mockFetch\n222\t        .mockReturnValueOnce(makeFetchResponse([sampleUser], null))\n223\t        .mockReturnValueOnce(makeFetchResponse([filteredUser], null));\n224\t\n225\t      const { result } = renderHook(() => useUserSearch());\n226\t\n227\t      await waitFor(() => expect(result.current.users).toHaveLength(1));\n228\t\n229\t      vi.useFakeTimers({ toFake: [\"setTimeout\", \"clearTimeout\"] });\n230\t\n231\t      act(() => {\n232\t        result.current.setQuery(\"filtered\");\n233\t      });\n234\t      await act(async () => {\n235\t        vi.advanceTimersByTime(400);\n236\t      });\n237\t\n238\t      expect(result.current.users).toHaveLength(1);\n239\t      expect(result.current.users[0]?.resolved_id).toBe(\"filtered@example.com\");\n240\t    });\n241\t\n242\t    it(\"setQuery('') fetches without q param\", async () => {\n243\t      const { result } = renderHook(() => useUserSearch());\n244\t\n245\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(1));\n246\t\n247\t      vi.useFakeTimers({ toFake: [\"setTimeout\", \"clearTimeout\"] });\n248\t\n249\t      // First set a query, then clear it\n250\t      act(() => {\n251\t        result.current.setQuery(\"something\");\n252\t      });\n253\t      await act(async () => {\n254\t        vi.advanceTimersByTime(400);\n255\t      });\n256\t      expect(mockFetch).toHaveBeenCalledTimes(2);\n257\t\n258\t      act(() => {\n259\t        result.current.setQuery(\"\");\n260\t      });\n261\t      await act(async () => {\n262\t        vi.advanceTimersByTime(400);\n263\t      });\n264\t      expect(mockFetch).toHaveBeenCalledTimes(3);\n265\t\n266\t      const url = new URL(mockFetch.mock.calls[2][0] as string);\n267\t      expect(url.searchParams.get(\"q\")).toBeNull();\n268\t    });\n269\t\n270\t    it(\"debounces rapid setQuery calls — only one fetch after settling\", async () => {\n271\t      const { result } = renderHook(() => useUserSearch());\n272\t\n273\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(1));\n274\t\n275\t      vi.useFakeTimers({ toFake: [\"setTimeout\", \"clearTimeout\"] });\n276\t\n277\t      // Rapid-fire three calls within the debounce window\n278\t      act(() => {\n279\t        result.current.setQuery(\"a\");\n280\t      });\n281\t      act(() => {\n282\t        vi.advanceTimersByTime(100);\n283\t      });\n284\t      act(() => {\n285\t        result.current.setQuery(\"ab\");\n286\t      });\n287\t      act(() => {\n288\t        vi.advanceTimersByTime(100);\n289\t      });\n290\t      act(() => {\n291\t        result.current.setQuery(\"abc\");\n292\t      });\n293\t\n294\t      // Advance past the debounce window and flush the async fetch\n295\t      await act(async () => {\n296\t        vi.advanceTimersByTime(400);\n297\t      });\n298\t\n299\t      // Only one additional fetch (the initial mount fetch already counted)\n300\t      expect(mockFetch).toHaveBeenCalledTimes(2);\n301\t\n302\t      // The final fetch should use the last query value\n303\t      const url = new URL(mockFetch.mock.calls[1][0] as string);\n304\t      expect(url.searchParams.get(\"q\")).toBe(\"abc\");\n305\t    });\n306\t  });\n307\t});\n308\t"}]},"parent_tool_use_id":null,"session_id":"3ede4574-d28a-41bf-9f8d-fc7392620cec","uuid":"96f4c6e7-d31a-4a72-b286-dfe0abaa00c1","timestamp":"2026-04-15T17:45:01.450Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/users/__tests