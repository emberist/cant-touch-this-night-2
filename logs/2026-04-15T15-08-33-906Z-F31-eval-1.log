{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YAGCdf1afLCyq32xwT581Q","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport Box from \"@mui/material/Box\";\n4\timport Button from \"@mui/material/Button\";\n5\timport Checkbox from \"@mui/material/Checkbox\";\n6\timport Chip from \"@mui/material/Chip\";\n7\timport FormControlLabel from \"@mui/material/FormControlLabel\";\n8\timport FormGroup from \"@mui/material/FormGroup\";\n9\timport Slider from \"@mui/material/Slider\";\n10\timport Stack from \"@mui/material/Stack\";\n11\timport Switch from \"@mui/material/Switch\";\n12\timport TextField from \"@mui/material/TextField\";\n13\timport Typography from \"@mui/material/Typography\";\n14\timport type {\n15\t  GeneratorFormState,\n16\t  Preset,\n17\t} from \"@/components/generate/useGenerator\";\n18\t\n19\t// ─── Types ────────────────────────────────────────────────────────────────────\n20\t\n21\texport interface GeneratorFormProps {\n22\t  form: GeneratorFormState;\n23\t  setForm: (updates: Partial<GeneratorFormState>) => void;\n24\t  applyPreset: (preset: Preset) => void;\n25\t  onSubmit: () => void;\n26\t  disabled: boolean;\n27\t}\n28\t\n29\t// ─── Constants ────────────────────────────────────────────────────────────────\n30\t\n31\tconst VARIANCE_MARKS = [\n32\t  { value: 0, label: \"Low\" },\n33\t  { value: 50, label: \"Medium\" },\n34\t  { value: 100, label: \"High\" },\n35\t];\n36\t\n37\tfunction varianceToSlider(v: string): number {\n38\t  if (v === \"low\") return 0;\n39\t  if (v === \"high\") return 100;\n40\t  return 50;\n41\t}\n42\t\n43\tfunction sliderToVariance(v: number): GeneratorFormState[\"numeric_variance\"] {\n44\t  if (v <= 25) return \"low\";\n45\t  if (v >= 75) return \"high\";\n46\t  return \"medium\";\n47\t}\n48\t\n49\t// ─── Component ────────────────────────────────────────────────────────────────\n50\t\n51\texport function GeneratorForm({\n52\t  form,\n53\t  setForm,\n54\t  applyPreset,\n55\t  onSubmit,\n56\t  disabled,\n57\t}: GeneratorFormProps): React.JSX.Element {\n58\t  return (\n59\t    <Box data-testid=\"generator-form\">\n60\t      {/* ── Preset templates ────────────────────────────────────────── */}\n61\t      <Box sx={{ mb: 2 }}>\n62\t        <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n63\t          Preset templates\n64\t        </Typography>\n65\t        <Stack direction=\"row\" spacing={1} sx={{ mt: 0.5 }}>\n66\t          <Chip\n67\t            label=\"Realistic\"\n68\t            size=\"small\"\n69\t            clickable\n70\t            onClick={() => applyPreset(\"realistic\")}\n71\t          />\n72\t          <Chip\n73\t            label=\"High volume\"\n74\t            size=\"small\"\n75\t            clickable\n76\t            onClick={() => applyPreset(\"high-volume\")}\n77\t          />\n78\t          <Chip\n79\t            label=\"Stress test\"\n80\t            size=\"small\"\n81\t            clickable\n82\t            onClick={() => applyPreset(\"stress-test\")}\n83\t          />\n84\t        </Stack>\n85\t      </Box>\n86\t\n87\t      {/* ── Volume ──────────────────────────────────────────────────── */}\n88\t      <Stack direction=\"row\" spacing={2} sx={{ mb: 2 }}>\n89\t        <TextField\n90\t          label=\"Total events\"\n91\t          type=\"number\"\n92\t          size=\"small\"\n93\t          value={form.total}\n94\t          onChange={(e) => {\n95\t            const v = Number.parseInt(e.target.value, 10);\n96\t            if (!Number.isNaN(v)) setForm({ total: v });\n97\t          }}\n98\t          slotProps={{\n99\t            htmlInput: { min: 1, max: 1_000_000 },\n100\t            inputLabel: { shrink: true },\n101\t          }}\n102\t          sx={{ width: 160 }}\n103\t        />\n104\t        <TextField\n105\t          label=\"Users\"\n106\t          type=\"number\"\n107\t          size=\"small\"\n108\t          value={form.users}\n109\t          onChange={(e) => {\n110\t            const v = Number.parseInt(e.target.value, 10);\n111\t            if (!Number.isNaN(v)) setForm({ users: v });\n112\t          }}\n113\t          slotProps={{\n114\t            htmlInput: { min: 1 },\n115\t            inputLabel: { shrink: true },\n116\t          }}\n117\t          sx={{ width: 120 }}\n118\t        />\n119\t      </Stack>\n120\t\n121\t      {/* ── Date range ──────────────────────────────────────────────── */}\n122\t      <Stack direction=\"row\" spacing={2} sx={{ mb: 2 }}>\n123\t        <TextField\n124\t          label=\"Start\"\n125\t          type=\"date\"\n126\t          size=\"small\"\n127\t          value={form.start}\n128\t          onChange={(e) => setForm({ start: e.target.value })}\n129\t          slotProps={{ inputLabel: { shrink: true } }}\n130\t          sx={{ width: 160 }}\n131\t        />\n132\t        <TextField\n133\t          label=\"End\"\n134\t          type=\"date\"\n135\t          size=\"small\"\n136\t          value={form.end}\n137\t          onChange={(e) => setForm({ end: e.target.value })}\n138\t          slotProps={{ inputLabel: { shrink: true } }}\n139\t          sx={{ width: 160 }}\n140\t        />\n141\t      </Stack>\n142\t\n143\t      {/* ── Event mix ───────────────────────────────────────────────── */}\n144\t      <Box sx={{ mb: 2 }}>\n145\t        <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n146\t          Event mix\n147\t        </Typography>\n148\t        <FormGroup>\n149\t          {form.event_types.map((et, idx) => (\n150\t            <Box\n151\t              key={et.name}\n152\t              sx={{ display: \"flex\", alignItems: \"center\", gap: 2, mb: 0.5 }}\n153\t            >\n154\t              <FormControlLabel\n155\t                control={\n156\t                  <Checkbox\n157\t                    checked={et.weight > 0}\n158\t                    onChange={(e) => {\n159\t                      const updated = form.event_types.map((t, i) =>\n160\t                        i === idx\n161\t                          ? { ...t, weight: e.target.checked ? 0.1 : 0 }\n162\t                          : t,\n163\t                      );\n164\t                      setForm({ event_types: updated });\n165\t                    }}\n166\t                    size=\"small\"\n167\t                  />\n168\t                }\n169\t                label={et.name}\n170\t                sx={{ minWidth: 200, m: 0 }}\n171\t              />\n172\t              <Slider\n173\t                size=\"small\"\n174\t                value={et.weight}\n175\t                min={0}\n176\t                max={1}\n177\t                step={0.01}\n178\t                disabled={et.weight === 0}\n179\t                onChange={(_, v) => {\n180\t                  const updated = form.event_types.map((t, i) =>\n181\t                    i === idx ? { ...t, weight: v as number } : t,\n182\t                  );\n183\t                  setForm({ event_types: updated });\n184\t                }}\n185\t                aria-label={`${et.name} weight`}\n186\t                sx={{ width: 120 }}\n187\t              />\n188\t              <Typography variant=\"caption\" sx={{ minWidth: 36 }}>\n189\t                {(et.weight * 100).toFixed(0)}%\n190\t              </Typography>\n191\t            </Box>\n192\t          ))}\n193\t        </FormGroup>\n194\t      </Box>\n195\t\n196\t      {/* ── Identity resolution ─────────────────────────────────────── */}\n197\t      <Box sx={{ mb: 2 }}>\n198\t        <FormControlLabel\n199\t          control={\n200\t            <Switch\n201\t              checked={form.identity_resolution}\n202\t              onChange={(e) =>\n203\t                setForm({ identity_resolution: e.target.checked })\n204\t              }\n205\t              slotProps={{ input: { \"aria-label\": \"Identity resolution\" } }}\n206\t            />\n207\t          }\n208\t          label=\"Identity resolution\"\n209\t        />\n210\t        <Box sx={{ mt: 1, px: 1 }}>\n211\t          <Typography variant=\"caption\" color=\"text.secondary\">\n212\t            Anonymous ratio: {form.anonymous_ratio}%\n213\t          </Typography>\n214\t          <Slider\n215\t            size=\"small\"\n216\t            value={form.anonymous_ratio}\n217\t            min={0}\n218\t            max={100}\n219\t            disabled={!form.identity_resolution}\n220\t            onChange={(_, v) => setForm({ anonymous_ratio: v as number })}\n221\t            aria-label=\"Anonymous ratio\"\n222\t            sx={{ mt: 0.5 }}\n223\t          />\n224\t        </Box>\n225\t      </Box>\n226\t\n227\t      {/* ── Numeric variance ────────────────────────────────────────── */}\n228\t      <Box sx={{ mb: 3, px: 1 }}>\n229\t        <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n230\t          Numeric property variance\n231\t        </Typography>\n232\t        <Slider\n233\t          size=\"small\"\n234\t          value={varianceToSlider(form.numeric_variance)}\n235\t          min={0}\n236\t          max={100}\n237\t          step={50}\n238\t          marks={VARIANCE_MARKS}\n239\t          onChange={(_, v) =>\n240\t            setForm({ numeric_variance: sliderToVariance(v as number) })\n241\t          }\n242\t          aria-label=\"Numeric variance\"\n243\t        />\n244\t      </Box>\n245\t\n246\t      {/* ── Submit ──────────────────────────────────────────────────── */}\n247\t      <Button variant=\"contained\" onClick={onSubmit} disabled={disabled}>\n248\t        Generate\n249\t      </Button>\n250\t    </Box>\n251\t  );\n252\t}\n253\t"}]},"parent_tool_use_id":null,"session_id":"3d324c3e-ac44-4876-8051-93925eeee4fd","uuid":"2a878fd4-19dc-43d8-a494-d381f42dc439","timestamp":"2026-04-15T18:51:46.838Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/generate/GeneratorForm.tsx","content":"\"use client\";\n\nimport Box from \"@mui/material/Box\";\nimport Button from \"@mui/material/Button\";\nimport Checkbox from \"@mui/material/Checkbox\";\nimport Chip from \"@mui/material/Chip\";\nimport FormControlLabel from \"@mui/material/FormControlLabel\";\nimport FormGroup from \"@mui/material/FormGroup\";\nimport Slider from \"@mui/material/Slider\";\nimport Stack from \"@mui/material/Stack\";\nimport Switch from \"@mui/material/Switch\";\nimport TextField from \"@mui/material/TextField\";\nimport Typography from \"@mui/material/Typography\";\nimport type {\n  GeneratorFormState,\n  Preset,\n} from \"@/components/generate/useGenerator\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface GeneratorFormProps {\n  form: GeneratorFormState;\n  setForm: (updates: Partial<GeneratorFormState>) => void;\n  applyPreset: (preset: Preset) => void;\n  onSubmit: () => void;\n  disabled: boolean;\n}\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst VARIANCE_MARKS = [\n  { value: 0, label: \"Low\" },\n  { value: 50, label: \"Medium\" },\n  { value: 100, label: \"High\" },\n];\n\nfunction varianceToSlider(v: string): number {\n  if (v === \"low\") return 0;\n  if (v === \"high\") return 100;\n  return 50;\n}\n\nfunction sliderToVariance(v: number): GeneratorFormState[\"numeric_variance\"] {\n  if (v <= 25) return \"low\";\n  if (v >= 75) return \"high\";\n  return \"medium\";\n}\n\n// ─── Component ────────────────────────────────────────────────────────────────\n\nexport function GeneratorForm({\n  form,\n  setForm,\n  applyPreset,\n  onSubmit,\n  disabled,\n}: GeneratorFormProps): React.JSX.Element {\n  return (\n    <Box data-testid=\"generator-form\">\n      {/* ── Preset templates ────────────────────────────────────────── */}\n      <Box sx={{ mb: 2 }}>\n        <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n          Preset templates\n        </Typography>\n        <Stack direction=\"row\" spacing={1} sx={{ mt: 0.5 }}>\n          <Chip\n            label=\"Realistic\"\n            size=\"small\"\n            clickable\n            onClick={() => applyPreset(\"realistic\")}\n          />\n          <Chip\n            label=\"High volume\"\n            size=\"small\"\n            clickable\n            onClick={() => applyPreset(\"high-volume\")}\n          />\n          <Chip\n            label=\"Stress test\"\n            size=\"small\"\n            clickable\n            onClick={() => applyPreset(\"stress-test\")}\n          />\n        </Stack>\n      </Box>\n\n      {/* ── Volume ──────────────────────────────────────────────────── */}\n      <Stack direction=\"row\" spacing={2} sx={{ mb: 2 }}>\n        <TextField\n          label=\"Total events\"\n          type=\"number\"\n          size=\"small\"\n          value={form.total}\n          onChange={(e) => {\n            const v = Number.parseInt(e.target.value, 10);\n            if (!Number.isNaN(v)) setForm({ total: v });\n          }}\n          slotProps={{\n            htmlInput: { min: 1, max: 1_000_000 },\n            inputLabel: { shrink: true },\n          }}\n          sx={{ width: 160 }}\n        />\n        <TextField\n          label=\"Users\"\n          type=\"number\"\n          size=\"small\"\n          value={form.users}\n          onChange={(e) => {\n            const v = Number.parseInt(e.target.value, 10);\n            if (!Number.isNaN(v)) setForm({ users: v });\n          }}\n          slotProps={{\n            htmlInput: { min: 1 },\n            inputLabel: { shrink: true },\n          }}\n          sx={{ width: 120 }}\n        />\n      </Stack>\n\n      {/* ── Date range ──────────────────────────────────────────────── */}\n      <Stack direction=\"row\" spacing={2} sx={{ mb: 2 }}>\n        <TextField\n          label=\"Start\"\n          type=\"date\"\n          size=\"small\"\n          value={form.start}\n          onChange={(e) => setForm({ start: e.target.value })}\n          slotProps={{ inputLabel: { shrink: true } }}\n          sx={{ width: 160 }}\n        />\n        <TextField\n          label=\"End\"\n          type=\"date\"\n          size=\"small\"\n          value={form.end}\n          onChange={(e) => setForm({ end: e.target.value })}\n          slotProps={{ inputLabel: { shrink: true } }}\n          sx={{ width: 160 }}\n        />\n      </Stack>\n\n      {/* ── Event mix ───────────────────────────────────────────────── */}\n      <Box sx={{ mb: 2 }}>\n        <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n          Event mix\n        </Typography>\n        <FormGroup>\n          {form.event_types.map((et, idx) => (\n            <Box\n              key={et.name}\n              sx={{ display: \"flex\", alignItems: \"center\", gap: 2, mb: 0.5 }}\n            >\n              <FormControlLabel\n                control={\n                  <Checkbox\n                    checked={et.weight > 0}\n                    onChange={(e) => {\n                      const updated = form.event_types.map((t, i) =>\n                        i === idx\n                          ? { ...t, weight: e.target.checked ? 0.1 : 0 }\n                          : t,\n                      );\n                      setForm({ event_types: updated });\n                    }}\n                    size=\"small\"\n                  />\n                }\n                label={et.name}\n                sx={{ minWidth: 200, m: 0 }}\n              />\n              <Slider\n                size=\"small\"\n                value={et.weight}\n                min={0}\n                max={1}\n                step={0.01}\n                disabled={et.weight === 0}\n                onChange={(_, v) => {\n                  const updated = form.event_types.map((t, i) =>\n                    i === idx ? { ...t, weight: v as number } : t,\n                  );\n                  setForm({ event_types: updated });\n                }}\n                aria-label={`${et.name} weight`}\n                sx={{ width: 120 }}\n              />\n              <Typography variant=\"caption\" sx={{ minWidth: 36 }}>\n                {(et.weight * 100).toFixed(0)}%\n              </Typography>\n            </Box>\n          ))}\n        </FormGroup>\n      </Box>\n\n      {/* ── Identity resolution ─────────────────────────────────────── */}\n      <Box sx={{ mb: 2 }}>\n        <FormControlLabel\n          control={\n            <Switch\n              checked={form.identity_resolution}\n              onChange={(e) =>\n                setForm({ identity_resolution: e.target.checked })\n              }\n              slotProps={{ input: { \"aria-label\": \"Identity resolution\" } }}\n            />\n          }\n          label=\"Identity resolution\"\n        />\n        <Box sx={{ mt: 1, px: 1 }}>\n          <Typography variant=\"caption\" color=\"text.secondary\">\n            Anonymous ratio: {form.anonymous_ratio}%\n          </Typography>\n          <Slider\n            size=\"small\"\n            value={form.anonymous_ratio}\n            min={0}\n            max={100}\n            disabled={!form.identity_resolution}\n            onChange={(_, v) => setForm({ anonymous_ratio: v as number })}\n            aria-label=\"Anonymous ratio\"\n            sx={{ mt: 0.5 }}\n          />\n        </Box>\n      </Box>\n\n      {/* ── Numeric variance ────────────────────────────────────────── */}\n      <Box sx={{ mb: 3, px: 1 }}>\n        <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n          Numeric property variance\n        </Typography>\n        <Slider\n          size=\"small\"\n          value={varianceToSlider(form.numeric_variance)}\n          min={0}\n          max={100}\n          step={50}\n          marks={VARIANCE_MARKS}\n          onChange={(_, v) =>\n            setForm({ numeric_variance: sliderToVariance(v as number) })\n          }\n          aria-label=\"Numeric variance\"\n        />\n      </Box>\n\n      {/* ── Submit ──────────────────────────────────────────────────── */}\n      <Button variant=\"contained\" onClick={onSubmit} disabled={disabled}>\n        Generate\n      </Button>\n    </Box>\n  );\n}\n","numLines":253,"startLine":1,"totalLines":253}}}
