{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JdGy1Lc79AZFoqwBxAk1UV","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport { useCallback, useEffect, useRef, useState } from \"react\";\n4\timport type {\n5\t  EventTypeWeight,\n6\t  JobState,\n7\t  JobStatus,\n8\t  NumericVariance,\n9\t} from \"@/lib/generator\";\n10\t\n11\t// ─── Types ────────────────────────────────────────────────────────────────────\n12\t\n13\texport interface GeneratorFormState {\n14\t  total: number;\n15\t  users: number;\n16\t  start: string;\n17\t  end: string;\n18\t  event_types: EventTypeWeight[];\n19\t  identity_resolution: boolean;\n20\t  anonymous_ratio: number;\n21\t  numeric_variance: NumericVariance;\n22\t}\n23\t\n24\texport interface ProgressState {\n25\t  job_id: string;\n26\t  status: JobStatus;\n27\t  inserted: number;\n28\t  total: number;\n29\t  throughput: number;\n30\t  eta_seconds: number;\n31\t  elapsed_ms: number;\n32\t  error?: string;\n33\t}\n34\t\n35\texport type Preset = \"realistic\" | \"high-volume\" | \"stress-test\";\n36\t\n37\texport interface UseGeneratorResult {\n38\t  form: GeneratorFormState;\n39\t  setForm: (updates: Partial<GeneratorFormState>) => void;\n40\t  applyPreset: (preset: Preset) => void;\n41\t  startJob: () => Promise<void>;\n42\t  cancelJob: () => Promise<void>;\n43\t  fetchJobs: () => Promise<void>;\n44\t  jobActive: boolean;\n45\t  progress: ProgressState | null;\n46\t  jobs: JobState[];\n47\t  error: string | null;\n48\t}\n49\t\n50\t// ─── Constants ────────────────────────────────────────────────────────────────\n51\t\n52\tconst DEFAULT_EVENT_TYPES: EventTypeWeight[] = [\n53\t  { name: \"Page Viewed\", weight: 0.4 },\n54\t  { name: \"Button Clicked\", weight: 0.15 },\n55\t  { name: \"Signup Completed\", weight: 0.12 },\n56\t  { name: \"Purchase Completed\", weight: 0.13 },\n57\t  { name: \"Subscription Renewed\", weight: 0.12 },\n58\t  { name: \"Support Ticket Opened\", weight: 0.08 },\n59\t];\n60\t\n61\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n62\t\n63\tfunction todayISO(): string {\n64\t  return new Date().toISOString().slice(0, 10);\n65\t}\n66\t\n67\tfunction daysAgoISO(n: number): string {\n68\t  const d = new Date();\n69\t  d.setDate(d.getDate() - n);\n70\t  return d.toISOString().slice(0, 10);\n71\t}\n72\t\n73\tfunction defaultForm(): GeneratorFormState {\n74\t  return {\n75\t    total: 10000,\n76\t    users: 100,\n77\t    start: daysAgoISO(30),\n78\t    end: todayISO(),\n79\t    event_types: DEFAULT_EVENT_TYPES,\n80\t    identity_resolution: true,\n81\t    anonymous_ratio: 30,\n82\t    numeric_variance: \"medium\",\n83\t  };\n84\t}\n85\t\n86\tconst TERMINAL_STATUSES = new Set<JobStatus>([\n87\t  \"complete\",\n88\t  \"failed\",\n89\t  \"cancelled\",\n90\t]);\n91\t\n92\t// ─── Hook ─────────────────────────────────────────────────────────────────────\n93\t\n94\texport function useGenerator(): UseGeneratorResult {\n95\t  const [form, setFormState] = useState<GeneratorFormState>(defaultForm);\n96\t  const [jobActive, setJobActive] = useState(false);\n97\t  const [progress, setProgress] = useState<ProgressState | null>(null);\n98\t  const [jobs, setJobs] = useState<JobState[]>([]);\n99\t  const [error, setError] = useState<string | null>(null);\n100\t\n101\t  // Tracks the current job_id for cancelJob()\n102\t  const currentJobIdRef = useRef<string | null>(null);\n103\t  // Holds the active EventSource so we can close it\n104\t  const esRef = useRef<EventSource | null>(null);\n105\t\n106\t  // Close any active EventSource on unmount\n107\t  useEffect(() => {\n108\t    return () => {\n109\t      if (esRef.current) {\n110\t        esRef.current.close();\n111\t        esRef.current = null;\n112\t      }\n113\t    };\n114\t  }, []);\n115\t\n116\t  const setForm = useCallback((updates: Partial<GeneratorFormState>) => {\n117\t    setFormState((prev) => {\n118\t      const next = { ...prev, ...updates };\n119\t      // Special rule: toggling identity_resolution off resets anonymous_ratio\n120\t      if (updates.identity_resolution === false) {\n121\t        next.anonymous_ratio = 0;\n122\t      }\n123\t      return next;\n124\t    });\n125\t  }, []);\n126\t\n127\t  const applyPreset = useCallback((preset: Preset) => {\n128\t    switch (preset) {\n129\t      case \"realistic\":\n130\t        setFormState((prev) => ({\n131\t          ...prev,\n132\t          total: 10000,\n133\t          users: 100,\n134\t          start: daysAgoISO(30),\n135\t          end: todayISO(),\n136\t        }));\n137\t        break;\n138\t      case \"high-volume\":\n139\t        setFormState((prev) => ({\n140\t          ...prev,\n141\t          total: 100000,\n142\t          users: 200,\n143\t          start: daysAgoISO(90),\n144\t          end: todayISO(),\n145\t        }));\n146\t        break;\n147\t      case \"stress-test\":\n148\t        setFormState((prev) => ({\n149\t          ...prev,\n150\t          total: 1000000,\n151\t          users: 500,\n152\t          start: daysAgoISO(365),\n153\t          end: todayISO(),\n154\t        }));\n155\t        break;\n156\t    }\n157\t  }, []);\n158\t\n159\t  const fetchJobs = useCallback(async () => {\n160\t    try {\n161\t      const res = await fetch(\"/api/generate/jobs\");\n162\t      if (res.ok) {\n163\t        const data = (await res.json()) as JobState[];\n164\t        setJobs(data);\n165\t      }\n166\t    } catch {\n167\t      // non-fatal: jobs list stays stale\n168\t    }\n169\t  }, []);\n170\t\n171\t  // Load jobs on mount\n172\t  useEffect(() => {\n173\t    void fetchJobs();\n174\t  }, [fetchJobs]);\n175\t\n176\t  const startJob = useCallback(async (): Promise<void> => {\n177\t    setError(null);\n178\t\n179\t    const body: GeneratorFormState = form;\n180\t\n181\t    let res: Response;\n182\t    try {\n183\t      res = await fetch(\"/api/generate/start\", {\n184\t        method: \"POST\",\n185\t        headers: { \"Content-Type\": \"application/json\" },\n186\t        body: JSON.stringify(body),\n187\t      });\n188\t    } catch (err) {\n189\t      setError(err instanceof Error ? err.message : \"Network error\");\n190\t      return;\n191\t    }\n192\t\n193\t    if (!res.ok) {\n194\t      const data = (await res.json()) as { error?: string };\n195\t      setError(data.error ?? `HTTP ${res.status}`);\n196\t      return;\n197\t    }\n198\t\n199\t    const { job_id } = (await res.json()) as { job_id: string };\n200\t    currentJobIdRef.current = job_id;\n201\t    setJobActive(true);\n202\t    setProgress({\n203\t      job_id,\n204\t      status: \"queued\",\n205\t      inserted: 0,\n206\t      total: form.total,\n207\t      throughput: 0,\n208\t      eta_seconds: 0,\n209\t      elapsed_ms: 0,\n210\t    });\n211\t\n212\t    // Open SSE stream\n213\t    const es = new EventSource(`/api/generate/${job_id}/status`);\n214\t    esRef.current = es;\n215\t\n216\t    es.onmessage = (e: MessageEvent) => {\n217\t      try {\n218\t        const data = JSON.parse(e.data as string) as Partial<ProgressState> & {\n219\t          status: JobStatus;\n220\t        };\n221\t        setProgress((prev) => ({\n222\t          job_id,\n223\t          status: data.status,\n224\t          inserted: data.inserted ?? prev?.inserted ?? 0,\n225\t          total: data.total ?? prev?.total ?? form.total,\n226\t          throughput: data.throughput ?? prev?.throughput ?? 0,\n227\t          eta_seconds: data.eta_seconds ?? prev?.eta_seconds ?? 0,\n228\t          elapsed_ms: data.elapsed_ms ?? prev?.elapsed_ms ?? 0,\n229\t          error: data.error,\n230\t        }));\n231\t\n232\t        if (TERMINAL_STATUSES.has(data.status)) {\n233\t          setJobActive(false);\n234\t          es.close();\n235\t          esRef.current = null;\n236\t          // Refresh job list after completion\n237\t          void fetchJobs();\n238\t        }\n239\t      } catch {\n240\t        // ignore malformed SSE payload\n241\t      }\n242\t    };\n243\t\n244\t    es.onerror = () => {\n245\t      setJobActive(false);\n246\t      setError(\"SSE connection error\");\n247\t      es.close();\n248\t      esRef.current = null;\n249\t    };\n250\t  }, [form, fetchJobs]);\n251\t\n252\t  const cancelJob = useCallback(async (): Promise<void> => {\n253\t    const jobId = currentJobIdRef.current;\n254\t    if (!jobId) return;\n255\t\n256\t    try {\n257\t      await fetch(`/api/generate/${jobId}/cancel`, { method: \"POST\" });\n258\t    } catch {\n259\t      // ignore\n260\t    }\n261\t  }, []);\n262\t\n263\t  return {\n264\t    form,\n265\t    setForm,\n266\t    applyPreset,\n267\t    startJob,\n268\t    cancelJob,\n269\t    fetchJobs,\n270\t    jobActive,\n271\t    progress,\n272\t    jobs,\n273\t    error,\n274\t  };\n275\t}\n276\t"}]},"parent_tool_use_id":null,"session_id":"3d324c3e-ac44-4876-8051-93925eeee4fd","uuid":"6f7a0662-ae53-4689-bd7b-9955d510f783","timestamp":"2026-04-15T18:51:43.617Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/generate/useGenerator.ts","content":"\"use client\";\n\nimport { useCallback, useEffect, useRef, useState } from \"react\";\nimport type {\n  EventTypeWeight,\n  JobState,\n  JobStatus,\n  NumericVariance,\n} from \"@/lib/generator\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface GeneratorFormState {\n  total: number;\n  users: number;\n  start: string;\n  end: string;\n  event_types: EventTypeWeight[];\n  identity_resolution: boolean;\n  anonymous_ratio: number;\n  numeric_variance: NumericVariance;\n}\n\nexport interface ProgressState {\n  job_id: string;\n  status: JobStatus;\n  inserted: number;\n  total: number;\n  throughput: number;\n  eta_seconds: number;\n  elapsed_ms: number;\n  error?: string;\n}\n\nexport type Preset = \"realistic\" | \"high-volume\" | \"stress-test\";\n\nexport interface UseGeneratorResult {\n  form: GeneratorFormState;\n  setForm: (updates: Partial<GeneratorFormState>) => void;\n  applyPreset: (preset: Preset) => void;\n  startJob: () => Promise<void>;\n  cancelJob: () => Promise<void>;\n  fetchJobs: () => Promise<void>;\n  jobActive: boolean;\n  progress: ProgressState | null;\n  jobs: JobState[];\n  error: string | null;\n}\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst DEFAULT_EVENT_TYPES: EventTypeWeight[] = [\n  { name: \"Page Viewed\", weight: 0.4 },\n  { name: \"Button Clicked\", weight: 0.15 },\n  { name: \"Signup Completed\", weight: 0.12 },\n  { name: \"Purchase Completed\", weight: 0.13 },\n  { name: \"Subscription Renewed\", weight: 0.12 },\n  { name: \"Support Ticket Opened\", weight: 0.08 },\n];\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction todayISO(): string {\n  return new Date().toISOString().slice(0, 10);\n}\n\nfunction daysAgoISO(n: number): string {\n  const d = new Date();\n  d.setDate(d.getDate() - n);\n  return d.toISOString().slice(0, 10);\n}\n\nfunction defaultForm(): GeneratorFormState {\n  return {\n    total: 10000,\n    users: 100,\n    start: daysAgoISO(30),\n    end: todayISO(),\n    event_types: DEFAULT_EVENT_TYPES,\n    identity_resolution: true,\n    anonymous_ratio: 30,\n    numeric_variance: \"medium\",\n  };\n}\n\nconst TERMINAL_STATUSES = new Set<JobStatus>([\n  \"complete\",\n  \"failed\",\n  \"cancelled\",\n]);\n\n// ─── Hook ─────────────────────────────────────────────────────────────────────\n\nexport function useGenerator(): UseGeneratorResult {\n  const [form, setFormState] = useState<GeneratorFormState>(defaultForm);\n  const [jobActive, setJobActive] = useState(false);\n  const [progress, setProgress] = useState<ProgressState | null>(null);\n  const [jobs, setJobs] = useState<JobState[]>([]);\n  const [error, setError] = useState<string | null>(null);\n\n  // Tracks the current job_id for cancelJob()\n  const currentJobIdRef = useRef<string | null>(null);\n  // Holds the active EventSource so we can close it\n  const esRef = useRef<EventSource | null>(null);\n\n  // Close any active EventSource on unmount\n  useEffect(() => {\n    return () => {\n      if (esRef.current) {\n        esRef.current.close();\n        esRef.current = null;\n      }\n    };\n  }, []);\n\n  const setForm = useCallback((updates: Partial<GeneratorFormState>) => {\n    setFormState((prev) => {\n      const next = { ...prev, ...updates };\n      // Special rule: toggling identity_resolution off resets anonymous_ratio\n      if (updates.identity_resolution === false) {\n        next.anonymous_ratio = 0;\n      }\n      return next;\n    });\n  }, []);\n\n  const applyPreset = useCallback((preset: Preset) => {\n    switch (preset) {\n      case \"realistic\":\n        setFormState((prev) => ({\n          ...prev,\n          total: 10000,\n          users: 100,\n          start: daysAgoISO(30),\n          end: todayISO(),\n        }));\n        break;\n      case \"high-volume\":\n        setFormState((prev) => ({\n          ...prev,\n          total: 100000,\n          users: 200,\n          start: daysAgoISO(90),\n          end: todayISO(),\n        }));\n        break;\n      case \"stress-test\":\n        setFormState((prev) => ({\n          ...prev,\n          total: 1000000,\n          users: 500,\n          start: daysAgoISO(365),\n          end: todayISO(),\n        }));\n        break;\n    }\n  }, []);\n\n  const fetchJobs = useCallback(async () => {\n    try {\n      const res = await fetch(\"/api/generate/jobs\");\n      if (res.ok) {\n        const data = (await res.json()) as JobState[];\n        setJobs(data);\n      }\n    } catch {\n      // non-fatal: jobs list stays stale\n    }\n  }, []);\n\n  // Load jobs on mount\n  useEffect(() => {\n    void fetchJobs();\n  }, [fetchJobs]);\n\n  const startJob = useCallback(async (): Promise<void> => {\n    setError(null);\n\n    const body: GeneratorFormState = form;\n\n    let res: Response;\n    try {\n      res = await fetch(\"/api/generate/start\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(body),\n      });\n    } catch (err) {\n      setError(err instanceof Error ? err.message : \"Network error\");\n      return;\n    }\n\n    if (!res.ok) {\n      const data = (await res.json()) as { error?: string };\n      setError(data.error ?? `HTTP ${res.status}`);\n      return;\n    }\n\n    const { job_id } = (await res.json()) as { job_id: string };\n    currentJobIdRef.current = job_id;\n    setJobActive(true);\n    setProgress({\n      job_id,\n      status: \"queued\",\n      inserted: 0,\n      total: form.total,\n      throughput: 0,\n      eta_seconds: 0,\n      elapsed_ms: 0,\n    });\n\n    // Open SSE stream\n    const es = new EventSource(`/api/generate/${job_id}/status`);\n    esRef.current = es;\n\n    es.onmessage = (e: MessageEvent) => {\n      try {\n        const data = JSON.parse(e.data as string) as Partial<ProgressState> & {\n          status: JobStatus;\n        };\n        setProgress((prev) => ({\n          job_id,\n          status: data.status,\n          inserted: data.inserted ?? prev?.inserted ?? 0,\n          total: data.total ?? prev?.total ?? form.total,\n          throughput: data.throughput ?? prev?.throughput ?? 0,\n          eta_seconds: data.eta_seconds ?? prev?.eta_seconds ?? 0,\n          elapsed_ms: data.elapsed_ms ?? prev?.elapsed_ms ?? 0,\n          error: data.error,\n        }));\n\n        if (TERMINAL_STATUSES.has(data.status)) {\n          setJobActive(false);\n          es.close();\n          esRef.current = null;\n          // Refresh job list after completion\n          void fetchJobs();\n        }\n      } catch {\n        // ignore malformed SSE payload\n      }\n    };\n\n    es.onerror = () => {\n      setJobActive(false);\n      setError(\"SSE connection error\");\n      es.close();\n      esRef.current = null;\n    };\n  }, [form, fetchJobs]);\n\n  const cancelJob = useCallback(async (): Promise<void> => {\n    const jobId = currentJobIdRef.current;\n    if (!jobId) return;\n\n    try {\n      await fetch(`/api/generate/${jobId}/cancel`, { method: \"POST\" });\n    } catch {\n      // ignore\n    }\n  }, []);\n\n  return {\n    form,\n    setForm,\n    applyPreset,\n    startJob,\n    cancelJob,\n    fetchJobs,\n    jobActive,\n    progress,\n    jobs,\n    error,\n  };\n}\n","numLines":276,"startLine":1,"totalLines":276}}}
