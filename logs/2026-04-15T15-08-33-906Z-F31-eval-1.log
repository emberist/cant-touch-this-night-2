{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BP85yKoLFw3UPnBGZx23VS","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { act, renderHook, waitFor } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport { useGenerator } from \"@/components/generate/useGenerator\";\n5\t\n6\t// ─── Mock EventSource ─────────────────────────────────────────────────────────\n7\t\n8\tinterface MockESInstance {\n9\t  url: string;\n10\t  onmessage: ((e: { data: string }) => void) | null;\n11\t  onerror: ((e: Event) => void) | null;\n12\t  onopen: ((e: Event) => void) | null;\n13\t  close: ReturnType<typeof vi.fn>;\n14\t  simulateMessage: (data: string) => void;\n15\t}\n16\t\n17\tconst mockEventSourceInstances: MockESInstance[] = [];\n18\t\n19\tclass MockEventSource {\n20\t  url: string;\n21\t  onmessage: ((e: { data: string }) => void) | null = null;\n22\t  onerror: ((e: Event) => void) | null = null;\n23\t  onopen: ((e: Event) => void) | null = null;\n24\t  close = vi.fn();\n25\t\n26\t  constructor(url: string) {\n27\t    this.url = url;\n28\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n29\t    mockEventSourceInstances.push(this as any);\n30\t  }\n31\t\n32\t  simulateMessage(data: string) {\n33\t    this.onmessage?.({ data });\n34\t  }\n35\t}\n36\t\n37\t// ─── Mock fetch ───────────────────────────────────────────────────────────────\n38\t\n39\tconst mockFetch = vi.fn();\n40\t\n41\tfunction makeOkResponse(body: unknown) {\n42\t  return Promise.resolve({\n43\t    ok: true,\n44\t    json: () => Promise.resolve(body),\n45\t  });\n46\t}\n47\t\n48\tfunction makeErrorResponse(\n49\t  status = 500,\n50\t  body: unknown = { error: \"server error\" },\n51\t) {\n52\t  return Promise.resolve({\n53\t    ok: false,\n54\t    status,\n55\t    json: () => Promise.resolve(body),\n56\t  });\n57\t}\n58\t\n59\t// ─── Setup / Teardown ─────────────────────────────────────────────────────────\n60\t\n61\tbeforeEach(() => {\n62\t  vi.stubGlobal(\"fetch\", mockFetch);\n63\t  vi.stubGlobal(\"EventSource\", MockEventSource);\n64\t  mockEventSourceInstances.length = 0;\n65\t  // Default: fetchJobs returns empty array on mount\n66\t  mockFetch.mockImplementation((url: string) => {\n67\t    if ((url as string).includes(\"/api/generate/jobs\"))\n68\t      return makeOkResponse([]);\n69\t    return Promise.reject(new Error(`Unexpected fetch: ${url}`));\n70\t  });\n71\t});\n72\t\n73\tafterEach(() => {\n74\t  vi.clearAllMocks();\n75\t  vi.unstubAllGlobals();\n76\t  mockEventSourceInstances.length = 0;\n77\t});\n78\t\n79\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n80\t\n81\tfunction todayISO(): string {\n82\t  return new Date().toISOString().slice(0, 10);\n83\t}\n84\tfunction daysAgoISO(n: number): string {\n85\t  const d = new Date();\n86\t  d.setDate(d.getDate() - n);\n87\t  return d.toISOString().slice(0, 10);\n88\t}\n89\t\n90\t// ─── Tests ────────────────────────────────────────────────────────────────────\n91\t\n92\tdescribe(\"useGenerator\", () => {\n93\t  // ── Initial form state ────────────────────────────────────────────────────\n94\t\n95\t  describe(\"initial form state\", () => {\n96\t    it(\"total defaults to 10000\", () => {\n97\t      const { result } = renderHook(() => useGenerator());\n98\t      expect(result.current.form.total).toBe(10000);\n99\t    });\n100\t\n101\t    it(\"users defaults to 100\", () => {\n102\t      const { result } = renderHook(() => useGenerator());\n103\t      expect(result.current.form.users).toBe(100);\n104\t    });\n105\t\n106\t    it(\"identity_resolution defaults to true\", () => {\n107\t      const { result } = renderHook(() => useGenerator());\n108\t      expect(result.current.form.identity_resolution).toBe(true);\n109\t    });\n110\t\n111\t    it(\"anonymous_ratio defaults to 30\", () => {\n112\t      const { result } = renderHook(() => useGenerator());\n113\t      expect(result.current.form.anonymous_ratio).toBe(30);\n114\t    });\n115\t\n116\t    it(\"numeric_variance defaults to 'medium'\", () => {\n117\t      const { result } = renderHook(() => useGenerator());\n118\t      expect(result.current.form.numeric_variance).toBe(\"medium\");\n119\t    });\n120\t\n121\t    it(\"start defaults to approximately 30 days ago (YYYY-MM-DD)\", () => {\n122\t      const { result } = renderHook(() => useGenerator());\n123\t      expect(result.current.form.start).toBe(daysAgoISO(30));\n124\t    });\n125\t\n126\t    it(\"end defaults to today (YYYY-MM-DD)\", () => {\n127\t      const { result } = renderHook(() => useGenerator());\n128\t      expect(result.current.form.end).toBe(todayISO());\n129\t    });\n130\t\n131\t    it(\"event_types defaults to 6 entries\", () => {\n132\t      const { result } = renderHook(() => useGenerator());\n133\t      expect(result.current.form.event_types).toHaveLength(6);\n134\t    });\n135\t\n136\t    it(\"event_types includes 'Page Viewed' with weight 0.4\", () => {\n137\t      const { result } = renderHook(() => useGenerator());\n138\t      const pv = result.current.form.event_types.find(\n139\t        (et) => et.name === \"Page Viewed\",\n140\t      );\n141\t      expect(pv).toBeDefined();\n142\t      expect(pv?.weight).toBe(0.4);\n143\t    });\n144\t\n145\t    it(\"event_types includes 'Purchase Completed' with weight 0.13\", () => {\n146\t      const { result } = renderHook(() => useGenerator());\n147\t      const pc = result.current.form.event_types.find(\n148\t        (et) => et.name === \"Purchase Completed\",\n149\t      );\n150\t      expect(pc).toBeDefined();\n151\t      expect(pc?.weight).toBe(0.13);\n152\t    });\n153\t\n154\t    it(\"jobActive is false initially\", () => {\n155\t      const { result } = renderHook(() => useGenerator());\n156\t      expect(result.current.jobActive).toBe(false);\n157\t    });\n158\t\n159\t    it(\"progress is null initially\", () => {\n160\t      const { result } = renderHook(() => useGenerator());\n161\t      expect(result.current.progress).toBeNull();\n162\t    });\n163\t\n164\t    it(\"error is null initially\", () => {\n165\t      const { result } = renderHook(() => useGenerator());\n166\t      expect(result.current.error).toBeNull();\n167\t    });\n168\t  });\n169\t\n170\t  // ── applyPreset ───────────────────────────────────────────────────────────\n171\t\n172\t  describe(\"applyPreset\", () => {\n173\t    it(\"'realistic' sets total=10000, users=100\", () => {\n174\t      const { result } = renderHook(() => useGenerator());\n175\t      act(() => result.current.applyPreset(\"realistic\"));\n176\t      expect(result.current.form.total).toBe(10000);\n177\t      expect(result.current.form.users).toBe(100);\n178\t    });\n179\t\n180\t    it(\"'realistic' sets date range to last 30 days\", () => {\n181\t      const { result } = renderHook(() => useGenerator());\n182\t      act(() => result.current.applyPreset(\"realistic\"));\n183\t      expect(result.current.form.start).toBe(daysAgoISO(30));\n184\t      expect(result.current.form.end).toBe(todayISO());\n185\t    });\n186\t\n187\t    it(\"'high-volume' sets total=100000\", () => {\n188\t      const { result } = renderHook(() => useGenerator());\n189\t      act(() => result.current.applyPreset(\"high-volume\"));\n190\t      expect(result.current.form.total).toBe(100000);\n191\t    });\n192\t\n193\t    it(\"'high-volume' sets date range to last 90 days\", () => {\n194\t      const { result } = renderHook(() => useGenerator());\n195\t      act(() => result.current.applyPreset(\"high-volume\"));\n196\t      expect(result.current.form.start).toBe(daysAgoISO(90));\n197\t      expect(result.current.form.end).toBe(todayISO());\n198\t    });\n199\t\n200\t    it(\"'stress-test' sets total=1000000\", () => {\n201\t      const { result } = renderHook(() => useGenerator());\n202\t      act(() => result.current.applyPreset(\"stress-test\"));\n203\t      expect(result.current.form.total).toBe(1000000);\n204\t    });\n205\t\n206\t    it(\"'stress-test' sets date range to last 365 days\", () => {\n207\t      const { result } = renderHook(() => useGenerator());\n208\t      act(() => result.current.applyPreset(\"stress-test\"));\n209\t      expect(result.current.form.start).toBe(daysAgoISO(365));\n210\t      expect(result.current.form.end).toBe(todayISO());\n211\t    });\n212\t  });\n213\t\n214\t  // ── startJob ──────────────────────────────────────────────────────────────\n215\t\n216\t  describe(\"startJob\", () => {\n217\t    it(\"calls POST /api/generate/start with correct body\", async () => {\n218\t      mockFetch.mockImplementation((url: string) => {\n219\t        if ((url as string).includes(\"/api/generate/jobs\"))\n220\t          return makeOkResponse([]);\n221\t        if ((url as string).includes(\"/api/generate/start\"))\n222\t          return makeOkResponse({ job_id: \"test-job-123\" });\n223\t        return Promise.reject(new Error(`Unexpected: ${url}`));\n224\t      });\n225\t\n226\t      const { result } = renderHook(() => useGenerator());\n227\t\n228\t      await act(async () => {\n229\t        await result.current.startJob();\n230\t      });\n231\t\n232\t      const startCall = (mockFetch.mock.calls as [string, RequestInit][]).find(\n233\t        ([url]) => url.includes(\"/api/generate/start\"),\n234\t      );\n235\t      expect(startCall).toBeDefined();\n236\t      expect(startCall![1].method).toBe(\"POST\");\n237\t      const body = JSON.parse(startCall![1].body as string) as Record<\n238\t        string,\n239\t        unknown\n240\t      >;\n241\t      expect(body.total).toBe(10000);\n242\t      expect(body.users).toBe(100);\n243\t    });\n244\t\n245\t    it(\"sets jobActive to true after successful start\", async () => {\n246\t      mockFetch.mockImplementation((url: string) => {\n247\t        if ((url as string).includes(\"/api/generate/jobs\"))\n248\t          return makeOkResponse([]);\n249\t        if ((url as string).includes(\"/api/generate/start\"))\n250\t          return makeOkResponse({ job_id: \"test-job-123\" });\n251\t        return Promise.reject(new Error(`Unexpected: ${url}`));\n252\t      });\n253\t\n254\t      const { result } = renderHook(() => useGenerator());\n255\t\n256\t      await act(async () => {\n257\t        await result.current.startJob();\n258\t      });\n259\t\n260\t      expect(result.current.jobActive).toBe(true);\n261\t    });\n262\t\n263\t    it(\"opens SSE connection to /api/generate/[job_id]/status\", async () => {\n264\t      mockFetch.mockImplementation((url: string) => {\n265\t        if ((url as string).includes(\"/api/generate/jobs\"))\n266\t          return makeOkResponse([]);\n267\t        if ((url as string).includes(\"/api/generate/start\"))\n268\t          return makeOkResponse({ job_id: \"test-job-123\" });\n269\t        return Promise.reject(new Error(`Unexpected: ${url}`));\n270\t      });\n271\t\n272\t      const { result } = renderHook(() => useGenerator());\n273\t\n274\t      await act(async () => {\n275\t        await result.current.startJob();\n276\t      });\n277\t\n278\t      expect(mockEventSourceInstances).toHaveLength(1);\n279\t      expect(mockEventSourceInstances[0].url).toBe(\n280\t        \"/api/generate/test-job-123/status\",\n281\t      );\n282\t    });\n283\t\n284\t    it(\"sets error state when POST fails\", async () => {\n285\t      mockFetch.mockImplementation((url: string) => {\n286\t        if ((url as string).includes(\"/api/generate/jobs\"))\n287\t          return makeOkResponse([]);\n288\t        if ((url as string).includes(\"/api/generate/start\"))\n289\t          return makeErrorResponse(500, { error: \"Internal Server Error\" });\n290\t        return Promise.reject(new Error(`Unexpected: ${url}`));\n291\t      });\n292\t\n293\t      const { result } = renderHook(() => useGenerator());\n294\t\n295\t      await act(async () => {\n296\t        await result.current.startJob();\n297\t      });\n298\t\n299\t      expect(result.current.error).not.toBeNull();\n300\t      expect(result.current.jobActive).toBe(false);\n301\t    });\n302\t  });\n303\t\n304\t  // ── SSE progress ──────────────────────────────────────────────────────────\n305\t\n306\t  describe(\"SSE progress messages\", () => {\n307\t    async function startJobAndGetES(\n308\t      result: ReturnType<\n309\t        typeof renderHook<ReturnType<typeof useGenerator>, unknown>\n310\t      >[\"result\"],\n311\t    ) {\n312\t      mockFetch.mockImplementation((url: string) => {\n313\t        if ((url as string).includes(\"/api/generate/jobs\"))\n314\t          return makeOkResponse([]);\n315\t        if ((url as string).includes(\"/api/generate/start\"))\n316\t          return makeOkResponse({ job_id: \"job-abc\" });\n317\t        return Promise.reject(new Error(`Unexpected: ${url}`));\n318\t      });\n319\t\n320\t      await act(async () => {\n321\t        await result.current.startJob();\n322\t      });\n323\t\n324\t      return mockEventSourceInstances[0];\n325\t    }\n326\t\n327\t    it(\"updates progress state on running message\", async () => {\n328\t      const { result } = renderHook(() => useGenerator());\n329\t      const es = await startJobAndGetES(result);\n330\t\n331\t      act(() => {\n332\t        es.simulateMessage(\n333\t          JSON.stringify({\n334\t            status: \"running\",\n335\t            inserted: 50000,\n336\t            total: 1000000,\n337\t            throughput: 125000,\n338\t            eta_seconds: 7,\n339\t          }),\n340\t        );\n341\t      });\n342\t\n343\t      await waitFor(() => expect(result.current.progress).not.toBeNull());\n344\t      expect(result.current.progress?.inserted).toBe(50000);\n345\t      expect(result.current.progress?.total).toBe(1000000);\n346\t      expect(result.current.progress?.throughput).toBe(125000);\n347\t      expect(result.current.progress?.eta_seconds).toBe(7);\n348\t      expect(result.current.progress?.status).toBe(\"running\");\n349\t    });\n350\t\n351\t    it(\"sets jobActive to false on terminal status 'complete'\", async () => {\n352\t      const { result } = renderHook(() => useGenerator());\n353\t      const es = await startJobAndGetES(result);\n354\t\n355\t      act(() => {\n356\t        es.simulateMessage(\n357\t          JSON.stringify({\n358\t            status: \"complete\",\n359\t            inserted: 1000000,\n360\t            total: 1000000,\n361\t            elapsed_ms: 8200,\n362\t          }),\n363\t        );\n364\t      });\n365\t\n366\t      await waitFor(() => expect(result.current.jobActive).toBe(false));\n367\t    });\n368\t\n369\t    it(\"sets jobActive to false on terminal status 'failed'\", async () => {\n370\t      const { result } = renderHook(() => useGenerator());\n371\t      const es = await startJobAndGetES(result);\n372\t\n373\t      act(() => {\n374\t        es.simulateMessage(\n375\t          JSON.stringify({\n376\t            status: \"failed\",\n377\t            inserted: 10000,\n378\t            total: 1000000,\n379\t            elapsed_ms: 1000,\n380\t          }),\n381\t        );\n382\t      });\n383\t\n384\t      await waitFor(() => expect(result.current.jobActive).toBe(false));\n385\t    });\n386\t\n387\t    it(\"sets jobActive to false on terminal status 'cancelled'\", async () => {\n388\t      const { result } = renderHook(() => useGenerator());\n389\t      const es = await startJobAndGetES(result);\n390\t\n391\t      act(() => {\n392\t        es.simulateMessage(\n393\t          JSON.stringify({\n394\t            status: \"cancelled\",\n395\t            inserted: 20000,\n396\t            total: 1000000,\n397\t            elapsed_ms: 2000,\n398\t          }),\n399\t        );\n400\t      });\n401\t\n402\t      await waitFor(() => expect(result.current.jobActive).toBe(false));\n403\t    });\n404\t\n405\t    it(\"closes the EventSource after terminal status\", async () => {\n406\t      const { result } = renderHook(() => useGenerator());\n407\t      const es = await startJobAndGetES(result);\n408\t\n409\t      act(() => {\n410\t        es.simulateMessage(\n411\t          JSON.stringify({\n412\t            status: \"complete\",\n413\t            inserted: 1000000,\n414\t            total: 1000000,\n415\t            elapsed_ms: 8200,\n416\t          }),\n417\t        );\n418\t      });\n419\t\n420\t      await waitFor(() => expect(result.current.jobActive).toBe(false));\n421\t      expect(es.close).toHaveBeenCalled();\n422\t    });\n423\t  });\n424\t\n425\t  // ── cancelJob ─────────────────────────────────────────────────────────────\n426\t\n427\t  describe(\"cancelJob\", () => {\n428\t    it(\"calls POST /api/generate/[job_id]/cancel\", async () => {\n429\t      mockFetch.mockImplementation((url: string) => {\n430\t        if ((url as string).includes(\"/api/generate/jobs\"))\n431\t          return makeOkResponse([]);\n432\t        if ((url as string).includes(\"/api/generate/start\"))\n433\t          return makeOkResponse({ job_id: \"job-xyz\" });\n434\t        if ((url as string).includes(\"/cancel\"))\n435\t          return makeOkResponse({ cancelled: true });\n436\t        return Promise.reject(new Error(`Unexpected: ${url}`));\n437\t      });\n438\t\n439\t      const { result } = renderHook(() => useGenerator());\n440\t\n441\t      await act(async () => {\n442\t        await result.current.startJob();\n443\t      });\n444\t      await act(async () => {\n445\t        await result.current.cancelJob();\n446\t      });\n447\t\n448\t      const cancelCall = (mockFetch.mock.calls as [string, RequestInit][]).find(\n449\t        ([url]) => url.includes(\"/cancel\"),\n450\t      );\n451\t      expect(cancelCall).toBeDefined();\n452\t      expect(cancelCall![0]).toBe(\"/api/generate/job-xyz/cancel\");\n453\t      expect(cancelCall![1].method).toBe(\"POST\");\n454\t    });\n455\t  });\n456\t\n457\t  // ── identity_resolution toggle ────────────────────────────────────────────\n458\t\n459\t  describe(\"setForm identity_resolution\", () => {\n460\t    it(\"toggling identity_resolution off resets anonymous_ratio to 0\", () => {\n461\t      const { result } = renderHook(() => useGenerator());\n462\t      expect(result.current.form.anonymous_ratio).toBe(30);\n463\t\n464\t      act(() => {\n465\t        result.current.setForm({ identity_resolution: false });\n466\t      });\n467\t\n468\t      expect(result.current.form.identity_resolution).toBe(false);\n469\t      expect(result.current.form.anonymous_ratio).toBe(0);\n470\t    });\n471\t\n472\t    it(\"toggling identity_resolution on keeps anonymous_ratio at 0\", () => {\n473\t      const { result } = renderHook(() => useGenerator());\n474\t\n475\t      act(() => {\n476\t        result.current.setForm({ identity_resolution: false });\n477\t      });\n478\t      act(() => {\n479\t        result.current.setForm({ identity_resolution: true });\n480\t      });\n481\t\n482\t      // Turning back on should not auto-restore ratio — user must set it\n483\t      expect(result.current.form.identity_resolution).toBe(true);\n484\t      expect(result.current.form.anonymous_ratio).toBe(0);\n485\t    });\n486\t  });\n487\t});\n488\t"}]},"parent_tool_use_id":null,"session_id":"3d324c3e-ac44-4876-8051-93925eeee4fd","uuid":"2df846cb-ee99-46a1-8d4e-4388bbc270e9","timestamp":"2026-04-15T18:51:39.438Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/generate/__tests__/useGenerator.test.ts","content":"// @vitest-environment jsdom\nimport { act, renderHook, waitFor } from \"@testing-library/react\";\nimport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\nimport { useGenerator } from \"@/components/generate/useGenerator\";\n\n// ─── Mock EventSource ─────────────────────────────────────────────────────────\n\ninterface MockESInstance {\n  url: string;\n  onmessage: ((e: { data: string }) => void) | null;\n  onerror: ((e: Event) => void) | null;\n  onopen: ((e: Event) => void) | null;\n  close: ReturnType<typeof vi.fn>;\n  simulateMessage: (data: string) => void;\n}\n\nconst mockEventSourceInstances: MockESInstance[] = [];\n\nclass MockEventSource {\n  url: string;\n  onmessage: ((e: { data: string }) => void) | null = null;\n  onerror: ((e: Event) => void) | null = null;\n  onopen: ((e: Event) => void) | null = null;\n  close = vi.fn();\n\n  constructor(url: string) {\n    this.url = url;\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    mockEventSourceInstances.push(this as any);\n  }\n\n  simulateMessage(data: string) {\n    this.onmessage?.({ data });\n  }\n}\n\n// ─── Mock fetch ───────────────────────────────────────────────────────────────\n\nconst mockFetch = vi.fn();\n\nfunction makeOkResponse(body: unknown) {\n  return Promise.resolve({\n    ok: true,\n    json: () => Promise.resolve(body),\n  });\n}\n\nfunction makeErrorResponse(\n  status = 500,\n  body: unknown = { error: \"server error\" },\n) {\n  return Promise.resolve({\n    ok: false,\n    status,\n    json: () => Promise.resolve(body),\n  });\n}\n\n// ─── Setup / Teardown ─────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  vi.stubGlobal(\"fetch\", mockFetch);\n  vi.stubGlobal(\"EventSource\", MockEventSource);\n  mockEventSourceInstances.length = 0;\n  // Default: fetchJobs returns empty array on mount\n  mockFetch.mockImplementation((url: string) => {\n    if ((url as string).includes(\"/api/generate/jobs\"))\n      return makeOkResponse([]);\n    return Promise.reject(new Error(`Unexpected fetch: ${url}`));\n  });\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n  vi.unstubAllGlobals();\n  mockEventSourceInstances.length = 0;\n});\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction todayISO(): string {\n  return new Date().toISOString().slice(0, 10);\n}\nfunction daysAgoISO(n: number): string {\n  const d = new Date();\n  d.setDate(d.getDate() - n);\n  return d.toISOString().slice(0, 10);\n}\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\ndescribe(\"useGenerator\", () => {\n  // ── Initial form state ────────────────────────────────────────────────────\n\n  describe(\"initial form state\", () => {\n    it(\"total defaults to 10000\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.form.total).toBe(10000);\n    });\n\n    it(\"users defaults to 100\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.form.users).toBe(100);\n    });\n\n    it(\"identity_resolution defaults to true\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.form.identity_resolution).toBe(true);\n    });\n\n    it(\"anonymous_ratio defaults to 30\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.form.anonymous_ratio).toBe(30);\n    });\n\n    it(\"numeric_variance defaults to 'medium'\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.form.numeric_variance).toBe(\"medium\");\n    });\n\n    it(\"start defaults to approximately 30 days ago (YYYY-MM-DD)\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.form.start).toBe(daysAgoISO(30));\n    });\n\n    it(\"end defaults to today (YYYY-MM-DD)\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.form.end).toBe(todayISO());\n    });\n\n    it(\"event_types defaults to 6 entries\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.form.event_types).toHaveLength(6);\n    });\n\n    it(\"event_types includes 'Page Viewed' with weight 0.4\", () => {\n      const { result } = renderHook(() => useGenerator());\n      const pv = result.current.form.event_types.find(\n        (et) => et.name === \"Page Viewed\",\n      );\n      expect(pv).toBeDefined();\n      expect(pv?.weight).toBe(0.4);\n    });\n\n    it(\"event_types includes 'Purchase Completed' with weight 0.13\", () => {\n      const { result } = renderHook(() => useGenerator());\n      const pc = result.current.form.event_types.find(\n        (et) => et.name === \"Purchase Completed\",\n      );\n      expect(pc).toBeDefined();\n      expect(pc?.weight).toBe(0.13);\n    });\n\n    it(\"jobActive is false initially\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.jobActive).toBe(false);\n    });\n\n    it(\"progress is null initially\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.progress).toBeNull();\n    });\n\n    it(\"error is null initially\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.error).toBeNull();\n    });\n  });\n\n  // ── applyPreset ───────────────────────────────────────────────────────────\n\n  describe(\"applyPreset\", () => {\n    it(\"'realistic' sets total=10000, users=100\", () => {\n      const { result } = renderHook(() => useGenerator());\n      act(() => result.current.applyPreset(\"realistic\"));\n      expect(result.current.form.total).toBe(10000);\n      expect(result.current.form.users).toBe(100);\n    });\n\n    it(\"'realistic' sets date range to last 30 days\", () => {\n      const { result } = renderHook(() => useGenerator());\n      act(() => result.current.applyPreset(\"realistic\"));\n      expect(result.current.form.start).toBe(daysAgoISO(30));\n      expect(result.current.form.end).toBe(todayISO());\n    });\n\n    it(\"'high-volume' sets total=100000\", () => {\n      const { result } = renderHook(() => useGenerator());\n      act(() => result.current.applyPreset(\"high-volume\"));\n      expect(result.current.form.total).toBe(100000);\n    });\n\n    it(\"'high-volume' sets date range to last 90 days\", () => {\n      const { result } = renderHook(() => useGenerator());\n      act(() => result.current.applyPreset(\"high-volume\"));\n      expect(result.current.form.start).toBe(daysAgoISO(90));\n      expect(result.current.form.end).toBe(todayISO());\n    });\n\n    it(\"'stress-test' sets total=1000000\", () => {\n      const { result } = renderHook(() => useGenerator());\n      act(() => result.current.applyPreset(\"stress-test\"));\n      expect(result.current.form.total).toBe(1000000);\n    });\n\n    it(\"'stress-test' sets date range to last 365 days\", () => {\n      const { result } = renderHook(() => useGenerator());\n      act(() => result.current.applyPreset(\"stress-test\"));\n      expect(result.current.form.start).toBe(daysAgoISO(365));\n      expect(result.current.form.end).toBe(todayISO());\n    });\n  });\n\n  // ── startJob ──────────────────────────────────────────────────────────────\n\n  describe(\"startJob\", () => {\n    it(\"calls POST /api/generate/start with correct body\", async () => {\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/generate/jobs\"))\n          return makeOkResponse([]);\n        if ((url as string).includes(\"/api/generate/start\"))\n          return makeOkResponse({ job_id: \"test-job-123\" });\n        return Promise.reject(new Error(`Unexpected: ${url}`));\n      });\n\n      const { result } = renderHook(() => useGenerator());\n\n      await act(async () => {\n        await result.current.startJob();\n      });\n\n      const startCall = (mockFetch.mock.calls as [string, RequestInit][]).find(\n        ([url]) => url.includes(\"/api/generate/start\"),\n      );\n      expect(startCall).toBeDefined();\n      expect(startCall![1].method).toBe(\"POST\");\n      const body = JSON.parse(startCall![1].body as string) as Record<\n        string,\n        unknown\n      >;\n      expect(body.total).toBe(10000);\n      expect(body.users).toBe(100);\n    });\n\n    it(\"sets jobActive to true after successful start\", async () => {\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/generate/jobs\"))\n          return makeOkResponse([]);\n        if ((url as string).includes(\"/api/generate/start\"))\n          return makeOkResponse({ job_id: \"test-job-123\" });\n        return Promise.reject(new Error(`Unexpected: ${url}`));\n      });\n\n      const { result } = renderHook(() => useGenerator());\n\n      await act(async () => {\n        await result.current.startJob();\n      });\n\n      expect(result.current.jobActive).toBe(true);\n    });\n\n    it(\"opens SSE connection to /api/generate/[job_id]/status\", async () => {\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/generate/jobs\"))\n          return makeOkResponse([]);\n        if ((url as string).includes(\"/api/generate/start\"))\n          return makeOkResponse({ job_id: \"test-job-123\" });\n        return Promise.reject(new Error(`Unexpected: ${url}`));\n      });\n\n      const { result } = renderHook(() => useGenerator());\n\n      await act(async () => {\n        await result.current.startJob();\n      });\n\n      expect(mockEventSourceInstances).toHaveLength(1);\n      expect(mockEventSourceInstances[0].url).toBe(\n        \"/api/generate/test-job-123/status\",\n      );\n    });\n\n    it(\"sets error state when POST fails\", async () => {\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/generate/jobs\"))\n          return makeOkResponse([]);\n        if ((url as string).includes(\"/api/generate/start\"))\n          return makeErrorResponse(500, { error: \"Internal Server Error\" });\n        return Promise.reject(new Error(`Unexpected: ${url}`));\n      });\n\n      const { result } = renderHook(() => useGenerator());\n\n      await act(async () => {\n        await result.current.startJob();\n      });\n\n      expect(result.current.error).not.toBeNull();\n      expect(result.current.jobActive).toBe(false);\n    });\n  });\n\n  // ── SSE progress ──────────────────────────────────────────────────────────\n\n  describe(\"SSE progress messages\", () => {\n    async function startJobAndGetES(\n      result: ReturnType<\n        typeof renderHook<ReturnType<typeof useGenerator>, unknown>\n      >[\"result\"],\n    ) {\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/generate/jobs\"))\n          return makeOkResponse([]);\n        if ((url as string).includes(\"/api/generate/start\"))\n          return makeOkResponse({ job_id: \"job-abc\" });\n        return Promise.reject(new Error(`Unexpected: ${url}`));\n      });\n\n      await act(async () => {\n        await result.current.startJob();\n      });\n\n      return mockEventSourceInstances[0];\n    }\n\n    it(\"updates progress state on running message\", async () => {\n      const { result } = renderHook(() => useGenerator());\n      const es = await startJobAndGetES(result);\n\n      act(() => {\n        es.simulateMessage(\n          JSON.stringify({\n            status: \"running\",\n            inserted: 50000,\n            total: 1000000,\n            throughput: 125000,\n            eta_seconds: 7,\n          }),\n        );\n      });\n\n      await waitFor(() => expect(result.current.progress).not.toBeNull());\n      expect(result.current.progress?.inserted).toBe(50000);\n      expect(result.current.progress?.total).toBe(1000000);\n      expect(result.current.progress?.throughput).toBe(125000);\n      expect(result.current.progress?.eta_seconds).toBe(7);\n      expect(result.current.progress?.status).toBe(\"running\");\n    });\n\n    it(\"sets jobActive to false on terminal status 'complete'\", async () => {\n      const { result } = renderHook(() => useGenerator());\n      const es = await startJobAndGetES(result);\n\n      act(() => {\n        es.simulateMessage(\n          JSON.stringify({\n            status: \"complete\",\n            inserted: 1000000,\n            total: 1000000,\n            elapsed_ms: 8200,\n          }),\n        );\n      });\n\n      await waitFor(() => expect(result.current.jobActive).toBe(false));\n    });\n\n    it(\"sets jobActive to false on terminal status 'failed'\", async () => {\n      const { result } = renderHook(() => useGenerator());\n      const es = await startJobAndGetES(result);\n\n      act(() => {\n        es.simulateMessage(\n          JSON.stringify({\n            status: \"failed\",\n            inserted: 10000,\n            total: 1000000,\n            elapsed_ms: 1000,\n          }),\n        );\n      });\n\n      await waitFor(() => expect(result.current.jobActive).toBe(false));\n    });\n\n    it(\"sets jobActive to false on terminal status 'cancelled'\", async () => {\n      const { result } = renderHook(() => useGenerator());\n      const es = await startJobAndGetES(result);\n\n      act(() => {\n        es.simulateMessage(\n          JSON.stringify({\n            status: \"cancelled\",\n            inserted: 20000,\n            total: 1000000,\n            elapsed_ms: 2000,\n          }),\n        );\n      });\n\n      await waitFor(() => expect(result.current.jobActive).toBe(false));\n    });\n\n    it(\"closes the EventSource after terminal status\", async () => {\n      const { result } = renderHook(() => useGenerator());\n      const es = await startJobAndGetES(result);\n\n      act(() => {\n        es.simulateMessage(\n          JSON.stringify({\n            status: \"complete\",\n            inserted: 1000000,\n            total: 1000000,\n            elapsed_ms: 8200,\n          }),\n        );\n      });\n\n      await waitFor(() => expect(result.current.jobActive).toBe(false));\n      expect(es.close).toHaveBeenCalled();\n    });\n  });\n\n  // ── cancelJob ─────────────────────────────────────────────────────────────\n\n  describe(\"cancelJob\", () => {\n    it(\"calls POST /api/generate/[job_id]/cancel\", async () => {\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/generate/jobs\"))\n          return makeOkResponse([]);\n        if ((url as string).includes(\"/api/generate/start\"))\n          return makeOkResponse({ job_id: \"job-xyz\" });\n        if ((url as string).includes(\"/cancel\"))\n          return makeOkResponse({ cancelled: true });\n        return Promise.reject(new Error(`Unexpected: ${url}`));\n      });\n\n      const { result } = renderHook(() => useGenerator());\n\n      await act(async () => {\n        await result.current.startJob();\n      });\n      await act(async () => {\n        await result.current.cancelJob();\n      });\n\n      const cancelCall = (mockFetch.mock.calls as [string, RequestInit][]).find(\n        ([url]) => url.includes(\"/cancel\"),\n      );\n      expect(cancelCall).toBeDefined();\n      expect(cancelCall![0]).toBe(\"/api/generate/job-xyz/cancel\");\n      expect(cancelCall![1].method).toBe(\"POST\");\n    });\n  });\n\n  // ── identity_resolution toggle ────────────────────────────────────────────\n\n  describe(\"setForm identity_resolution\", () => {\n    it(\"toggling identity_resolution off resets anonymous_ratio to 0\", () => {\n      const { result } = renderHook(() => useGenerator());\n      expect(result.current.form.anonymous_ratio).toBe(30);\n\n      act(() => {\n        result.current.setForm({ identity_resolution: false });\n      });\n\n      expect(result.current.form.identity_resolution).toBe(false);\n      expect(result.current.form.anonymous_ratio).toBe(0);\n    });\n\n    it(\"toggling identity_resolution on keeps anonymous_ratio at 0\", () => {\n      const { result } = renderHook(() => useGenerator());\n\n      act(() => {\n        result.current.setForm({ identity_resolution: false });\n      });\n      act(() => {\n        result.current.setForm({ identity_resolution: true });\n      });\n\n      // Turning back on should not auto-restore ratio — user must set it\n      expect(result.current.form.identity_resolution).toBe(true);\n      expect(result.current.form.anonymous_ratio).toBe(0);\n    });\n  });\n});\n","numLines":488,"startLine":1,"totalLines":488}}}
