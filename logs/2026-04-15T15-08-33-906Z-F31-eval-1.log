{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WXLSRvprkWbnQuwrW9Z8jV","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { cleanup, fireEvent, render, screen } from \"@testing-library/react\";\n3\timport { afterEach, describe, expect, it, vi } from \"vitest\";\n4\timport { ProgressPanel } from \"@/components/generate/ProgressPanel\";\n5\timport type { ProgressState } from \"@/components/generate/useGenerator\";\n6\t\n7\t// ─── Setup / Teardown ─────────────────────────────────────────────────────────\n8\t\n9\tafterEach(() => {\n10\t  cleanup();\n11\t  vi.clearAllMocks();\n12\t});\n13\t\n14\t// ─── Fixtures ─────────────────────────────────────────────────────────────────\n15\t\n16\tfunction makeProgress(overrides: Partial<ProgressState> = {}): ProgressState {\n17\t  return {\n18\t    job_id: \"test-job-1\",\n19\t    status: \"running\",\n20\t    inserted: 50000,\n21\t    total: 1000000,\n22\t    throughput: 125000,\n23\t    eta_seconds: 7,\n24\t    elapsed_ms: 400,\n25\t    ...overrides,\n26\t  };\n27\t}\n28\t\n29\t// ─── Tests ────────────────────────────────────────────────────────────────────\n30\t\n31\tdescribe(\"ProgressPanel\", () => {\n32\t  describe(\"progress bar\", () => {\n33\t    it(\"renders with correct percentage label\", () => {\n34\t      render(<ProgressPanel progress={makeProgress()} onCancel={vi.fn()} />);\n35\t      // 50000/1000000 = 5%\n36\t      expect(screen.getByText(/5%/)).toBeTruthy();\n37\t    });\n38\t\n39\t    it(\"renders inserted/total counts\", () => {\n40\t      render(<ProgressPanel progress={makeProgress()} onCancel={vi.fn()} />);\n41\t      expect(screen.getByText(/50[,.]?000/)).toBeTruthy();\n42\t      expect(screen.getByText(/1[,.]?000[,.]?000/)).toBeTruthy();\n43\t    });\n44\t  });\n45\t\n46\t  describe(\"throughput and ETA\", () => {\n47\t    it(\"displays throughput text\", () => {\n48\t      render(<ProgressPanel progress={makeProgress()} onCancel={vi.fn()} />);\n49\t      // Should show something like \"125,000 events/sec\" or \"~125000 events/sec\"\n50\t      expect(screen.getByText(/125[,.]?000/)).toBeTruthy();\n51\t    });\n52\t\n53\t    it(\"displays ETA text when eta_seconds > 0\", () => {\n54\t      render(\n55\t        <ProgressPanel\n56\t          progress={makeProgress({ eta_seconds: 7 })}\n57\t          onCancel={vi.fn()}\n58\t        />,\n59\t      );\n60\t      expect(screen.getByText(/7s|7 sec/i)).toBeTruthy();\n61\t    });\n62\t  });\n63\t\n64\t  describe(\"status chip\", () => {\n65\t    it(\"shows 'Running' chip when status is running\", () => {\n66\t      render(\n67\t        <ProgressPanel\n68\t          progress={makeProgress({ status: \"running\" })}\n69\t          onCancel={vi.fn()}\n70\t        />,\n71\t      );\n72\t      expect(screen.getByText(/running/i)).toBeTruthy();\n73\t    });\n74\t\n75\t    it(\"shows 'Queued' chip when status is queued\", () => {\n76\t      render(\n77\t        <ProgressPanel\n78\t          progress={makeProgress({\n79\t            status: \"queued\",\n80\t            inserted: 0,\n81\t            throughput: 0,\n82\t            eta_seconds: 0,\n83\t          })}\n84\t          onCancel={vi.fn()}\n85\t        />,\n86\t      );\n87\t      expect(screen.getByText(/queued/i)).toBeTruthy();\n88\t    });\n89\t\n90\t    it(\"shows 'Complete' chip when status is complete\", () => {\n91\t      render(\n92\t        <ProgressPanel\n93\t          progress={makeProgress({\n94\t            status: \"complete\",\n95\t            inserted: 1000000,\n96\t            eta_seconds: 0,\n97\t          })}\n98\t          onCancel={vi.fn()}\n99\t        />,\n100\t      );\n101\t      expect(screen.getByText(/complete/i)).toBeTruthy();\n102\t    });\n103\t\n104\t    it(\"shows 'Failed' chip when status is failed\", () => {\n105\t      render(\n106\t        <ProgressPanel\n107\t          progress={makeProgress({ status: \"failed\" })}\n108\t          onCancel={vi.fn()}\n109\t        />,\n110\t      );\n111\t      expect(screen.getByText(/failed/i)).toBeTruthy();\n112\t    });\n113\t\n114\t    it(\"shows 'Cancelled' chip when status is cancelled\", () => {\n115\t      render(\n116\t        <ProgressPanel\n117\t          progress={makeProgress({ status: \"cancelled\" })}\n118\t          onCancel={vi.fn()}\n119\t        />,\n120\t      );\n121\t      expect(screen.getByText(/cancelled/i)).toBeTruthy();\n122\t    });\n123\t  });\n124\t\n125\t  describe(\"cancel button\", () => {\n126\t    it(\"cancel button is visible when status is 'running'\", () => {\n127\t      render(\n128\t        <ProgressPanel\n129\t          progress={makeProgress({ status: \"running\" })}\n130\t          onCancel={vi.fn()}\n131\t        />,\n132\t      );\n133\t      expect(screen.queryByRole(\"button\", { name: /cancel/i })).not.toBeNull();\n134\t    });\n135\t\n136\t    it(\"cancel button is visible when status is 'queued'\", () => {\n137\t      render(\n138\t        <ProgressPanel\n139\t          progress={makeProgress({\n140\t            status: \"queued\",\n141\t            inserted: 0,\n142\t            throughput: 0,\n143\t            eta_seconds: 0,\n144\t          })}\n145\t          onCancel={vi.fn()}\n146\t        />,\n147\t      );\n148\t      expect(screen.queryByRole(\"button\", { name: /cancel/i })).not.toBeNull();\n149\t    });\n150\t\n151\t    it(\"cancel button calls onCancel when clicked\", () => {\n152\t      const mockCancel = vi.fn();\n153\t      render(\n154\t        <ProgressPanel\n155\t          progress={makeProgress({ status: \"running\" })}\n156\t          onCancel={mockCancel}\n157\t        />,\n158\t      );\n159\t      fireEvent.click(screen.getByRole(\"button\", { name: /cancel/i }));\n160\t      expect(mockCancel).toHaveBeenCalledTimes(1);\n161\t    });\n162\t\n163\t    it(\"cancel button is hidden when status is 'complete'\", () => {\n164\t      render(\n165\t        <ProgressPanel\n166\t          progress={makeProgress({\n167\t            status: \"complete\",\n168\t            inserted: 1000000,\n169\t            eta_seconds: 0,\n170\t          })}\n171\t          onCancel={vi.fn()}\n172\t        />,\n173\t      );\n174\t      expect(screen.queryByRole(\"button\", { name: /cancel/i })).toBeNull();\n175\t    });\n176\t\n177\t    it(\"cancel button is hidden when status is 'failed'\", () => {\n178\t      render(\n179\t        <ProgressPanel\n180\t          progress={makeProgress({ status: \"failed\" })}\n181\t          onCancel={vi.fn()}\n182\t        />,\n183\t      );\n184\t      expect(screen.queryByRole(\"button\", { name: /cancel/i })).toBeNull();\n185\t    });\n186\t  });\n187\t\n188\t  describe(\"completion links\", () => {\n189\t    it(\"shows links to /explore and /trends when status is 'complete'\", () => {\n190\t      render(\n191\t        <ProgressPanel\n192\t          progress={makeProgress({\n193\t            status: \"complete\",\n194\t            inserted: 1000000,\n195\t            eta_seconds: 0,\n196\t          })}\n197\t          onCancel={vi.fn()}\n198\t        />,\n199\t      );\n200\t      const links = screen.getAllByRole(\"link\");\n201\t      const hrefs = links.map((l) => l.getAttribute(\"href\"));\n202\t      expect(hrefs).toContain(\"/explore\");\n203\t      expect(hrefs).toContain(\"/trends\");\n204\t    });\n205\t\n206\t    it(\"does not show completion links when status is 'running'\", () => {\n207\t      render(\n208\t        <ProgressPanel\n209\t          progress={makeProgress({ status: \"running\" })}\n210\t          onCancel={vi.fn()}\n211\t        />,\n212\t      );\n213\t      const links = screen.queryAllByRole(\"link\");\n214\t      const hrefs = links.map((l) => l.getAttribute(\"href\"));\n215\t      expect(hrefs).not.toContain(\"/explore\");\n216\t      expect(hrefs).not.toContain(\"/trends\");\n217\t    });\n218\t\n219\t    it(\"does not show completion links when status is 'failed'\", () => {\n220\t      render(\n221\t        <ProgressPanel\n222\t          progress={makeProgress({ status: \"failed\" })}\n223\t          onCancel={vi.fn()}\n224\t        />,\n225\t      );\n226\t      const links = screen.queryAllByRole(\"link\");\n227\t      const hrefs = links.map((l) => l.getAttribute(\"href\"));\n228\t      expect(hrefs).not.toContain(\"/explore\");\n229\t      expect(hrefs).not.toContain(\"/trends\");\n230\t    });\n231\t  });\n232\t});\n233\t"}]},"parent_tool_use_id":null,"session_id":"3d324c3e-ac44-4876-8051-93925eeee4fd","uuid":"87bdcc0a-5723-4359-873e-c0f9e502e462","timestamp":"2026-04-15T18:51:40.078Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/generate/__tests__/ProgressPanel.test.tsx","content":"// @vitest-environment jsdom\nimport { cleanup, fireEvent, render, screen } from \"@testing-library/react\";\nimport { afterEach, describe, expect, it, vi } from \"vitest\";\nimport { ProgressPanel } from \"@/components/generate/ProgressPanel\";\nimport type { ProgressState } from \"@/components/generate/useGenerator\";\n\n// ─── Setup / Teardown ─────────────────────────────────────────────────────────\n\nafterEach(() => {\n  cleanup();\n  vi.clearAllMocks();\n});\n\n// ─── Fixtures ─────────────────────────────────────────────────────────────────\n\nfunction makeProgress(overrides: Partial<ProgressState> = {}): ProgressState {\n  return {\n    job_id: \"test-job-1\",\n    status: \"running\",\n    inserted: 50000,\n    total: 1000000,\n    throughput: 125000,\n    eta_seconds: 7,\n    elapsed_ms: 400,\n    ...overrides,\n  };\n}\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\ndescribe(\"ProgressPanel\", () => {\n  describe(\"progress bar\", () => {\n    it(\"renders with correct percentage label\", () => {\n      render(<ProgressPanel progress={makeProgress()} onCancel={vi.fn()} />);\n      // 50000/1000000 = 5%\n      expect(screen.getByText(/5%/)).toBeTruthy();\n    });\n\n    it(\"renders inserted/total counts\", () => {\n      render(<ProgressPanel progress={makeProgress()} onCancel={vi.fn()} />);\n      expect(screen.getByText(/50[,.]?000/)).toBeTruthy();\n      expect(screen.getByText(/1[,.]?000[,.]?000/)).toBeTruthy();\n    });\n  });\n\n  describe(\"throughput and ETA\", () => {\n    it(\"displays throughput text\", () => {\n      render(<ProgressPanel progress={makeProgress()} onCancel={vi.fn()} />);\n      // Should show something like \"125,000 events/sec\" or \"~125000 events/sec\"\n      expect(screen.getByText(/125[,.]?000/)).toBeTruthy();\n    });\n\n    it(\"displays ETA text when eta_seconds > 0\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({ eta_seconds: 7 })}\n          onCancel={vi.fn()}\n        />,\n      );\n      expect(screen.getByText(/7s|7 sec/i)).toBeTruthy();\n    });\n  });\n\n  describe(\"status chip\", () => {\n    it(\"shows 'Running' chip when status is running\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({ status: \"running\" })}\n          onCancel={vi.fn()}\n        />,\n      );\n      expect(screen.getByText(/running/i)).toBeTruthy();\n    });\n\n    it(\"shows 'Queued' chip when status is queued\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({\n            status: \"queued\",\n            inserted: 0,\n            throughput: 0,\n            eta_seconds: 0,\n          })}\n          onCancel={vi.fn()}\n        />,\n      );\n      expect(screen.getByText(/queued/i)).toBeTruthy();\n    });\n\n    it(\"shows 'Complete' chip when status is complete\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({\n            status: \"complete\",\n            inserted: 1000000,\n            eta_seconds: 0,\n          })}\n          onCancel={vi.fn()}\n        />,\n      );\n      expect(screen.getByText(/complete/i)).toBeTruthy();\n    });\n\n    it(\"shows 'Failed' chip when status is failed\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({ status: \"failed\" })}\n          onCancel={vi.fn()}\n        />,\n      );\n      expect(screen.getByText(/failed/i)).toBeTruthy();\n    });\n\n    it(\"shows 'Cancelled' chip when status is cancelled\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({ status: \"cancelled\" })}\n          onCancel={vi.fn()}\n        />,\n      );\n      expect(screen.getByText(/cancelled/i)).toBeTruthy();\n    });\n  });\n\n  describe(\"cancel button\", () => {\n    it(\"cancel button is visible when status is 'running'\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({ status: \"running\" })}\n          onCancel={vi.fn()}\n        />,\n      );\n      expect(screen.queryByRole(\"button\", { name: /cancel/i })).not.toBeNull();\n    });\n\n    it(\"cancel button is visible when status is 'queued'\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({\n            status: \"queued\",\n            inserted: 0,\n            throughput: 0,\n            eta_seconds: 0,\n          })}\n          onCancel={vi.fn()}\n        />,\n      );\n      expect(screen.queryByRole(\"button\", { name: /cancel/i })).not.toBeNull();\n    });\n\n    it(\"cancel button calls onCancel when clicked\", () => {\n      const mockCancel = vi.fn();\n      render(\n        <ProgressPanel\n          progress={makeProgress({ status: \"running\" })}\n          onCancel={mockCancel}\n        />,\n      );\n      fireEvent.click(screen.getByRole(\"button\", { name: /cancel/i }));\n      expect(mockCancel).toHaveBeenCalledTimes(1);\n    });\n\n    it(\"cancel button is hidden when status is 'complete'\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({\n            status: \"complete\",\n            inserted: 1000000,\n            eta_seconds: 0,\n          })}\n          onCancel={vi.fn()}\n        />,\n      );\n      expect(screen.queryByRole(\"button\", { name: /cancel/i })).toBeNull();\n    });\n\n    it(\"cancel button is hidden when status is 'failed'\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({ status: \"failed\" })}\n          onCancel={vi.fn()}\n        />,\n      );\n      expect(screen.queryByRole(\"button\", { name: /cancel/i })).toBeNull();\n    });\n  });\n\n  describe(\"completion links\", () => {\n    it(\"shows links to /explore and /trends when status is 'complete'\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({\n            status: \"complete\",\n            inserted: 1000000,\n            eta_seconds: 0,\n          })}\n          onCancel={vi.fn()}\n        />,\n      );\n      const links = screen.getAllByRole(\"link\");\n      const hrefs = links.map((l) => l.getAttribute(\"href\"));\n      expect(hrefs).toContain(\"/explore\");\n      expect(hrefs).toContain(\"/trends\");\n    });\n\n    it(\"does not show completion links when status is 'running'\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({ status: \"running\" })}\n          onCancel={vi.fn()}\n        />,\n      );\n      const links = screen.queryAllByRole(\"link\");\n      const hrefs = links.map((l) => l.getAttribute(\"href\"));\n      expect(hrefs).not.toContain(\"/explore\");\n      expect(hrefs).not.toContain(\"/trends\");\n    });\n\n    it(\"does not show completion links when status is 'failed'\", () => {\n      render(\n        <ProgressPanel\n          progress={makeProgress({ status: \"failed\" })}\n          onCancel={vi.fn()}\n        />,\n      );\n      const links = screen.queryAllByRole(\"link\");\n      const hrefs = links.map((l) => l.getAttribute(\"href\"));\n      expect(hrefs).not.toContain(\"/explore\");\n      expect(hrefs).not.toContain(\"/trends\");\n    });\n  });\n});\n","numLines":233,"startLine":1,"totalLines":233}}}
