nst btn = page.getByRole(\"button\", { name: /^generate$/i });\n    await expect(btn).toBeVisible();\n    await expect(btn).toBeEnabled();\n  });\n\n  test(\"progress panel is hidden on initial load\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/generate`);\n    await expect(page.getByTestId(\"progress-panel\")).not.toBeVisible();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":517,"cache_read_input_tokens":62268,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":517},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3d324c3e-ac44-4876-8051-93925eeee4fd","uuid":"a4e909b4-6d96-43bd-b3e9-0ada9de0a6c7"}
