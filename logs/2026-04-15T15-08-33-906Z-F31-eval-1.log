{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QJ9f1AwoZpE81GfWoQVTKF","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { cleanup, fireEvent, render, screen } from \"@testing-library/react\";\n3\timport { afterEach, describe, expect, it, vi } from \"vitest\";\n4\timport { GeneratorForm } from \"@/components/generate/GeneratorForm\";\n5\timport type { GeneratorFormState } from \"@/components/generate/useGenerator\";\n6\t\n7\t// ─── Fixtures ─────────────────────────────────────────────────────────────────\n8\t\n9\tfunction makeDefaultForm(): GeneratorFormState {\n10\t  const today = new Date().toISOString().slice(0, 10);\n11\t  const d = new Date();\n12\t  d.setDate(d.getDate() - 30);\n13\t  const start = d.toISOString().slice(0, 10);\n14\t  return {\n15\t    total: 10000,\n16\t    users: 100,\n17\t    start,\n18\t    end: today,\n19\t    event_types: [\n20\t      { name: \"Page Viewed\", weight: 0.4 },\n21\t      { name: \"Button Clicked\", weight: 0.15 },\n22\t      { name: \"Signup Completed\", weight: 0.12 },\n23\t      { name: \"Purchase Completed\", weight: 0.13 },\n24\t      { name: \"Subscription Renewed\", weight: 0.12 },\n25\t      { name: \"Support Ticket Opened\", weight: 0.08 },\n26\t    ],\n27\t    identity_resolution: true,\n28\t    anonymous_ratio: 30,\n29\t    numeric_variance: \"medium\",\n30\t  };\n31\t}\n32\t\n33\t// ─── Setup / Teardown ─────────────────────────────────────────────────────────\n34\t\n35\tafterEach(() => {\n36\t  cleanup();\n37\t  vi.clearAllMocks();\n38\t});\n39\t\n40\t// ─── Tests ────────────────────────────────────────────────────────────────────\n41\t\n42\tdescribe(\"GeneratorForm\", () => {\n43\t  describe(\"form fields rendering\", () => {\n44\t    it(\"renders total events number input\", () => {\n45\t      render(\n46\t        <GeneratorForm\n47\t          form={makeDefaultForm()}\n48\t          setForm={vi.fn()}\n49\t          applyPreset={vi.fn()}\n50\t          onSubmit={vi.fn()}\n51\t          disabled={false}\n52\t        />,\n53\t      );\n54\t      // role=spinbutton for input[type=number]\n55\t      const totalInputs = screen.getAllByRole(\"spinbutton\");\n56\t      expect(totalInputs.length).toBeGreaterThanOrEqual(1);\n57\t    });\n58\t\n59\t    it(\"renders users number input\", () => {\n60\t      render(\n61\t        <GeneratorForm\n62\t          form={makeDefaultForm()}\n63\t          setForm={vi.fn()}\n64\t          applyPreset={vi.fn()}\n65\t          onSubmit={vi.fn()}\n66\t          disabled={false}\n67\t        />,\n68\t      );\n69\t      const spinbuttons = screen.getAllByRole(\"spinbutton\");\n70\t      expect(spinbuttons.length).toBeGreaterThanOrEqual(2);\n71\t    });\n72\t\n73\t    it(\"renders start date input\", () => {\n74\t      render(\n75\t        <GeneratorForm\n76\t          form={makeDefaultForm()}\n77\t          setForm={vi.fn()}\n78\t          applyPreset={vi.fn()}\n79\t          onSubmit={vi.fn()}\n80\t          disabled={false}\n81\t        />,\n82\t      );\n83\t      expect(screen.getByLabelText(/start/i)).toBeTruthy();\n84\t    });\n85\t\n86\t    it(\"renders end date input\", () => {\n87\t      render(\n88\t        <GeneratorForm\n89\t          form={makeDefaultForm()}\n90\t          setForm={vi.fn()}\n91\t          applyPreset={vi.fn()}\n92\t          onSubmit={vi.fn()}\n93\t          disabled={false}\n94\t        />,\n95\t      );\n96\t      expect(screen.getByLabelText(/end/i)).toBeTruthy();\n97\t    });\n98\t\n99\t    it(\"renders 6 event type checkboxes\", () => {\n100\t      render(\n101\t        <GeneratorForm\n102\t          form={makeDefaultForm()}\n103\t          setForm={vi.fn()}\n104\t          applyPreset={vi.fn()}\n105\t          onSubmit={vi.fn()}\n106\t          disabled={false}\n107\t        />,\n108\t      );\n109\t      const checkboxes = screen.getAllByRole(\"checkbox\");\n110\t      // At least 6 for event types (there's also identity_resolution switch)\n111\t      expec