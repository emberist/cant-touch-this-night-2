{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QZTru1x7xT13edkufsG3x7","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport Box from \"@mui/material/Box\";\n4\timport Button from \"@mui/material/Button\";\n5\timport Chip from \"@mui/material/Chip\";\n6\timport LinearProgress from \"@mui/material/LinearProgress\";\n7\timport Link from \"@mui/material/Link\";\n8\timport Stack from \"@mui/material/Stack\";\n9\timport Typography from \"@mui/material/Typography\";\n10\timport NextLink from \"next/link\";\n11\timport type { ProgressState } from \"@/components/generate/useGenerator\";\n12\t\n13\t// ─── Types ────────────────────────────────────────────────────────────────────\n14\t\n15\texport interface ProgressPanelProps {\n16\t  progress: ProgressState;\n17\t  onCancel: () => void;\n18\t}\n19\t\n20\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n21\t\n22\tfunction formatCount(n: number): string {\n23\t  return n.toLocaleString();\n24\t}\n25\t\n26\tfunction statusColor(\n27\t  status: ProgressState[\"status\"],\n28\t): \"default\" | \"primary\" | \"success\" | \"error\" | \"warning\" {\n29\t  switch (status) {\n30\t    case \"queued\":\n31\t      return \"default\";\n32\t    case \"running\":\n33\t      return \"primary\";\n34\t    case \"complete\":\n35\t      return \"success\";\n36\t    case \"failed\":\n37\t      return \"error\";\n38\t    case \"cancelled\":\n39\t      return \"warning\";\n40\t  }\n41\t}\n42\t\n43\tfunction statusLabel(status: ProgressState[\"status\"]): string {\n44\t  switch (status) {\n45\t    case \"queued\":\n46\t      return \"Queued\";\n47\t    case \"running\":\n48\t      return \"Running\";\n49\t    case \"complete\":\n50\t      return \"Complete\";\n51\t    case \"failed\":\n52\t      return \"Failed\";\n53\t    case \"cancelled\":\n54\t      return \"Cancelled\";\n55\t  }\n56\t}\n57\t\n58\tconst ACTIVE_STATUSES = new Set<ProgressState[\"status\"]>([\"queued\", \"running\"]);\n59\t\n60\t// ─── Component ────────────────────────────────────────────────────────────────\n61\t\n62\texport function ProgressPanel({\n63\t  progress,\n64\t  onCancel,\n65\t}: ProgressPanelProps): React.JSX.Element {\n66\t  const pct =\n67\t    progress.total > 0\n68\t      ? Math.round((progress.inserted / progress.total) * 100)\n69\t      : 0;\n70\t\n71\t  const isActive = ACTIVE_STATUSES.has(progress.status);\n72\t  const isComplete = progress.status === \"complete\";\n73\t\n74\t  return (\n75\t    <Box data-testid=\"progress-panel\">\n76\t      {/* ── Status chip ─────────────────────────────────────────────── */}\n77\t      <Stack direction=\"row\" spacing={2} sx={{ mb: 1.5, alignItems: \"center\" }}>\n78\t        <Chip\n79\t          label={statusLabel(progress.status)}\n80\t          color={statusColor(progress.status)}\n81\t          size=\"small\"\n82\t        />\n83\t        {isActive && (\n84\t          <Button\n85\t            size=\"small\"\n86\t            variant=\"outlined\"\n87\t            color=\"error\"\n88\t            onClick={onCancel}\n89\t          >\n90\t            Cancel\n91\t          </Button>\n92\t        )}\n93\t      </Stack>\n94\t\n95\t      {/* ── Progress bar ────────────────────────────────────────────── */}\n96\t      <Box sx={{ mb: 1 }}>\n97\t        <Box sx={{ display: \"flex\", justifyContent: \"space-between\", mb: 0.5 }}>\n98\t          <Typography variant=\"body2\">\n99\t            {formatCount(progress.inserted)} / {formatCount(progress.total)}{\" \"}\n100\t            events inserted\n101\t          </Typography>\n102\t          <Typography variant=\"body2\" sx={{ fontWeight: \"bold\" }}>\n103\t            {pct}%\n104\t          </Typography>\n105\t        </Box>\n106\t        <LinearProgress\n107\t          variant=\"determinate\"\n108\t          value={pct}\n109\t          sx={{ height: 8, borderRadius: 1 }}\n110\t        />\n111\t      </Box>\n112\t\n113\t      {/* ── Throughput & ETA ─────────────────