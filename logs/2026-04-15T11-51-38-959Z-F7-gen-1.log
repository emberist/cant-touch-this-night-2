{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014H1JXaCH7dCkxPjy2rXrL2","type":"tool_result","content":"1\timport { IdentityConflictError, insertEvent } from \"@/lib/identity\";\n2\t\n3\texport async function POST(request: Request): Promise<Response> {\n4\t  let body: unknown;\n5\t\n6\t  try {\n7\t    body = await request.json();\n8\t  } catch {\n9\t    return Response.json({ error: \"Invalid JSON body.\" }, { status: 400 });\n10\t  }\n11\t\n12\t  try {\n13\t    const row = await insertEvent(body);\n14\t    return Response.json(row, { status: 201 });\n15\t  } catch (error) {\n16\t    if (error instanceof IdentityConflictError) {\n17\t      return Response.json(\n18\t        { error: (error as Error).message },\n19\t        { status: 409 },\n20\t      );\n21\t    }\n22\t    if (error instanceof Error) {\n23\t      return Response.json({ error: error.message }, { status: 400 });\n24\t    }\n25\t    return Response.json({ error: \"Unexpected error.\" }, { status: 500 });\n26\t  }\n27\t}\n28\t"}]},"parent_tool_use_id":"toolu_01Vg6SNewd4rjWGYrY7ddqno","session_id":"8abfa75e-8428-4312-86e7-bde2aa8c0983","uuid":"0083982f-bbd9-4a14-91f1-4e820e7849a6","timestamp":"2026-04-15T12:37:35.539Z"}
