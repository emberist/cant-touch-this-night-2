{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WuAGF5VX4Y1gDumzHzU4DE","type":"tool_result","content":"1\timport { NextResponse } from \"next/server\";\n2\timport { clickhouse } from \"@/lib/clickhouse\";\n3\timport {\n4\t  getCachedSchema,\n5\t  type SchemaResponse,\n6\t  setCachedSchema,\n7\t} from \"@/lib/schema-cache\";\n8\t\n9\t/**\n10\t * GET /api/schema\n11\t *\n12\t * Returns distinct event names and, per event, the detected property names\n13\t * with inferred types (\"numeric\" | \"string\").\n14\t *\n15\t * Computed by sampling the last 10,000 events. Cached in memory for 60 s.\n16\t */\n17\texport async function GET(_req: Request): Promise<NextResponse> {\n18\t  const cached = getCachedSchema();\n19\t  if (cached !== null) {\n20\t    return NextResponse.json(cached);\n21\t  }\n22\t\n23\t  // Single query: sample the last 10,000 events, expand property keys, detect\n24\t  // numeric types.  One output row per (event_name, property_key) with\n25\t  // is_numeric = 1 if at least one sample value parses as a non-null float.\n26\t  //\n27\t  // JSONExtractKeys returns an Array(String); arrayJoin flattens it into rows.\n28\t  // JSONExtractFloat on a non-numeric string returns 0 — isNull check guards\n29\t  // nulls that come from malformed JSON.\n30\t  const result = await clickhouse.query({\n31\t    query: `\n32\t      SELECT\n33\t        event_name,\n34\t        property_key,\n35\t        maxIf(1, NOT isNull(JSONExtractFloat(properties, property_key))\n36\t                 AND JSONExtractFloat(properties, property_key) != 0) AS is_numeric\n37\t      FROM (\n38\t        SELECT event_name, properties\n39\t        FROM events\n40\t        ORDER BY ingested_at DESC\n41\t        LIMIT 10000\n42\t      ) AS sample\n43\t      LEFT ARRAY JOIN JSONExtractKeys(properties) AS property_key\n44\t      GROUP BY event_name, property_key\n45\t      ORDER BY event_name, property_key\n46\t    `,\n47\t    format: \"JSONEachRow\",\n48\t  });\n49\t\n50\t  const rows = await result.json<{\n51\t    event_name: string;\n52\t    property_key: string;\n53\t    is_numeric: number;\n54\t  }>();\n55\t\n56\t  // Build response by grouping rows\n57\t  const eventNamesSet = new Set<string>();\n58\t  const properties: SchemaResponse[\"properties\"] = {};\n59\t\n60\t  for (const row of rows) {\n61\t    eventNamesSet.add(row.event_name);\n62\t\n63\t    // Skip empty property keys (events with properties = '{}')\n64\t    if (!row.property_key) continue;\n65\t\n66\t    if (!properties[row.event_name]) {\n67\t      properties[row.event_name] = {};\n68\t    }\n69\t    properties[row.event_name][row.property_key] = row.is_numeric\n70\t      ? \"numeric\"\n71\t      : \"string\";\n72\t  }\n73\t\n74\t  const schema: SchemaResponse = {\n75\t    event_names: Array.from(eventNamesSet).sort(),\n76\t    properties,\n77\t  };\n78\t\n79\t  setCachedSchema(schema);\n80\t\n81\t  return NextResponse.json(schema);\n82\t}\n83\t"}]},"parent_tool_use_id":null,"session_id":"f1d99829-aefd-46dd-ba16-f0a57cb36174","uuid":"fb16fe7f-3395-48a1-9da2-538b22732d1e","timestamp":"2026-04-15T12:59:28.012Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/schema/route.ts","content":"import { NextResponse } from \"next/server\";\nimport { clickhouse } from \"@/lib/clickhouse\";\nimport {\n  getCachedSchema,\n  type SchemaResponse,\n  setCachedSchema,\n} from \"@/lib/schema-cache\";\n\n/**\n * GET /api/schema\n *\n * Returns distinct event names and, per event, the detected property names\n * with inferred types (\"numeric\" | \"string\").\n *\n * Computed by sampling the last 10,000 events. Cached in memory for 60 s.\n */\nexport async function GET(_req: Request): Promise<NextResponse> {\n  const cached = getCachedSchema();\n  if (cached !== null) {\n    return NextResponse.json(cached);\n  }\n\n  // Single query: sample the last 10,000 events, expand property keys, detect\n  // numeric types.  One output row per (event_name, property_key) with\n  // is_numeric = 1 if at least one sample value parses as a non-null float.\n  //\n  // JSONExtractKeys returns an Array(String); arrayJoin flattens it into rows.\n  // JSONExtractFloat on a non-numeric string returns 0 — isNull check guards\n  // nulls that come from malformed JSON.\n  const result = await clickhouse.query({\n    query: `\n      SELECT\n        event_name,\n        property_key,\n        maxIf(1, NOT isNull(JSONExtractFloat(properties, property_key))\n                 AND JSONExtractFloat(properties, property_key) != 0) AS is_numeric\n      FROM (\n        SELECT event_name, properties\n        FROM events\n        ORDER BY ingested_at DESC\n        LIMIT 10000\n      ) AS sample\n      LEFT ARRAY JOIN JSONExtractKeys(properties) AS property_key\n      GROUP BY event_name, property_key\n      ORDER BY event_name, property_key\n    `,\n    format: \"JSONEachRow\",\n  });\n\n  const rows = await result.json<{\n    event_name: string;\n    property_key: string;\n    is_numeric: number;\n  }>();\n\n  // Build response by grouping rows\n  const eventNamesSet = new Set<string>();\n  const properties: SchemaResponse[\"properties\"] = {};\n\n  for (const row of rows) {\n    eventNamesSet.add(row.event_name);\n\n    // Skip empty property keys (events with properties = '{}')\n    if (!row.property_key) continue;\n\n    if (!properties[row.event_name]) {\n      properties[row.event_name] = {};\n    }\n    properties[row.event_name][row.property_key] = row.is_numeric\n      ? \"numeric\"\n      : \"string\";\n  }\n\n  const schema: SchemaResponse = {\n    event_names: Array.from(eventNamesSet).sort(),\n    properties,\n  };\n\n  setCachedSchema(schema);\n\n  return NextResponse.json(schema);\n}\n","numLines":83,"startLine":1,"totalLines":83}}}
