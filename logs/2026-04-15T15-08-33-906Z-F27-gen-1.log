{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01WsRnDDB1mwQsuF3svJuSaV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Ba7LYSdGMbPRGQShfsA5xQ","name":"Write","input":{"file_path":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/test/QuickFireButtons.tsx","content":"\"use client\";\n\nimport { useState } from \"react\";\nimport Box from \"@mui/material/Box\";\nimport Button from \"@mui/material/Button\";\nimport Stack from \"@mui/material/Stack\";\nimport Typography from \"@mui/material/Typography\";\nimport { generateId, useEventSender } from \"@/components/test/useEventSender\";\nimport type { EventPayload } from \"@/components/test/useEventSender\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\ninterface ButtonFeedback {\n  type: \"success\" | \"error\";\n  message: string;\n}\n\n// ─── Quick-fire button config ─────────────────────────────────────────────────\n\nconst TEST_USER_ID = \"test@example.com\";\n\n// ─── Component ────────────────────────────────────────────────────────────────\n\nexport function QuickFireButtons(): React.JSX.Element {\n  const { sendEvent, lastDeviceId } = useEventSender();\n  const [feedback, setFeedback] = useState<Record<string, ButtonFeedback | null>>({});\n  const [loadingButton, setLoadingButton] = useState<string | null>(null);\n\n  async function fire(id: string, getPayload: () => EventPayload): Promise<void> {\n    setLoadingButton(id);\n    setFeedback((prev) => ({ ...prev, [id]: null }));\n    const result = await sendEvent(getPayload());\n    setLoadingButton(null);\n    setFeedback((prev) => ({\n      ...prev,\n      [id]: result.success\n        ? { type: \"success\", message: \"Sent\" }\n        : { type: \"error\", message: result.error ?? \"Error\" },\n    }));\n  }\n\n  const buttons: Array<{\n    id: string;\n    label: string;\n    getPayload: () => EventPayload;\n  }> = [\n    {\n      id: \"anon-page-view\",\n      label: \"Anonymous Page View\",\n      getPayload: () => ({\n        event_name: \"Page Viewed\",\n        device_id: generateId(),\n        properties: { page: \"/home\" },\n      }),\n    },\n    {\n      id: \"button-click\",\n      label: \"Button Click\",\n      getPayload: () => ({\n        event_name: \"Button Clicked\",\n        device_id: lastDeviceId ?? generateId(),\n        properties: { button_name: \"Get Started\" },\n      }),\n    },\n    {\n      id: \"identify-user\",\n      label: \"Identify User\",\n      getPayload: () => ({\n        event_name: \"Identify\",\n        device_id: lastDeviceId ?? generateId(),\n        user_id: TEST_USER_ID,\n      }),\n    },\n    {\n      id: \"purchase\",\n      label: \"Purchase\",\n      getPayload: () => ({\n        event_name: \"Purchase Completed\",\n        user_id: TEST_USER_ID,\n        properties: { amount: 49.99, currency: \"USD\" },\n      }),\n    },\n    {\n      id: \"signup\",\n      label: \"Signup\",\n      getPayload: () => ({\n        event_name: \"Signup Completed\",\n        device_id: generateId(),\n        user_id: `user-${generateId()}@example.com`,\n      }),\n    },\n  ];\n\n  return (\n    <Box data-testid=\"quick-fire-buttons\">\n      <Stack spacing={1}>\n        {buttons.map(({ id, label, getPayload }) => (\n          <Box key={id}>\n            <Button\n              variant=\"outlined\"\n              size=\"small\"\n              disabled={loadingButton === id}\n              onClick={() => void fire(id, getPayload)}\n              fullWidth\n            >\n              {label}\n            </Button>\n            {feedback[id] != null && (\n              <Typography\n                variant=\"caption\"\n                color={feedback[id]?.type === \"success\" ? \"success.main\" : \"error.main\"}\n                sx={{ display: \"block\", mt: 0.25 }}\n              >\n                {feedback[id]?.type === \"success\"\n                  ? \"Sent\"\n                  : `Error: ${feedback[id]?.message}`}\n              </Typography>\n            )}\n          </Box>\n        ))}\n      </Stack>\n    </Box>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":522,"cache_read_input_tokens":95842,"cache_creation":{"ephemeral_5m_input_tokens":522,"ephemeral_1h_input_tokens":0},"output_tokens":73,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"27b757f3-6d9d-4fd7-9868-cc1b8f1bb385","uuid":"026a7d86-1cbe-416e-ab80-c8c6caf78cd7"}
