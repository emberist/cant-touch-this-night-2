{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018D3RW8SYvXy1tiWGPRVPcQ","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport {\n3\t  cleanup,\n4\t  fireEvent,\n5\t  render,\n6\t  screen,\n7\t  waitFor,\n8\t} from \"@testing-library/react\";\n9\timport { afterEach, describe, expect, it, vi } from \"vitest\";\n10\timport { SeedDataButton } from \"@/components/test/SeedDataButton\";\n11\timport type { SeedResult } from \"@/components/test/useEventSender\";\n12\t\n13\t// ─── Setup ────────────────────────────────────────────────────────────────────\n14\t\n15\tafterEach(() => {\n16\t  cleanup();\n17\t  vi.clearAllMocks();\n18\t});\n19\t\n20\t// ─── Tests ────────────────────────────────────────────────────────────────────\n21\t\n22\tdescribe(\"SeedDataButton\", () => {\n23\t  describe(\"container\", () => {\n24\t    it(\"renders data-testid='seed-data-button' container\", () => {\n25\t      render(\n26\t        <SeedDataButton\n27\t          sendSeed={vi\n28\t            .fn<[], Promise<SeedResult>>()\n29\t            .mockResolvedValue({ success: true, eventCount: 0 })}\n30\t        />,\n31\t      );\n32\t      expect(screen.getByTestId(\"seed-data-button\")).toBeTruthy();\n33\t    });\n34\t  });\n35\t\n36\t  describe(\"button click\", () => {\n37\t    it(\"clicking the button calls sendSeed\", async () => {\n38\t      const mockSendSeed = vi\n39\t        .fn<[], Promise<SeedResult>>()\n40\t        .mockResolvedValue({ success: true, eventCount: 12000 });\n41\t      render(<SeedDataButton sendSeed={mockSendSeed} />);\n42\t\n43\t      fireEvent.click(screen.getByRole(\"button\", { name: /seed/i }));\n44\t\n45\t      await waitFor(() => expect(mockSendSeed).toHaveBeenCalledTimes(1));\n46\t    });\n47\t  });\n48\t\n49\t  describe(\"loading state\", () => {\n50\t    it(\"disables the button while seed is in progress\", async () => {\n51\t      let resolvePromise!: (v: SeedResult) => void;\n52\t      const mockSendSeed = vi.fn<[], Promise<SeedResult>>().mockReturnValue(\n53\t        new Promise<SeedResult>((resolve) => {\n54\t          resolvePromise = resolve;\n55\t        }),\n56\t      );\n57\t      render(<SeedDataButton sendSeed={mockSendSeed} />);\n58\t\n59\t      fireEvent.click(screen.getByRole(\"button\", { name: /seed/i }));\n60\t\n61\t      await waitFor(() => {\n62\t        const btn = screen.getByRole(\"button\", { name: /seed/i });\n63\t        expect(btn).toHaveProperty(\"disabled\", true);\n64\t      });\n65\t\n66\t      resolvePromise({ success: true, eventCount: 12000 });\n67\t\n68\t      await waitFor(() => {\n69\t        const btn = screen.getByRole(\"button\", { name: /seed/i });\n70\t        expect(btn).toHaveProperty(\"disabled\", false);\n71\t      });\n72\t    });\n73\t  });\n74\t\n75\t  describe(\"result display\", () => {\n76\t    it(\"displays the event count on successful completion\", async () => {\n77\t      const mockSendSeed = vi\n78\t        .fn<[], Promise<SeedResult>>()\n79\t        .mockResolvedValue({ success: true, eventCount: 12000 });\n80\t      render(<SeedDataButton sendSeed={mockSendSeed} />);\n81\t\n82\t      fireEvent.click(screen.getByRole(\"button\", { name: /seed/i }));\n83\t\n84\t      await waitFor(() => {\n85\t        // Allow for comma-separated formatting or plain number\n86\t        expect(screen.queryByText(/12[,.]?000|12000/)).toBeTruthy();\n87\t      });\n88\t    });\n89\t\n90\t    it(\"shows an error message on failure\", async () => {\n91\t      const mockSendSeed = vi\n92\t        .fn<[], Promise<SeedResult>>()\n93\t        .mockResolvedValue({ success: false, error: \"Server error\" });\n94\t      render(<SeedDataButton sendSeed={mockSendSeed} />);\n95\t\n96\t      fireEvent.click(screen.getByRole(\"button\", { name: /seed/i }));\n97\t\n98\t      await waitFor(() => {\n99\t        expect(screen.queryByText(/error|failed/i)).toBeTruthy();\n100\t      });\n101\t    });\n102\t  });\n103\t});\n104\t"}]},"parent_tool_use_id":null,"session_id":"27b757f3-6d9d-4fd7-9868-cc1b8f1bb385","uuid":"28a97aa0-cd7e-4047-b371-6798c8a3ff7c","timestamp":"2026-04-15T17:56:40.915Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/test/__tests__/SeedDataButton.test.tsx","content":"// @vitest-environment jsdom\nimport {\n  cleanup,\n  fireEvent,\n  render,\n  screen,\n  waitFor,\n} from \"@testing-library/react\";\nimport { afterEach, describe, expect, it, vi } from \"vitest\";\nimport { SeedDataButton } from \"@/components/test/SeedDataButton\";\nimport type { SeedResult } from \"@/components/test/useEventSender\";\n\n// ─── Setup ────────────────────────────────────────────────────────────────────\n\nafterEach(() => {\n  cleanup();\n  vi.clearAllMocks();\n});\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\ndescribe(\"SeedDataButton\", () => {\n  describe(\"container\", () => {\n    it(\"renders data-testid='seed-data-button' container\", () => {\n      render(\n        <SeedDataButton\n          sendSeed={vi\n            .fn<[], Promise<SeedResult>>()\n            .mockResolvedValue({ success: true, eventCount: 0 })}\n        />,\n      );\n      expect(screen.getByTestId(\"seed-data-button\")).toBeTruthy();\n    });\n  });\n\n  describe(\"button click\", () => {\n    it(\"clicking the button calls sendSeed\", async () => {\n      const mockSendSeed = vi\n        .fn<[], Promise<SeedResult>>()\n        .mockResolvedValue({ success: true, eventCount: 12000 });\n      render(<SeedDataButton sendSeed={mockSendSeed} />);\n\n      fireEvent.click(screen.getByRole(\"button\", { name: /seed/i }));\n\n      await waitFor(() => expect(mockSendSeed).toHaveBeenCalledTimes(1));\n    });\n  });\n\n  describe(\"loading state\", () => {\n    it(\"disables the button while seed is in progress\", async () => {\n      let resolvePromise!: (v: SeedResult) => void;\n      const mockSendSeed = vi.fn<[], Promise<SeedResult>>().mockReturnValue(\n        new Promise<SeedResult>((resolve) => {\n          resolvePromise = resolve;\n        }),\n      );\n      render(<SeedDataButton sendSeed={mockSendSeed} />);\n\n      fireEvent.click(screen.getByRole(\"button\", { name: /seed/i }));\n\n      await waitFor(() => {\n        const btn = screen.getByRole(\"button\", { name: /seed/i });\n        expect(btn).toHaveProperty(\"disabled\", true);\n      });\n\n      resolvePromise({ success: true, eventCount: 12000 });\n\n      await waitFor(() => {\n        const btn = screen.getByRole(\"button\", { name: /seed/i });\n        expect(btn).toHaveProperty(\"disabled\", false);\n      });\n    });\n  });\n\n  describe(\"result display\", () => {\n    it(\"displays the event count on successful completion\", async () => {\n      const mockSendSeed = vi\n        .fn<[], Promise<SeedResult>>()\n        .mockResolvedValue({ success: true, eventCount: 12000 });\n      render(<SeedDataButton sendSeed={mockSendSeed} />);\n\n      fireEvent.click(screen.getByRole(\"button\", { name: /seed/i }));\n\n      await waitFor(() => {\n        // Allow for comma-separated formatting or plain number\n        expect(screen.queryByText(/12[,.]?000|12000/)).toBeTruthy();\n      });\n    });\n\n    it(\"shows an error message on failure\", async () => {\n      const mockSendSeed = vi\n        .fn<[], Promise<SeedResult>>()\n        .mockResolvedValue({ success: false, error: \"Server error\" });\n      render(<SeedDataButton sendSeed={mockSendSeed} />);\n\n      fireEvent.click(screen.getByRole(\"button\", { name: /seed/i }));\n\n      await waitFor(() => {\n        expect(screen.queryByText(/error|failed/i)).toBeTruthy();\n      });\n    });\n  });\n});\n","numLines":104,"startLine":1,"totalLines":104}}}
