───────────────────────────────\n61\t\n62\tdescribe(\"useUserProfile\", () => {\n63\t  describe(\"initial fetch\", () => {\n64\t    it(\"fetches profile from /api/users/{id} on mount\", async () => {\n65\t      renderHook(() => useUserProfile(\"user@example.com\"));\n66\t      await waitFor(() => expect(mockFetch).toHaveBeenCalled());\n67\t      const calledUrl = mockFetch.mock.calls[0][0] as string;\n68\t      expect(calledUrl).toBe(\"/api/users/user%40example.com\");\n69\t    });\n70\t\n71\t    it(\"populates profile with API response data on success\", async () => {\n72\t      const { result } = renderHook(() => useUserProfile(\"user@example.com\"));\n73\t      await waitFor(() => expect(result.current.profile).not.toBeNull());\n74\t      expect(result.current.profile?.resolved_id).toBe(\"user@example.com\");\n75\t      expect(result.current.profile?.identity_cluster.user_ids).toEqual([\n76\t        \"user@example.com\",\n77\t      ]);\n78\t      expect(result.current.profile?.identity_cluster.device_ids).toEqual([\n79\t        \"device-abc\",\n80\t        \"device-xyz\",\n81\t      ]);\n82\t      expect(result.current.profile?.events).toHaveLength(1);\n83\t    });\n84\t  });\n85\t\n86\t  describe(\"loading state\", () => {\n87\t    it(\"sets loading to true during fetch, false after completion\", async () => {\n88\t      let resolveFetch!: (v: unknown) => void;\n89\t      mockFetch.mockReturnValueOnce(\n90\t        new Promise((resolve) => {\n91\t          resolveFetch = resolve;\n92\t        }),\n93\t      );\n94\t\n95\t      const { result } = renderHook(() => useUserProfile(\"user@example.com\"));\n96\t      await waitFor(() => expect(result.current.loading).toBe(true));\n97\t\n98\t      resolveFetch({\n99\t        ok: true,\n100\t        status: 200,\n101\t        json: () => Promise.resolve(sampleProfile),\n102\t      });\n103\t\n104\t      await waitFor(() => expect(result.current.loading).toBe(false));\n105\t    });\n106\t\n107\t    it(\"sets loading to f