{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DCUUwbbWPvkqNzdNPxX3yN","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { act, renderHook, waitFor } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport { useEventExplorer } from \"@/components/explore/useEventExplorer\";\n5\t\n6\t// ─── Fixtures ─────────────────────────────────────────────────────────────────\n7\t\n8\tconst sampleEvent = {\n9\t  event_id: \"uuid-1\",\n10\t  event_name: \"Page Viewed\",\n11\t  timestamp: \"2026-04-15T10:00:00.000Z\",\n12\t  device_id: \"dev-1\",\n13\t  user_id: null,\n14\t  properties: \"{}\",\n15\t  ingested_at: \"2026-04-15T10:00:00.100Z\",\n16\t  resolved_id: \"dev-1\",\n17\t};\n18\t\n19\tfunction makeFetchResponse(\n20\t  events: unknown[],\n21\t  next_cursor: string | null = null,\n22\t) {\n23\t  return Promise.resolve({\n24\t    ok: true,\n25\t    json: () => Promise.resolve({ events, next_cursor }),\n26\t  });\n27\t}\n28\t\n29\t// ─── Setup ────────────────────────────────────────────────────────────────────\n30\t\n31\tconst mockFetch = vi.fn();\n32\t\n33\tbeforeEach(() => {\n34\t  vi.stubGlobal(\"fetch\", mockFetch);\n35\t  mockFetch.mockReturnValue(makeFetchResponse([sampleEvent], null));\n36\t});\n37\t\n38\tafterEach(() => {\n39\t  vi.clearAllMocks();\n40\t  vi.unstubAllGlobals();\n41\t});\n42\t\n43\t// ─── Tests ────────────────────────────────────────────────────────────────────\n44\t\n45\tdescribe(\"useEventExplorer\", () => {\n46\t  describe(\"initial fetch\", () => {\n47\t    it(\"fetches events from /api/events/list on mount\", async () => {\n48\t      renderHook(() => useEventExplorer());\n49\t      await waitFor(() => expect(mockFetch).toHaveBeenCalled());\n50\t      const url = new URL(mockFetch.mock.calls[0][0] as string);\n51\t      expect(url.pathname).toBe(\"/api/events/list\");\n52\t    });\n53\t\n54\t    it(\"populates events after initial fetch\", async () => {\n55\t      const { result } = renderHook(() => useEventExplorer());\n56\t      await waitFor(() => expect(result.current.events).toHaveLength(1));\n57\t      expect(result.current.events[0].event_id).toBe(\"uuid-1\");\n58\t    });\n59\t  });\n60\t\n61\t  describe(\"loading state\", () => {\n62\t    it(\"sets loading to true during fetch\", async () => {\n63\t      let resolveFetch!: (v: unknown) => void;\n64\t      mockFetch.mockReturnValueOnce(\n65\t        new Promise((resolve) => {\n66\t          resolveFetch = resolve;\n67\t        }),\n68\t      );\n69\t\n70\t      const { result } = renderHook(() => useEventExplorer());\n71\t      // Loading should become true while the fetch is pending\n72\t      await waitFor(() => expect(result.current.loading).toBe(true));\n73\t\n74\t      // Resolve the fetch so cleanup doesn't hang\n75\t      act(() => {\n76\t        resolveFetch({\n77\t          ok: true,\n78\t          json: () => Promise.resolve({ events: [], next_cursor: null }),\n79\t        });\n80\t      });\n81\t      await waitFor(() => expect(result.current.loading).toBe(false));\n82\t    });\n83\t\n84\t    it(\"sets loading to false after fetch completes\", async () => {\n85\t      const { result } = renderHook(() => useEventExplorer());\n86\t      await waitFor(() => expect(result.current.loading).toBe(false));\n87\t      expect(result.current.events).toHaveLength(1);\n88\t    });\n89\t  });\n90\t\n91\t  describe(\"hasMore\", () => {\n92\t    it(\"hasMore is false when API returns next_cursor: null\", async () => {\n93\t      mockFetch.mockReturnValue(makeFetchResponse([sampleEvent], null));\n94\t      const { result } = renderHook(() => useEventExplorer());\n95\t      await waitFor(() => expect(result.current.loading).toBe(false));\n96\t      expect(result.current.hasMore).toBe(false);\n97\t    });\n98\t\n99\t    it(\"hasMore is true when API returns a next_cursor\", async () => {\n100\t      mockFetch.mockReturnValue(\n101\t        makeFetchResponse([sampleEvent], \"2026-04-14T10:00:00.000Z\"),\n102\t      );\n103\t      const { result } = renderHook(() => useEventExplorer());\n104\t      await waitFor(() => expect(result.current.loading).toBe(false));\n105\t      expect(result.current.hasMore).toBe(true);\n106\t    });\n107\t  });\n108\t\n109\t  describe(\"loadMore\", () => {\n110\t    it(\"appends the next page of events using the cursor\", async () => {\n111\t      const secondEvent = { ...sampleEvent, event_id: \"uuid-2\" };\n112\t      mockFetch\n113\t        .mockReturnValueOnce(\n114\t          makeFetchResponse([sampleEvent], \"2026-04-14T10:00:00.000Z\"),\n115\t        )\n116\t        .mockReturnValueOnce(makeFetchResponse([secondEvent], null));\n117\t\n118\t      const { result } = renderHook(() => useEventExplorer());\n119\t      await waitFor(() => expect(result.current.loading).toBe(false));\n120\t\n121\t      act(() => {\n122\t        result.current.loadMore();\n123\t      });\n124\t      await waitFor(() => expect(result.current.events).toHaveLength(2));\n125\t\n126\t      // Second fetch should include the cursor as 'before' param\n127\t      const url = new URL(mockFetch.mock.calls[1][0] as string);\n128\t      expect(url.searchParams.get(\"before\")).toBe(\"2026-04-14T10:00:00.000Z\");\n129\t    });\n130\t\n131\t    it(\"does not fetch if hasMore is false\", async () => {\n132\t      // Initial fetch returns no cursor → hasMore=false\n133\t      mockFetch.mockReturnValue(makeFetchResponse([sampleEvent], null));\n134\t      const { result } = renderHook(() => useEventExplorer());\n135\t      await waitFor(() => expect(result.current.loading).toBe(false));\n136\t\n137\t      act(() => {\n138\t        result.current.loadMore();\n139\t      });\n140\t\n141\t      // Still only 1 fetch call (the initial one)\n142\t      expect(mockFetch).toHaveBeenCalledTimes(1);\n143\t    });\n144\t  });\n145\t\n146\t  describe(\"setFilter\", () => {\n147\t    it(\"re-fetches with event_name param when filter is set\", async () => {\n148\t      const { result } = renderHook(() => useEventExplorer());\n149\t      await waitFor(() => expect(result.current.loading).toBe(false));\n150\t\n151\t      act(() => {\n152\t        result.current.setFilter(\"Purchase Completed\");\n153\t      });\n154\t      await waitFor(() => expect(result.current.loading).toBe(false));\n155\t\n156\t      // Second fetch call should include event_name\n157\t      const url = new URL(mockFetch.mock.calls[1][0] as string);\n158\t      expect(url.searchParams.get(\"event_name\")).toBe(\"Purchase Completed\");\n159\t    });\n160\t\n161\t    it(\"resets events list when filter changes\", async () => {\n162\t      // Second fetch returns a different event\n163\t      const filteredEvent = {\n164\t        ...sampleEvent,\n165\t        event_id: \"uuid-filtered\",\n166\t        event_name: \"Purchase Completed\",\n167\t      };\n168\t      mockFetch\n169\t        .mockReturnValueOnce(makeFetchResponse([sampleEvent], null))\n170\t        .mockReturnValueOnce(makeFetchResponse([filteredEvent], null));\n171\t\n172\t      const { result } = renderHook(() => useEventExplorer());\n173\t      await waitFor(() => expect(result.current.events).toHaveLength(1));\n174\t\n175\t      act(() => {\n176\t        result.current.setFilter(\"Purchase Completed\");\n177\t      });\n178\t      await waitFor(() =>\n179\t        expect(result.current.events[0]?.event_id).toBe(\"uuid-filtered\"),\n180\t      );\n181\t      // Should be exactly the filtered result, not combined\n182\t      expect(result.current.events).toHaveLength(1);\n183\t    });\n184\t\n185\t    it(\"updates filter state\", async () => {\n186\t      const { result } = renderHook(() => useEventExplorer());\n187\t      await waitFor(() => expect(result.current.loading).toBe(false));\n188\t\n189\t      act(() => {\n190\t        result.current.setFilter(\"Button Clicked\");\n191\t      });\n192\t      expect(result.current.filter).toBe(\"Button Clicked\");\n193\t    });\n194\t\n195\t    it(\"passes null filter (clears filter)\", async () => {\n196\t      const { result } = renderHook(() => useEventExplorer());\n197\t      await waitFor(() => expect(result.current.loading).toBe(false));\n198\t\n199\t      act(() => {\n200\t        result.current.setFilter(null);\n201\t      });\n202\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(2));\n203\t\n204\t      const url = new URL(mockFetch.mock.calls[1][0] as string);\n205\t      expect(url.searchParams.get(\"event_name\")).toBeNull();\n206\t    });\n207\t  });\n208\t});\n209\t"}]},"parent_tool_use_id":null,"session_id":"27b757f3-6d9d-4fd7-9868-cc1b8f1bb385","uuid":"7416daaf-7841-4500-a344-b46f6d1dae5d","timestamp":"2026-04-15T17:46:19.761Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/explore/__tests__/useEventExplorer.test.ts","content":"// @vitest-environment jsdom\nimport { act, renderHook, waitFor } from \"@testing-library/react\";\nimport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\nimport { useEventExplorer } from \"@/components/explore/useEventExplorer\";\n\n// ─── Fixtures ─────────────────────────────────────────────────────────────────\n\nconst sampleEvent = {\n  event_id: \"uuid-1\",\n  event_name: \"Page Viewed\",\n  timestamp: \"2026-04-15T10:00:00.000Z\",\n  device_id: \"dev-1\",\n  user_id: null,\n  properties: \"{}\",\n  ingested_at: \"2026-04-15T10:00:00.100Z\",\n  resolved_id: \"dev-1\",\n};\n\nfunction makeFetchResponse(\n  events: unknown[],\n  next_cursor: string | null = null,\n) {\n  return Promise.resolve({\n    ok: true,\n    json: () => Promise.resolve({ events, next_cursor }),\n  });\n}\n\n// ─── Setup ────────────────────────────────────────────────────────────────────\n\nconst mockFetch = vi.fn();\n\nbeforeEach(() => {\n  vi.stubGlobal(\"fetch\", mockFetch);\n  mockFetch.mockReturnValue(makeFetchResponse([sampleEvent], null));\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n  vi.unstubAllGlobals();\n});\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\ndescribe(\"useEventExplorer\", () => {\n  describe(\"initial fetch\", () => {\n    it(\"fetches events from /api/events/list on mount\", async () => {\n      renderHook(() => useEventExplorer());\n      await waitFor(() => expect(mockFetch).toHaveBeenCalled());\n      const url = new URL(mockFetch.mock.calls[0][0] as string);\n      expect(url.pathname).toBe(\"/api/events/list\");\n    });\n\n    it(\"populates events after initial fetch\", async () => {\n      const { result } = renderHook(() => useEventExplorer());\n      await waitFor(() => expect(result.current.events).toHaveLength(1));\n      expect(result.current.events[0].event_id).toBe(\"uuid-1\");\n    });\n  });\n\n  describe(\"loading state\", () => {\n    it(\"sets loading to true during fetch\", async () => {\n      let resolveFetch!: (v: unknown) => void;\n      mockFetch.mockReturnValueOnce(\n        new Promise((resolve) => {\n          resolveFetch = resolve;\n        }),\n      );\n\n      const { result } = renderHook(() => useEventExplorer());\n      // Loading should become true while the fetch is pending\n      await waitFor(() => expect(result.current.loading).toBe(true));\n\n      // Resolve the fetch so cleanup doesn't hang\n      act(() => {\n        resolveFetch({\n          ok: true,\n          json: () => Promise.resolve({ events: [], next_cursor: null }),\n        });\n      });\n      await waitFor(() => expect(result.current.loading).toBe(false));\n    });\n\n    it(\"sets loading to false after fetch completes\", async () => {\n      const { result } = renderHook(() => useEventExplorer());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n      expect(result.current.events).toHaveLength(1);\n    });\n  });\n\n  describe(\"hasMore\", () => {\n    it(\"hasMore is false when API returns next_cursor: null\", async () => {\n      mockFetch.mockReturnValue(makeFetchResponse([sampleEvent], null));\n      const { result } = renderHook(() => useEventExplorer());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n      expect(result.current.hasMore).toBe(false);\n    });\n\n    it(\"hasMore is true when API returns a next_cursor\", async () => {\n      mockFetch.mockReturnValue(\n        makeFetchResponse([sampleEvent], \"2026-04-14T10:00:00.000Z\"),\n      );\n      const { result } = renderHook(() => useEventExplorer());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n      expect(result.current.hasMore).toBe(true);\n    });\n  });\n\n  describe(\"loadMore\", () => {\n    it(\"appends the next page of events using the cursor\", async () => {\n      const secondEvent = { ...sampleEvent, event_id: \"uuid-2\" };\n      mockFetch\n        .mockReturnValueOnce(\n          makeFetchResponse([sampleEvent], \"2026-04-14T10:00:00.000Z\"),\n        )\n        .mockReturnValueOnce(makeFetchResponse([secondEvent], null));\n\n      const { result } = renderHook(() => useEventExplorer());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      act(() => {\n        result.current.loadMore();\n      });\n      await waitFor(() => expect(result.current.events).toHaveLength(2));\n\n      // Second fetch should include the cursor as 'before' param\n      const url = new URL(mockFetch.mock.calls[1][0] as string);\n      expect(url.searchParams.get(\"before\")).toBe(\"2026-04-14T10:00:00.000Z\");\n    });\n\n    it(\"does not fetch if hasMore is false\", async () => {\n      // Initial fetch returns no cursor → hasMore=false\n      mockFetch.mockReturnValue(makeFetchResponse([sampleEvent], null));\n      const { result } = renderHook(() => useEventExplorer());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      act(() => {\n        result.current.loadMore();\n      });\n\n      // Still only 1 fetch call (the initial one)\n      expect(mockFetch).toHaveBeenCalledTimes(1);\n    });\n  });\n\n  describe(\"setFilter\", () => {\n    it(\"re-fetches with event_name param when filter is set\", async () => {\n      const { result } = renderHook(() => useEventExplorer());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      act(() => {\n        result.current.setFilter(\"Purchase Completed\");\n      });\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      // Second fetch call should include event_name\n      const url = new URL(mockFetch.mock.calls[1][0] as string);\n      expect(url.searchParams.get(\"event_name\")).toBe(\"Purchase Completed\");\n    });\n\n    it(\"resets events list when filter changes\", async () => {\n      // Second fetch returns a different event\n      const filteredEvent = {\n        ...sampleEvent,\n        event_id: \"uuid-filtered\",\n        event_name: \"Purchase Completed\",\n      };\n      mockFetch\n        .mockReturnValueOnce(makeFetchResponse([sampleEvent], null))\n        .mockReturnValueOnce(makeFetchResponse([filteredEvent], null));\n\n      const { result } = renderHook(() => useEventExplorer());\n      await waitFor(() => expect(result.current.events).toHaveLength(1));\n\n      act(() => {\n        result.current.setFilter(\"Purchase Completed\");\n      });\n      await waitFor(() =>\n        expect(result.current.events[0]?.event_id).toBe(\"uuid-filtered\"),\n      );\n      // Should be exactly the filtered result, not combined\n      expect(result.current.events).toHaveLength(1);\n    });\n\n    it(\"updates filter state\", async () => {\n      const { result } = renderHook(() => useEventExplorer());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      act(() => {\n        result.current.setFilter(\"Button Clicked\");\n      });\n      expect(result.current.filter).toBe(\"Button Clicked\");\n    });\n\n    it(\"passes null filter (clears filter)\", async () => {\n      const { result } = renderHook(() => useEventExplorer());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      act(() => {\n        result.current.setFilter(null);\n      });\n      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(2));\n\n      const url = new URL(mockFetch.mock.calls[1][0] as string);\n      expect(url.searchParams.get(\"event_name\")).toBeNull();\n    });\n  });\n});\n","numLines":209,"startLine":1,"totalLines":209}}}
