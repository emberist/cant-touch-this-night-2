{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01WG9pmprQpoQtcJh6X1m8Bm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EbR7vTTUxjUwKwZTCHciB7","name":"Write","input":{"file_path":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/test/useEventSender.ts","content":"\"use client\";\n\nimport { useCallback, useState } from \"react\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface EventPayload {\n  event_name: string;\n  device_id?: string;\n  user_id?: string;\n  timestamp?: string;\n  properties?: Record<string, unknown>;\n}\n\nexport interface SendResult {\n  success: boolean;\n  error?: string;\n}\n\nexport interface SeedResult {\n  success: boolean;\n  eventCount?: number;\n  error?: string;\n}\n\nexport interface UseEventSenderResult {\n  lastDeviceId: string | null;\n  sendEvent: (payload: EventPayload) => Promise<SendResult>;\n  sendSeed: () => Promise<SeedResult>;\n  loading: boolean;\n}\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nexport function generateId(): string {\n  return Math.random().toString(36).slice(2, 10);\n}\n\n// ─── Hook ─────────────────────────────────────────────────────────────────────\n\nexport function useEventSender(): UseEventSenderResult {\n  const [lastDeviceId, setLastDeviceId] = useState<string | null>(null);\n  const [loading, setLoading] = useState(false);\n\n  const sendEvent = useCallback(\n    async (payload: EventPayload): Promise<SendResult> => {\n      setLoading(true);\n      try {\n        const res = await fetch(\"/api/events\", {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify(payload),\n        });\n\n        if (!res.ok) {\n          const data = (await res.json()) as { error?: string };\n          return {\n            success: false,\n            error: data.error ?? `HTTP ${res.status}`,\n          };\n        }\n\n        if (payload.device_id) {\n          setLastDeviceId(payload.device_id);\n        }\n\n        return { success: true };\n      } catch (err) {\n        return {\n          success: false,\n          error: err instanceof Error ? err.message : \"Unknown error\",\n        };\n      } finally {\n        setLoading(false);\n      }\n    },\n    [],\n  );\n\n  const sendSeed = useCallback(async (): Promise<SeedResult> => {\n    setLoading(true);\n    try {\n      const res = await fetch(\"/api/seed\", { method: \"POST\" });\n\n      if (!res.ok) {\n        const data = (await res.json()) as { error?: string };\n        return {\n          success: false,\n          error: data.error ?? `HTTP ${res.status}`,\n        };\n      }\n\n      const statusRes = await fetch(\"/api/seed/status\");\n      const statusData = (await statusRes.json()) as {\n        event_count?: number;\n        user_count?: number;\n      };\n\n      return { success: true, eventCount: statusData.event_count };\n    } catch (err) {\n      return {\n        success: false,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      };\n    } finally {\n      setLoading(false);\n    }\n  }, []);\n\n  return { lastDeviceId, sendEvent, sendSeed, loading };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":522,"cache_read_input_tokens":94272,"cache_creation":{"ephemeral_5m_input_tokens":522,"ephemeral_1h_input_tokens":0},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"27b757f3-6d9d-4fd7-9868-cc1b8f1bb385","uuid":"11beef9f-a9d5-4233-adec-47bf458bcff5"}
