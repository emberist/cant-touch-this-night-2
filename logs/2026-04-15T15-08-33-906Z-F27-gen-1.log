e MUI renders the helper text in multiple places for accessibility reasons. Let me switch to `queryAllByText` and check if at least one match exists, which should be cleaner than trying to handle the multiple elements case with error handling.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2522,"cache_read_input_tokens":109118,"cache_creation":{"ephemeral_5m_input_tokens":2522,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"27b757f3-6d9d-4fd7-9868-cc1b8f1bb385","uuid":"2ac78f2e-052e-4b0d-b9c1-446363fedfe4"}
