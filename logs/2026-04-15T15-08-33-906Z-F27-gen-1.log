{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KbgsYFQ2Ypf89RQeh3r51z","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { act, renderHook, waitFor } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport { useFunnels } from \"@/components/funnels/useFunnels\";\n5\t\n6\t// ─── Fixtures ─────────────────────────────────────────────────────────────────\n7\t\n8\tconst sampleSchema = {\n9\t  event_names: [\"Page Viewed\", \"Signup Completed\", \"Purchase Completed\"],\n10\t  properties: {\n11\t    \"Purchase Completed\": {\n12\t      amount: \"numeric\" as const,\n13\t      currency: \"string\" as const,\n14\t    },\n15\t  },\n16\t};\n17\t\n18\tconst sampleFunnelResponse = {\n19\t  steps: [\n20\t    {\n21\t      name: \"Page Viewed\",\n22\t      users: 1000,\n23\t      conversion_from_prev: null,\n24\t      conversion_overall: 1.0,\n25\t    },\n26\t    {\n27\t      name: \"Purchase Completed\",\n28\t      users: 88,\n29\t      conversion_from_prev: 0.088,\n30\t      conversion_overall: 0.088,\n31\t    },\n32\t  ],\n33\t};\n34\t\n35\t// ─── Fetch mocking ────────────────────────────────────────────────────────────\n36\t\n37\tconst mockFetch = vi.fn();\n38\t\n39\tfunction makeResponse(body: unknown) {\n40\t  return Promise.resolve({\n41\t    ok: true,\n42\t    json: () => Promise.resolve(body),\n43\t  });\n44\t}\n45\t\n46\tfunction schemaResponse() {\n47\t  return makeResponse(sampleSchema);\n48\t}\n49\t\n50\tfunction funnelResponse() {\n51\t  return makeResponse(sampleFunnelResponse);\n52\t}\n53\t\n54\tfunction errorResponse() {\n55\t  return Promise.reject(new Error(\"network error\"));\n56\t}\n57\t\n58\tbeforeEach(() => {\n59\t  vi.stubGlobal(\"fetch\", mockFetch);\n60\t  mockFetch.mockImplementation((url: string) => {\n61\t    if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n62\t    return errorResponse();\n63\t  });\n64\t});\n65\t\n66\tafterEach(() => {\n67\t  vi.clearAllMocks();\n68\t  vi.unstubAllGlobals();\n69\t});\n70\t\n71\t// ─── Tests ────────────────────────────────────────────────────────────────────\n72\t\n73\tdescribe(\"useFunnels\", () => {\n74\t  describe(\"initial state\", () => {\n75\t    it(\"starts with 2 empty steps\", () => {\n76\t      const { result } = renderHook(() => useFunnels());\n77\t      expect(result.current.steps).toHaveLength(2);\n78\t      expect(result.current.steps[0]).toBe(\"\");\n79\t      expect(result.current.steps[1]).toBe(\"\");\n80\t    });\n81\t\n82\t    it(\"starts with null result\", () => {\n83\t      const { result } = renderHook(() => useFunnels());\n84\t      expect(result.current.result).toBeNull();\n85\t    });\n86\t\n87\t    it(\"startDate defaults to approximately 30 days ago (YYYY-MM-DD format)\", () => {\n88\t      const { result } = renderHook(() => useFunnels());\n89\t      const today = new Date();\n90\t      const thirtyDaysAgo = new Date(today);\n91\t      thirtyDaysAgo.setDate(today.getDate() - 30);\n92\t      const expectedStart = thirtyDaysAgo.toISOString().slice(0, 10);\n93\t      expect(result.current.startDate).toBe(expectedStart);\n94\t    });\n95\t\n96\t    it(\"endDate defaults to today (YYYY-MM-DD format)\", () => {\n97\t      const { result } = renderHook(() => useFunnels());\n98\t      const today = new Date().toISOString().slice(0, 10);\n99\t      expect(result.current.endDate).toBe(today);\n100\t    });\n101\t  });\n102\t\n103\t  describe(\"addStep\", () => {\n104\t    it(\"appends an empty step\", () => {\n105\t      const { result } = renderHook(() => useFunnels());\n106\t      act(() => {\n107\t        result.current.addStep();\n108\t      });\n109\t      expect(result.current.steps).toHaveLength(3);\n110\t      expect(result.current.steps[2]).toBe(\"\");\n111\t    });\n112\t\n113\t    it(\"is a no-op when already at 5 steps\", () => {\n114\t      const { result } = renderHook(() => useFunnels());\n115\t      act(() => {\n116\t        result.current.addStep();\n117\t        result.current.addStep();\n118\t        result.current.addStep();\n119\t      });\n120\t      expect(result.current.steps).toHaveLength(5);\n121\t      act(() => {\n122\t        result.current.addStep();\n123\t      });\n124\t      expect(result.current.steps).toHaveLength(5);\n125\t    });\n126\t  });\n127\t\n128\t  describe(\"removeStep\", () => {\n129\t    it(\"removes a step at the given index\", () => {\n130\t      const { result } = renderHook(() => useFunnels());\n131\t      act(() => {\n132\t        result.current.setStep(0, \"Page Viewed\");\n133\t        result.current.setStep(1, \"Purchase Completed\");\n134\t        result.current.addStep();\n135\t        result.current.setStep(2, \"Signup Completed\");\n136\t      });\n137\t      act(() => {\n138\t        result.current.removeStep(1);\n139\t      });\n140\t      expect(result.current.steps).toHaveLength(2);\n141\t      expect(result.current.steps[0]).toBe(\"Page Viewed\");\n142\t      expect(result.current.steps[1]).toBe(\"Signup Completed\");\n143\t    });\n144\t\n145\t    it(\"is a no-op when at 2 steps\", () => {\n146\t      const { result } = renderHook(() => useFunnels());\n147\t      expect(result.current.steps).toHaveLength(2);\n148\t      act(() => {\n149\t        result.current.removeStep(0);\n150\t      });\n151\t      expect(result.current.steps).toHaveLength(2);\n152\t    });\n153\t  });\n154\t\n155\t  describe(\"setStep\", () => {\n156\t    it(\"updates a step at the given index\", () => {\n157\t      const { result } = renderHook(() => useFunnels());\n158\t      act(() => {\n159\t        result.current.setStep(0, \"Page Viewed\");\n160\t      });\n161\t      expect(result.current.steps[0]).toBe(\"Page Viewed\");\n162\t    });\n163\t\n164\t    it(\"does not affect other steps when updating one\", () => {\n165\t      const { result } = renderHook(() => useFunnels());\n166\t      act(() => {\n167\t        result.current.setStep(0, \"Page Viewed\");\n168\t        result.current.setStep(1, \"Purchase Completed\");\n169\t      });\n170\t      act(() => {\n171\t        result.current.setStep(0, \"Signup Completed\");\n172\t      });\n173\t      expect(result.current.steps[0]).toBe(\"Signup Completed\");\n174\t      expect(result.current.steps[1]).toBe(\"Purchase Completed\");\n175\t    });\n176\t  });\n177\t\n178\t  describe(\"runFunnel — validation\", () => {\n179\t    it(\"does not fetch when both steps are empty\", async () => {\n180\t      mockFetch.mockImplementation((url: string) => {\n181\t        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n182\t        return errorResponse();\n183\t      });\n184\t\n185\t      const { result } = renderHook(() => useFunnels());\n186\t      await waitFor(() => expect(result.current.loading).toBe(false));\n187\t\n188\t      act(() => {\n189\t        result.current.runFunnel();\n190\t      });\n191\t\n192\t      const funnelCalls = (mockFetch.mock.calls as [string, unknown][]).filter(\n193\t        ([url]) => (url as string).includes(\"/api/funnels\"),\n194\t      );\n195\t      expect(funnelCalls).toHaveLength(0);\n196\t    });\n197\t\n198\t    it(\"does not fetch when only one step is non-empty\", async () => {\n199\t      mockFetch.mockImplementation((url: string) => {\n200\t        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n201\t        return errorResponse();\n202\t      });\n203\t\n204\t      const { result } = renderHook(() => useFunnels());\n205\t      await waitFor(() => expect(result.current.loading).toBe(false));\n206\t\n207\t      act(() => {\n208\t        result.current.setStep(0, \"Page Viewed\");\n209\t      });\n210\t      act(() => {\n211\t        result.current.runFunnel();\n212\t      });\n213\t\n214\t      const funnelCalls = (mockFetch.mock.calls as [string, unknown][]).filter(\n215\t        ([url]) => (url as string).includes(\"/api/funnels\"),\n216\t      );\n217\t      expect(funnelCalls).toHaveLength(0);\n218\t    });\n219\t\n220\t    it(\"fetches /api/funnels when all steps are non-empty and date range is set\", async () => {\n221\t      mockFetch.mockImplementation((url: string) => {\n222\t        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n223\t        if ((url as string).includes(\"/api/funnels\")) return funnelResponse();\n224\t        return errorResponse();\n225\t      });\n226\t\n227\t      const { result } = renderHook(() => useFunnels());\n228\t      await waitFor(() => expect(result.current.loading).toBe(false));\n229\t\n230\t      act(() => {\n231\t        result.current.setStep(0, \"Page Viewed\");\n232\t        result.current.setStep(1, \"Purchase Completed\");\n233\t      });\n234\t      act(() => {\n235\t        result.current.runFunnel();\n236\t      });\n237\t\n238\t      await waitFor(() => {\n239\t        const calls = mockFetch.mock.calls as [string, unknown][];\n240\t        return calls.some(([url]) => (url as string).includes(\"/api/funnels\"));\n241\t      });\n242\t\n243\t      const funnelCalls = (mockFetch.mock.calls as [string, unknown][]).filter(\n244\t        ([url]) => (url as string).includes(\"/api/funnels\"),\n245\t      );\n246\t      expect(funnelCalls.length).toBeGreaterThan(0);\n247\t    });\n248\t  });\n249\t\n250\t  describe(\"loading state\", () => {\n251\t    it(\"sets loading=false after initial schema fetch\", async () => {\n252\t      const { result } = renderHook(() => useFunnels());\n253\t      await waitFor(() => expect(result.current.loading).toBe(false));\n254\t    });\n255\t\n256\t    it(\"sets loading=true during funnel fetch, false after\", async () => {\n257\t      let resolveFunnel!: (v: unknown) => void;\n258\t      mockFetch.mockImplementation((url: string) => {\n259\t        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n260\t        if ((url as string).includes(\"/api/funnels\")) {\n261\t          return new Promise((resolve) => {\n262\t            resolveFunnel = resolve;\n263\t          });\n264\t        }\n265\t        return errorResponse();\n266\t      });\n267\t\n268\t      const { result } = renderHook(() => useFunnels());\n269\t      await waitFor(() => expect(result.current.loading).toBe(false));\n270\t\n271\t      act(() => {\n272\t        result.current.setStep(0, \"Page Viewed\");\n273\t        result.current.setStep(1, \"Purchase Completed\");\n274\t      });\n275\t      act(() => {\n276\t        result.current.runFunnel();\n277\t      });\n278\t\n279\t      await waitFor(() => expect(result.current.loading).toBe(true));\n280\t\n281\t      act(() => {\n282\t        resolveFunnel({\n283\t          ok: true,\n284\t          json: () => Promise.resolve(sampleFunnelResponse),\n285\t        });\n286\t      });\n287\t\n288\t      await waitFor(() => expect(result.current.loading).toBe(false));\n289\t    });\n290\t  });\n291\t\n292\t  describe(\"result state\", () => {\n293\t    it(\"stores funnel response in result on success\", async () => {\n294\t      mockFetch.mockImplementation((url: string) => {\n295\t        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n296\t        if ((url as string).includes(\"/api/funnels\")) return funnelResponse();\n297\t        return errorResponse();\n298\t      });\n299\t\n300\t      const { result } = renderHook(() => useFunnels());\n301\t      await waitFor(() => expect(result.current.loading).toBe(false));\n302\t\n303\t      act(() => {\n304\t        result.current.setStep(0, \"Page Viewed\");\n305\t        result.current.setStep(1, \"Purchase Completed\");\n306\t      });\n307\t      act(() => {\n308\t        result.current.runFunnel();\n309\t      });\n310\t\n311\t      await waitFor(() => expect(result.current.result).not.toBeNull());\n312\t      expect(result.current.result?.steps).toHaveLength(2);\n313\t    });\n314\t\n315\t    it(\"sets error state on fetch failure\", async () => {\n316\t      mockFetch.mockImplementation((url: string) => {\n317\t        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n318\t        if ((url as string).includes(\"/api/funnels\")) return errorResponse();\n319\t        return errorResponse();\n320\t      });\n321\t\n322\t      const { result } = renderHook(() => useFunnels());\n323\t      await waitFor(() => expect(result.current.loading).toBe(false));\n324\t\n325\t      act(() => {\n326\t        result.current.setStep(0, \"Page Viewed\");\n327\t        result.current.setStep(1, \"Purchase Completed\");\n328\t      });\n329\t      act(() => {\n330\t        result.current.runFunnel();\n331\t      });\n332\t\n333\t      await waitFor(() => expect(result.current.error).not.toBeNull());\n334\t      expect(result.current.result).toBeNull();\n335\t    });\n336\t  });\n337\t});\n338\t"}]},"parent_tool_use_id":null,"session_id":"27b757f3-6d9d-4fd7-9868-cc1b8f1bb385","uuid":"9cf2f813-96d3-4f02-87b4-50209a48d422","timestamp":"2026-04-15T17:46:27.327Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/funnels/__tests__/useFunnels.test.ts","content":"// @vitest-environment jsdom\nimport { act, renderHook, waitFor } from \"@testing-library/react\";\nimport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\nimport { useFunnels } from \"@/components/funnels/useFunnels\";\n\n// ─── Fixtures ─────────────────────────────────────────────────────────────────\n\nconst sampleSchema = {\n  event_names: [\"Page Viewed\", \"Signup Completed\", \"Purchase Completed\"],\n  properties: {\n    \"Purchase Completed\": {\n      amount: \"numeric\" as const,\n      currency: \"string\" as const,\n    },\n  },\n};\n\nconst sampleFunnelResponse = {\n  steps: [\n    {\n      name: \"Page Viewed\",\n      users: 1000,\n      conversion_from_prev: null,\n      conversion_overall: 1.0,\n    },\n    {\n      name: \"Purchase Completed\",\n      users: 88,\n      conversion_from_prev: 0.088,\n      conversion_overall: 0.088,\n    },\n  ],\n};\n\n// ─── Fetch mocking ────────────────────────────────────────────────────────────\n\nconst mockFetch = vi.fn();\n\nfunction makeResponse(body: unknown) {\n  return Promise.resolve({\n    ok: true,\n    json: () => Promise.resolve(body),\n  });\n}\n\nfunction schemaResponse() {\n  return makeResponse(sampleSchema);\n}\n\nfunction funnelResponse() {\n  return makeResponse(sampleFunnelResponse);\n}\n\nfunction errorResponse() {\n  return Promise.reject(new Error(\"network error\"));\n}\n\nbeforeEach(() => {\n  vi.stubGlobal(\"fetch\", mockFetch);\n  mockFetch.mockImplementation((url: string) => {\n    if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n    return errorResponse();\n  });\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n  vi.unstubAllGlobals();\n});\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\ndescribe(\"useFunnels\", () => {\n  describe(\"initial state\", () => {\n    it(\"starts with 2 empty steps\", () => {\n      const { result } = renderHook(() => useFunnels());\n      expect(result.current.steps).toHaveLength(2);\n      expect(result.current.steps[0]).toBe(\"\");\n      expect(result.current.steps[1]).toBe(\"\");\n    });\n\n    it(\"starts with null result\", () => {\n      const { result } = renderHook(() => useFunnels());\n      expect(result.current.result).toBeNull();\n    });\n\n    it(\"startDate defaults to approximately 30 days ago (YYYY-MM-DD format)\", () => {\n      const { result } = renderHook(() => useFunnels());\n      const today = new Date();\n      const thirtyDaysAgo = new Date(today);\n      thirtyDaysAgo.setDate(today.getDate() - 30);\n      const expectedStart = thirtyDaysAgo.toISOString().slice(0, 10);\n      expect(result.current.startDate).toBe(expectedStart);\n    });\n\n    it(\"endDate defaults to today (YYYY-MM-DD format)\", () => {\n      const { result } = renderHook(() => useFunnels());\n      const today = new Date().toISOString().slice(0, 10);\n      expect(result.current.endDate).toBe(today);\n    });\n  });\n\n  describe(\"addStep\", () => {\n    it(\"appends an empty step\", () => {\n      const { result } = renderHook(() => useFunnels());\n      act(() => {\n        result.current.addStep();\n      });\n      expect(result.current.steps).toHaveLength(3);\n      expect(result.current.steps[2]).toBe(\"\");\n    });\n\n    it(\"is a no-op when already at 5 steps\", () => {\n      const { result } = renderHook(() => useFunnels());\n      act(() => {\n        result.current.addStep();\n        result.current.addStep();\n        result.current.addStep();\n      });\n      expect(result.current.steps).toHaveLength(5);\n      act(() => {\n        result.current.addStep();\n      });\n      expect(result.current.steps).toHaveLength(5);\n    });\n  });\n\n  describe(\"removeStep\", () => {\n    it(\"removes a step at the given index\", () => {\n      const { result } = renderHook(() => useFunnels());\n      act(() => {\n        result.current.setStep(0, \"Page Viewed\");\n        result.current.setStep(1, \"Purchase Completed\");\n        result.current.addStep();\n        result.current.setStep(2, \"Signup Completed\");\n      });\n      act(() => {\n        result.current.removeStep(1);\n      });\n      expect(result.current.steps).toHaveLength(2);\n      expect(result.current.steps[0]).toBe(\"Page Viewed\");\n      expect(result.current.steps[1]).toBe(\"Signup Completed\");\n    });\n\n    it(\"is a no-op when at 2 steps\", () => {\n      const { result } = renderHook(() => useFunnels());\n      expect(result.current.steps).toHaveLength(2);\n      act(() => {\n        result.current.removeStep(0);\n      });\n      expect(result.current.steps).toHaveLength(2);\n    });\n  });\n\n  describe(\"setStep\", () => {\n    it(\"updates a step at the given index\", () => {\n      const { result } = renderHook(() => useFunnels());\n      act(() => {\n        result.current.setStep(0, \"Page Viewed\");\n      });\n      expect(result.current.steps[0]).toBe(\"Page Viewed\");\n    });\n\n    it(\"does not affect other steps when updating one\", () => {\n      const { result } = renderHook(() => useFunnels());\n      act(() => {\n        result.current.setStep(0, \"Page Viewed\");\n        result.current.setStep(1, \"Purchase Completed\");\n      });\n      act(() => {\n        result.current.setStep(0, \"Signup Completed\");\n      });\n      expect(result.current.steps[0]).toBe(\"Signup Completed\");\n      expect(result.current.steps[1]).toBe(\"Purchase Completed\");\n    });\n  });\n\n  describe(\"runFunnel — validation\", () => {\n    it(\"does not fetch when both steps are empty\", async () => {\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n        return errorResponse();\n      });\n\n      const { result } = renderHook(() => useFunnels());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      act(() => {\n        result.current.runFunnel();\n      });\n\n      const funnelCalls = (mockFetch.mock.calls as [string, unknown][]).filter(\n        ([url]) => (url as string).includes(\"/api/funnels\"),\n      );\n      expect(funnelCalls).toHaveLength(0);\n    });\n\n    it(\"does not fetch when only one step is non-empty\", async () => {\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n        return errorResponse();\n      });\n\n      const { result } = renderHook(() => useFunnels());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      act(() => {\n        result.current.setStep(0, \"Page Viewed\");\n      });\n      act(() => {\n        result.current.runFunnel();\n      });\n\n      const funnelCalls = (mockFetch.mock.calls as [string, unknown][]).filter(\n        ([url]) => (url as string).includes(\"/api/funnels\"),\n      );\n      expect(funnelCalls).toHaveLength(0);\n    });\n\n    it(\"fetches /api/funnels when all steps are non-empty and date range is set\", async () => {\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n        if ((url as string).includes(\"/api/funnels\")) return funnelResponse();\n        return errorResponse();\n      });\n\n      const { result } = renderHook(() => useFunnels());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      act(() => {\n        result.current.setStep(0, \"Page Viewed\");\n        result.current.setStep(1, \"Purchase Completed\");\n      });\n      act(() => {\n        result.current.runFunnel();\n      });\n\n      await waitFor(() => {\n        const calls = mockFetch.mock.calls as [string, unknown][];\n        return calls.some(([url]) => (url as string).includes(\"/api/funnels\"));\n      });\n\n      const funnelCalls = (mockFetch.mock.calls as [string, unknown][]).filter(\n        ([url]) => (url as string).includes(\"/api/funnels\"),\n      );\n      expect(funnelCalls.length).toBeGreaterThan(0);\n    });\n  });\n\n  describe(\"loading state\", () => {\n    it(\"sets loading=false after initial schema fetch\", async () => {\n      const { result } = renderHook(() => useFunnels());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n    });\n\n    it(\"sets loading=true during funnel fetch, false after\", async () => {\n      let resolveFunnel!: (v: unknown) => void;\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n        if ((url as string).includes(\"/api/funnels\")) {\n          return new Promise((resolve) => {\n            resolveFunnel = resolve;\n          });\n        }\n        return errorResponse();\n      });\n\n      const { result } = renderHook(() => useFunnels());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      act(() => {\n        result.current.setStep(0, \"Page Viewed\");\n        result.current.setStep(1, \"Purchase Completed\");\n      });\n      act(() => {\n        result.current.runFunnel();\n      });\n\n      await waitFor(() => expect(result.current.loading).toBe(true));\n\n      act(() => {\n        resolveFunnel({\n          ok: true,\n          json: () => Promise.resolve(sampleFunnelResponse),\n        });\n      });\n\n      await waitFor(() => expect(result.current.loading).toBe(false));\n    });\n  });\n\n  describe(\"result state\", () => {\n    it(\"stores funnel response in result on success\", async () => {\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n        if ((url as string).includes(\"/api/funnels\")) return funnelResponse();\n        return errorResponse();\n      });\n\n      const { result } = renderHook(() => useFunnels());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      act(() => {\n        result.current.setStep(0, \"Page Viewed\");\n        result.current.setStep(1, \"Purchase Completed\");\n      });\n      act(() => {\n        result.current.runFunnel();\n      });\n\n      await waitFor(() => expect(result.current.result).not.toBeNull());\n      expect(result.current.result?.steps).toHaveLength(2);\n    });\n\n    it(\"sets error state on fetch failure\", async () => {\n      mockFetch.mockImplementation((url: string) => {\n        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n        if ((url as string).includes(\"/api/funnels\")) return errorResponse();\n        return errorResponse();\n      });\n\n      const { result } = renderHook(() => useFunnels());\n      await waitFor(() => expect(result.current.loading).toBe(false));\n\n      act(() => {\n        result.current.setStep(0, \"Page Viewed\");\n        result.current.setStep(1, \"Purchase Completed\");\n      });\n      act(() => {\n        result.current.runFunnel();\n      });\n\n      await waitFor(() => expect(result.current.error).not.toBeNull());\n      expect(result.current.result).toBeNull();\n    });\n  });\n});\n","numLines":338,"startLine":1,"totalLines":338}}}
