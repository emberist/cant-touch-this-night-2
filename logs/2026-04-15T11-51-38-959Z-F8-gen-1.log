{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y6cye8ehCBit3GtWkHNBoo","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQueryEventsWithResolvedId } = vi.hoisted(() => ({\n6\t  mockQueryEventsWithResolvedId: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/identity\", () => ({\n10\t  queryEventsWithResolvedId: mockQueryEventsWithResolvedId,\n11\t}));\n12\t\n13\timport { GET } from \"@/app/api/events/list/route\";\n14\t\n15\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n16\t\n17\tfunction makeRequest(params: Record<string, string> = {}): Request {\n18\t  const url = new URL(\"http://localhost/api/events/list\");\n19\t  for (const [k, v] of Object.entries(params)) {\n20\t    url.searchParams.set(k, v);\n21\t  }\n22\t  return new Request(url.toString());\n23\t}\n24\t\n25\tconst sampleEvent = {\n26\t  event_id: \"uuid-1\",\n27\t  event_name: \"Page Viewed\",\n28\t  timestamp: \"2026-04-15T10:00:00.000Z\",\n29\t  device_id: \"dev-1\",\n30\t  user_id: null,\n31\t  properties: \"{}\",\n32\t  ingested_at: \"2026-04-15T10:00:00.100Z\",\n33\t  resolved_id: \"dev-1\",\n34\t};\n35\t\n36\t// ─── Tests ────────────────────────────────────────────────────────────────────\n37\t\n38\tbeforeEach(() => {\n39\t  mockQueryEventsWithResolvedId.mockResolvedValue([sampleEvent]);\n40\t});\n41\t\n42\tafterEach(() => {\n43\t  vi.clearAllMocks();\n44\t});\n45\t\n46\tdescribe(\"GET /api/events/list\", () => {\n47\t  describe(\"success — 200\", () => {\n48\t    it(\"returns 200 with events array and next_cursor fields\", async () => {\n49\t      const res = await GET(makeRequest());\n50\t\n51\t      expect(res.status).toBe(200);\n52\t      const body = await res.json();\n53\t      expect(body).toHaveProperty(\"events\");\n54\t      expect(body).toHaveProperty(\"next_cursor\");\n55\t      expect(Array.isArray(body.events)).toBe(true);\n56\t    });\n57\t\n58\t    it(\"returns empty events array and null cursor when no events match\", async () => {\n59\t      mockQueryEventsWithResolvedId.mockResolvedValue([]);\n60\t\n61\t      const res = await GET(makeRequest());\n62\t      const body = await res.json();\n63\t\n64\t      expect(res.status).toBe(200);\n65\t      expect(body.events).toEqual([]);\n66\t      expect(body.next_cursor).toBeNull();\n67\t    });\n68\t\n69\t    it(\"returns null next_cursor when fewer events than limit are returned (no more pages)\", async () => {\n70\t      // default limit is 50; we return only 1 event — fewer than limit\n71\t      mockQueryEventsWithResolvedId.mockResolvedValue([sampleEvent]);\n72\t\n73\t      const res = await GET(makeRequest());\n74\t      const body = await res.json();\n75\t\n76\t      expect(body.next_cursor).toBeNull();\n77\t    });\n78\t\n79\t    it(\"returns last event timestamp as next_cursor when result count equals limit\", async () => {\n80\t      const events = [\n81\t        {\n82\t          ...sampleEvent,\n83\t          timestamp: \"2026-04-15T10:00:00.000Z\",\n84\t          event_id: \"uuid-1\",\n85\t        },\n86\t        {\n87\t          ...sampleEvent,\n88\t          timestamp: \"2026-04-14T09:00:00.000Z\",\n89\t          event_id: \"uuid-2\",\n90\t        },\n91\t      ];\n92\t      mockQueryEventsWithResolvedId.mockResolvedValue(events);\n93\t\n94\t      // limit=2 → results.length (2) === limit (2) → return last timestamp\n95\t      const res = await GET(makeRequest({ limit: \"2\" }));\n96\t      const body = await res.json();\n97\t\n98\t      expect(body.next_cursor).toBe(\"2026-04-14T09:00:00.000Z\");\n99\t    });\n100\t\n101\t    it(\"includes the returned events in the response body\", async () => {\n102\t      const res = await GET(makeRequest());\n103\t      const body = await res.json();\n104\t\n105\t      expect(body.events).toEqual([sampleEvent]);\n106\t    });\n107\t  });\n108\t\n109\t  describe(\"query param forwarding\", () => {\n110\t    it(\"passes event_name query param to queryEventsWithResolvedId\", async () => {\n111\t      await GET(makeRequest({ event_name: \"Purchase Completed\" }));\n112\t\n113\t      expect(mockQueryEventsWithResolvedId).toHaveBeenCalledWith(\n114\t        expect.objectContaining({ event_name: \"Purchase Completed\" }),\n115\t      );\n116\t    });\n117\t\n118\t    it(\"passes resolved_id query param to queryEventsWithResolvedId\", async () => {\n119\t      await GET(makeRequest({ resolved_id: \"user@test.com\" }));\n120\t\n121\t      expect(mockQueryEventsWithResolvedId).toHaveBeenCalledWith(\n122\t        expect.objectContaining({ resolved_id: \"user@test.com\" }),\n123\t      );\n124\t    });\n125\t\n126\t    it(\"passes before cursor query param to queryEventsWithResolvedId\", async () => {\n127\t      const before = \"2026-04-14T11:59:59.000Z\";\n128\t      await GET(makeRequest({ before }));\n129\t\n130\t      expect(mockQueryEventsWithResolvedId).toHaveBeenCalledWith(\n131\t        expect.objectContaining({ before }),\n132\t      );\n133\t    });\n134\t\n135\t    it(\"uses default limit of 50 when limit param is not specified\", async () => {\n136\t      await GET(makeRequest());\n137\t\n138\t      expect(mockQueryEventsWithResolvedId).toHaveBeenCalledWith(\n139\t        expect.objectContaining({ limit: 50 }),\n140\t      );\n141\t    });\n142\t\n143\t    it(\"respects custom limit param\", async () => {\n144\t      await GET(makeRequest({ limit: \"100\" }));\n145\t\n146\t      expect(mockQueryEventsWithResolvedId).toHaveBeenCalledWith(\n147\t        expect.objectContaining({ limit: 100 }),\n148\t      );\n149\t    });\n150\t\n151\t    it(\"clamps limit to max 200\", async () => {\n152\t      await GET(makeRequest({ limit: \"500\" }));\n153\t\n154\t      expect(mockQueryEventsWithResolvedId).toHaveBeenCalledWith(\n155\t        expect.objectContaining({ limit: 200 }),\n156\t    