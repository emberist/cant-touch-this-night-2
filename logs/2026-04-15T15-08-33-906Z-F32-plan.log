{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0141quvUdpZ6jpfki2RovHxG","type":"tool_result","content":"1\t/**\n2\t * Integration tests for identity resolution (BR-101).\n3\t * Requires a running ClickHouse server at localhost:8123 (or CLICKHOUSE_URL).\n4\t * Uses a dedicated `minipanel_test` database — never touches `minipanel`.\n5\t *\n6\t * Run with: pnpm test (requires ./clickhouse server -- --path=.clickhouse)\n7\t */\n8\t\n9\timport { createClient } from \"@clickhouse/client\";\n10\timport { afterAll, afterEach, beforeAll, describe, expect, it } from \"vitest\";\n11\timport {\n12\t  getEventsByResolvedId,\n13\t  IdentityConflictError,\n14\t  insertEvent,\n15\t  queryEventsWithResolvedId,\n16\t} from \"@/lib/identity\";\n17\t\n18\tconst CLICKHOUSE_URL = process.env.CLICKHOUSE_URL ?? \"http://localhost:8123\";\n19\tconst TEST_DB = \"minipanel_test\";\n20\t\n21\tasync function isClickHouseReachable(): Promise<boolean> {\n22\t  try {\n23\t    const res = await fetch(`${CLICKHOUSE_URL}/ping`, {\n24\t      signal: AbortSignal.timeout(2000),\n25\t    });\n26\t    return res.ok;\n27\t  } catch {\n28\t    return false;\n29\t  }\n30\t}\n31\t\n32\t// Test-scoped client — always uses minipanel_test\n33\tconst testClient = createClient({\n34\t  url: CLICKHOUSE_URL,\n35\t  database: TEST_DB,\n36\t  password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n37\t});\n38\t\n39\tdescribe.skipIf(!(await isClickHouseReachable()))(\n40\t  \"identity integration — real ClickHouse (minipanel_test)\",\n41\t  () => {\n42\t    beforeAll(async () => {\n43\t      // Create test database and tables (idempotent)\n44\t      const adminClient = createClient({\n45\t        url: CLICKHOUSE_URL,\n46\t        password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n47\t      });\n48\t\n49\t      await adminClient.command({\n50\t        query: `CREATE DATABASE IF NOT EXISTS ${TEST_DB}`,\n51\t      });\n52\t\n53\t      await adminClient.command({\n54\t        query: `\n55\t          CREATE TABLE IF NOT EXISTS ${TEST_DB}.events\n56\t          (\n57\t            event_id    UUID                     DEFAULT generateUUIDv4(),\n58\t            event_name  LowCardinality(String),\n59\t            timestamp   DateTime64(3, 'UTC'),\n60\t            device_id   Nullable(String),\n61\t            user_id     Nullable(String),\n62\t            properties  String,\n63\t            ingested_at DateTime64(3, 'UTC')     DEFAULT now64()\n64\t          )\n65\t          ENGINE = MergeTree()\n66\t          ORDER BY (timestamp, event_id)\n67\t          PARTITION BY toYYYYMM(timestamp)\n68\t        `,\n69\t      });\n70\t\n71\t      await adminClient.command({\n72\t        query: `\n73\t          CREATE TABLE IF NOT EXISTS ${TEST_DB}.identity_mappings\n74\t          (\n75\t            device_id  String,\n76\t            user_id    String,\n77\t            created_at DateTime64(3, 'UTC') DEFAULT now64()\n78\t          )\n79\t          ENGINE = ReplacingMergeTree(created_at)\n80\t          ORDER BY (device_id)\n81\t        `,\n82\t      });\n83\t\n84\t      await adminClient.close();\n85\t    });\n86\t\n87\t    afterAll(async () => {\n88\t      await testClient.close();\n89\t    });\n90\t\n91\t    afterEach(async () => {\n92\t      // Truncate after every test to keep isolation\n93\t      await testClient.command({ query: \"TRUNCATE TABLE events\" });\n94\t      await testClient.command({ query: \"TRUNCATE TABLE identity_mappings\" });\n95\t    });\n96\t\n97\t    // ── BR-101 Scenario 1 ─────────────────────────────────────────────────────\n98\t    it(\"BR-101 S1: anonymous event followed by identify event → all events attributed to user (retroactive merge)\", async () => {\n99\t      // Anonymous event (device only)\n100\t      await insertEvent(\n101\t        { event_name: \"Page Viewed\", device_id: \"dev-s1\" },\n102\t        testClient,\n103\t      );\n104\t\n105\t      // Identify event (links device to user)\n106\t      await insertEvent(\n107\t        {\n108\t          event_name: \"Signup Completed\",\n109\t          device_id: \"dev-s1\",\n110\t          user_id: \"user-s1@test.com\",\n111\t        },\n112\t        testClient,\n113\t      );\n114\t\n115\t      // Query by user's resolved_id — should return BOTH events\n116\t      const events = await queryEventsWithResolvedId(\n117\t        { resolved_id: \"user-s1@test.com\", limit: 50 },\n118\t        testClient,\n119\t      );\n120\t\n121\t      expect(events.length).toBe(2);\n122\t      expect(events.every((e) => e.resolved_id === \"user-s1@test.com\")).toBe(\n123\t        true,\n124\t      );\n125\t    });\n126\t\n127\t    // ── BR-101 Scenario 2 ─────────────────────────────────────────────────────\n128\t    it(\"BR-101 S2: two devices linked to same user → events from both devices returned\", async () => {\n129\t      await insertEvent(\n130\t        {\n131\t          event_name: \"Page Viewed\",\n132\t          device_id: \"dev-s2a\",\n133\t          user_id: \"user-s2@test.com\",\n134\t        },\n135\t        testClient,\n136\t      );\n137\t\n138\t      await insertEvent(\n139\t        {\n140\t          event_name: \"Button Clicked\",\n141\t          device_id: \"dev-s2b\",\n142\t          user_id: \"user-s2@test.com\",\n143\t        },\n144\t        testClient,\n145\t      );\n146\t\n147\t      const events = await getEventsByResolvedId(\n148\t        \"user-s2@test.com\",\n149\t        testClient,\n150\t      );\n151\t\n152\t      expect(events.length).toBe(2);\n153\t      const deviceIds = events.map((e) => e.device_id);\n154\t      expect(deviceIds).toContain(\"dev-s2a\");\n155\t      expect(deviceIds).toContain(\"dev-s2b\");\n156\t    });\n157\t\n158\t    // ── BR-101 Scenario 3 ─────────────────────────────────────────────────────\n159\t    it(\"BR-101 S3: device mapped to two different users → second mapping throws IdentityConflictError (409)\", async () => {\n160\t      // First mapping\n161\t      await insertEvent(\n162\t        {\n163\t          event_name: \"Signup Completed\",\n164\t          device_id: \"dev-s3\",\n165\t          user_id: \"user-s3a@test.com\",\n166\t        },\n167\t        testClient,\n168\t      );\n169\t\n170\t      // Second mapping to a different user — must reject\n171\t      await expect(\n172\t        insertEvent(\n173\t          {\n174\t            event_name: \"Purchase Completed\",\n175\t            device_id: \"dev-s3\",\n176\t            user_id: \"user-s3b@test.com\",\n177\t          },\n178\t          testClient,\n179\t        ),\n180\t      ).rejects.toThrow(IdentityConflictError);\n181\t    });\n182\t\n183\t    it(\"BR-101 S3: IdentityConflictError has status 409\", async () => {\n184\t      await insertEvent(\n185\t        {\n186\t          event_name: \"Signup Completed\",\n187\t          device_id: \"dev-s3x\",\n188\t          user_id: \"user-s3x-a@test.com\",\n189\t        },\n190\t        testClient,\n191\t      );\n192\t\n193\t      try {\n194\t        await insertEvent(\n195\t          {\n196\t            event_name: \"Page Viewed\",\n197\t            device_id: \"dev-s3x\",\n198\t            user_id: \"user-s3x-b@test.com\",\n199\t          },\n200\t          testClient,\n201\t        );\n202\t        expect.fail(\"should have thrown\");\n203\t      } catch (err) {\n204\t        expect(err).toBeInstanceOf(IdentityConflictError);\n205\t        expect((err as IdentityConflictError).status).toBe(409);\n206\t      }\n207\t    });\n208\t\n209\t    // ── BR-101 Scenario 4 ─────────────────────────────────────────────────────\n210\t    it(\"BR-101 S4: same device + same user sent twice → second call succeeds (idempotent)\", async () => {\n211\t      await insertEvent(\n212\t        {\n213\t          event_name: \"Signup Completed\",\n214\t          device_id: \"dev-s4\",\n215\t          user_id: \"user-s4@test.com\",\n216\t        },\n217\t        testClient,\n218\t      );\n219\t\n220\t      // Identical mapping — must not throw\n221\t      await expect(\n222\t        insertEvent(\n223\t          {\n224\t            event_name: \"Page Viewed\",\n225\t            device_id: \"dev-s4\",\n226\t            user_id: \"user-s4@test.com\",\n227\t          },\n228\t          testClient,\n229\t        ),\n230\t      ).resolves.not.toThrow();\n231\t\n232\t      // Both events inserted\n233\t      const events = await getEventsByResolvedId(\n234\t        \"user-s4@test.com\",\n235\t        testClient,\n236\t      );\n237\t      expect(events.length).toBe(2);\n238\t    });\n239\t  },\n240\t);\n241\t"}]},"parent_tool_use_id":null,"session_id":"5fe73c9f-ac98-4fa5-9938-c1c192812548","uuid":"5648acb5-65b5-4999-9edb-9ac9313b0940","timestamp":"2026-04-15T18:54:16.650Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/identity.integration.test.ts","content":"/**\n * Integration tests for identity resolution (BR-101).\n * Requires a running ClickHouse server at localhost:8123 (or CLICKHOUSE_URL).\n * Uses a dedicated `minipanel_test` database — never touches `minipanel`.\n *\n * Run with: pnpm test (requires ./clickhouse server -- --path=.clickhouse)\n */\n\nimport { createClient } from \"@clickhouse/client\";\nimport { afterAll, afterEach, beforeAll, describe, expect, it } from \"vitest\";\nimport {\n  getEventsByResolvedId,\n  IdentityConflictError,\n  insertEvent,\n  queryEventsWithResolvedId,\n} from \"@/lib/identity\";\n\nconst CLICKHOUSE_URL = process.env.CLICKHOUSE_URL ?? \"http://localhost:8123\";\nconst TEST_DB = \"minipanel_test\";\n\nasync function isClickHouseReachable(): Promise<boolean> {\n  try {\n    const res = await fetch(`${CLICKHOUSE_URL}/ping`, {\n      signal: AbortSignal.timeout(2000),\n    });\n    return res.ok;\n  } catch {\n    return false;\n  }\n}\n\n// Test-scoped client — always uses minipanel_test\nconst testClient = createClient({\n  url: CLICKHOUSE_URL,\n  database: TEST_DB,\n  password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n});\n\ndescribe.skipIf(!(await isClickHouseReachable()))(\n  \"identity integration — real ClickHouse (minipanel_test)\",\n  () => {\n    beforeAll(async () => {\n      // Create test database and tables (idempotent)\n      const adminClient = createClient({\n        url: CLICKHOUSE_URL,\n        password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n      });\n\n      await adminClient.command({\n        query: `CREATE DATABASE IF NOT EXISTS ${TEST_DB}`,\n      });\n\n      await adminClient.command({\n        query: `\n          CREATE TABLE IF NOT EXISTS ${TEST_DB}.events\n          (\n            event_id    UUID                     DEFAULT generateUUIDv4(),\n            event_name  LowCardinality(String),\n            timestamp   DateTime64(3, 'UTC'),\n            device_id   Nullable(String),\n            user_id     Nullable(String),\n            properties  String,\n            ingested_at DateTime64(3, 'UTC')     DEFAULT now64()\n          )\n          ENGINE = MergeTree()\n          ORDER BY (timestamp, event_id)\n          PARTITION BY toYYYYMM(timestamp)\n        `,\n      });\n\n      await adminClient.command({\n        query: `\n          CREATE TABLE IF NOT EXISTS ${TEST_DB}.identity_mappings\n          (\n            device_id  String,\n            user_id    String,\n            created_at DateTime64(3, 'UTC') DEFAULT now64()\n          )\n          ENGINE = ReplacingMergeTree(created_at)\n          ORDER BY (device_id)\n        `,\n      });\n\n      await adminClient.close();\n    });\n\n    afterAll(async () => {\n      await testClient.close();\n    });\n\n    afterEach(async () => {\n      // Truncate after every test to keep isolation\n      await testClient.command({ query: \"TRUNCATE TABLE events\" });\n      await testClient.command({ query: \"TRUNCATE TABLE identity_mappings\" });\n    });\n\n    // ── BR-101 Scenario 1 ─────────────────────────────────────────────────────\n    it(\"BR-101 S1: anonymous event followed by identify event → all events attributed to user (retroactive merge)\", async () => {\n      // Anonymous event (device only)\n      await insertEvent(\n        { event_name: \"Page Viewed\", device_id: \"dev-s1\" },\n        testClient,\n      );\n\n      // Identify event (links device to user)\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s1\",\n          user_id: \"user-s1@test.com\",\n        },\n        testClient,\n      );\n\n      // Query by user's resolved_id — should return BOTH events\n      const events = await queryEventsWithResolvedId(\n        { resolved_id: \"user-s1@test.com\", limit: 50 },\n        testClient,\n      );\n\n      expect(events.length).toBe(2);\n      expect(events.every((e) => e.resolved_id === \"user-s1@test.com\")).toBe(\n        true,\n      );\n    });\n\n    // ── BR-101 Scenario 2 ─────────────────────────────────────────────────────\n    it(\"BR-101 S2: two devices linked to same user → events from both devices returned\", async () => {\n      await insertEvent(\n        {\n          event_name: \"Page Viewed\",\n          device_id: \"dev-s2a\",\n          user_id: \"user-s2@test.com\",\n        },\n        testClient,\n      );\n\n      await insertEvent(\n        {\n          event_name: \"Button Clicked\",\n          device_id: \"dev-s2b\",\n          user_id: \"user-s2@test.com\",\n        },\n        testClient,\n      );\n\n      const events = await getEventsByResolvedId(\n        \"user-s2@test.com\",\n        testClient,\n      );\n\n      expect(events.length).toBe(2);\n      const deviceIds = events.map((e) => e.device_id);\n      expect(deviceIds).toContain(\"dev-s2a\");\n      expect(deviceIds).toContain(\"dev-s2b\");\n    });\n\n    // ── BR-101 Scenario 3 ─────────────────────────────────────────────────────\n    it(\"BR-101 S3: device mapped to two different users → second mapping throws IdentityConflictError (409)\", async () => {\n      // First mapping\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s3\",\n          user_id: \"user-s3a@test.com\",\n        },\n        testClient,\n      );\n\n      // Second mapping to a different user — must reject\n      await expect(\n        insertEvent(\n          {\n            event_name: \"Purchase Completed\",\n            device_id: \"dev-s3\",\n            user_id: \"user-s3b@test.com\",\n          },\n          testClient,\n        ),\n      ).rejects.toThrow(IdentityConflictError);\n    });\n\n    it(\"BR-101 S3: IdentityConflictError has status 409\", async () => {\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s3x\",\n          user_id: \"user-s3x-a@test.com\",\n        },\n        testClient,\n      );\n\n      try {\n        await insertEvent(\n          {\n            event_name: \"Page Viewed\",\n            device_id: \"dev-s3x\",\n            user_id: \"user-s3x-b@test.com\",\n          },\n          testClient,\n        );\n        expect.fail(\"should have thrown\");\n      } catch (err) {\n        expect(err).toBeInstanceOf(IdentityConflictError);\n        expect((err as IdentityConflictError).status).toBe(409);\n      }\n    });\n\n    // ── BR-101 Scenario 4 ─────────────────────────────────────────────────────\n    it(\"BR-101 S4: same device + same user sent twice → second call succeeds (idempotent)\", async () => {\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s4\",\n          user_id: \"user-s4@test.com\",\n        },\n        testClient,\n      );\n\n      // Identical mapping — must not throw\n      await expect(\n        insertEvent(\n          {\n            event_name: \"Page Viewed\",\n            device_id: \"dev-s4\",\n            user_id: \"user-s4@test.com\",\n          },\n          testClient,\n        ),\n      ).resolves.not.toThrow();\n\n      // Both events inserted\n      const events = await getEventsByResolvedId(\n        \"user-s4@test.com\",\n        testClient,\n      );\n      expect(events.length).toBe(2);\n    });\n  },\n);\n","numLines":241,"startLine":1,"totalLines":241}}}
