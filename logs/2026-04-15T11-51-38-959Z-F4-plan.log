{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TPDk9pds2PqqDcQkS1XDqf","type":"tool_result","content":"1\timport { execFileSync } from \"node:child_process\";\n2\timport path from \"node:path\";\n3\timport { fileURLToPath } from \"node:url\";\n4\t\n5\tconst DEFAULT_URL = \"http://localhost:8123\";\n6\tconst DEFAULT_PASSWORD = \"password\";\n7\t\n8\tfunction parseClickhouseUrl(urlStr: string): { host: string; port: string } {\n9\t  const parsed = new URL(urlStr);\n10\t  return {\n11\t    host: parsed.hostname,\n12\t    port: parsed.port || \"8123\",\n13\t  };\n14\t}\n15\t\n16\texport function runMigration(): void {\n17\t  const urlStr = process.env.CLICKHOUSE_URL ?? DEFAULT_URL;\n18\t  const password = process.env.CLICKHOUSE_PASSWORD ?? DEFAULT_PASSWORD;\n19\t  const { host, port } = parseClickhouseUrl(urlStr);\n20\t\n21\t  const scriptDir = path.dirname(fileURLToPath(import.meta.url));\n22\t  const schemaFile = path.resolve(scriptDir, \"schema.sql\");\n23\t\n24\t  execFileSync(\n25\t    \"./clickhouse\",\n26\t    [\n27\t      \"client\",\n28\t      `--host=${host}`,\n29\t      `--port=${port}`,\n30\t      `--password=${password}`,\n31\t      `--queries-file=${schemaFile}`,\n32\t    ],\n33\t    { stdio: \"inherit\" },\n34\t  );\n35\t\n36\t  console.log(\"Migration completed successfully.\");\n37\t}\n38\t\n39\t// Run only when this file is the entry point (not when imported as a module)\n40\tconst isDirectRun =\n41\t  process.argv[1] !== undefined &&\n42\t  path.resolve(process.argv[1]) ===\n43\t    path.resolve(fileURLToPath(import.meta.url));\n44\t\n45\tif (isDirectRun) {\n46\t  try {\n47\t    runMigration();\n48\t  } catch (err) {\n49\t    console.error(\"Migration failed:\", String(err));\n50\t    process.exit(1);\n51\t  }\n52\t}\n53\t"}]},"parent_tool_use_id":null,"session_id":"e92c3ed8-599e-43a5-b6af-1da180fb9a4a","uuid":"5faa45a4-4ffc-4055-b4f4-a83ca1acb246","timestamp":"2026-04-15T12:12:25.995Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/scripts/migrate.ts","content":"import { execFileSync } from \"node:child_process\";\nimport path from \"node:path\";\nimport { fileURLToPath } from \"node:url\";\n\nconst DEFAULT_URL = \"http://localhost:8123\";\nconst DEFAULT_PASSWORD = \"password\";\n\nfunction parseClickhouseUrl(urlStr: string): { host: string; port: string } {\n  const parsed = new URL(urlStr);\n  return {\n    host: parsed.hostname,\n    port: parsed.port || \"8123\",\n  };\n}\n\nexport function runMigration(): void {\n  const urlStr = process.env.CLICKHOUSE_URL ?? DEFAULT_URL;\n  const password = process.env.CLICKHOUSE_PASSWORD ?? DEFAULT_PASSWORD;\n  const { host, port } = parseClickhouseUrl(urlStr);\n\n  const scriptDir = path.dirname(fileURLToPath(import.meta.url));\n  const schemaFile = path.resolve(scriptDir, \"schema.sql\");\n\n  execFileSync(\n    \"./clickhouse\",\n    [\n      \"client\",\n      `--host=${host}`,\n      `--port=${port}`,\n      `--password=${password}`,\n      `--queries-file=${schemaFile}`,\n    ],\n    { stdio: \"inherit\" },\n  );\n\n  console.log(\"Migration completed successfully.\");\n}\n\n// Run only when this file is the entry point (not when imported as a module)\nconst isDirectRun =\n  process.argv[1] !== undefined &&\n  path.resolve(process.argv[1]) ===\n    path.resolve(fileURLToPath(import.meta.url));\n\nif (isDirectRun) {\n  try {\n    runMigration();\n  } catch (err) {\n    console.error(\"Migration failed:\", String(err));\n    process.exit(1);\n  }\n}\n","numLines":53,"startLine":1,"totalLines":53}}}
