{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PVsvmpHwgYFNPydQ89ankm","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\timport type { EventRow } from \"@/lib/identity\";\n3\t\n4\t// ─── Types ────────────────────────────────────────────────────────────────────\n5\t\n6\texport interface UserListItem {\n7\t  resolved_id: string;\n8\t  first_seen: string;\n9\t  last_seen: string;\n10\t  event_count: number;\n11\t}\n12\t\n13\texport interface IdentityCluster {\n14\t  user_ids: string[];\n15\t  device_ids: string[];\n16\t}\n17\t\n18\texport interface UserProfile {\n19\t  resolved_id: string;\n20\t  first_seen: string;\n21\t  last_seen: string;\n22\t  identity_cluster: IdentityCluster;\n23\t  events: EventRow[];\n24\t}\n25\t\n26\texport interface UserSearchOptions {\n27\t  q?: string;\n28\t  limit?: number;\n29\t  cursor?: string;\n30\t}\n31\t\n32\texport interface UserSearchResult {\n33\t  users: UserListItem[];\n34\t  next_cursor: string | null;\n35\t}\n36\t\n37\t// ─── Type alias for the ClickHouse client ─────────────────────────────────────\n38\t\n39\ttype ClickHouseClientLike = typeof clickhouse;\n40\t\n41\t// ─── searchUsers ──────────────────────────────────────────────────────────────\n42\t\n43\t/**\n44\t * Returns a paginated list of distinct resolved identities from the events\n45\t * table, joined with identity_mappings FINAL.\n46\t *\n47\t * Cursor is the last resolved_id from the previous page (lexicographic order).\n48\t * q is applied as a substring ILIKE filter on resolved_id.\n49\t */\n50\texport async function searchUsers(\n51\t  options: UserSearchOptions = {},\n52\t  client: ClickHouseClientLike = clickhouse,\n53\t): Promise<UserSearchResult> {\n54\t  const { q, cursor } = options;\n55\t  const limit = Math.min(options.limit ?? 50, 200);\n56\t\n57\t  const conditions: string[] = [];\n58\t  const params: Record<string, string | number> = { limit };\n59\t\n60\t  if (q) {\n61\t    conditions.push(\"resolved_id ILIKE {q:String}\");\n62\t    params.q = `%${q}%`;\n63\t  }\n64\t\n65\t  if (cursor) {\n66\t    conditions.push(\"resolved_id > {cursor:String}\");\n67\t    params.cursor = cursor;\n68\t  }\n69\t\n70\t  const having =\n71\t    conditions.length > 0 ? `HAVING ${conditions.join(\" AND \")}` : \"\";\n72\t\n73\t  const result = await client.query({\n74\t    query: `\n75\t      SELECT\n76\t        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id,\n77\t        min(e.timestamp) AS first_seen,\n78\t        max(e.timestamp) AS last_seen,\n79\t        count() AS event_count\n80\t      FROM events e\n81\t      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n82\t        ON e.device_id = m.device_id\n83\t      GROUP BY resolved_id\n84\t      ${having}\n85\t      ORDER BY resolved_id ASC\n86\t      LIMIT {limit:UInt64}\n87\t    `,\n88\t    query_params: params,\n89\t    format: \"JSONEachRow\",\n90\t  });\n91\t\n92\t  const rows = await result.json<\n93\t    Omit<UserListItem, \"event_count\"> & { event_count: number | string }\n94\t  >();\n95\t\n96\t  const users: UserListItem[] = rows.map((row) => ({\n97\t    resolved_id: row.resolved_id,\n98\t    first_seen: row.first_seen,\n99\t    last_seen: row.last_seen,\n100\t    event_count: Number(row.event_count),\n101\t  }));\n102\t\n103\t  const next_cursor =\n104\t    users.length === limit ? users[users.length - 1].resolved_id : null;\n105\t\n106\t  return { users, next_cursor };\n107\t}\n108\t\n109\t// ─── getUserProfile ────────────────────────────────────────────────────────────\n110\t\n111\t/**\n112\t * Returns a full user profile for a given resolved_id, including:\n113\t * - first_seen / last_seen timestamps\n114\t * - identity_cluster: all user_ids and device_ids associated with this identity\n115\t * - recent events (up to 200, newest first)\n116\t *\n117\t * Returns null if no events are found for the given resolved_id.\n118\t */\n119\texport async function getUserProfile(\n120\t  resolved_id: string,\n121\t  client: ClickHouseClientLike = clickhouse,\n122\t): Promise<UserProfile | null> {\n123\t  // ── Query 1: stats ──────────────────────────────────────────────────────────\n124\t\n125\t  const statsResult = await client.query({\n126\t    query: `\n127\t      SELECT\n128\t        count() AS event_count,\n129\t        min(e.timestamp) AS first_seen,\n130\t        max(e.timestamp) AS last_seen\n131\t      FROM events e\n132\t      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n133\t        ON e.device_id = m.device_id\n134\t      WHERE coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\n135\t    `,\n136\t    query_params: { resolved_id },\n137\t    format: \"JSONEachRow\",\n138\t  });\n139\t\n140\t  const statsRows = await statsResult.json<{\n141\t    event_count: number | string;\n142\t    first_seen: string;\n143\t    last_seen: string;\n144\t  }>();\n145\t\n146\t  if (statsRows.length === 0 || Number(statsRows[0].event_count) === 0) {\n147\t    return null;\n148\t  }\n149\t\n150\t  const { first_seen, last_seen } = statsRows[0];\n151\t\n152\t  // ── Query 2: identity cluster ───────────────────────────────────────────────\n153\t\n154\t  const clusterResult = await client.query({\n155\t    query: `\n156\t      SELECT DISTINCT\n157\t        e.user_id,\n158\t        e.device_id\n159\t      FROM events e\n160\t      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n161\t        ON e.device_id = m.device_id\n162\t      WHERE coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\n163\t    `,\n164\t    query_params: { resolved_id },\n165\t    format: \"JSONEachRow\",\n166\t  });\n167\t\n168\t  const clusterRows = await clusterResult.json<{\n169\t    user_id: string | null;\n170\t    device_id: string | null;\n171\t  }>();\n172\t\n173\t  const user_ids = [\n174\t    ...new Set(\n175\t      clusterRows\n176\t        .map((r) => r.user_id)\n177\t        .filter((id): id is string => id !== null),\n178\t    ),\n179\t  ];\n180\t  const device_ids = [\n181\t    ...new Set(\n182\t      clusterRows\n183\t        .map((r) => r.device_id)\n184\t        .filter((id): id is string => id !== null),\n185\t    ),\n186\t  ];\n187\t\n188\t  // ── Query 3: events ─────────────────────────────────────────────────────────\n189\t\n190\t  const eventsResult = await client.query({\n191\t    query: `\n192\t      SELECT\n193\t        e.event_id,\n194\t        e.event_name,\n195\t        e.timestamp,\n196\t        e.device_id,\n197\t        e.user_id,\n198\t        e.properties,\n199\t        e.ingested_at,\n200\t        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id\n201\t      FROM events e\n202\t      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n203\t        ON e.device_id = m.device_id\n204\t      WHERE coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\n205\t      ORDER BY e.timestamp DESC, e.event_id DESC\n206\t      LIMIT 200\n207\t    `,\n208\t    query_params: { resolved_id },\n209\t    format: \"JSONEachRow\",\n210\t  });\n211\t\n212\t  const events = await eventsResult.json<EventRow>();\n213\t\n214\t  return {\n215\t    resolved_id,\n216\t    first_seen: first_seen as string,\n217\t    last_seen: last_seen as string,\n218\t    identity_cluster: { user_ids, device_ids },\n219\t    events,\n220\t  };\n221\t}\n222\t"}]},"parent_tool_use_id":null,"session_id":"c5a33b82-0097-40c7-af8c-a099d2dd2a2d","uuid":"b491c21c-fbed-4640-809c-827425aa0f1e","timestamp":"2026-04-15T17:26:00.150Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/users.ts","content":"import { clickhouse } from \"@/lib/clickhouse\";\nimport type { EventRow } from \"@/lib/identity\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface UserListItem {\n  resolved_id: string;\n  first_seen: string;\n  last_seen: string;\n  event_count: number;\n}\n\nexport interface IdentityCluster {\n  user_ids: string[];\n  device_ids: string[];\n}\n\nexport interface UserProfile {\n  resolved_id: string;\n  first_seen: string;\n  last_seen: string;\n  identity_cluster: IdentityCluster;\n  events: EventRow[];\n}\n\nexport interface UserSearchOptions {\n  q?: string;\n  limit?: number;\n  cursor?: string;\n}\n\nexport interface UserSearchResult {\n  users: UserListItem[];\n  next_cursor: string | null;\n}\n\n// ─── Type alias for the ClickHouse client ─────────────────────────────────────\n\ntype ClickHouseClientLike = typeof clickhouse;\n\n// ─── searchUsers ──────────────────────────────────────────────────────────────\n\n/**\n * Returns a paginated list of distinct resolved identities from the events\n * table, joined with identity_mappings FINAL.\n *\n * Cursor is the last resolved_id from the previous page (lexicographic order).\n * q is applied as a substring ILIKE filter on resolved_id.\n */\nexport async function searchUsers(\n  options: UserSearchOptions = {},\n  client: ClickHouseClientLike = clickhouse,\n): Promise<UserSearchResult> {\n  const { q, cursor } = options;\n  const limit = Math.min(options.limit ?? 50, 200);\n\n  const conditions: string[] = [];\n  const params: Record<string, string | number> = { limit };\n\n  if (q) {\n    conditions.push(\"resolved_id ILIKE {q:String}\");\n    params.q = `%${q}%`;\n  }\n\n  if (cursor) {\n    conditions.push(\"resolved_id > {cursor:String}\");\n    params.cursor = cursor;\n  }\n\n  const having =\n    conditions.length > 0 ? `HAVING ${conditions.join(\" AND \")}` : \"\";\n\n  const result = await client.query({\n    query: `\n      SELECT\n        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id,\n        min(e.timestamp) AS first_seen,\n        max(e.timestamp) AS last_seen,\n        count() AS event_count\n      FROM events e\n      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n        ON e.device_id = m.device_id\n      GROUP BY resolved_id\n      ${having}\n      ORDER BY resolved_id ASC\n      LIMIT {limit:UInt64}\n    `,\n    query_params: params,\n    format: \"JSONEachRow\",\n  });\n\n  const rows = await result.json<\n    Omit<UserListItem, \"event_count\"> & { event_count: number | string }\n  >();\n\n  const users: UserListItem[] = rows.map((row) => ({\n    resolved_id: row.resolved_id,\n    first_seen: row.first_seen,\n    last_seen: row.last_seen,\n    event_count: Number(row.event_count),\n  }));\n\n  const next_cursor =\n    users.length === limit ? users[users.length - 1].resolved_id : null;\n\n  return { users, next_cursor };\n}\n\n// ─── getUserProfile ────────────────────────────────────────────────────────────\n\n/**\n * Returns a full user profile for a given resolved_id, including:\n * - first_seen / last_seen timestamps\n * - identity_cluster: all user_ids and device_ids associated with this identity\n * - recent events (up to 200, newest first)\n *\n * Returns null if no events are found for the given resolved_id.\n */\nexport async function getUserProfile(\n  resolved_id: string,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<UserProfile | null> {\n  // ── Query 1: stats ──────────────────────────────────────────────────────────\n\n  const statsResult = await client.query({\n    query: `\n      SELECT\n        count() AS event_count,\n        min(e.timestamp) AS first_seen,\n        max(e.timestamp) AS last_seen\n      FROM events e\n      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n        ON e.device_id = m.device_id\n      WHERE coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\n    `,\n    query_params: { resolved_id },\n    format: \"JSONEachRow\",\n  });\n\n  const statsRows = await statsResult.json<{\n    event_count: number | string;\n    first_seen: string;\n    last_seen: string;\n  }>();\n\n  if (statsRows.length === 0 || Number(statsRows[0].event_count) === 0) {\n    return null;\n  }\n\n  const { first_seen, last_seen } = statsRows[0];\n\n  // ── Query 2: identity cluster ───────────────────────────────────────────────\n\n  const clusterResult = await client.query({\n    query: `\n      SELECT DISTINCT\n        e.user_id,\n        e.device_id\n      FROM events e\n      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n        ON e.device_id = m.device_id\n      WHERE coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\n    `,\n    query_params: { resolved_id },\n    format: \"JSONEachRow\",\n  });\n\n  const clusterRows = await clusterResult.json<{\n    user_id: string | null;\n    device_id: string | null;\n  }>();\n\n  const user_ids = [\n    ...new Set(\n      clusterRows\n        .map((r) => r.user_id)\n        .filter((id): id is string => id !== null),\n    ),\n  ];\n  const device_ids = [\n    ...new Set(\n      clusterRows\n        .map((r) => r.device_id)\n        .filter((id): id is string => id !== null),\n    ),\n  ];\n\n  // ── Query 3: events ─────────────────────────────────────────────────────────\n\n  const eventsResult = await client.query({\n    query: `\n      SELECT\n        e.event_id,\n        e.event_name,\n        e.timestamp,\n        e.device_id,\n        e.user_id,\n        e.properties,\n        e.ingested_at,\n        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id\n      FROM events e\n      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n        ON e.device_id = m.device_id\n      WHERE coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\n      ORDER BY e.timestamp DESC, e.event_id DESC\n      LIMIT 200\n    `,\n    query_params: { resolved_id },\n    format: \"JSONEachRow\",\n  });\n\n  const events = await eventsResult.json<EventRow>();\n\n  return {\n    resolved_id,\n    first_seen: first_seen as string,\n    last_seen: last_seen as string,\n    identity_cluster: { user_ids, device_ids },\n    events,\n  };