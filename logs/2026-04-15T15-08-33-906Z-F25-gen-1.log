rl as string).includes(\"/api/trends\")) return trendsResponse();\n62\t    return errorResponse();\n63\t  });\n64\t});\n65\t\n66\tafterEach(() => {\n67\t  vi.clearAllMocks();\n68\t  vi.unstubAllGlobals();\n69\t});\n70\t\n71\t// ─── Tests ────────────────────────────────────────────────────────────────────\n72\t\n73\tdescribe(\"useTrends\", () => {\n74\t  describe(\"schema fetch on mount\", () => {\n75\t    it(\"fetches /api/schema on mount\", async () => {\n76\t      renderHook(() => useTrends());\n77\t      await waitFor(() => expect(mockFetch).toHaveBeenCalled());\n78\t      const calls = (mockFetch.mock.calls as [string][]).map(([url]) => url);\n79\t      expect(calls.some((url) => url.includes(\"/api/schema\"))).toBe(true);\n80\t    });\n81\t\n82\t    it(\"exposes event names from schema after mount\", async () => {\n83\t      const { result } = renderHook(() => useTrends());\n84\t      await waitFor(() => expect(result.current.schema).not.toBeNull());\n85\t      expect(result.current.schema?.event_names).toEqual(\n86\t        sampleSchema.event_names,\n87\t      );\n88\t    });\n89\t\n90\t    it(\"exposes properties from schema after mount\", async () => {\n91\t      const { result } = renderHook(() => useTrends());\n92\t      await waitFor(() => expect(result.current.schema).not.toBeNull());\n93\t      expect(result.current.schema?.properties).toEqual(\n94\t        sampleSchema.properties,\n95\t      );\n96\t    });\n97\t  });\n98\t\n99\t  describe(\"defaults\", () => {\n100\t    it(\"measure defaults to 'count'\", async () => {\n101\t      const { result } = renderHook(() => useTrends());\n102\t      expect(result.current.controls.measure).toBe(\"count\");\n103\t    });\n104\t\n105\t    it(\"granularity defaults to 'day'\", async () => {\n106\t      const { result } = renderHook(() => useTrends());\n107\t      expect(result.current.controls.granularity).toBe(\"day\");\n108\t    });\n109\t\n110\t    it(\"eventName defaults to null\", async () => {\n111\t      const { result } = renderHook(() => useTrends());\n112\t      expect(result.current.controls.eventName).toBeNull();\n113\t    });\n114\t\n115\t    it(\"breakdown defaults to null\", async () => {\n116\t      const { result } = renderHook(() => useTrends());\n117\t      expect(result.current.controls.breakdown).toBeNull();\n118\t    });\n119\t\n120\t    it(\"breakdownLimit defaults to 10\", async () => {\n121\t      const { result } = renderHook(() => useTrends());\n122\t      expect(result.current.controls.breakdownLimit).toBe(10);\n123\t    });\n124\t\n125\t    it(\"startDate defaults to approximately 30 days ago (YYYY-MM-DD format)\", async () => {\n126\t      const { result } = renderHook(() => useTrends());\n127\t      const today = new Date();\n128\t      const thirtyDaysAgo = new Date(today);\n129\t      thirtyDaysAgo.setDate(today.getDate() - 30);\n130\t      const expectedStart = thirtyDaysAgo.toISOString().slice(0, 10);\n131\t      expect(result.current.controls.startDate).toBe(expectedStart);\n132\t    });\n133\t\n134\t    it(\"endDate defaults to today (YYYY-MM-DD format)\", async () => {\n135\t      const { result } = renderHook(() => useTrends());\n136\t      const today = new Date().toISOString().slice(0, 10);\n137\t      expect(result.current.controls.endDate).toBe(today);\n138\t    });\n139\t  });\n140\t\n141\t  describe(\"trends fetch\", () => {\n142\t    it(\"does not fetch /api/trends on mount when eventName is null\", async () => {\n143\t      renderHook(() => useTrends());\n144\t      await waitFor(() => expect(mockFetch).toHaveBeenCalled());\n145\t      const calls = (mockFetch.mock.calls as [string][]).map(([url]) => url);\n146\t      expect(calls.every((url) => !url.includes(\"/api/trends\"))).toBe(true);\n147\t    });\n148\t\n149\t    it(\"fetches /api/trends when eventName is set\", async () => {\n150\t      const { result } = renderHook(() => useTrends());\n151\t      await waitFor(() => expect(result.current.schema).not.toBeNull());\n152\t\n153\t      act(() => {\n154\t        result.current.setters.setEventName(\"Page Viewed\");\n155\t      });\n156\t\n157\t      await waitFor(() => {\n158\t        const calls = (mockFetch.mock.calls as [string][]).map(([url]) => url);\n159\t        return calls.some((url) => url.includes(\"/api/trends\"));\n160\t      });\n161\t\n162\t      const trendsCalls = (mockFetch.mock.calls as [string][])\n163\t        .map(([url]) => url)\n164\t        .filter((url) => url.includes(\"/api/trends\"));\n165\t      expect(trendsCalls.length).toBeGreaterThan(0);\n166\t    });\n167\t\n168\t    it(\"includes event_name in the trends fetch URL\", async () => {\n169\t      const { result } = renderHook(() => useTrends());\n170\t      await waitFor(() => expect(result.current.schema).not.toBeNull());\n171\t\n172\t      act(() => {\n173\t        result.current.setters.setEventName(\"Purchase Completed\");\n174\t      });\n175\t\n176\t      await waitFor(() => {\n177\t        const calls = (mockFetch.mock.calls as [string][]).map(([url]) => url);\n178\t        return calls.some(\n179\t          (url) =>\n180\t            url.includes(\"/api/trends\") &&\n181\t            url.includes(\"event_name=Purchase+Completed\"),\n182\t        );\n183\t      });\n184\t    });\n185\t\n186\t    it(\"changing eventName triggers a new trends fetch\", async () => {\n187\t      const { result } = renderHook(() => useTrends());\n188\t      await waitFor(() => expect(result.current.schema).not.toBeNull());\n189\t\n190\t      act(() => {\n191\t        result.current.setters.setEventName(\"Page Viewed\");\n192\t      });\n193\t      await waitFor(() => result.current.series.length > 0);\n194\t\n195\t      act(() => {\n196\t        result.current.setters.setEventName(\"Purchase Completed\");\n197\t      });\n198\t\n199\t      await waitFor(() => {\n200\t        const calls = (mockFetch.mock.calls as [string][]).map(([url]) => url);\n201\t        const trendsCallUrls = calls.filter((url) =>\n202\t          url.includes(\"/api/trends\"),\n203\t        );\n204\t        return trendsCallUrls.some((url) => url.includes(\"Purchase+Completed\"));\n205\t      });\n206\t    });\n207\t\n208\t    it(\"populates series after trends fetch\", async () => {\n209\t      const { result } = renderHook(() => useTrends());\n210\t      await waitFor(() => expect(result.current.schema).not.toBeNull());\n211\t\n212\t      act(() => {\n213\t        result.current.setters.setEventName(\"Page Viewed\");\n214\t      });\n215\t\n216\t      await waitFor(() => expect(result.current.series).toHaveLength(1));\n217\t      expect(result.current.series[0].label).toBe(\"Page Viewed\");\n218\t    });\n219\t  });\n220\t\n221\t  describe(\"loading state\", () => {\n222\t    it(\"sets loading to false after schema fetch completes\", async () => {\n223\t      const { result } = renderHook(() => useTrends());\n224\t      await waitFor(() => expect(result.current.loading).toBe(false));\n225\t    });\n226\t\n227\t    it(\"sets loading to true during trends fetch\", async () => {\n228\t      let resolveTrends!: (v: unknown) => void;\n229\t      mockFetch.mockImplementation((url: string) => {\n230\t        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n231\t        if ((url as string).includes(\"/api/trends\"))\n232\t          return new Promise((resolve) => {\n233\t            resolveTrends = resolve;\n234\t          });\n235\t        return errorResponse();\n236\t      });\n237\t\n238\t      const { result } = renderHook(() => useTrends());\n239\t      await waitFor(() => expect(result.current.schema).not.toBeNull());\n240\t\n241\t      act(() => {\n242\t        result.current.setters.setEventName(\"Page Viewed\");\n243\t      });\n244\t\n245\t      await waitFor(() => expect(result.current.loading).toBe(true));\n246\t\n247\t      act(() => {\n248\t        resolveTrends({\n249\t          ok: true,\n250\t          json: () => Promise.resolve({ series: [] }),\n251\t        });\n252\t      });\n253\t\n254\t      await waitFor(() => expect(result.current.loading).toBe(false));\n255\t    });\n256\t  });\n257\t\n258\t  describe(\"numericProperties\", () => {\n259\t    it(\"returns empty array when eventName is null\", async () => {\n260\t      const { result } = renderHook(() => useTrends());\n261\t      await waitFor(() => expect(result.current.schema).not.toBeNull());\n262\t      expect(result.current.numericProperties).toEqual([]);\n263\t    });\n264\t\n265\t    it(\"derives numeric-only properties for the selected event\", async () => {\n266\t      const { result } = renderHook(() => useTrends());\n267\t      await waitFor(() => expect(result.current.schema).not.toBeNull());\n268\t\n269\t      act(() => {\n270\t        result.current.setters.setEventName(\"Purchase Completed\");\n271\t      });\n272\t\n273\t      await waitFor(() =>\n274\t        expect(result.current.numericProperties.length).toBeGreaterThan(0),\n275\t      );\n276\t\n277\t      // \"amount\" and \"quantity\" are numeric; \"currency\" and \"plan\" are strings\n278\t      expect(result.current.numericProperties).toContain(\"amount\");\n279\t      expect(result.current.numericProperties).toContain(\"quantity\");\n280\t      expect(result.current.numericProperties).not.toContain(\"currency\");\n281\t      expect(result.current.numericProperties).not.toContain(\"plan\");\n282\t    });\n283\t\n284\t    it(\"returns empty array for an event with no schema properties\", async () => {\n285\t      const { result } = renderHook(() => useTrends());\n286\t      await waitFor(() => expect(result.current.schema).not.toBeNull());\n287\t\n288\t      act(() => {\n289\t        result.current.setters.setEventName(\"Signup Completed\");\n290\t      });\n291\t\n292\t      await waitFor(() => expect(result.current.loading).toBe(false));\n293\t      expect(result.current.numericProperties).toEqual([]);\n294\t    });\n295\t  });\n296\t\n297\t  describe(\"error handling\", () => {\n298\t    it(\"handles schema fetch error gracefully (schema stays null)\", async () => {\n299\t      mockFetch.mockImplementation(() => errorResponse());\n300\t\n301\t      const { result } = renderHook(() => useTrends());\n302\t      await waitFor(() => expect(result.current.loading).toBe(false));\n303\t      expect(result.current.schema).toBeNull();\n304\t    });\n305\t\n306\t    it(\"sets error state when trends fetch fails\", async () => {\n307\t      mockFetch.mockImplementation((url: string) => {\n308\t        if ((url as string).includes(\"/api/schema\")) return schemaResponse();\n309\t        if ((url as string).includes(\"/api/trends\")) return errorResponse();\n310\t        return errorResponse();\n311\t      });\n312\t\n313\t      const { result } = renderHook(() => useTrends());\n314\t      await waitFor(() => expect(result.current.schema).not.toBeNull());\n315\t\n316\t      act(() => {\n317\t        result.current.setters.setEventName(\"Page Viewed\");\n318\t      });\n319\t\n320\t      await waitFor(() => expect(result.current.error).not.toBeNull());\n321\t      expect(result.current.series).toEqual([]);\n322\t    });\n323\t  });\n324\t});\n325\t"}]},"parent_tool_use_id":null,"session_id":"a95ae396-124a-4cd9-a015-7f076b7b8d80","uuid":"f0c3e279-2e7b-4145-b3f8-968536c22e47","timestamp":"2026-04-15T17:15:59.089Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/trends/__tests__/useTrends.test.ts","content":"// @vitest-environment jsdom\nimport { act, renderHook, waitFor } from \"@testing-library/react\";\nimport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\nimport { useTrends } from \"@/components/trends/useTrends\";\n\n// ─── Fixtures ─────────────────────────────────────────────────────────────────\n\nconst sampleSchema = {\n  event_names: [\"Page Viewed\", \"Purchase Completed\", \"Signup Completed\"],\n  properties: {\n    \"Purchase Completed\": {\n      amount: \"numer