w\n      await act(async () => {\n        vi.advanceTimersByTime(400);\n      });\n\n      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(2));\n\n      // The final fetch should use the last query value\n      const url = new URL(mockFetch.mock.calls[1][0] as string);\n      expect(url.searchParams.get(\"q\")).toBe(\"abc\");\n    });\n  });\n});\n","structuredPatch":[{"oldStart":188,"oldLines":21,"newStart":188,"newLines":22,"lines":["   });"," ","   describe(\"setQuery\", () => {","+    // Fake only setTimeout/clearTimeout so setInterval (used by waitFor) still works","+    beforeEach(() => {","+      vi.useFakeTimers({ toFake: [\"setTimeout\", \"clearTimeout\"] });","+    });","+","     it(\"re-fetches with q param when query is set\", async () => {","-      vi.useFakeTimers();","       const { result } = renderHook(() => useUserSearch());"," ","-      // Advance timers to let the initial fetch happen","-      await act(async () => {","-        vi.runAllTimers();","-      });","+      // Let the initial mount fetch complete","       await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(1));"," ","       act(() => {","         result.current.setQuery(\"test@\");","       });"," ","-      // Advance timers past the debounce delay","+      // Advance past the debounce delay and flush the resulting async work","       await act(async () => {","         vi.advanceTimersByTime(400);","       });"]},{"oldStart":214,"oldLines":7,"newStart":215,"newLines":6,"lines":["     });"," ","     it(\"resets users list and cursor when query changes\", async () => {","-      vi.useFakeTimers();","       const filteredUser = {","         ...sampleUser,","         resolved_id: \"filtered@example.com\","]},{"oldStart":226,"oldLines":9,"newStart":226,"newLines":6,"lines":[" ","       const { result } = renderHook(() => useUserSearch());"," ","-      await act(async () => {","-        vi.runAllTimers();","-      });","       await waitFor(() => expect(result.current.use