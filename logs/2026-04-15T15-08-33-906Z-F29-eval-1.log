{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q1i4gucYTsdDAACkVSKu61","type":"tool_result","content":"1\t/**\n2\t * Integration test: verifies actual ClickHouse connectivity.\n3\t * Skipped when no ClickHouse server is reachable at localhost:8123.\n4\t *\n5\t * Run with: pnpm test (requires ./clickhouse server -- --path=.clickhouse)\n6\t */\n7\timport { describe, expect, it } from \"vitest\";\n8\t\n9\tconst CLICKHOUSE_URL = process.env.CLICKHOUSE_URL ?? \"http://localhost:8123\";\n10\t\n11\tasync function isClickHouseReachable(): Promise<boolean> {\n12\t  try {\n13\t    const res = await fetch(`${CLICKHOUSE_URL}/ping`, {\n14\t      signal: AbortSignal.timeout(2000),\n15\t    });\n16\t    return res.ok;\n17\t  } catch {\n18\t    return false;\n19\t  }\n20\t}\n21\t\n22\tdescribe.skipIf(!(await isClickHouseReachable()))(\n23\t  \"clickhouse integration — real server\",\n24\t  () => {\n25\t    it(\"client can execute SELECT 1 against a live ClickHouse server\", async () => {\n26\t      const { clickhouse } = await import(\"@/lib/clickhouse\");\n27\t      const result = await clickhouse.query({\n28\t        query: \"SELECT 1 AS value\",\n29\t        format: \"JSONEachRow\",\n30\t      });\n31\t      const rows = await result.json<{ value: number }>();\n32\t      expect(rows).toHaveLength(1);\n33\t      expect(rows[0].value).toBe(1);\n34\t    });\n35\t\n36\t    it(\"client ping returns a successful response\", async () => {\n37\t      const { clickhouse } = await import(\"@/lib/clickhouse\");\n38\t      const ping = await clickhouse.ping();\n39\t      expect(ping.success).toBe(true);\n40\t    });\n41\t  },\n42\t);\n43\t"}]},"parent_tool_use_id":null,"session_id":"47e39113-7079-4837-9310-eb1a726ebc0e","uuid":"aac46048-5ff3-478d-b3fa-9568da7f1412","timestamp":"2026-04-15T18:25:52.374Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/clickhouse.integration.test.ts","content":"/**\n * Integration test: verifies actual ClickHouse connectivity.\n * Skipped when no ClickHouse server is reachable at localhost:8123.\n *\n * Run with: pnpm test (requires ./clickhouse server -- --path=.clickhouse)\n */\nimport { describe, expect, it } from \"vitest\";\n\nconst CLICKHOUSE_URL = process.env.CLICKHOUSE_URL ?? \"http://localhost:8123\";\n\nasync function isClickHouseReachable(): Promise<boolean> {\n  try {\n    const res = await fetch(`${CLICKHOUSE_URL}/ping`, {\n      signal: AbortSignal.timeout(2000),\n    });\n    return res.ok;\n  } catch {\n    return false;\n  }\n}\n\ndescribe.skipIf(!(await isClickHouseReachable()))(\n  \"clickhouse integration — real server\",\n  () => {\n    it(\"client can execute SELECT 1 against a live ClickHouse server\", async () => {\n      const { clickhouse } = await import(\"@/lib/clickhouse\");\n      const result = await clickhouse.query({\n        query: \"SELECT 1 AS value\",\n        format: \"JSONEachRow\",\n      });\n      const rows = await result.json<{ value: number }>();\n      expect(rows).toHaveLength(1);\n      expect(rows[0].value).toBe(1);\n    });\n\n    it(\"client ping returns a successful response\", async () => {\n      const { clickhouse } = await import(\"@/lib/clickhouse\");\n      const ping = await clickhouse.ping();\n      expect(ping.success).toBe(true);\n    });\n  },\n);\n","numLines":43,"startLine":1,"totalLines":43}}}
