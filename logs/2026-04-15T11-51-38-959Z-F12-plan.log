{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0189PDDm3622XoC5WcpSxz7X","type":"tool_result","content":"1\timport { queryTrends } from \"@/lib/trends\";\n2\t\n3\t// ─── Validation helpers ───────────────────────────────────────────────────────\n4\t\n5\tconst VALID_MEASURES = new Set([\"count\", \"unique_users\"]);\n6\tconst VALID_GRANULARITIES = new Set([\"day\", \"week\"]);\n7\t\n8\t/**\n9\t * Returns an error string if the measure is invalid, otherwise null.\n10\t * Valid forms: \"count\", \"unique_users\", \"sum:<prop>\", \"avg:<prop>\",\n11\t * \"min:<prop>\", \"max:<prop>\" where <prop> is a non-empty string.\n12\t */\n13\tfunction validateMeasure(measure: string): string | null {\n14\t  if (VALID_MEASURES.has(measure)) return null;\n15\t  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n16\t  if (match) return null;\n17\t  return `Invalid measure \"${measure}\". Must be count, unique_users, sum:<prop>, avg:<prop>, min:<prop>, or max:<prop>.`;\n18\t}\n19\t\n20\t// ─── Route handler ────────────────────────────────────────────────────────────\n21\t\n22\t/**\n23\t * GET /api/trends\n24\t *\n25\t * Query params:\n26\t *   event_name   (required)\n27\t *   measure      default \"count\"\n28\t *   granularity  default \"day\"\n29\t *   start        (required) ISO date YYYY-MM-DD\n30\t *   end          (required) ISO date YYYY-MM-DD\n31\t *   breakdown    (optional) property name\n32\t *   breakdown_limit (optional) default 10\n33\t */\n34\texport async function GET(request: Request): Promise<Response> {\n35\t  const { searchParams } = new URL(request.url);\n36\t\n37\t  const event_name = searchParams.get(\"event_name\");\n38\t  const measure = searchParams.get(\"measure\") ?? \"count\";\n39\t  const granularity = searchParams.get(\"granularity\") ?? \"day\";\n40\t  const start = searchParams.get(\"start\");\n41\t  const end = searchParams.get(\"end\");\n42\t  const breakdown = searchParams.get(\"breakdown\") ?? undefined;\n43\t  const breakdownLimitRaw = searchParams.get(\"breakdown_limit\");\n44\t\n45\t  // ── Required param checks ─────────────────────────────────────────────────\n46\t\n47\t  if (!event_name) {\n48\t    return Response.json({ error: \"event_name is required.\" }, { status: 400 });\n49\t  }\n50\t\n51\t  if (!start) {\n52\t    return Response.json({ error: \"start is required.\" }, { status: 400 });\n53\t  }\n54\t\n55\t  if (!end) {\n56\t    return Response.json({ error: \"end is required.\" }, { status: 400 });\n57\t  }\n58\t\n59\t  // ── Optional param validation ─────────────────────────────────────────────\n60\t\n61\t  const measureError = validateMeasure(measure);\n62\t  if (measureError) {\n63\t    return Response.json({ error: measureError }, { status: 400 });\n64\t  }\n65\t\n66\t  if (!VALID_GRANULARITIES.has(granularity)) {\n67\t    return Response.json(\n68\t      {\n69\t        error: `Invalid granularity \"${granularity}\". Must be \"day\" or \"week\".`,\n70\t      },\n71\t      { status: 400 },\n72\t    );\n73\t  }\n74\t\n75\t  let breakdown_limit = 10;\n76\t  if (breakdownLimitRaw !== null) {\n77\t    const parsed = Number(breakdownLimitRaw);\n78\t    if (Number.isFinite(parsed) && parsed > 0) {\n79\t      breakdown_limit = Math.floor(parsed);\n80\t    }\n81\t  }\n82\t\n83\t  // ── Execute query ─────────────────────────────────────────────────────────\n84\t\n85\t  try {\n86\t    const response = await queryTrends({\n87\t      event_name,\n88\t      measure,\n89\t      granularity: granularity as \"day\" | \"week\",\n90\t      start,\n91\t      end,\n92\t      breakdown,\n93\t      breakdown_limit,\n94\t    });\n95\t    return Response.json(response);\n96\t  } catch (err) {\n97\t    const message =\n98\t      err instanceof Error ? err.message : \"Internal server error.\";\n99\t    return Response.json({ error: message }, { status: 500 });\n100\t  }\n101\t}\n102\t"}]},"parent_tool_use_id":null,"session_id":"470cc455-57a5-49ec-b42a-d326a6c8b9bd","uuid":"67978fe4-da66-4068-b84f-1403f095a2c1","timestamp":"2026-04-15T13:30:49.985Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/trends/route.ts","content":"import { queryTrends } from \"@/lib/trends\";\n\n// ─── Validation helpers ───────────────────────────────────────────────────────\n\nconst VALID_MEASURES = new Set([\"count\", \"unique_users\"]);\nconst VALID_GRANULARITIES = new Set([\"day\", \"week\"]);\n\n/**\n * Returns an error string if the measure is invalid, otherwise null.\n * Valid forms: \"count\", \"unique_users\", \"sum:<prop>\", \"avg:<prop>\",\n * \"min:<prop>\", \"max:<prop>\" where <prop> is a non-empty string.\n */\nfunction validateMeasure(measure: string): string | null {\n  if (VALID_MEASURES.has(measure)) return null;\n  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n  if (match) return null;\n  return `Invalid measure \"${measure}\". Must be count, unique_users, sum:<prop>, avg:<prop>, min:<prop>, or max:<prop>.`;\n}\n\n// ─── Route handler ────────────────────────────────────────────────────────────\n\n/**\n * GET /api/trends\n *\n * Query params:\n *   event_name   (required)\n *   measure      default \"count\"\n *   granularity  default \"day\"\n *   start        (required) ISO date YYYY-MM-DD\n *   end          (required) ISO date YYYY-MM-DD\n *   breakdown    (optional) property name\n *   breakdown_limit (optional) default 10\n */\nexport async function GET(request: Request): Promise<Response> {\n  const { searchParams } = new URL(request.url);\n\n  const event_name = searchParams.get(\"event_name\");\n  const measure = searchParams.get(\"measure\") ?? \"count\";\n  const granularity = searchParams.get(\"granularity\") ?? \"day\";\n  const start = searchParams.get(\"start\");\n  const end = searchParams.get(\"end\");\n  const breakdown = searchParams.get(\"breakdown\") ?? undefined;\n  const breakdownLimitRaw = searchParams.get(\"breakdown_limit\");\n\n  // ── Required param checks ─────────────────────────────────────────────────\n\n  if (!event_name) {\n    return Response.json({ error: \"event_name is required.\" }, { status: 400 });\n  }\n\n  if (!start) {\n    return Response.json({ error: \"start is required.\" }, { status: 400 });\n  }\n\n  if (!end) {\n    return Response.json({ error: \"end is required.\" }, { status: 400 });\n  }\n\n  // ── Optional param validation ─────────────────────────────────────────────\n\n  const measureError = validateMeasure(measure);\n  if (measureError) {\n    return Response.json({ error: measureError }, { status: 400 });\n  }\n\n  if (!VALID_GRANULARITIES.has(granularity)) {\n    return Response.json(\n      {\n        error: `Invalid granularity \"${granularity}\". Must be \"day\" or \"week\".`,\n      },\n      { status: 400 },\n    );\n  }\n\n  let breakdown_limit = 10;\n  if (breakdownLimitRaw !== null) {\n    const parsed = Number(breakdownLimitRaw);\n    if (Number.isFinite(parsed) && parsed > 0) {\n      breakdown_limit = Math.floor(parsed);\n    }\n  }\n\n  // ── Execute query ─────────────────────────────────────────────────────────\n\n  try {\n    const response = await queryTrends({\n      event_name,\n      measure,\n      granularity: granularity as \"day\" | \"week\",\n      start,\n      end,\n      breakdown,\n      breakdown_limit,\n    });\n    return Response.json(response);\n  } catch (err) {\n    const message =\n      err instanceof Error ? err.message : \"Internal server error.\";\n    return Response.json({ error: message }, { status: 500 });\n  }\n}\n","numLines":102,"startLine":1,"totalLines":102}}}
