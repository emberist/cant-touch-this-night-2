{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011vhkpyCrQYRNF6sqyYUr3m","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQuery } = vi.hoisted(() => ({\n6\t  mockQuery: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: {\n11\t    query: mockQuery,\n12\t  },\n13\t}));\n14\t\n15\timport { buildTrendsQuery, queryTrends } from \"@/lib/trends\";\n16\t\n17\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n18\t\n19\tfunction mockQueryReturns(rows: unknown[]) {\n20\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n21\t}\n22\t\n23\tconst baseParams = {\n24\t  event_name: \"Page Viewed\",\n25\t  measure: \"count\",\n26\t  granularity: \"day\" as const,\n27\t  start: \"2026-04-01\",\n28\t  end: \"2026-04-15\",\n29\t};\n30\t\n31\t// ─── Tests ────────────────────────────────────────────────────────────────────\n32\t\n33\tbeforeEach(() => {\n34\t  mockQueryReturns([]);\n35\t});\n36\t\n37\tafterEach(() => {\n38\t  vi.clearAllMocks();\n39\t});\n40\t\n41\t// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n42\t\n43\tdescribe(\"buildTrendsQuery\", () => {\n44\t  describe(\"measure expressions\", () => {\n45\t    it(\"uses count() for measure=count\", () => {\n46\t      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n47\t      expect(query).toContain(\"count()\");\n48\t    });\n49\t\n50\t    it(\"uses uniqExact and identity_mappings FINAL for measure=unique_users\", () => {\n51\t      const { query } = buildTrendsQuery({\n52\t        ...baseParams,\n53\t        measure: \"unique_users\",\n54\t      });\n55\t      expect(query).toContain(\"uniqExact\");\n56\t      expect(query).toContain(\"identity_mappings FINAL\");\n57\t    });\n58\t\n59\t    it(\"does not include identity_mappings JOIN for measure=count\", () => {\n60\t      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n61\t      expect(query).not.toContain(\"identity_mappings\");\n62\t    });\n63\t\n64\t    it(\"uses sum(JSONExtractFloat) for measure=sum:amount\", () => {\n65\t      const { query } = buildTrendsQuery({\n66\t        ...baseParams,\n67\t        measure: \"sum:amount\",\n68\t      });\n69\t      expect(query).toContain(\"sum(JSONExtractFloat\");\n70\t      expect(query).toContain(\"'amount'\");\n71\t    });\n72\t\n73\t    it(\"uses avg(JSONExtractFloat) for measure=avg:amount\", () => {\n74\t      const { query } = buildTrendsQuery({\n75\t        ...baseParams,\n76\t        measure: \"avg:amount\",\n77\t      });\n78\t      expect(query).toContain(\"avg(JSONExtractFloat\");\n79\t      expect(query).toContain(\"'amount'\");\n80\t    });\n81\t\n82\t    it(\"uses min(JSONExtractFloat) for measure=min:amount\", () => {\n83\t      const { query } = buildTrendsQuery({\n84\t        ...baseParams,\n85\t        measure: \"min:amount\",\n86\t      });\n87\t      expect(query).toContain(\"min(JSONExtractFloat\");\n88\t    });\n89\t\n90\t    it(\"uses max(JSONExtractFloat) for measure=max:amount\", () => {\n91\t      const { query } = buildTrendsQuery({\n92\t        ...baseParams,\n93\t        measure: \"max:amount\",\n94\t      });\n95\t      expect(query).toContain(\"max(JSONExtractFloat\");\n96\t    });\n97\t  });\n98\t\n99\t  describe(\"granularity\", () => {\n100\t    it(\"groups by toDate for granularity=day\", () => {\n101\t      const { query } = buildTrendsQuery({\n102\t        ...baseParams,\n103\t        granularity: \"day\",\n104\t      });\n105\t      expect(query).toContain(\"toDate(\");\n106\t    });\n107\t\n108\t    it(\"groups by toMonday for granularity=week\", () => {\n109\t      const { query } = buildTrendsQuery({\n110\t        ...baseParams,\n111\t        granularity: \"week\",\n112\t      });\n113\t      expect(query).toContain(\"toMonday(\");\n114\t    });\n115\t  });\n116\t\n117\t  describe(\"date range\", () => {\n118\t    it(\"includes start and end_exclusive in query params\", () => {\n119\t      const { query_params } = buildTrendsQuery({\n120\t        ...baseParams,\n121\t        start: \"2026-04-01\",\n122\t        end: \"2026-04-15\",\n123\t      });\n124\t      expect(query_params).toHaveProperty(\"start\");\n125\t      expect(query_params).toHaveProperty(\"end_exclusive\");\n126\t      expect(query_params.start).toContain(\"2026-04-01\");\n127\t      expect(query_params.end_exclusive).toContain(\"2026-04-16\");\n128\t    });\n129\t\n130\t    it(\"start param uses ClickHouse-compatible space-separated format (no T or Z)\", () => {\n131\t      const { query_params } = buildTrendsQuery({\n132\t        ...baseParams,\n133\t        start: \"2026-04-01\",\n134\t      });\n135\t      expect(query_params.start).toBe(\"2026-04-01 00:00:00.000\");\n136\t      expect(query_params.start).not.toContain(\"T\");\n137\t      expect(query_params.start).not.toContain(\"Z\");\n138\t    });\n139\t\n140\t    it(\"end_exclusive param uses ClickHouse-compatible space-separated format (no T or Z)\", () => {\n141\t      const { query_params } = buildTrendsQuery({\n142\t        ...baseParams,\n143\t        end: \"2026-04-15\",\n144\t      });\n145\t      expect(query_params.end_exclusive).toBe(\"2026-04-16 00:00:00.000\");\n146\t      expect(query_params.end_exclusive).not.toContain(\"T\");\n147\t      expect(query_params.end_exclusive).not.toContain(\"Z\");\n148\t    });\n149\t\n150\t    it(\"end_exclusive correctly handles month rollover (April 30 → May 1)\", () => {\n151\t      const { query_params } = buildTrendsQuery({\n152\t        ...baseParams,\n153\t        end: \"2026-04-30\",\n154\t      });\n155\t      expect(query_params.end_exclusive).toBe(\"2026-05-01 00:00:00.000\");\n156\t    });\n157\t\n158\t    it(\"references start and end_exclusive params in the WHERE clause\", () => {\n159\t      const { query } = buildTrendsQuery(baseParams);\n160\t      expect(query).toContain(\"{start:String}\");\n161\t      expect(query).toContain(\"{end_exclusive:String}\");\n162\t    });\n163\t\n164\t    it(\"includes event_name in query params\", () => {\n165\t      const { query_params } = buildTrendsQuery({\n166\t        ...baseParams,\n167\t        event_name: \"Purchase Completed\",\n168\t      });\n169\t      expect(query_params.event_name).toBe(\"Purchase Completed\");\n170\t    });\n171\t  });\n172\t\n173\t  describe(\"breakdown\", () => {\n174\t    it(\"does not include breakdown_val column when no breakdown is given\", () => {\n175\t      const { query } = buildTrendsQuery(baseParams);\n176\t      expect(query).not.toContain(\"breakdown_val\");\n177\t    });\n178\t\n179\t    it(\"includes JSONExtractString and breakdown_val when breakdown is provided\", () => {\n180\t      const { query } = buildTrendsQuery({\n181\t        ...baseParams,\n182\t        breakdown: \"country\",\n183\t      });\n184\t      expect(query).toContain(\"JSONExtractString\");\n185\t      expect(query).toContain(\"breakdown_val\");\n186\t      expect(query).toContain(\"'country'\");\n187\t    });\n188\t\n189\t    it(\"groups by breakdown_val in addition to bucket when breakdown is provided\", () => {\n190\t      const { query } = buildTrendsQuery({\n191\t        ...baseParams,\n192\t        breakdown: \"country\",\n193\t      });\n194\t      expect(query).toContain(\"GROUP BY bucket, breakdown_val\");\n195\t    });\n196\t  });\n197\t});\n198\t\n199\t// ─── queryTrends ──────────────────────────────────────────────────────────────\n200\t\n201\tdescribe(\"queryTrends\", () => {\n202\t  describe(\"without breakdown\", () => {\n203\t    it(\"returns a single series with label = event_name\", async () => {\n204\t      mockQueryReturns([\n205\t        { bucket: \"2026-04-01\", value: 5 },\n206\t        { bucket: \"2026-04-02\", value: 3 },\n207\t      ]);\n208\t\n209\t      const result = await queryTrends({\n210\t        ...baseParams,\n211\t        event_name: \"Page Viewed\",\n212\t      });\n213\t\n214\t      expect(result.series).toHaveLength(1);\n215\t      expect(result.series[0].label).toBe(\"Page Viewed\");\n216\t    });\n217\t\n218\t    it(\"maps rows to { date, value } data points\", async () => {\n219\t      mockQueryReturns([\n220\t        { bucket: \"2026-04-01\", value: 5 },\n221\t        { bucket: \"2026-04-02\", value: 3 },\n222\t      ]);\n223\t\n224\t      const result = await queryTrends(baseParams);\n225\t\n226\t      expect(result.series[0].data).toEqual([\n227\t        { date: \"2026-04-01\", value: 5 },\n228\t        { date: \"2026-04-02\", value: 3 },\n229\t      ]);\n230\t    });\n231\t\n232\t    it(\"coerces string values returned by ClickHouse to numbers\", async () => {\n233\t      mockQueryReturns([{ bucket: \"2026-04-01\", value: \"42\" }]);\n234\t\n235\t      const result = await queryTrends(baseParams);\n236\t\n237\t      expect(result.series[0].data[0].value).toBe(42);\n238\t      expect(typeof result.series[0].data[0].value).toBe(\"number\");\n239\t    });\n240\t\n241\t    it(\"returns { series: [] } when ClickHouse returns no rows\", async () => {\n242\t      mockQueryReturns([]);\n243\t\n244\t      const result = await queryTrends(baseParams);\n245\t\n246\t      expect(result.series).toEqual([]);\n247\t    });\n248\t  });\n249\t\n250\t  describe(\"with breakdown\", () => {\n251\t    it(\"returns one series per distinct breakdown value\", async () => {\n252\t      mockQueryReturns([\n253\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n254\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n255\t        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n256\t      ]);\n257\t\n258\t      const result = await queryTrends({\n259\t        ...baseParams,\n260\t        breakdown: \"country\",\n261\t      });\n262\t\n263\t      const labels = result.series.map((s) => s.label);\n264\t      expect(labels).toContain(\"US\");\n265\t      expect(labels).toContain(\"DE\");\n266\t    });\n267\t\n268\t    it(\"orders data points within each series chronologically\", async () => {\n269\t      mockQueryReturns([\n270\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n271\t        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n272\t      ]);\n273\t\n274\t      const result = await queryTrends({\n275\t        ...baseParams,\n276\t        breakdown: \"country\",\n277\t      });\n278\t\n279\t      const usSeries = result.series.find((s) => s.label === \"US\");\n280\t      expect(usSeries?.data[0].date).toBe(\"2026-04-01\");\n281\t      expect(usSeries?.data[1].date).toBe(\"2026-04-02\");\n282\t    });\n283\t\n284\t    it(\"respects breakdown_limit and groups remaining values as Other\", async () => {\n285\t      mockQueryReturns([\n286\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n287\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n288\t        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n289\t      ]);\n290\t\n291\t      const result = await queryTrends({\n292\t        ...baseParams,\n293\t        breakdown: \"country\",\n294\t        breakdown_limit: 2,\n295\t      });\n296\t\n297\t      expect(result.series).toHaveLength(3); // US, DE, Other\n298\t      const labels = result.series.map((s) => s.label);\n299\t      expect(labels).toContain(\"US\");\n300\t      expect(labels).toContain(\"DE\");\n301\t      expect(labels).toContain(\"Other\");\n302\t      expect(labels).not.toContain(\"FR\");\n303\t    });\n304\t\n305\t    it(\"Other series aggregates values of non-top breakdown values by date\", async () => {\n306\t      mockQueryReturns([\n307\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n308\t        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n309\t        { bucket: \"2026-04-01\", breakdown_val: \"JP\", value: 7 },\n310\t      ]);\n311\t\n312\t      const result = await queryTrends({\n313\t        ...baseParams,\n314\t        breakdown: \"country\",\n315\t        breakdown_limit: 1,\n316\t      });\n317\t\n318\t      const otherSeries = result.series.find((s) => s.label === \"Other\");\n319\t      expect(otherSeries).toBeDefined();\n320\t      // FR (10) + JP (7) = 17\n321\t      expect(otherSeries?.data[0].value).toBe(17);\n322\t    });\n323\t\n324\t    it(\"does not add Other series when all values are within the limit\", async () => {\n325\t      mockQueryReturns([\n326\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n327\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n328\t      ]);\n329\t\n330\t      const result = await queryTrends({\n331\t        ...baseParams,\n332\t        breakdown: \"country\",\n333\t        breakdown_limit: 10,\n334\t      });\n335\t\n336\t      const labels = result.series.map((s) => s.label);\n337\t      expect(labels).not.toContain(\"Other\");\n338\t    });\n339\t\n340\t    it(\"sorts series by total value descending (top values first)\", async () => {\n341\t      mockQueryReturns([\n342\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n343\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n344\t        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 25 },\n345\t      ]);\n346\t\n347\t      const result = await queryTrends({\n348\t        ...baseParams,\n349\t        breakdown: \"country\",\n350\t        breakdown_limit: 10,\n351\t      });\n352\t\n353\t      expect(result.series[0].label).toBe(\"US\");\n354\t      expect(result.series[1].label).toBe(\"DE\");\n355\t      expect(result.series[2].label).toBe(\"FR\");\n356\t    });\n357\t  });\n358\t});\n359\t"}]},"parent_tool_use_id":null,"session_id":"470cc455-57a5-49ec-b42a-d326a6c8b9bd","uuid":"e6a1c03f-d715-40d2-a573-2706a35cae74","timestamp":"2026-04-15T13:31:06.142Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/trends.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockQuery } = vi.hoisted(() => ({\n  mockQuery: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    query: mockQuery,\n  },\n}));\n\nimport { buildTrendsQuery, queryTrends } from \"@/lib/trends\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction mockQueryReturns(rows: unknown[]) {\n  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n}\n\nconst baseParams = {\n  event_name: \"Page Viewed\",\n  measure: \"count\",\n  granularity: \"day\" as const,\n  start: \"2026-04-01\",\n  end: \"2026-04-15\",\n};\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockQueryReturns([]);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\n// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n\ndescribe(\"buildTrendsQuery\", () => {\n  describe(\"measure expressions\", () => {\n    it(\"uses count() for measure=count\", () => {\n      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n      expect(query).toContain(\"count()\");\n    });\n\n    it(\"uses uniqExact and identity_mappings FINAL for measure=unique_users\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"unique_users\",\n      });\n      expect(query).toContain(\"uniqExact\");\n      expect(query).toContain(\"identity_mappings FINAL\");\n    });\n\n    it(\"does not include identity_mappings JOIN for measure=count\", () => {\n      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n      expect(query).not.toContain(\"identity_mappings\");\n    });\n\n    it(\"uses sum(JSONExtractFloat) for measure=sum:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"sum:amount\",\n      });\n      expect(query).toContain(\"sum(JSONExtractFloat\");\n      expect(query).toContain(\"'amount'\");\n    });\n\n    it(\"uses avg(JSONExtractFloat) for measure=avg:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"avg:amount\",\n      });\n      expect(query).toContain(\"avg(JSONExtractFloat\");\n      expect(query).toContain(\"'amount'\");\n    });\n\n    it(\"uses min(JSONExtractFloat) for measure=min:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"min:amount\",\n      });\n      expect(query).toContain(\"min(JSONExtractFloat\");\n    });\n\n    it(\"uses max(JSONExtractFloat) for measure=max:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"max:amount\",\n      });\n      expect(query).toContain(\"max(JSONExtractFloat\");\n    });\n  });\n\n  describe(\"granularity\", () => {\n    it(\"groups by toDate for granularity=day\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        granularity: \"day\",\n      });\n      expect(query).toContain(\"toDate(\");\n    });\n\n    it(\"groups by toMonday for granularity=week\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        granularity: \"week\",\n      });\n      expect(query).toContain(\"toMonday(\");\n    });\n  });\n\n  describe(\"date range\", () => {\n    it(\"includes start and end_exclusive in query params\", () => {\n      const { query_params } = buildTrendsQuery({\n        ...baseParams,\n        start: \"2026-04-01\",\n        end: \"2026-04-15\",\n      });\n      expect(query_params).toHaveProperty(\"start\");\n      expect(query_params).toHaveProperty(\"end_exclusive\");\n      expect(query_params.start).toContain(\"2026-04-01\");\n      expect(query_params.end_exclusive).toContain(\"2026-04-16\");\n    });\n\n    it(\"start param uses ClickHouse-compatible space-separated format (no T or Z)\", () => {\n      const { query_params } = buildTrendsQuery({\n        ...baseParams,\n        start: \"2026-04-01\",\n      });\n      expect(query_params.start).toBe(\"2026-04-01 00:00:00.000\");\n      expect(query_params.start).not.toContain(\"T\");\n      expect(query_params.start).not.toContain(\"Z\");\n    });\n\n    it(\"end_exclusive param uses ClickHouse-compatible space-separated format (no T or Z)\", () => {\n      const { query_params } = buildTrendsQuery({\n        ...baseParams,\n        end: \"2026-04-15\",\n      });\n      expect(query_params.end_exclusive).toBe(\"2026-04-16 00:00:00.000\");\n      expect(query_params.end_exclusive).not.toContain(\"T\");\n      expect(query_params.end_exclusive).not.toContain(\"Z\");\n    });\n\n    it(\"end_exclusive correctly handles month rollover (April 30 → May 1)\", () => {\n      const { query_params } = buildTrendsQuery({\n        ...baseParams,\n        end: \"2026-04-30\",\n      });\n      expect(query_params.end_exclusive).toBe(\"2026-05-01 00:00:00.000\");\n    });\n\n    it(\"references start and end_exclusive params in the WHERE clause\", () => {\n      const { query } = buildTrendsQuery(baseParams);\n      expect(query).toContain(\"{start:String}\");\n      expect(query).toContain(\"{end_exclusive:String}\");\n    });\n\n    it(\"includes event_name in query params\", () => {\n      const { query_params } = buildTrendsQuery({\n        ...baseParams,\n        event_name: \"Purchase Completed\",\n      });\n      expect(query_params.event_name).toBe(\"Purchase Completed\");\n    });\n  });\n\n  describe(\"breakdown\", () => {\n    it(\"does not include breakdown_val column when no breakdown is given\", () => {\n      const { query } = buildTrendsQuery(baseParams);\n      expect(query).not.toContain(\"breakdown_val\");\n    });\n\n    it(\"includes JSONExtractString and breakdown_val when breakdown is provided\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n      expect(query).toContain(\"JSONExtractString\");\n      expect(query).toContain(\"breakdown_val\");\n      expect(query).toContain(\"'country'\");\n    });\n\n    it(\"groups by breakdown_val in addition to bucket when breakdown is provided\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n      expect(query).toContain(\"GROUP BY bucket, breakdown_val\");\n    });\n  });\n});\n\n// ─── queryTrends ──────────────────────────────────────────────────────────────\n\ndescribe(\"queryTrends\", () => {\n  describe(\"without breakdown\", () => {\n    it(\"returns a single series with label = event_name\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", value: 5 },\n        { bucket: \"2026-04-02\", value: 3 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        event_name: \"Page Viewed\",\n      });\n\n      expect(result.series).toHaveLength(1);\n      expect(result.series[0].label).toBe(\"Page Viewed\");\n    });\n\n    it(\"maps rows to { date, value } data points\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", value: 5 },\n        { bucket: \"2026-04-02\", value: 3 },\n      ]);\n\n      const result = await queryTrends(baseParams);\n\n      expect(result.series[0].data).toEqual([\n        { date: \"2026-04-01\", value: 5 },\n        { date: \"2026-04-02\", value: 3 },\n      ]);\n    });\n\n    it(\"coerces string values returned by ClickHouse to numbers\", async () => {\n      mockQueryReturns([{ bucket: \"2026-04-01\", value: \"42\" }]);\n\n      const result = await queryTrends(baseParams);\n\n      expect(result.series[0].data[0].value).toBe(42);\n      expect(typeof result.series[0].data[0].value).toBe(\"number\");\n    });\n\n    it(\"returns { series: [] } when ClickHouse returns no rows\", async () => {\n      mockQueryReturns([]);\n\n      const result = await queryTrends(baseParams);\n\n      expect(result.series).toEqual([]);\n    });\n  });\n\n  describe(\"with breakdown\", () => {\n    it(\"returns one series per distinct breakdown value\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n\n      const labels = result.series.map((s) => s.label);\n      expect(labels).toContain(\"US\");\n      expect(labels).toContain(\"DE\");\n    });\n\n    it(\"orders data points within each series chronologically\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n\n      const usSeries = result.series.find((s) => s.label === \"US\");\n      expect(usSeries?.data[0].date).toBe(\"2026-04-01\");\n      expect(usSeries?.data[1].date).toBe(\"2026-04-02\");\n    });\n\n    it(\"respects breakdown_limit and groups remaining values as Other\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 2,\n      });\n\n      expect(result.series).toHaveLength(3); // US, DE, Other\n      const labels = result.series.map((s) => s.label);\n      expect(labels).toContain(\"US\");\n      expect(labels).toContain(\"DE\");\n      expect(labels).toContain(\"Other\");\n      expect(labels).not.toContain(\"FR\");\n    });\n\n    it(\"Other series aggregates values of non-top breakdown values by date\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n        { bucket: \"2026-04-01\", breakdown_val: \"JP\", value: 7 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 1,\n      });\n\n      const otherSeries = result.series.find((s) => s.label === \"Other\");\n      expect(otherSeries).toBeDefined();\n      // FR (10) + JP (7) = 17\n      expect(otherSeries?.data[0].value).toBe(17);\n    });\n\n    it(\"does not add Other series when all values are within the limit\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 10,\n      });\n\n      const labels = result.series.map((s) => s.label);\n      expect(labels).not.toContain(\"Other\");\n    });\n\n    it(\"sorts series by total value descending (top values first)\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 25 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 10,\n      });\n\n      expect(result.series[0].label).toBe(\"US\");\n      expect(result.series[1].label).toBe(\"DE\");\n      expect(result.series[2].label).toBe(\"FR\");\n    });\n  });\n});\n","numLines":359,"startLine":1,"totalLines":359}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011JC8mT5YQi6xxkm7Mm9Nof","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQueryTrends } = vi.hoisted(() => ({\n6\t  mockQueryTrends: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/trends\", () => ({\n10\t  queryTrends: mockQueryTrends,\n11\t}));\n12\t\n13\timport { GET } from \"@/app/api/trends/route\";\n14\t\n15\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n16\t\n17\tfunction makeRequest(params: Record<string, string> = {}): Request {\n18\t  const url = new URL(\"http://localhost/api/trends\");\n19\t  for (const [k, v] of Object.entries(params)) {\n20\t    url.searchParams.set(k, v);\n21\t  }\n22\t  return new Request(url.toString());\n23\t}\n24\t\n25\tconst sampleResponse = {\n26\t  series: [\n27\t    {\n28\t      label: \"Page Viewed\",\n29\t      data: [{ date: \"2026-04-01\", value: 5 }],\n30\t    },\n31\t  ],\n32\t};\n33\t\n34\t// ─── Tests ────────────────────────────────────────────────────────────────────\n35\t\n36\tbeforeEach(() => {\n37\t  mockQueryTrends.mockResolvedValue(sampleResponse);\n38\t});\n39\t\n40\tafterEach(() => {\n41\t  vi.clearAllMocks();\n42\t});\n43\t\n44\tdescribe(\"GET /api/trends\", () => {\n45\t  describe(\"success — 200\", () => {\n46\t    it(\"returns 200 with series response shape\", async () => {\n47\t      const res = await GET(\n48\t        makeRequest({\n49\t          event_name: \"Page Viewed\",\n50\t          start: \"2026-04-01\",\n51\t          end: \"2026-04-15\",\n52\t        }),\n53\t      );\n54\t\n55\t      expect(res.status).toBe(200);\n56\t      const body = await res.json();\n57\t      expect(body).toHaveProperty(\"series\");\n58\t      expect(Array.isArray(body.series)).toBe(true);\n59\t    });\n60\t\n61\t    it(\"returns the series data