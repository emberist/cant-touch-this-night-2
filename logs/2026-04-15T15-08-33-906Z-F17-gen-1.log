{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B921BaHzhN4bAAyWaE2uUn","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQueryTrends } = vi.hoisted(() => ({\n6\t  mockQueryTrends: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/trends\", () => ({\n10\t  queryTrends: mockQueryTrends,\n11\t}));\n12\t\n13\timport { GET } from \"@/app/api/trends/route\";\n14\t\n15\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n16\t\n17\tfunction makeRequest(params: Record<string, string> = {}): Request {\n18\t  const url = new URL(\"http://localhost/api/trends\");\n19\t  for (const [k, v] of Object.entries(params)) {\n20\t    url.searchParams.set(k, v);\n21\t  }\n22\t  return new Request(url.toString());\n23\t}\n24\t\n25\tconst sampleResponse = {\n26\t  series: [\n27\t    {\n28\t      label: \"Page Viewed\",\n29\t      data: [{ date: \"2026-04-01\", value: 5 }],\n30\t    },\n31\t  ],\n32\t};\n33\t\n34\t// ─── Tests ────────────────────────────────────────────────────────────────────\n35\t\n36\tbeforeEach(() => {\n37\t  mockQueryTrends.mockResolvedValue(sampleResponse);\n38\t});\n39\t\n40\tafterEach(() => {\n41\t  vi.clearAllMocks();\n42\t});\n43\t\n44\tdescribe(\"GET /api/trends\", () => {\n45\t  describe(\"success — 200\", () => {\n46\t    it(\"returns 200 with series response shape\", async () => {\n47\t      const res = await GET(\n48\t        makeRequest({\n49\t          event_name: \"Page Viewed\",\n50\t          start: \"2026-04-01\",\n51\t          end: \"2026-04-15\",\n52\t        }),\n53\t      );\n54\t\n55\t      expect(res.status).toBe(200);\n56\t      const body = await res.json();\n57\t      expect(body).toHaveProperty(\"series\");\n58\t      expect(Array.isArray(body.series)).toBe(true);\n59\t    });\n60\t\n61\t    it(\"returns the series data from queryTrends in the response body\", async () => {\n62\t      const res = await GET(\n63\t        makeRequest({\n64\t          event_name: \"Page Viewed\",\n65\t          start: \"2026-04-01\",\n66\t          end: \"2026-04-15\",\n67\t        }),\n68\t      );\n69\t      const body = await res.json();\n70\t\n71\t      expect(body.series).toEqual(sampleResponse.series);\n72\t    });\n73\t  });\n74\t\n75\t  describe(\"validation errors — 400\", () => {\n76\t    it(\"returns 400 when event_name is missing\", async () => {\n77\t      const res = await GET(\n78\t        makeRequest({ start: \"2026-04-01\", end: \"2026-04-15\" }),\n79\t      );\n80\t\n81\t      expect(res.status).toBe(400);\n82\t      const body = await res.json();\n83\t      expect(body).toHaveProperty(\"error\");\n84\t      expect(typeof body.error).toBe(\"string\");\n85\t    });\n86\t\n87\t    it(\"returns 400 when start is missing\", async () => {\n88\t      const res = await GET(\n89\t        makeRequest({ event_name: \"Page Viewed\", end: \"2026-04-15\" }),\n90\t      );\n91\t\n92\t      expect(res.status).toBe(400);\n93\t      const body = await res.json();\n94\t      expect(body).toHaveProperty(\"error\");\n95\t    });\n96\t\n97\t    it(\"returns 400 when end is missing\", async () => {\n98\t      const res = await GET(\n99\t        makeRequest({ event_name: \"Page Viewed\", start: \"2026-04-01\" }),\n100\t      );\n101\t\n102\t      expect(res.status).toBe(400);\n103\t      const body = await res.json();\n104\t      expect(body).toHaveProperty(\"error\");\n105\t    });\n106\t\n107\t    it(\"returns 400 for invalid measure format (sum: with no property)\", async () => {\n108\t      const res = await GET(\n109\t        makeRequest({\n110\t          event_name: \"Page Viewed\",\n111\t          start: \"2026-04-01\",\n112\t          end: \"2026-04-15\",\n113\t          measure: \"sum:\",\n114\t        }),\n115\t      );\n116\t\n117\t      expect(res.status).toBe(400);\n118\t      const body = aw