{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0119pw7kUJkcdT6DHUPJTtBy","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// vi.mock is hoisted before imports — child_process is mocked for every import of migrate.ts\n4\tconst mockExecFileSync = vi.fn();\n5\t\n6\tvi.mock(\"node:child_process\", () => ({\n7\t  execFileSync: mockExecFileSync,\n8\t}));\n9\t\n10\tdescribe(\"runMigration\", () => {\n11\t  let runMigration: () => void;\n12\t\n13\t  beforeEach(async () => {\n14\t    vi.resetModules();\n15\t    mockExecFileSync.mockReset();\n16\t    const mod = await import(\"../migrate\");\n17\t    runMigration = mod.runMigration;\n18\t  });\n19\t\n20\t  afterEach(() => {\n21\t    delete process.env.CLICKHOUSE_URL;\n22\t    delete process.env.CLICKHOUSE_PASSWORD;\n23\t  });\n24\t\n25\t  it(\"calls ./clickhouse with client subcommand and --queries-file pointing to schema.sql\", () => {\n26\t    delete process.env.CLICKHOUSE_URL;\n27\t    delete process.env.CLICKHOUSE_PASSWORD;\n28\t\n29\t    runMigration();\n30\t\n31\t    expect(mockExecFileSync).toHaveBeenCalledOnce();\n32\t    const [binary, args] = mockExecFileSync.mock.calls[0] as [string, string[]];\n33\t    expect(binary).toBe(\"./clickhouse\");\n34\t    expect(args[0]).toBe(\"client\");\n35\t    const queriesFileArg = args.find((a) => a.startsWith(\"--queries-file=\"));\n36\t    expect(queriesFileArg).toBeDefined();\n37\t    expect(queriesFileArg).toMatch(/schema\\.sql$/);\n38\t  });\n39\t\n40\t  it(\"uses default host (localhost), port (8123), and password (password) when env vars are absent\", () => {\n41\t    delete process.env.CLICKHOUSE_URL;\n42\t    delete process.env.CLICKHOUSE_PASSWORD;\n43\t\n44\t    runMigration();\n45\t\n46\t    const [, args] = mockExecFileSync.mock.calls[0] as [string, string[]];\n47\t    expect(args).toContain(\"--host=localhost\");\n48\t    expect(args).toContain(\"--port=8123\");\n49\t    expect(args).toContain(\"--password=password\");\n50\t  });\n51\t\n52\t  it(\"parses custom CLICKHOUSE_URL into correct --host and --port flags\", () => {\n53\t    process.env.CLICKHOUSE_URL = \"http://custom-host:9000\";\n54\t    delete process.env.CLICKHOUSE_PASSWORD;\n55\t\n56\t    runMigration();\n57\t\n58\t    const [, args] = mockExecFileSync.mock.calls[0] as [string, string[]];\n59\t    expect(args).toContain(\"--host=custom-host\");\n60\t    expect(args).toContain(\"--port=9000\");\n61\t  });\n62\t\n63\t  it(\"uses custom CLICKHOUSE_PASSWORD from env var\", () => {\n64\t    delete process.env.CLICKHOUSE_URL;\n65\t    process.env.CLICKHOUSE_PASSWORD = \"supersecret\";\n66\t\n67\t    runMigration();\n68\t\n69\t    const [, args] = mockExecFileSync.mock.calls[0] as [string, string[]];\n70\t    expect(args).toContain(\"--password=supersecret\");\n71\t  });\n72\t\n73\t  it(\"throws when execFileSync exits with non-zero (child process failure)\", () => {\n74\t    delete process.env.CLICKHOUSE_URL;\n75\t    delete process.env.CLICKHOUSE_PASSWORD;\n76\t    mockExecFileSync.mockImplementation(() => {\n77\t      throw new Error(\"Command failed: ./clickhouse client\");\n78\t    });\n79\t\n80\t    expect(() => runMigration()).toThrow(\"Command failed\");\n81\t  });\n82\t\n83\t  it(\"logs a success message after a successful migration\", () => {\n84\t    delete process.env.CLICKHOUSE_URL;\n85\t    delete process.env.CLICKHOUSE_PASSWORD;\n86\t    const consoleSpy = vi.spyOn(console, \"log\").mockImplementation(() => {});\n87\t\n88\t    runMigration();\n89\t\n90\t    expect(consoleSpy).toHaveBeenCalledWith(expect.stringContaining(\"success\"));\n91\t    consoleSpy.mockRestore();\n92\t  });\n93\t});\n94\t"}]},"parent_tool_use_id":"toolu_01M5ZuU7GngkufmPuRhSjm2h","session_id":"0753a1fd-dd5e-4de5-9e44-2e4e736c96a0","uuid":"93ebee40-bffb-4a21-9f6d-f77d8750d7c1","timestamp":"2026-04-15T15:15:17.211Z"}
