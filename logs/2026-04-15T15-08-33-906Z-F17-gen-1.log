{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YbZR7Srhh3R8ifcGEPCSqL","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockSearchUsers } = vi.hoisted(() => ({\n6\t  mockSearchUsers: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/users\", () => ({\n10\t  searchUsers: mockSearchUsers,\n11\t}));\n12\t\n13\timport { GET } from \"@/app/api/users/route\";\n14\t\n15\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n16\t\n17\tfunction makeRequest(params: Record<string, string> = {}): Request {\n18\t  const url = new URL(\"http://localhost/api/users\");\n19\t  for (const [k, v] of Object.entries(params)) {\n20\t    url.searchParams.set(k, v);\n21\t  }\n22\t  return new Request(url.toString());\n23\t}\n24\t\n25\tconst sampleResponse = {\n26\t  users: [\n27\t    {\n28\t      resolved_id: \"user@test.com\",\n29\t      first_seen: \"2026-04-01T00:00:00.000Z\",\n30\t      last_seen: \"2026-04-15T00:00:00.000Z\",\n31\t      event_count: 42,\n32\t    },\n33\t  ],\n34\t  next_cursor: null,\n35\t};\n36\t\n37\t// ─── Tests ────────────────────────────────────────────────────────────────────\n38\t\n39\tbeforeEach(() => {\n40\t  mockSearchUsers.mockResolvedValue(sampleResponse);\n41\t});\n42\t\n43\tafterEach(() => {\n44\t  vi.clearAllMocks();\n45\t});\n46\t\n47\tdescribe(\"GET /api/users\", () => {\n48\t  describe(\"success — 200\", () => {\n49\t    it(\"returns 200 with users array and next_cursor\", async () => {\n50\t      const res = await GET(makeRequest());\n51\t\n52\t      expect(res.status).toBe(200);\n53\t      const body = await res.json();\n54\t      expect(body).toHaveProperty(\"users\");\n55\t      expect(body).toHaveProperty(\"next_cursor\");\n56\t      expect(Array.isArray(body.users)).toBe(true);\n57\t    });\n58\t\n59\t    it(\"forwards q, limit, cursor params to searchUsers\", async () => {\n60\t      await GET(\n61\t        makeRequest({ q: \"john\", limit: \"25\", cursor: \"abc@test.com\" }),\n62\t      );\n63\t\n64\t      expect(mockSearchUsers).toHaveBeenCalledWith(\n65\t        expect.objectContaining({\n66\t          q: \"john\",\n67\t          limit: 25,\n68\t          cursor: \"abc@test.com\",\n69\t        }),\n70\t      );\n71\t    });\n72\t\n73\t    it(\"defaults limit to 50 when not provided\", async () => {\n74\t      await GET(makeRequest());\n75\t\n76\t      expect(mockSearchUsers).toHaveBeenCalledWith(\n77\t        expect.objectContaining({ limit: 50 }),\n78\t      );\n79\t    });\n80\t\n81\t    it(\"caps limit at 200\", async () => {\n82\t      await GET(makeRequest({ limit: \"500\" }));\n83\t\n84\t      expect(mockSearchUsers).toHaveBeenCalledWith(\n85\t        expect.objectContaining({ limit: 200 }),\n86\t      );\n87\t    });\n88\t  });\n89\t\n90\t  describe(\"validation errors — 400\", () => {\n91\t    it(\"returns 400 when limit is not a positive integer\", async () => {\n92\t      const res = await GET(makeRequest({ limit: \"abc\" }));\n93\t\n94\t      expect(res.status).toBe(400);\n95\t      const body = await res.json();\n96\t      expect(body).toHaveProperty(\"error\");\n97\t      expect(typeof body.error).toBe(\"string\");\n98\t    });\n99\t\n100\t    it(\"returns 400 for zero limit\", async () => {\n101\t      const res = await GET(makeRequest({ limit: \"0\" }));\n102\t\n103\t      expect(res.status).toBe(400);\n104\t      const body = await res.json();\n105\t      expect(body).toHaveProperty(\"error\");\n106\t    });\n107\t\n108\t    it(\"returns 400 for negative limit\", async () => {\n109\t      const res = await GET(makeRequest({ limit: \"-5\" }));\n110\t\n111\t      expect(res.status).toBe(400);\n112\t      const body = await res.json();\n113\t      expect(body).toHaveProperty(\"error\");\n114\t    });\n115\t  });\n116\t\n117\t  describe(\"error handling — 500\", () => {\n118\t    it(\"returns 500 when searchUsers throws\", async () => {\n119\t      mockSearchUsers.mockRejectedValue(\n120\t        new Error(\"ClickHouse connection failed\"),\n121\t      );\n122\t\n123\t      const res = await GET(makeRequest());\n124\t\n125\t      expect(res.status).toBe(500);\n126\t      const body = await res.json();\n127\t      expect(body).toHaveProperty(\"error\");\n128\t    });\n129\t  });\n130\t});\n131\t"}]},"parent_tool_use_id":"toolu_01M5ZuU7GngkufmPuRhSjm2h","session_id":"0753a1fd-dd5e-4de5-9e44-2e4e736c96a0","uuid":"4c8ec349-7a36-41a0-a74d-2572919968f0","timestamp":"2026-04-15T15:15:07.775Z"}
