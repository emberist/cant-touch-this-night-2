ST /api/funnels\", () => {\n67\t  describe(\"validation errors — 400\", () => {\n68\t    it(\"returns 400 when body is not valid JSON\", async () => {\n69\t      const res = await POST(makeMalformedRequest());\n70\t\n71\t      expect(res.status).toBe(400);\n72\t      const body = await res.json();\n73\t      expect(body).toHaveProperty(\"error\");\n74\t    });\n75\t\n76\t    it(\"returns 400 when steps is missing\", async () => {\n77\t      const res = await POST(\n78\t        makeRequest({ start: \"2026-04-01\", end: \"2026-04-15\" }),\n79\t      );\n80\t\n81\t      expect(res.status).toBe(400);\n82\t      const body = await res.json();\n83\t      expect(body).toHaveProperty(\"error\");\n84\t    });\n85\t\n86\t    it(\"returns 400 when steps has fewer than 2 entries\", async () => {\n87\t      const res = await POST(\n88\t        makeRequest({\n89\t          steps: [\"Page Viewed\"],\n90\t          start: \"2026-04-01\",\n91\t          end: \"2026-04-15\",\n92\t        }),\n93\t      );\n94\t\n95\t      expect(res.status).toBe(400);\n96\t      const body = await res.json();\n97\t      expect(body).toHaveProperty(\"error\");\n98\t    });\n99\t\n100\t    it(\"returns 400 when steps has more than 5 entries\", async () => {\n101\t      const res = await POST(\n102\t        makeRequest({\n103\t          steps: [\"A\", \"B\", \"C\", \"D\", \"E\", \"F\"],\n104\t          start: \"2026-04-01\",\n105\t          end: \"2026-04-15\",\n106\t        }),\n107\t      );\n108\t\n109\t      expect(res.status).toBe(400);\n110\t      const body = await res.json();\n111\t      expect(body).toHaveProperty(\"error\");\n112\t    });\n113\t\n114\t    it(\"returns 400 when steps contains non-string entries\", async () => {\n115\t      const res = await POST(\n116\t        makeRequest({\n117\t          steps: [\"Page Viewed\", 42],\n118\t          start: \"2026-04-01\",\n119\t          end: \"2026-04-15\",\n120\t        }),\n121\t      );\n122\t\n123\t      expect(res.status).toBe(400);\n12