{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TBFBhCDPaZaZ4wU16p2cAh","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\t\n3\t// ─── Types ────────────────────────────────────────────────────────────────────\n4\t\n5\texport interface TrendsParams {\n6\t  event_name: string;\n7\t  /** \"count\" | \"unique_users\" | \"sum:<prop>\" | \"avg:<prop>\" | \"min:<prop>\" | \"max:<prop>\" */\n8\t  measure: string;\n9\t  granularity: \"day\" | \"week\";\n10\t  /** ISO date string (YYYY-MM-DD) — inclusive lower bound */\n11\t  start: string;\n12\t  /** ISO date string (YYYY-MM-DD) — inclusive upper bound */\n13\t  end: string;\n14\t  breakdown?: string;\n15\t  breakdown_limit?: number;\n16\t}\n17\t\n18\texport interface SeriesPoint {\n19\t  date: string;\n20\t  value: number;\n21\t}\n22\t\n23\texport interface Series {\n24\t  label: string;\n25\t  data: SeriesPoint[];\n26\t}\n27\t\n28\texport interface TrendsResponse {\n29\t  series: Series[];\n30\t}\n31\t\n32\texport interface TrendsQuerySpec {\n33\t  query: string;\n34\t  query_params: Record<string, string>;\n35\t}\n36\t\n37\t// ─── Type alias for the ClickHouse client ────────────────────────────────────\n38\t\n39\ttype ClickHouseClientLike = typeof clickhouse;\n40\t\n41\t// ─── Internal helpers ─────────────────────────────────────────────────────────\n42\t\n43\t/** Returns the exclusive upper bound timestamp for the given ISO date.\n44\t *  Returns ClickHouse-compatible format: \"YYYY-MM-DD HH:MM:SS.mmm\" (no T/Z).\n45\t */\n46\tfunction computeEndExclusive(end: string): string {\n47\t  const [y, m, d] = end.split(\"-\").map(Number);\n48\t  const dt = new Date(Date.UTC(y, m - 1, d + 1));\n49\t  const year = dt.getUTCFullYear();\n50\t  const month = String(dt.getUTCMonth() + 1).padStart(2, \"0\");\n51\t  const day = String(dt.getUTCDate()).padStart(2, \"0\");\n52\t  return `${year}-${month}-${day} 00:00:00.000`;\n53\t}\n54\t\n55\t/** Builds the SQL aggregate expression for the given measure. */\n56\tfunction buildAggregateExpr(measure: string): string {\n57\t  if (measure === \"count\") return \"count()\";\n58\t  if (measure === \"unique_users\") {\n59\t    return \"uniqExact(coalesce(e.user_id, m.user_id, e.device_id))\";\n60\t  }\n61\t  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n62\t  if (match) {\n63\t    const fn = match[1];\n64\t    const prop = match[2];\n65\t    return `${fn}(JSONExtractFloat(e.properties, '${prop}'))`;\n66\t  }\n67\t  // Fallback — should be unreachable after route-level validation\n68\t  return \"count()\";\n69\t}\n70\t\n71\t/** Builds the SQL date-bucket expression for the given granularity. */\n72\tfunction buildBucketExpr(granularity: \"day\" | \"week\"): string {\n73\t  return granularity === \"week\"\n74\t    ? \"toMonday(e.timestamp)\"\n75\t    : \"toDate(e.timestamp)\";\n76\t}\n77\t\n78\t// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n79\t\n80\t/**\n81\t * Constructs the ClickHouse SQL query and bound parameters for a trends\n82\t * request. Exported for unit testing of SQL correctness.\n83\t */\n84\texport function buildTrendsQuery(params: TrendsParams): TrendsQuerySpec {\n85\t  const { event_name, measure, granularity, start, end, breakdown } = params;\n86\t\n87\t  const aggregateExpr = buildAggregateExpr(measure);\n88\t  const bucketExpr = buildBucketExpr(granularity);\n89\t  const needsJoin = measure === \"unique_users\";\n90\t\n91\t  const joinClause = needsJoin\n92\t    ? \"LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\\n      ON e.device_id = m.device_id\"\n93\t    : \"\";\n94\t\n95\t  const query_params: Record<string, string> = {\n96\t    event_name,\n97\t    start: `${start} 00:00:00.000`,\n98\t    end_exclusive: computeEndExclusive(end),\n99\t  };\n100\t"}]},"parent_tool_use_id":"toolu_01M5ZuU7GngkufmPuRhSjm2h","session_id":"0753a1fd-dd5e-4de5-9e44-2e4e736c96a0","uuid":"874773c6-314e-4575-b893-207f802a83