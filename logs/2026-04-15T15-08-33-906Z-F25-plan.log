{Paper} data-testid=\"event-table\">\n56\t      <Table size=\"small\">\n57\t        <TableHead>\n58\t          <TableRow>\n59\t            <TableCell>Timestamp</TableCell>\n60\t            <TableCell>Event Name</TableCell>\n61\t            <TableCell>Resolved Identity</TableCell>\n62\t            <TableCell>Properties</TableCell>\n63\t          </TableRow>\n64\t        </TableHead>\n65\t        <TableBody>\n66\t          {events.map((event) => (\n67\t            <TableRow key={event.event_id}>\n68\t              <TableCell sx={{ whiteSpace: \"nowrap\" }}>\n69\t                {new Date(event.timestamp).toLocaleString()}\n70\t              </TableCell>\n71\t              <TableCell>{event.event_name}</TableCell>\n72\t              <TableCell>\n73\t                <IdentityChip resolved_id={event.resolved_id} />\n74\t              </TableCell>\n75\t              <TableCell>\n76\t                <JsonChip properties={event.properties} />\n77\t              </TableCell>\n78\t            </TableRow>\n79\t          ))}\n80\t          {events.length === 0 && !loading && (\n81\t            <TableRow>\n82\t              <TableCell\n83\t                colSpan={4}\n84\t                sx={{ color: \"text.secondary\", py: 4, textAlign: \"center\" }}\n85\t              >\n86\t                {emptyMessage}\n87\t              </TableCell>\n88\t            </TableRow>\n89\t          )}\n90\t          {loading && (\n91\t            <TableRow>\n92\t              <TableCell colSpan={4}>\n93\t                <Skeleton variant=\"rectangular\" height={36} />\n94\t              </TableCell>\n95\t            </TableRow>\n96\t          )}\n97\t          {hasMore && !loading && (\n98\t            <TableRow ref={sentinelRef} aria-hidden=\"true\">\n99\t              <TableCell colSpan={4} sx={{ p: 0, border: 0 }} />\n100\t            </TableRow>\n101\t          )}\n102\t        </TableBody>\n103\t      </Table>\n104\t    </TableContainer>\n105\t  );\n106\t}\n107\t"}]},"parent_tool_use_id":nu