cursor\");\n55\t      expect(Array.isArray(body.events)).toBe(true);\n56\t    });\n57\t\n58\t    it(\"returns empty events array and null cursor when no events match\", async () => {\n59\t      mockQueryEventsWithResolvedId.mockResolvedValue([]);\n60\t\n61\t      const res = await GET(makeRequest());\n62\t      const body = await res.json();\n63\t\n64\t      expect(res.status).toBe(200);\n65\t      expect(body.events).toEqual([]);\n66\t      expect(body.next_cursor).toBeNull();\n67\t    });\n68\t\n69\t    it(\"returns null next_cursor when fewer events than limit are returned (no more pages)\", async () => {\n70\t      // default limit is 50; we return only 1 event — fewer than limit\n71\t      mockQueryEventsWithResolvedId.mockResolvedValue([sampleEvent]);\n72\t\n73\t      const res = await GET(makeRequest());\n74\t      const body = await res.json();\n75\t\n76\t      expect(body.next_cursor).toBeNull();\n77\t    });\n78\t\n79\t    it(\"returns last event timestamp as next_cursor when result count equals limit\", async () => {\n80\t      const events = [\n81\t        {\n82\t          ...sampleEvent,\n83\t          timestamp: \"2026-04-15T10:00:00.000Z\",\n84\t          event_id: \"uuid-1\",\n85\t        },\n86\t        {\n87\t          ...sampleEvent,\n88\t          timestamp: \"2026-04-14T09:00:00.000Z\",\n89\t          event_id: \"uuid-2\",\n90\t        },\n91\t      ];\n92\t      mockQueryEventsWithResolvedId.mockResolvedValue(events);\n93\t\n94\t      // limit=2 → results.length (2) === limit (2) → return last timestamp\n95\t      const res = await GET(makeRequest({ limit: \"2\" }));\n96\t      const body = await res.json();\n97\t\n98\t      expect(body.next_cursor).toBe(\"2026-04-14T09:00:00.000Z\");\n99\t    });\n100\t\n101\t    it(\"includes the returned events in the response body\", async () => {\n102\t      const res = await GET(makeRequest());\n103\t      const body = await res.json();\n104\t\n105\t      expect(body.events).toEqual([sampleEvent]);\n106\t