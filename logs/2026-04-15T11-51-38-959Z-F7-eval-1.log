{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HSBSuBQKJgeY2fp1jcMAem","type":"tool_result","content":"1\t/**\n2\t * Integration tests for POST /api/events/batch\n3\t *\n4\t * These tests require:\n5\t *   - A running dev server at http://localhost:3000\n6\t *   - A running ClickHouse instance at http://localhost:8123\n7\t *\n8\t * Run with:\n9\t *   pnpm dev &    # starts ClickHouse + Next.js via concurrently\n10\t *   pnpm test\n11\t */\n12\t\n13\timport { afterAll, beforeAll, describe, expect, it } from \"vitest\";\n14\t\n15\tconst BASE_URL = \"http://localhost:3000\";\n16\tconst ENDPOINT = `${BASE_URL}/api/events/batch`;\n17\t\n18\t/** Returns true if the dev server is reachable. */\n19\tasync function isServerAvailable(): Promise<boolean> {\n20\t  try {\n21\t    const res = await fetch(BASE_URL, {\n22\t      method: \"HEAD\",\n23\t      signal: AbortSignal.timeout(2000),\n24\t    });\n25\t    // Any HTTP response (even 404/500) means the server is up\n26\t    return res.status < 600;\n27\t  } catch {\n28\t    return false;\n29\t  }\n30\t}\n31\t\n32\tlet serverAvailable = false;\n33\t\n34\tbeforeAll(async () => {\n35\t  serverAvailable = await isServerAvailable();\n36\t  if (!serverAvailable) {\n37\t    console.warn(\n38\t      \"[integration] Dev server not available at http://localhost:3000 — skipping integration tests.\",\n39\t    );\n40\t  }\n41\t});\n42\t\n43\tafterAll(() => {\n44\t  // Nothing to tear down; we didn't start the server ourselves.\n45\t});\n46\t\n47\tdescribe(\"POST /api/events/batch — integration\", () => {\n48\t  it(\"valid array of events → 200 with { ok: N, errors: [] }\", async () => {\n49\t    if (!serverAvailable) {\n50\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n51\t      return;\n52\t    }\n53\t\n54\t    const res = await fetch(ENDPOINT, {\n55\t      method: \"POST\",\n56\t      headers: { \"Content-Type\": \"application/json\" },\n57\t      body: JSON.stringify([\n58\t        { event_name: \"Page Viewed\", device_id: \"batch-dev-1\" },\n59\t        { event_name: \"Button Clicked\", device_id: \"batch-dev-2\" },\n60\t      ]),\n61\t    });\n62\t\n63\t    expect(res.status).toBe(200);\n64\t\n65\t    const body = await res.json();\n66\t    expect(body).toHaveProperty(\"ok\");\n67\t    expect(body).toHaveProperty(\"errors\");\n68\t    expect(body.ok).toBe(2);\n69\t    expect(body.errors).toEqual([]);\n70\t  });\n71\t\n72\t  it(\"empty array → 200 with { ok: 0, errors: [] }\", async () => {\n73\t    if (!serverAvailable) {\n74\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n75\t      return;\n76\t    }\n77\t\n78\t    const res = await fetch(ENDPOINT, {\n79\t      method: \"POST\",\n80\t      headers: { \"Content-Type\": \"application/json\" },\n81\t      body: JSON.stringify([]),\n82\t    });\n83\t\n84\t    expect(res.status).toBe(200);\n85\t\n86\t    const body = await res.json();\n87\t    expect(body).toEqual({ ok: 0, errors: [] });\n88\t  });\n89\t\n90\t  it(\"body is a plain object (not array) → 400 with error field\", async () => {\n91\t    if (!serverAvailable) {\n92\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n93\t      return;\n94\t    }\n95\t\n96\t    const res = await fetch(ENDPOINT, {\n97\t      method: \"POST\",\n98\t      headers: { \"Content-Type\": \"application/json\" },\n99\t      body: JSON.stringify({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n100\t    });\n101\t\n102\t    expect(res.status).toBe(400);\n103\t\n104\t    const body = await res.json();\n105\t    expect(body).toHaveProperty(\"error\");\n106\t    expect(typeof body.error).toBe(\"string\");\n107\t    expect(body.error.length).toBeGreaterThan(0);\n108\t  });\n109\t\n110\t  it(\"body is not valid JSON → 400 with error field\", async () => {\n111\t    if (!serverAvailable) {\n112\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n113\t      return;\n114\t    }\n115\t\n116\t    const res = await fetch(ENDPOINT, {\n117\t      method: \"POST\",\n118\t      headers: { \"Content-Type\": \"application/json\" },\n119\t      body: \"{ this is not valid json !!!\",\n120\t    });\n121\t\n122\t    expect(res.status).toBe(400);\n123\t\n124\t    const body = await res.json();\n125\t    expect(body).toHaveProperty(\"error\");\n126\t    expect(typeof body.error).toBe(\"string\");\n127\t    expect(body.error.length).toBeGreaterThan(0);\n128\t  });\n129\t\n130\t  it(\"mixed batch: valid events succeed, invalid event (missing event_name) appears in errors\", async () => {\n131\t    if (!serverAvailable) {\n132\t      console.log(\"[skip] Dev server not running — skipping integration test.\");\n133\t      return;\n134\t    }\n135\t\n136\t    const res = await fetch(ENDPOINT, {\n137\t      method: \"POST\",\n138\t      headers: { \"Content-Type\": \"application/json\" },\n139\t      body: JSON.stringify([\n140\t        { event_name: \"Page Viewed\", device_id: \"batch-mix-dev-1\" }, // valid\n141\t        { device_id: \"batch-mix-dev-2\" }, // missing event_name → error\n142\t        { event_name: \"Signup Completed\", user_id: \"batch-mix-user@test.com\" }, // valid\n143\t      ]),\n144\t    });\n145\t\n146\t    expect(res.status).toBe(200);\n147\t\n148\t    const body = await res.json();\n149\t    expect(body.ok).toBe(2);\n150\t    expect(body.errors).toHaveLength(1);\n151\t    expect(body.errors[0]).toMatchObject({ index: 1 });\n152\t    expect(typeof body.errors[0].error).toBe(\"string\");\n153\t    expect(body.errors[0].error.length).toBeGreaterThan(0);\n154\t  });\n155\t});\n156\t"}]},"parent_tool_use_id":null,"session_id":"b590f7bd-14dc-4da8-95e6-c0dc741c4ce7","uuid":"3bf8e028-f53f-4e0f-b7c2-ed31d21cad91","timestamp":"2026-04-15T12:41:05.882Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/events/batch/__tests__/route.integration.test.ts","content":"/**\n * Integration tests for POST /api/events/batch\n *\n * These tests require:\n *   - A running dev server at http://localhost:3000\n *   - A running ClickHouse instance at http://localhost:8123\n *\n * Run with:\n *   pnpm dev &    # starts ClickHouse + Next.js via concurrently\n *   pnpm test\n */\n\nimport { afterAll, beforeAll, describe, expect, it } from \"vitest\";\n\nconst BASE_URL = \"http://localhost:3000\";\nconst ENDPOINT = `${BASE_URL}/api/events/batch`;\n\n/** Returns true if the dev server is reachable. */\nasync function isServerAvailable(): Promise<boolean> {\n  try {\n    const res = await fetch(BASE_URL, {\n      method: \"HEAD\",\n      signal: AbortSignal.timeout(2000),\n    });\n    // Any HTTP response (even 404/500) means the server is up\n    return res.status < 600;\n  } catch {\n    return false;\n  }\n}\n\nlet serverAvailable = false;\n\nbeforeAll(async () => {\n  serverAvailable = await isServerAvailable();\n  if (!serverAvailable) {\n    console.warn(\n      \"[integration] Dev server not available at http://localhost:3000 — skipping integration tests.\",\n    );\n  }\n});\n\nafterAll(() => {\n  // Nothing to tear down; we didn't start the server ourselves.\n});\n\ndescribe(\"POST /api/events/batch — integration\", () => {\n  it(\"valid array of events → 200 with { ok: N, errors: [] }\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const res = await fetch(ENDPOINT, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify([\n        { event_name: \"Page Viewed\", device_id: \"batch-dev-1\" },\n        { event_name: \"Button Clicked\", device_id: \"batch-dev-2\" },\n      ]),\n    });\n\n    expect(res.status).toBe(200);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"ok\");\n    expect(body).toHaveProperty(\"errors\");\n    expect(body.ok).toBe(2);\n    expect(body.errors).toEqual([]);\n  });\n\n  it(\"empty array → 200 with { ok: 0, errors: [] }\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const res = await fetch(ENDPOINT, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify([]),\n    });\n\n    expect(res.status).toBe(200);\n\n    const body = await res.json();\n    expect(body).toEqual({ ok: 0, errors: [] });\n  });\n\n  it(\"body is a plain object (not array) → 400 with error field\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const res = await fetch(ENDPOINT, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n    });\n\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n    expect(typeof body.error).toBe(\"string\");\n    expect(body.error.length).toBeGreaterThan(0);\n  });\n\n  it(\"body is not valid JSON → 400 with error field\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const res = await fetch(ENDPOINT, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: \"{ this is not valid json !!!\",\n    });\n\n    expect(res.status).toBe(400);\n\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n    expect(typeof body.error).toBe(\"string\");\n    expect(body.error.length).toBeGreaterThan(0);\n  });\n\n  it(\"mixed batch: valid events succeed, invalid event (missing event_name) appears in errors\", async () => {\n    if (!serverAvailable) {\n      console.log(\"[skip] Dev server not running — skipping integration test.\");\n      return;\n    }\n\n    const res = await fetch(ENDPOINT, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify([\n        { event_name: \"Page Viewed\", device_id: \"batch-mix-dev-1\" }, // valid\n        { device_id: \"batch-mix-dev-2\" }, // missing event_name → error\n        { event_name: \"Signup Completed\", user_id: \"batch-mix-user@test.com\" }, // valid\n      ]),\n    });\n\n    expect(res.status).toBe(200);\n\n    const body = await res.json();\n    expect(body.ok).toBe(2);\n    expect(body.errors).toHaveLength(1);\n    expect(body.errors[0]).toMatchObject({ index: 1 });\n    expect(typeof body.errors[0].error).toBe(\"string\");\n    expect(body.errors[0].error.length).toBeGreaterThan(0);\n  });\n});\n","numLines":156,"startLine":1,"totalLines":156}}}
