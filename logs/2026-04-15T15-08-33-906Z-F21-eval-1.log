{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0144WtPSJFcjAm5v6zFFs5KP","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { cleanup, fireEvent, render, screen } from \"@testing-library/react\";\n3\timport { afterEach, describe, expect, it, vi } from \"vitest\";\n4\timport { JsonChip } from \"@/components/ui/JsonChip\";\n5\t\n6\tafterEach(() => {\n7\t  cleanup();\n8\t  vi.clearAllMocks();\n9\t});\n10\t\n11\tdescribe(\"JsonChip\", () => {\n12\t  describe(\"empty / no-properties state\", () => {\n13\t    it(\"renders 'No properties' for an empty JSON object\", () => {\n14\t      render(<JsonChip properties=\"{}\" />);\n15\t      expect(screen.getByText(\"No properties\")).toBeTruthy();\n16\t    });\n17\t\n18\t    it(\"renders 'No properties' for an empty string\", () => {\n19\t      render(<JsonChip properties=\"\" />);\n20\t      expect(screen.getByText(\"No properties\")).toBeTruthy();\n21\t    });\n22\t  });\n23\t\n24\t  describe(\"with properties\", () => {\n25\t    it(\"renders a chip (button) with truncated key preview for JSON with multiple keys\", () => {\n26\t      render(\n27\t        <JsonChip properties='{\"page\":\"/home\",\"user\":\"alice\",\"count\":3}' />,\n28\t      );\n29\t      // The chip should be clickable (role=button) and show a short preview of keys\n30\t      const chip = screen.getByRole(\"button\");\n31\t      expect(chip).toBeTruthy();\n32\t      // Preview text should include key names, not the raw JSON values\n33\t      const text = chip.textContent ?? \"\";\n34\t      expect(text).not.toBe(\"\");\n35\t      // Should not show the full stringified JSON in preview\n36\t      expect(text).not.toContain('\"page\":\"/home\"');\n37\t    });\n38\t\n39\t    it(\"chip preview includes the first key name\", () => {\n40\t      render(<JsonChip properties='{\"amount\":49.99,\"currency\":\"USD\"}' />);\n41\t      const chip = screen.getByRole(\"button\");\n42\t      expect(chip.textContent).toContain(\"amount\");\n43\t    });\n44\t\n45\t    it(\"does not render 'No properties' when properties are present\", () => {\n46\t      render(<JsonChip properties='{\"x\":1}' />);\n47\t      expect(screen.queryByText(\"No properties\")).toBeNull();\n48\t    });\n49\t  });\n50\t\n51\t  describe(\"expansion\", () => {\n52\t    it(\"clicking the chip reveals the full JSON content\", () => {\n53\t      render(<JsonChip properties='{\"page\":\"/home\",\"user\":\"alice\"}' />);\n54\t      const chip = screen.getByRole(\"button\");\n55\t      fireEvent.click(chip);\n56\t      // After expansion, the formatted JSON should be visible in the document\n57\t      const expanded = screen.getByText(/\\/home/);\n58\t      expect(expanded).toBeTruthy();\n59\t    });\n60\t\n61\t    it(\"full JSON is not visible before clicking\", () => {\n62\t      render(<JsonChip properties='{\"secretKey\":\"hunter2\"}' />);\n63\t      expect(screen.queryByText(/hunter2/)).toBeNull();\n64\t    });\n65\t  });\n66\t});\n67\t"}]},"parent_tool_use_id":null,"session_id":"c94da9d5-a9cc-4b8e-8006-0e7e20cf4916","uuid":"5f5947dd-921b-4b2c-9eee-4ac62030ddc5","timestamp":"2026-04-15T16:41:22.439Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/ui/__tests__/JsonChip.test.tsx","content":"// @vitest-environment jsdom\nimport { cleanup, fireEvent, render, screen } from \"@testing-library/react\";\nimport { afterEach, describe, expect, it, vi } from \"vitest\";\nimport { JsonChip } from \"@/components/ui/JsonChip\";\n\nafterEach(() => {\n  cleanup();\n  vi.clearAllMocks();\n});\n\ndescribe(\"JsonChip\", () => {\n  describe(\"empty / no-properties state\", () => {\n    it(\"renders 'No properties' for an empty JSON object\", () => {\n      render(<JsonChip properties=\"{}\" />);\n      expect(screen.getByText(\"No properties\")).toBeTruthy();\n    });\n\n    it(\"renders 'No properties' for an empty string\", () => {\n      render(<JsonChip properties=\"\" />);\n      expect(screen.getByText(\"No properties\")).toBeTruthy();\n    });\n  });\n\n  describe(\"with properties\", () => {\n    it(\"renders a chip (button) with truncated key preview for JSON with multiple keys\", () => {\n      render(\n        <JsonChip properties='{\"page\":\"/home\",\"user\":\"alice\",\"count\":3}' />,\n      );\n      // The chip should be clickable (role=button) and show a short preview of keys\n      const chip = screen.getByRole(\"button\");\n      expect(chip).toBeTruthy();\n      // Preview text should include key names, not the raw JSON values\n      const text = chip.textContent ?? \"\";\n      expect(text).not.toBe(\"\");\n      // Should not show the full stringified JSON in preview\n      expect(text).not.toContain('\"page\":\"/home\"');\n    });\n\n    it(\"chip preview includes the first key name\", () => {\n      render(<JsonChip properties='{\"amount\":49.99,\"currency\":\"USD\"}' />);\n      const chip = screen.getByRole(\"button\");\n      expect(chip.textContent).toContain(\"amount\");\n    });\n\n    it(\"does not render 'No properties' when properties are present\", () => {\n      render(<JsonChip properties='{\"x\":1}' />);\n      expect(screen.queryByText(\"No properties\")).toBeNull();\n    });\n  });\n\n  describe(\"expansion\", () => {\n    it(\"clicking the chip reveals the full JSON content\", () => {\n      render(<JsonChip properties='{\"page\":\"/home\",\"user\":\"alice\"}' />);\n      const chip = screen.getByRole(\"button\");\n      fireEvent.click(chip);\n      // After expansion, the formatted JSON should be visible in the document\n      const expanded = screen.getByText(/\\/home/);\n      expect(expanded).toBeTruthy();\n    });\n\n    it(\"full JSON is not visible before clicking\", () => {\n      render(<JsonChip properties='{\"secretKey\":\"hunter2\"}' />);\n      expect(screen.queryByText(/hunter2/)).toBeNull();\n    });\n  });\n});\n","numLines":67,"startLine":1,"totalLines":67}}}
