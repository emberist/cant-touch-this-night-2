{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UgkJpYwLz7EaCYQctSts1m","type":"tool_result","content":"1\t/**\n2\t * Unit tests for /api/generate/* route handlers.\n3\t *\n4\t * These tests import the route handlers directly and mock @/lib/generator.\n5\t * No running server or ClickHouse instance required.\n6\t */\n7\t\n8\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n9\t\n10\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n11\t\n12\tconst { mockGetJob, mockCancelJob, mockListJobs } = vi.hoisted(() => ({\n13\t  mockGetJob: vi.fn(),\n14\t  mockCancelJob: vi.fn(),\n15\t  mockListJobs: vi.fn(),\n16\t}));\n17\t\n18\tvi.mock(\"@/lib/generator\", () => ({\n19\t  getJob: mockGetJob,\n20\t  cancelJob: mockCancelJob,\n21\t  listJobs: mockListJobs,\n22\t}));\n23\t\n24\timport { POST as cancelPOST } from \"@/app/api/generate/[job_id]/cancel/route\";\n25\timport { GET as statusGET } from \"@/app/api/generate/[job_id]/status/route\";\n26\timport { GET as jobsGET } from \"@/app/api/generate/jobs/route\";\n27\t\n28\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n29\t\n30\tfunction makeParams(job_id: string): { params: Promise<{ job_id: string }> } {\n31\t  return { params: Promise.resolve({ job_id }) };\n32\t}\n33\t\n34\tfunction makeRequest(url: string, method = \"GET\"): Request {\n35\t  return new Request(url, { method });\n36\t}\n37\t\n38\tconst COMPLETE_JOB = {\n39\t  job_id: \"test-job-123\",\n40\t  status: \"complete\" as const,\n41\t  inserted: 100,\n42\t  total: 100,\n43\t  throughput: 5000,\n44\t  eta_seconds: 0,\n45\t  elapsed_ms: 20,\n46\t  cancelled: false,\n47\t  created_at: Date.now(),\n48\t};\n49\t\n50\tconst RUNNING_JOB = {\n51\t  job_id: \"running-job-456\",\n52\t  status: \"running\" as const,\n53\t  inserted: 50,\n54\t  total: 100,\n55\t  throughput: 2500,\n56\t  eta_seconds: 1,\n57\t  elapsed_ms: 20,\n58\t  cancelled: false,\n59\t  created_at: Date.now(),\n60\t};\n61\t\n62\t// ─── Global setup ─────────────────────────────────────────────────────────────\n63\t\n64\tbeforeEach(() => {\n65\t  vi.useFakeTimers();\n66\t});\n67\t\n68\tafterEach(() => {\n69\t  vi.useRealTimers();\n70\t  vi.clearAllMocks();\n71\t});\n72\t\n73\t// ─── GET /api/generate/[job_id]/status ────────────────────────────────────────\n74\t\n75\tdescribe(\"GET /api/generate/[job_id]/status — unit\", () => {\n76\t  it(\"unknown job_id → 404 with error field\", async () => {\n77\t    mockGetJob.mockReturnValue(undefined);\n78\t\n79\t    const res = await statusGET(\n80\t      makeRequest(\"http://localhost/api/generate/nonexistent/status\"),\n81\t      makeParams(\"nonexistent\"),\n82\t    );\n83\t\n84\t    expect(res.status).toBe(404);\n85\t    const body = await res.json();\n86\t    expect(body).toHaveProperty(\"error\");\n87\t    expect(typeof body.error).toBe(\"string\");\n88\t    expect(body.error.length).toBeGreaterThan(0);\n89\t  });\n90\t\n91\t  it(\"known job_id → 200 with Content-Type: text/event-stream\", async () => {\n92\t    mockGetJob.mockReturnValue(COMPLETE_JOB);\n93\t\n94\t    const res = await statusGET(\n95\t      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n96\t      makeParams(\"test-job-123\"),\n97\t    );\n98\t\n99\t    expect(res.status).toBe(200);\n100\t    expect(res.headers.get(\"Content-Type\")).toContain(\"text/event-stream\");\n101\t\n102\t    res.body?.cancel();\n103\t  });\n104\t\n105\t  it(\"known job_id → Cache-Control: no-cache\", async () => {\n106\t    mockGetJob.mockReturnValue(COMPLETE_JOB);\n107\t\n108\t    const res = await statusGET(\n109\t      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n110\t      makeParams(\"test-job-123\"),\n111\t    );\n112\t\n113\t    expect(res.headers.get(\"Cache-Control\")).toBe(\"no-cache\");\n114\t\n115\t    res.body?.cancel();\n116\t  });\n117\t\n118\t  it(\"known job_id → Connection: keep-alive\", async () => {\n119\t    mockGetJob.mockReturnValue(COMPLETE_JOB);\n120\t\n121\t    const res = await statusGET(\n122\t      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n123\t      makeParams(\"test-job-123\"),\n124\t    );\n125\t\n126\t    expect(res.headers.get(\"Connection\")).toBe(\"keep-alive\");\n127\t\n128\t    res.body?.cancel();\n129\t  });\n130\t\n131\t  it(\"stream immediately enqueues SSE keep-alive comment\", async () => {\n132\t    mockGetJob.mockReturnValue(COMPLETE_JOB);\n133\t\n134\t    const res = await statusGET(\n135\t      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n136\t      makeParams(\"test-job-123\"),\n137\t    );\n138\t\n139\t    expect(res.body).not.toBeNull();\n140\t    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n141\t    const decoder = new TextDecoder();\n142\t\n143\t    // Keep-alive comment is enqueued synchronously in start() before any timer fires\n144\t    const { value } = await reader.read();\n145\t    expect(decoder.decode(value)).toBe(\":\\n\\n\");\n146\t\n147\t    reader.cancel();\n148\t  });\n149\t\n150\t  it(\"stream emits data: line with JSON containing status/inserted/total for complete job\", async () => {\n151\t    mockGetJob.mockReturnValue(COMPLETE_JOB);\n152\t\n153\t    const res = await statusGET(\n154\t      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n155\t      makeParams(\"test-job-123\"),\n156\t    );\n157\t\n158\t    expect(res.body).not.toBeNull();\n159\t    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n160\t    const decoder = new TextDecoder();\n161\t\n162\t    // Consume the keep-alive comment\n163\t    await reader.read();\n164\t\n165\t    // Advance clock 500ms to trigger the setInterval\n166\t    await vi.advanceTimersByTimeAsync(600);\n167\t\n168\t    const { value } = await reader.read();\n169\t    const text = decoder.decode(value);\n170\t\n171\t    expect(text).toMatch(/^data: /);\n172\t    const json = JSON.parse(text.replace(/^data: /, \"\").trim());\n173\t    expect(json).toHaveProperty(\"status\", \"complete\");\n174\t    expect(json).toHaveProperty(\"inserted\", 100);\n175\t    expect(json).toHaveProperty(\"total\", 100);\n176\t    expect(json).toHaveProperty(\"elapsed_ms\");\n177\t\n178\t    reader.cancel();\n179\t  });\n180\t\n181\t  it(\"complete job payload includes elapsed_ms (not throughput/eta_seconds)\", async () => {\n182\t    mockGetJob.mockReturnValue(COMPLETE_JOB);\n183\t\n184\t    const res = await statusGET(\n185\t      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n186\t      makeParams(\"test-job-123\"),\n187\t    );\n188\t\n189\t    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n190\t    const decoder = new TextDecoder();\n191\t\n192\t    // Skip keep-alive\n193\t    await reader.read();\n194\t    await vi.advanceTimersByTimeAsync(600);\n195\t\n196\t    const { value } = await reader.read();\n197\t    const json = JSON.parse(\n198\t      decoder\n199\t        .decode(value)\n200\t        .replace(/^data: /, \"\")\n201\t        .trim(),\n202\t    );\n203\t\n204\t    expect(json).toHaveProperty(\"elapsed_ms\");\n205\t    expect(json).not.toHaveProperty(\"throughput\");\n206\t    expect(json).not.toHaveProperty(\"eta_seconds\");\n207\t\n208\t    reader.cancel();\n209\t  });\n210\t\n211\t  it(\"running job payload includes throughput/eta_seconds (not elapsed_ms)\", async () => {\n212\t    // Return running status on first interval call, then complete on second (to close)\n213\t    mockGetJob\n214\t      .mockReturnValueOnce(RUNNING_JOB) // initial 404 check\n215\t      .mockReturnValueOnce(RUNNING_JOB) // interval call → running payload\n216\t      .mockReturnValue({ ...COMPLETE_JOB, job_id: \"running-job-456\" }); // close stream\n217\t\n218\t    const res = await statusGET(\n219\t      makeRequest(\"http://localhost/api/generate/running-job-456/status\"),\n220\t      makeParams(\"running-job-456\"),\n221\t    );\n222\t\n223\t    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n224\t    const decoder = new TextDecoder();\n225\t\n226\t    // Skip keep-alive\n227\t    await reader.read();\n228\t    await vi.advanceTimersByTimeAsync(600);\n229\t\n230\t    const { value } = await reader.read();\n231\t    const json = JSON.parse(\n232\t      decoder\n233\t        .decode(value)\n234\t        .replace(/^data: /, \"\")\n235\t        .trim(),\n236\t    );\n237\t\n238\t    expect(json).toHaveProperty(\"status\", \"running\");\n239\t    expect(json).toHaveProperty(\"throughput\");\n240\t    expect(json).toHaveProperty(\"eta_seconds\");\n241\t    expect(json).not.toHaveProperty(\"elapsed_ms\");\n242\t\n243\t    reader.cancel();\n244\t  });\n245\t\n246\t  it(\"stream closes after terminal status (complete)\", async () => {\n247\t    mockGetJob.mockReturnValue(COMPLETE_JOB);\n248\t\n249\t    const res = await statusGET(\n250\t      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n251\t      makeParams(\"test-job-123\"),\n252\t    );\n253\t\n254\t    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n255\t    const decoder = new TextDecoder();\n256\t\n257\t    // Skip keep-alive\n258\t    await reader.read();\n259\t\n260\t    // Advance time to trigger interval (stream emits payload and closes)\n261\t    await vi.advanceTimersByTimeAsync(600);\n262\t\n263\t    const { value } = await reader.read(); // data: line\n264\t    expect(decoder.decode(value)).toMatch(/data:/);\n265\t\n266\t    // Stream should now be closed\n267\t    const { done } = await reader.read();\n268\t    expect(done).toBe(true);\n269\t  });\n270\t});\n271\t\n272\t// ─── POST /api/generate/[job_id]/cancel ──────────────────────────────────────\n273\t\n274\tdescribe(\"POST /api/generate/[job_id]/cancel — unit\", () => {\n275\t  it(\"unknown job_id → 404 with error field\", async () => {\n276\t    mockCancelJob.mockReturnValue(false);\n277\t\n278\t    const res = await cancelPOST(\n279\t      makeRequest(\"http://localhost/api/generate/nonexistent/cancel\", \"POST\"),\n280\t      makeParams(\"nonexistent\"),\n281\t    );\n282\t\n283\t    expect(res.status).toBe(404);\n284\t    const body = await res.json();\n285\t    expect(body).toHaveProperty(\"error\");\n286\t    expect(typeof body.error).toBe(\"string\");\n287\t  });\n288\t\n289\t  it(\"known job_id → 200 with {cancelled: true}\", async () => {\n290\t    mockCancelJob.mockReturnValue(true);\n291\t\n292\t    const res = await cancelPOST(\n293\t      makeRequest(\"http://localhost/api/generate/test-job-123/cancel\", \"POST\"),\n294\t      makeParams(\"test-job-123\"),\n295\t    );\n296\t\n297\t    expect(res.status).toBe(200);\n298\t    const body = await res.json();\n299\t    expect(body).toEqual({ cancelled: true });\n300\t  });\n301\t\n302\t  it(\"calls cancelJob with the correct job_id\", async () => {\n303\t    mockCancelJob.mockReturnValue(true);\n304\t\n305\t    await cancelPOST(\n306\t      makeRequest(\"http://localhost/api/generate/my-job-id/cancel\", \"POST\"),\n307\t      makeParams(\"my-job-id\"),\n308\t    );\n309\t\n310\t    expect(mockCancelJob).toHaveBeenCalledWith(\"my-job-id\");\n311\t  });\n312\t});\n313\t\n314\t// ─── GET /api/generate/jobs ───────────────────────────────────────────────────\n315\t\n316\tdescribe(\"GET /api/generate/jobs — unit\", () => {\n317\t  it(\"returns 200 with JSON array\", async () => {\n318\t    mockListJobs.mockReturnValue([]);\n319\t\n320\t    const res = jobsGET();\n321\t\n322\t    expect(res.status).toBe(200);\n323\t    const body = await res.json();\n324\t    expect(Array.isArray(body)).toBe(true);\n325\t  });\n326\t\n327\t  it(\"returns empty array when no jobs exist\", async () => {\n328\t    mockListJobs.mockReturnValue([]);\n329\t\n330\t    const res = jobsGET();\n331\t    const body = await res.json();\n332\t\n333\t    expect(body).toEqual([]);\n334\t  });\n335\t\n336\t  it(\"returns jobs with job_id, status, inserted, and total fields\", async () => {\n337\t    const jobs = [\n338\t      {\n339\t        job_id: \"job-1\",\n340\t        status: \"complete\",\n341\t        inserted: 100,\n342\t        total: 100,\n343\t        throughput: 5000,\n344\t        eta_seconds: 0,\n345\t        elapsed_ms: 20,\n346\t        cancelled: false,\n347\t        created_at: Date.now(),\n348\t      },\n349\t      {\n350\t        job_id: \"job-2\",\n351\t        status: \"running\",\n352\t        inserted: 50,\n353\t        total: 200,\n354\t        throughput: 2500,\n355\t        eta_seconds: 1,\n356\t        elapsed_ms: 20,\n357\t        cancelled: false,\n358\t        created_at: Date.now(),\n359\t      },\n360\t    ];\n361\t    mockListJobs.mockReturnValue(jobs);\n362\t\n363\t    const res = jobsGET();\n364\t    const body = await res.json();\n365\t\n366\t    expect(Array.isArray(body)).toBe(true);\n367\t    expect(body).toHaveLength(2);\n368\t\n369\t    for (const job of body) {\n370\t      expect(job).toHaveProperty(\"job_id\");\n371\t      expect(job).toHaveProperty(\"status\");\n372\t      expect(job).toHaveProperty(\"inserted\");\n373\t      expect(job).toHaveProperty(\"total\");\n374\t    }\n375\t  });\n376\t\n377\t  it(\"calls listJobs to retrieve the job list\", async () => {\n378\t    mockListJobs.mockReturnValue([]);\n379\t\n380\t    jobsGET();\n381\t\n382\t    expect(mockListJobs).toHaveBeenCalledOnce();\n383\t  });\n384\t});\n385\t"}]},"parent_tool_use_id":null,"session_id":"b4c88b5c-8693-4026-950e-1b3f32ff042f","uuid":"462ad16c-162e-4433-a408-9cea3b674843","timestamp":"2026-04-15T18:34:49.052Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/generate/__tests__/route.unit.test.ts","content":"/**\n * Unit tests for /api/generate/* route handlers.\n *\n * These tests import the route handlers directly and mock @/lib/generator.\n * No running server or ClickHouse instance required.\n */\n\nimport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockGetJob, mockCancelJob, mockListJobs } = vi.hoisted(() => ({\n  mockGetJob: vi.fn(),\n  mockCancelJob: vi.fn(),\n  mockListJobs: vi.fn(),\n}));\n\nvi.mock(\"@/lib/generator\", () => ({\n  getJob: mockGetJob,\n  cancelJob: mockCancelJob,\n  listJobs: mockListJobs,\n}));\n\nimport { POST as cancelPOST } from \"@/app/api/generate/[job_id]/cancel/route\";\nimport { GET as statusGET } from \"@/app/api/generate/[job_id]/status/route\";\nimport { GET as jobsGET } from \"@/app/api/generate/jobs/route\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction makeParams(job_id: string): { params: Promise<{ job_id: string }> } {\n  return { params: Promise.resolve({ job_id }) };\n}\n\nfunction makeRequest(url: string, method = \"GET\"): Request {\n  return new Request(url, { method });\n}\n\nconst COMPLETE_JOB = {\n  job_id: \"test-job-123\",\n  status: \"complete\" as const,\n  inserted: 100,\n  total: 100,\n  throughput: 5000,\n  eta_seconds: 0,\n  elapsed_ms: 20,\n  cancelled: false,\n  created_at: Date.now(),\n};\n\nconst RUNNING_JOB = {\n  job_id: \"running-job-456\",\n  status: \"running\" as const,\n  inserted: 50,\n  total: 100,\n  throughput: 2500,\n  eta_seconds: 1,\n  elapsed_ms: 20,\n  cancelled: false,\n  created_at: Date.now(),\n};\n\n// ─── Global setup ─────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  vi.useFakeTimers();\n});\n\nafterEach(() => {\n  vi.useRealTimers();\n  vi.clearAllMocks();\n});\n\n// ─── GET /api/generate/[job_id]/status ────────────────────────────────────────\n\ndescribe(\"GET /api/generate/[job_id]/status — unit\", () => {\n  it(\"unknown job_id → 404 with error field\", async () => {\n    mockGetJob.mockReturnValue(undefined);\n\n    const res = await statusGET(\n      makeRequest(\"http://localhost/api/generate/nonexistent/status\"),\n      makeParams(\"nonexistent\"),\n    );\n\n    expect(res.status).toBe(404);\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n    expect(typeof body.error).toBe(\"string\");\n    expect(body.error.length).toBeGreaterThan(0);\n  });\n\n  it(\"known job_id → 200 with Content-Type: text/event-stream\", async () => {\n    mockGetJob.mockReturnValue(COMPLETE_JOB);\n\n    const res = await statusGET(\n      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n      makeParams(\"test-job-123\"),\n    );\n\n    expect(res.status).toBe(200);\n    expect(res.headers.get(\"Content-Type\")).toContain(\"text/event-stream\");\n\n    res.body?.cancel();\n  });\n\n  it(\"known job_id → Cache-Control: no-cache\", async () => {\n    mockGetJob.mockReturnValue(COMPLETE_JOB);\n\n    const res = await statusGET(\n      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n      makeParams(\"test-job-123\"),\n    );\n\n    expect(res.headers.get(\"Cache-Control\")).toBe(\"no-cache\");\n\n    res.body?.cancel();\n  });\n\n  it(\"known job_id → Connection: keep-alive\", async () => {\n    mockGetJob.mockReturnValue(COMPLETE_JOB);\n\n    const res = await statusGET(\n      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n      makeParams(\"test-job-123\"),\n    );\n\n    expect(res.headers.get(\"Connection\")).toBe(\"keep-alive\");\n\n    res.body?.cancel();\n  });\n\n  it(\"stream immediately enqueues SSE keep-alive comment\", async () => {\n    mockGetJob.mockReturnValue(COMPLETE_JOB);\n\n    const res = await statusGET(\n      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n      makeParams(\"test-job-123\"),\n    );\n\n    expect(res.body).not.toBeNull();\n    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n    const decoder = new TextDecoder();\n\n    // Keep-alive comment is enqueued synchronously in start() before any timer fires\n    const { value } = await reader.read();\n    expect(decoder.decode(value)).toBe(\":\\n\\n\");\n\n    reader.cancel();\n  });\n\n  it(\"stream emits data: line with JSON containing status/inserted/total for complete job\", async () => {\n    mockGetJob.mockReturnValue(COMPLETE_JOB);\n\n    const res = await statusGET(\n      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n      makeParams(\"test-job-123\"),\n    );\n\n    expect(res.body).not.toBeNull();\n    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n    const decoder = new TextDecoder();\n\n    // Consume the keep-alive comment\n    await reader.read();\n\n    // Advance clock 500ms to trigger the setInterval\n    await vi.advanceTimersByTimeAsync(600);\n\n    const { value } = await reader.read();\n    const text = decoder.decode(value);\n\n    expect(text).toMatch(/^data: /);\n    const json = JSON.parse(text.replace(/^data: /, \"\").trim());\n    expect(json).toHaveProperty(\"status\", \"complete\");\n    expect(json).toHaveProperty(\"inserted\", 100);\n    expect(json).toHaveProperty(\"total\", 100);\n    expect(json).toHaveProperty(\"elapsed_ms\");\n\n    reader.cancel();\n  });\n\n  it(\"complete job payload includes elapsed_ms (not throughput/eta_seconds)\", async () => {\n    mockGetJob.mockReturnValue(COMPLETE_JOB);\n\n    const res = await statusGET(\n      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n      makeParams(\"test-job-123\"),\n    );\n\n    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n    const decoder = new TextDecoder();\n\n    // Skip keep-alive\n    await reader.read();\n    await vi.advanceTimersByTimeAsync(600);\n\n    const { value } = await reader.read();\n    const json = JSON.parse(\n      decoder\n        .decode(value)\n        .replace(/^data: /, \"\")\n        .trim(),\n    );\n\n    expect(json).toHaveProperty(\"elapsed_ms\");\n    expect(json).not.toHaveProperty(\"throughput\");\n    expect(json).not.toHaveProperty(\"eta_seconds\");\n\n    reader.cancel();\n  });\n\n  it(\"running job payload includes throughput/eta_seconds (not elapsed_ms)\", async () => {\n    // Return running status on first interval call, then complete on second (to close)\n    mockGetJob\n      .mockReturnValueOnce(RUNNING_JOB) // initial 404 check\n      .mockReturnValueOnce(RUNNING_JOB) // interval call → running payload\n      .mockReturnValue({ ...COMPLETE_JOB, job_id: \"running-job-456\" }); // close stream\n\n    const res = await statusGET(\n      makeRequest(\"http://localhost/api/generate/running-job-456/status\"),\n      makeParams(\"running-job-456\"),\n    );\n\n    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n    const decoder = new TextDecoder();\n\n    // Skip keep-alive\n    await reader.read();\n    await vi.advanceTimersByTimeAsync(600);\n\n    const { value } = await reader.read();\n    const json = JSON.parse(\n      decoder\n        .decode(value)\n        .replace(/^data: /, \"\")\n        .trim(),\n    );\n\n    expect(json).toHaveProperty(\"status\", \"running\");\n    expect(json).toHaveProperty(\"throughput\");\n    expect(json).toHaveProperty(\"eta_seconds\");\n    expect(json).not.toHaveProperty(\"elapsed_ms\");\n\n    reader.cancel();\n  });\n\n  it(\"stream closes after terminal status (complete)\", async () => {\n    mockGetJob.mockReturnValue(COMPLETE_JOB);\n\n    const res = await statusGET(\n      makeRequest(\"http://localhost/api/generate/test-job-123/status\"),\n      makeParams(\"test-job-123\"),\n    );\n\n    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n    const decoder = new TextDecoder();\n\n    // Skip keep-alive\n    await reader.read();\n\n    // Advance time to trigger interval (stream emits payload and closes)\n    await vi.advanceTimersByTimeAsync(600);\n\n    const { value } = await reader.read(); // data: line\n    expect(decoder.decode(value)).toMatch(/data:/);\n\n    // Stream should now be closed\n    const { done } = await reader.read();\n    expect(done).toBe(true);\n  });\n});\n\n// ─── POST /api/generate/[job_id]/cancel ──────────────────────────────────────\n\ndescribe(\"POST /api/generate/[job_id]/cancel — unit\", () => {\n  it(\"unknown job_id → 404 with error field\", async () => {\n    mockCancelJob.mockReturnValue(false);\n\n    const res = await cancelPOST(\n      makeRequest(\"http://localhost/api/generate/nonexistent/cancel\", \"POST\"),\n      makeParams(\"nonexistent\"),\n    );\n\n    expect(res.status).toBe(404);\n    const body = await res.json();\n    expect(body).toHaveProperty(\"error\");\n    expect(typeof body.error).toBe(\"string\");\n  });\n\n  it(\"known job_id → 200 with {cancelled: true}\", async () => {\n    mockCancelJob.mockReturnValue(true);\n\n    const res = await cancelPOST(\n      makeRequest(\"http://localhost/api/generate/test-job-123/cancel\", \"POST\"),\n      makeParams(\"test-job-123\"),\n    );\n\n    expect(res.status).toBe(200);\n    const body = await res.json();\n    expect(body).toEqual({ cancelled: true });\n  });\n\n  it(\"calls cancelJob with the correct job_id\", async () => {\n    mockCancelJob.mockReturnValue(true);\n\n    await cancelPOST(\n      makeRequest(\"http://localhost/api/generate/my-job-id/cancel\", \"POST\"),\n      makeParams(\"my-job-id\"),\n    );\n\n    expect(mockCancelJob).toHaveBeenCalledWith(\"my-job-id\");\n  });\n});\n\n// ─── GET /api/generate/jobs ───────────────────────────────────────────────────\n\ndescribe(\"GET /api/generate/jobs — unit\", () => {\n  it(\"returns 200 with JSON array\", async () => {\n    mockListJobs.mockReturnValue([]);\n\n    const res = jobsGET();\n\n    expect(res.status).toBe(200);\n    const body = await res.json();\n    expect(Array.isArray(body)).toBe(true);\n  });\n\n  it(\"returns empty array when no jobs exist\", async () => {\n    mockListJobs.mockReturnValue([]);\n\n    const res = jobsGET();\n    const body = await res.json();\n\n    expect(body).toEqual([]);\n  });\n\n  it(\"returns jobs with job_id, status, inserted, and total fields\", async () => {\n    const jobs = [\n      {\n        job_id: \"job-1\",\n        status: \"complete\",\n        inserted: 100,\n        total: 100,\n        throughput: 5000,\n        eta_seconds: 0,\n        elapsed_ms: 20,\n        cancelled: false,\n        created_at: Date.now(),\n      },\n      {\n        job_id: \"job-2\",\n        status: \"running\",\n        inserted: 50,\n        total: 200,\n        throughput: 2500,\n        eta_seconds: 1,\n        elapsed_ms: 20,\n        cancelled: false,\n        created_at: Date.now(),\n      },\n    ];\n    mockListJobs.mockReturnValue(jobs);\n\n    const res = jobsGET();\n    const body = await res.json();\n\n    expect(Array.isArray(body)).toBe(true);\n    expect(body).toHaveLength(2);\n\n    for (const job of body) {\n      expect(job).toHaveProperty(\"job_id\");\n      expect(job).toHaveProperty(\"status\");\n      expect(job).toHaveProperty(\"inserted\");\n      expect(job).toHaveProperty(\"total\");\n    }\n  });\n\n  it(\"calls listJobs to retrieve the job list\", async () => {\n    mockListJobs.mockReturnValue([]);\n\n    jobsGET();\n\n    expect(mockListJobs).toHaveBeenCalledOnce();\n  });\n});\n","numLines":385,"startLine":1,"totalLines":385}}}
