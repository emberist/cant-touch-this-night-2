{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017rTUgab5sytNz4mQUtGKyS","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { cleanup, fireEvent, render, screen } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport { TrendChart } from \"@/components/TrendChart\";\n5\timport type { Series } from \"@/lib/trends\";\n6\t\n7\t// ─── Mock recharts ─────────────────────────────────────────────────────────────\n8\t// Recharts needs ResizeObserver and real DOM dimensions to render.\n9\t// jsdom has zero-size containers, so we stub the chart components.\n10\t\n11\tvi.mock(\"recharts\", () => ({\n12\t  ResponsiveContainer: ({ children }: { children: React.ReactNode }) => (\n13\t    <div>{children}</div>\n14\t  ),\n15\t  LineChart: ({ children }: { children: React.ReactNode }) => (\n16\t    <div data-testid=\"recharts-line-chart\">{children}</div>\n17\t  ),\n18\t  BarChart: ({ children }: { children: React.ReactNode }) => (\n19\t    <div data-testid=\"recharts-bar-chart\">{children}</div>\n20\t  ),\n21\t  AreaChart: ({ children }: { children: React.ReactNode }) => (\n22\t    <div data-testid=\"recharts-area-chart\">{children}</div>\n23\t  ),\n24\t  Line: () => null,\n25\t  Bar: () => null,\n26\t  Area: () => null,\n27\t  XAxis: () => null,\n28\t  YAxis: () => null,\n29\t  CartesianGrid: () => null,\n30\t  Tooltip: () => null,\n31\t  Legend: () => null,\n32\t}));\n33\t\n34\t// ─── Fixtures ─────────────────────────────────────────────────────────────────\n35\t\n36\tfunction makeSeries(numPoints: number): Series[] {\n37\t  const data = Array.from({ length: numPoints }, (_, i) => ({\n38\t    date: `2026-04-${String(i + 1).padStart(2, \"0\")}`,\n39\t    value: i * 10,\n40\t  }));\n41\t  return [{ label: \"Page Viewed\", data }];\n42\t}\n43\t\n44\tfunction makeMultiSeries(numPoints: number): Series[] {\n45\t  const data = Array.from({ length: numPoints }, (_, i) => ({\n46\t    date: `2026-04-${String(i + 1).padStart(2, \"0\")}`,\n47\t    value: i * 10,\n48\t  }));\n49\t  return [\n50\t    { label: \"US\", data },\n51\t    { label: \"UK\", data },\n52\t  ];\n53\t}\n54\t\n55\tafterEach(() => {\n56\t  cleanup();\n57\t  vi.clearAllMocks();\n58\t});\n59\t\n60\t// ─── Tests ────────────────────────────────────────────────────────────────────\n61\t\n62\tdescribe(\"TrendChart\", () => {\n63\t  describe(\"chart type toggle\", () => {\n64\t    it(\"renders chart type toggle with Line option\", () => {\n65\t      render(<TrendChart series={makeSeries(5)} loading={false} />);\n66\t      expect(screen.getByText(\"Line\")).toBeTruthy();\n67\t    });\n68\t\n69\t    it(\"renders chart type toggle with Bar option\", () => {\n70\t      render(<TrendChart series={makeSeries(5)} loading={false} />);\n71\t      expect(screen.getByText(\"Bar\")).toBeTruthy();\n72\t    });\n73\t\n74\t    it(\"renders chart type toggle with Area option\", () => {\n75\t      render(<TrendChart series={makeSeries(5)} loading={false} />);\n76\t      expect(screen.getByText(\"Area\")).toBeTruthy();\n77\t    });\n78\t\n79\t    it(\"renders chart type toggle with Table option\", () => {\n80\t      render(<TrendChart series={makeSeries(5)} loading={false} />);\n81\t      expect(screen.getByText(\"Table\")).toBeTruthy();\n82\t    });\n83\t  });\n84\t\n85\t  describe(\"empty state\", () => {\n86\t    it(\"renders an empty state message when series is empty\", () => {\n87\t      render(<TrendChart series={[]} loading={false} />);\n88\t      // Should show something indicating no data\n89\t      const noDataEl =\n90\t        screen.queryByText(/no data/i) ??\n91\t        screen.queryByTestId(\"trend-chart-empty\");\n92\t      expect(noDataEl).not.toBeNull();\n93\t    });\n94\t\n95\t    it(\"does not render a recharts chart when series is empty\", () => {\n96\t      render(<TrendChart series={[]} loading={false} />);\n97\t      expect(screen.queryByTestId(\"recharts-line-char