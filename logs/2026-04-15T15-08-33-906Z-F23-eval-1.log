\n    useTrends();\n\n  return (\n    <Box sx={{ p: 3, maxWidth: 1100 }}>\n      <Typography variant=\"h4\" component=\"h1\" gutterBottom>\n        Trends\n      </Typography>\n\n      <TrendsControls\n        schema={schema}\n        controls={controls}\n        setters={setters}\n        numericProperties={numericProperties}\n      />\n\n      <Divider sx={{ my: 3 }} />\n\n      <TrendChart series={series} loading={loading} />\n    </Box>\n  );\n}\n","numLines":33,"startLine":1,"totalLines":33}}}
