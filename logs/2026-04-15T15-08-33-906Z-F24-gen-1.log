t steps={funnelSteps} loading={loading} />\n    </Box>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":328,"cache_read_input_tokens":77249,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":328},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0e7de277-607b-42d2-9d00-d4050492645c","uuid":"108941ac-5304-4f78-baf6-339517e1df4e"}
