{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01RCFxE3J3XYo2e1ePfUCWJN","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017mRf5GnrVT3AVSeik5oZRf","name":"Read","input":{"file_path":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/TrendChart.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":6,"cache_creation_input_tokens":4263,"cache_read_input_tokens":102719,"cache_creation":{"ephemeral_5m_input_tokens":4263,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01NWeW8R45nb4Fb9vjB3jZJX","session_id":"0e7de277-607b-42d2-9d00-d4050492645c","uuid":"a3249124-8ffa-4d30-9497-844e04492dd5"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017mRf5GnrVT3AVSeik5oZRf","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport Box from \"@mui/material/Box\";\n4\timport Skeleton from \"@mui/material/Skeleton\";\n5\timport Table from \"@mui/material/Table\";\n6\timport TableBody from \"@mui/material/TableBody\";\n7\timport TableCell from \"@mui/material/TableCell\";\n8\timport TableHead from \"@mui/material/TableHead\";\n9\timport TableRow from \"@mui/material/TableRow\";\n10\timport ToggleButton from \"@mui/material/ToggleButton\";\n11\timport ToggleButtonGroup from \"@mui/material/ToggleButtonGroup\";\n12\timport Typography from \"@mui/material/Typography\";\n13\timport { useEffect, useState } from \"react\";\n14\timport {\n15\t  Area,\n16\t  AreaChart,\n17\t  Bar,\n18\t  BarChart,\n19\t  CartesianGrid,\n20\t  Legend,\n21\t  Line,\n22\t  LineChart,\n23\t  ResponsiveContainer,\n24\t  Tooltip,\n25\t  XAxis,\n26\t  YAxis,\n27\t} from \"recharts\";\n28\timport type { Series } from \"@/lib/trends\";\n29\t\n30\t// ─── Types ────────────────────────────────────────────────────────────────────\n31\t\n32\ttype ChartType = \"line\" | \"bar\" | \"area\" | \"table\";\n33\t\n34\tinterface TrendChartProps {\n35\t  series: Series[];\n36\t  loading: boolean;\n37\t}\n38\t\n39\t// ─── Colors ───────────────────────────────────────────────────────────────────\n40\t\n41\tconst COLORS = [\n42\t  \"#1976d2\",\n43\t  \"#e91e63\",\n44\t  \"#4caf50\",\n45\t  \"#ff9800\",\n46\t  \"#9c27b0\",\n47\t  \"#00bcd4\",\n48\t  \"#f44336\",\n49\t  \"#607d8b\",\n50\t];\n51\t\n52\t// ─── Table view ───────────────────────────────────────────────────────────────\n53\t\n54\tfunction TableView({ series }: { series: Series[] }): React.JSX.Element {\n55\t  if (series.length === 0) return <></>;\n56\t\n57\t  // Collect all unique dates across all series\n58\t  const allDates = Array.from(\n59\t    new Set(series.flatMap((s) => s.data.map((p) => p.date))),\n60\t  ).sort();\n61\t\n62\t  // Build a lookup: label → date → value\n63\t  const lookup = new Map<string, Map<string, number>>();\n64\t  for (const s of series) {\n65\t    const byDate = new Map<string, number>();\n66\t    for (const p of s.data) {\n67\t      byDate.set(p.date, p.value);\n68\t    }\n69\t    lookup.set(s.label, byDate);\n70\t  }\n71\t\n72\t  return (\n73\t    <Table size=\"small\">\n74\t      <TableHead>\n75\t        <TableRow>\n76\t          <TableCell>Date</TableCell>\n77\t          {series.map((s) => (\n78\t            <TableCell key={s.label} align=\"right\">\n79\t              {s.label}\n80\t            </TableCell>\n81\t          ))}\n82\t        </TableRow>\n83\t      </TableHead>\n84\t      <TableBody>\n85\t        {allDates.map((date) => (\n86\t          <TableRow key={date}>\n87\t            <TableCell>{date}</TableCell>\n88\t            {series.map((s) => (\n89\t              <TableCell key={s.label} align=\"right\">\n90\t                {lookup.get(s.label)?.get(date) ?? \"-\"}\n91\t              </TableCell>\n92\t            ))}\n93\t          </TableRow>\n94\t        ))}\n95\t      </TableBody>\n96\t    </Table>\n97\t  );\n98\t}\n99\t\n100\t// ─── Recharts data shape ──────────────────────────────────────────────────────\n101\t\n102\t/** Transform series into a flat array usable by Recharts (one row per date). */\n103\tfunction toRechartsData(series: Series[]): Record<string, string | number>[] {\n104\t  const allDates = Array.from(\n105\t    new Set(series.flatMap((s) => s.data.map((p) => p.date))),\n106\t  ).sort();\n107\t\n108\t  return allDates.map((date) => {\n109\t    const row: Record<string, string | number> = { date };\n110\t    for (const s of series) {\n111\t      const point = s.data.find((p) => p.date === date);\n112\t      row[s.label] = point?.value ?? 0;\n113\t    }\n114\t    return row;\n115\t  });\n116\t}\n117\t\n118\t// ─── Component ────────────────────────────────────────────────────────────────\n119\t\n120\texport function TrendChart({\n121\t  series,\n122\t  loading,\n123\t}: TrendChartProps): React.JSX.Element {\n124\t  // Determine initial chart type: if only 1 data bucket across all series → bar\n125\t  const isSingleBucket =\n126\t    series.length > 0 && series.every((s) => s.data.length === 1);\n127\t\n128\t  const [chartType, setChartType] = useState<ChartType>(\n129\t    isSingleBucket ? \"bar\" : \"line\",\n130\t  );\n131\t\n132\t  // Re-evaluate auto-switch when series changes\n133\t  useEffect(() => {\n134\t    if (series.length === 0) return;\n135\t    const single = series.every((s) => s.data.length === 1);\n136\t    setChartType(single ? \"bar\" : \"line\");\n137\t  }, [series]);\n138\t\n139\t  const data = toRechartsData(series);\n140\t  const hasData = series.length > 0;\n141\t\n142\t  return (\n143\t    <Box data-testid=\"trend-chart\">\n144\t      {/* ── Chart type toggle ──────────────────────────────────────────────── */}\n145\t      <Box sx={{ mb: 2 }}>\n146\t        <ToggleButtonGroup\n147\t          exclusive\n148\t          size=\"small\"\n149\t          value={chartType}\n150\t          onChange={(_, v: ChartType | null) => {\n151\t            if (v) setChartType(v);\n152\t          }}\n153\t        >\n154\t          <ToggleButton value=\"line\">Line</ToggleButton>\n155\t          <ToggleButton value=\"bar\">Bar</ToggleButton>\n156\t          <ToggleButton value=\"area\">Area</ToggleButton>\n157\t          <ToggleButton value=\"table\">Table</ToggleButton>\n158\t        </ToggleButtonGroup>\n159\t      </Box>\n160\t\n161\t      {/* ── Content area ──────────────────────────────────────────────────── */}\n162\t      {loading && (\n163\t        <Box data-testid=\"trend-chart-skeleton\">\n164\t          <Skeleton variant=\"rectangular\" height={300} />\n165\t        </Box>\n166\t      )}\n167\t\n168\t      {!loading && !hasData && (\n169\t        <Box\n170\t          data-testid=\"trend-chart-empty\"\n171\t          sx={{\n172\t            display: \"flex\",\n173\t            alignItems: \"center\",\n174\t            justifyContent: \"center\",\n175\t            height: 300,\n176\t            border: 1,\n177\t            borderColor: \"divider\",\n178\t            borderRadius: 1,\n179\t          }}\n180\t        >\n181\t          <Typography color=\"text.secondary\">No data</Typography>\n182\t        </Box>\n183\t      )}\n184\t\n185\t      {!loading && hasData && chartType === \"table\" && (\n186\t        <TableView series={series} />\n187\t      )}\n188\t\n189\t      {!loading && hasData && chartType === \"line\" && (\n190\t        <ResponsiveContainer width=\"100%\" height={300}>\n191\t          <LineChart data={data}>\n192\t            <CartesianGrid strokeDasharray=\"3 3\" />\n193\t            <XAxis dataKey=\"date\" />\n194\t            <YAxis />\n195\t            <Tooltip />\n196\t            <Legend />\n197\t            {series.map((s, i) => (\n198\t              <Line\n199\t                key={s.label}\n200\t                type=\"monotone\"\n201\t                dataKey={s.label}\n202\t                stroke={COLORS[i % COLORS.length]}\n203\t                dot={false}\n204\t              />\n205\t            ))}\n206\t          </LineChart>\n207\t        </ResponsiveContainer>\n208\t      )}\n209\t\n210\t      {!loading && hasData && chartType === \"bar\" && (\n211\t        <ResponsiveContainer width=\"100%\" height={300}>\n212\t          <BarChart data={data}>\n213\t            <CartesianGrid strokeDasharray=\"3 3\" />\n214\t            <XAxis dataKey=\"date\" />\n215\t            <YAxis />\n216\t            <Tooltip />\n217\t            <Legend />\n218\t            {series.map((s, i) => (\n219\t              <Bar\n220\t                key={s.label}\n221\t                dataKey={s.label}\n222\t                fill={COLORS[i % COLORS.length]}\n223\t              />\n224\t            ))}\n225\t          </BarChart>\n226\t        </ResponsiveContainer>\n227\t      )}\n228\t\n229\t      {!loading && hasData && chartType === \"area\" && (\n230\t        <ResponsiveContainer width=\"100%\" height={300}>\n231\t          <AreaChart data={data}>\n232\t            <CartesianGrid strokeDasharray=\"3 3\" />\n233\t            <XAxis dataKey=\"date\" />\n234\t            <YAxis />\n235\t            <Tooltip />\n236\t            <Legend />\n237\t            {series.map((s, i) => (\n238\t              <Area\n239\t                key={s.label}\n240\t                type=\"monotone\"\n241\t                dataKey={s.label}\n242\t                stroke={COLORS[i % COLORS.length]}\n243\t                fill={COLORS[i % COLORS.length]}\n244\t                fillOpacity={0.3}\n245\t              />\n246\t            ))}\n247\t          </AreaChart>\n248\t        </ResponsiveContainer>\n249\t      )}\n250\t    </Box>\n251\t  );\n252\t}\n253\t"}]},"parent_tool_use_id":"toolu_01NWeW8R45nb4Fb9vjB3jZJX","session_id":"0e7de277-607b-42d2-9d00-d4050492645c","uuid":"12f8e14a-715a-4b6d-b100-e3908bfc1d4c","timestamp":"2026-04-15T17:03:12.635Z"}
