{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0137m5owKay7irXoXCwCRsYj","type":"tool_result","content":"1\t/** Cached schema response shape (matches GET /api/schema response). */\n2\texport interface SchemaResponse {\n3\t  event_names: string[];\n4\t  properties: Record<string, Record<string, \"numeric\" | \"string\">>;\n5\t}\n6\t\n7\tconst TTL_MS = 60_000; // 60 seconds\n8\t\n9\tinterface CacheEntry {\n10\t  value: SchemaResponse;\n11\t  cachedAt: number;\n12\t}\n13\t\n14\tlet entry: CacheEntry | null = null;\n15\t\n16\t/** Returns the cached schema if it exists and is within TTL, otherwise null. */\n17\texport function getCachedSchema(): SchemaResponse | null {\n18\t  if (entry === null) return null;\n19\t  if (Date.now() - entry.cachedAt >= TTL_MS) {\n20\t    entry = null;\n21\t    return null;\n22\t  }\n23\t  return entry.value;\n24\t}\n25\t\n26\t/** Stores a new schema response in the cache with the current timestamp. */\n27\texport function setCachedSchema(value: SchemaResponse): void {\n28\t  entry = { value, cachedAt: Date.now() };\n29\t}\n30\t\n31\t/** Clears the cache. Used in tests and when data changes. */\n32\texport function invalidateSchemaCache(): void {\n33\t  entry = null;\n34\t}\n35\t"}]},"parent_tool_use_id":"toolu_01NWeW8R45nb4Fb9vjB3jZJX","session_id":"0e7de277-607b-42d2-9d00-d4050492645c","uuid":"f81c9d31-6cba-4224-a222-1b5fb9a1eaf3","timestamp":"2026-04-15T17:03:10.403Z"}
