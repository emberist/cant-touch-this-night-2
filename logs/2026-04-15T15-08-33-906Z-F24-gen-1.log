{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PifRuZ1cpEZ1YrXkjnqJXa","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport Autocomplete from \"@mui/material/Autocomplete\";\n4\timport Box from \"@mui/material/Box\";\n5\timport Chip from \"@mui/material/Chip\";\n6\timport FormControl from \"@mui/material/FormControl\";\n7\timport InputLabel from \"@mui/material/InputLabel\";\n8\timport type { SelectChangeEvent } from \"@mui/material/Select\";\n9\timport Select from \"@mui/material/Select\";\n10\timport Stack from \"@mui/material/Stack\";\n11\timport TextField from \"@mui/material/TextField\";\n12\timport ToggleButton from \"@mui/material/ToggleButton\";\n13\timport ToggleButtonGroup from \"@mui/material/ToggleButtonGroup\";\n14\timport Typography from \"@mui/material/Typography\";\n15\timport type {\n16\t  UseTrendsControls,\n17\t  UseTrendsSetters,\n18\t} from \"@/components/trends/useTrends\";\n19\timport type { SchemaResponse } from \"@/lib/schema-cache\";\n20\t\n21\t// ─── Types ────────────────────────────────────────────────────────────────────\n22\t\n23\tinterface TrendsControlsProps {\n24\t  schema: SchemaResponse | null;\n25\t  controls: UseTrendsControls;\n26\t  setters: UseTrendsSetters;\n27\t  numericProperties: string[];\n28\t}\n29\t\n30\t// ─── Measure helpers ──────────────────────────────────────────────────────────\n31\t\n32\t/** Extract the aggregate function key from the combined measure string. */\n33\tfunction parseMeasureFn(measure: string): string {\n34\t  if (measure === \"count\" || measure === \"unique_users\") return measure;\n35\t  const colon = measure.indexOf(\":\");\n36\t  return colon !== -1 ? measure.slice(0, colon) : measure;\n37\t}\n38\t\n39\t/** Extract the property name from the combined measure string. */\n40\tfunction parseMeasureProp(measure: string): string {\n41\t  const colon = measure.indexOf(\":\");\n42\t  return colon !== -1 ? measure.slice(colon + 1) : \"\";\n43\t}\n44\t\n45\tconst AGGREGATION_FNS = new Set([\"sum\", \"avg\", \"min\", \"max\"]);\n46\t\n47\tfunction isAggregation(measureFn: string): boolean {\n48\t  return AGGREGATION_FNS.has(measureFn);\n49\t}\n50\t\n51\t// ─── Date helpers ─────────────────────────────────────────────────────────────\n52\t\n53\tfunction todayISO(): string {\n54\t  return new Date().toISOString().slice(0, 10);\n55\t}\n56\t\n57\tfunction daysAgoISO(days: number): string {\n58\t  const d = new Date();\n59\t  d.setDate(d.getDate() - days);\n60\t  return d.toISOString().slice(0, 10);\n61\t}\n62\t\n63\t// ─── Component ────────────────────────────────────────────────────────────────\n64\t\n65\texport function TrendsControls({\n66\t  schema,\n67\t  controls,\n68\t  setters,\n69\t  numericProperties,\n70\t}: TrendsControlsProps): React.JSX.Element {\n71\t  const eventNames = schema?.event_names ?? [];\n72\t  const measureFn = parseMeasureFn(controls.measure);\n73\t  const measureProp = parseMeasureProp(controls.measure);\n74\t  const showPropertySelector = isAggregation(measureFn);\n75\t\n76\t  function handleMeasureFnChange(e: SelectChangeEvent) {\n77\t    const fn = e.target.value;\n78\t    if (fn === \"count\" || fn === \"unique_users\") {\n79\t      setters.setMeasure(fn);\n80\t    } else {\n81\t      // Keep current property or default to first numeric property\n82\t      const prop = measureProp || numericProperties[0] || \"\";\n83\t      setters.setMeasure(`${fn}:${prop}`);\n84\t    }\n85\t  }\n86\t\n87\t  function handlePropertyChange(_: React.SyntheticEvent, value: string | null) {\n88\t    if (value) {\n89\t      setters.setMeasure(`${measureFn}:${value}`);\n90\t    }\n91\t  }\n92\t\n93\t  function handlePreset(days: number) {\n94\t    setters.setStartDate(daysAgoISO(days));\n95\t    setters.setEndDate(todayISO());\n96\t  }\n97\t\n98\t  return (\n99\t    <Box data-testid=\"trends-controls\">\n100\t      <Stack spacing={2}>\n101\t        {/* ── Event name ──────────────────────────────────────────────────── */}\n102\t        <Autocomplete\n103\t          options={eventNames}\n104\t          value={controls.eventName}\n105\t          onChange={(_, value) => setters.setEventName(value)}\n106\t          renderInput={(params) => (\n107\t            <TextField {...params} label=\"Event name\" size=\"small\" />\n108\t          )}\n109\t          sx={{ minWidth: 260 }}\n110\t        />\n111\t\n112\t        {/* ── Measure ─────────────────────────────────────────────────────── */}\n113\t        <Box\n114\t          sx={{\n115\t            display: \"flex\",\n116\t            flexDirection: \"row\",\n117\t            gap: 1,\n118\t            alignItems: \"center\",\n119\t          }}\n120\t        >\n121\t          <FormControl size=\"small\" sx={{ minWidth: 160 }}>\n122\t            <InputLabel id=\"measure-fn-label\">Measure</InputLabel>\n123\t            <Select\n124\t              native\n125\t              labelId=\"measure-fn-label\"\n126\t              label=\"Measure\"\n127\t              value={measureFn}\n128\t              onChange={handleMeasureFnChange}\n129\t            >\n130\t              <option value=\"count\">Count</option>\n131\t              <option value=\"unique_users\">Unique Users</option>\n132\t              <option value=\"sum\">Sum of</option>\n133\t              <option value=\"avg\">Avg of</option>\n134\t              <option value=\"min\">Min of</option>\n135\t              <option value=\"max\">Max of</option>\n136\t            </Select>\n137\t          </FormControl>\n138\t\n139\t          {showPropertySelector && (\n140\t            <Autocomplete\n141\t              options={numericProperties}\n142\t              value={measureProp || null}\n143\t              onChange={handlePropertyChange}\n144\t              renderInput={(params) => (\n145\t                <TextField {...params} label=\"Property\" size=\"small\" />\n146\t              )}\n147\t              sx={{ minWidth: 200 }}\n148\t            />\n149\t          )}\n150\t        </Box>\n151\t\n152\t        {/* ── Granularity ─────────────────────────────────────────────────── */}\n153\t        <Box>\n154\t          <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n155\t            Granularity\n156\t          </Typography>\n157\t          <ToggleButtonGroup\n158\t            exclusive\n159\t            value={controls.granularity}\n160\t            onChange={(_, v: \"day\" | \"week\" | null) => {\n161\t              if (v) setters.setGranularity(v);\n162\t            }}\n163\t            size=\"small\"\n164\t          >\n165\t            <ToggleButton value=\"day\">Day</ToggleButton>\n166\t            <ToggleButton value=\"week\">Week</ToggleButton>\n167\t          </ToggleButtonGroup>\n168\t        </Box>\n169\t\n170\t        {/* ── Date range ──────────────────────────────────────────────────── */}\n171\t        <Box>\n172\t          <Typography variant=\"caption\" color=\"text.secondary\" gutterBottom>\n173\t            Date range\n174\t          </Typography>\n175\t          <Stack direction=\"row\" spacing={1} sx={{ mb: 1 }}>\n176\t            <Chip\n177\t              label=\"Last 7d\"\n178\t              size=\"small\"\n179\t              clickable\n180\t              onClick={() => handlePreset(7)}\n181\t            />\n182\t            <Chip\n183\t              label=\"Last 30d\"\n184\t              size=\"small\"\n185\t              clickable\n186\t              onClick={() => handlePreset(30)}\n187\t            />\n188\t            <Chip\n189\t              label=\"Last 90d\"\n190\t              size=\"small\"\n191\t              clickable\n192\t              onClick={() => handlePreset(90)}\n193\t            />\n194\t          </Stack>\n195\t          <Box sx={{ display: \"flex\", gap: 1 }}>\n196\t            <TextField\n197\t              label=\"Start\"\n198\t              type=\"date\"\n199\t              size=\"small\"\n200\t              value={controls.startDate}\n201\t              onChange={(e) => setters.setStartDate(e.target.value)}\n202\t              slotProps={{ inputLabel: { shrink: true } }}\n203\t            />\n204\t            <TextField\n205\t              label=\"End\"\n206\t              type=\"date\"\n207\t              size=\"small\"\n208\t              value={controls.endDate}\n209\t              onChange={(e) => setters.setEndDate(e.target.value)}\n210\t              slotProps={{ inputLabel: { shrink: true } }}\n211\t            />\n212\t          </Box>\n213\t        </Box>\n214\t\n215\t        {/* ── Breakdown ───────────────────────────────────────────────────── */}\n216\t        <Box\n217\t          sx={{\n218\t            display: \"flex\",\n219\t            flexDirection: \"row\",\n220\t            gap: 1,\n221\t            alignItems: \"center\",\n222\t          }}\n223\t        >\n224\t          <Autocomplete\n225\t            options={\n226\t              controls.eventName\n227\t                ? Object.keys(schema?.properties[controls.eventName] ?? {})\n228\t                : []\n229\t            }\n230\t            value={controls.breakdown}\n231\t            onChange={(_, value) => setters.setBreakdown(value)}\n232\t            renderInput={(params) => (\n233\t              <TextField {...params} label=\"Breakdown by\" size=\"small\" />\n234\t            )}\n235\t            sx={{ minWidth: 200 }}\n236\t          />\n237\t          {controls.breakdown && (\n238\t            <TextField\n239\t              label=\"Limit\"\n240\t              type=\"number\"\n241\t              size=\"small\"\n242\t              value={controls.breakdownLimit}\n243\t              onChange={(e) =>\n244\t                setters.setBreakdownLimit(Number(e.target.value))\n245\t              }\n246\t              sx={{ width: 80 }}\n247\t              slotProps={{ htmlInput: { min: 1, max: 50 } }}\n248\t            />\n249\t          )}\n250\t        </Box>\n251\t      </Stack>\n252\t    </Box>\n253\t  );\n254\t}\n255\t"}]},"parent_tool_use_id":"toolu_01NWeW