{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DqDAafN3mfMd8TG2z4NxFV","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { cleanup, render, screen } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport { TrendsControls } from \"@/components/trends/TrendsControls\";\n5\timport type {\n6\t  UseTrendsControls,\n7\t  UseTrendsSetters,\n8\t} from \"@/components/trends/useTrends\";\n9\t\n10\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n11\t\n12\tfunction makeControls(\n13\t  overrides: Partial<UseTrendsControls> = {},\n14\t): UseTrendsControls {\n15\t  return {\n16\t    eventName: null,\n17\t    measure: \"count\",\n18\t    granularity: \"day\",\n19\t    startDate: \"2026-03-16\",\n20\t    endDate: \"2026-04-15\",\n21\t    breakdown: null,\n22\t    breakdownLimit: 10,\n23\t    ...overrides,\n24\t  };\n25\t}\n26\t\n27\tfunction makeSetters(): UseTrendsSetters {\n28\t  return {\n29\t    setEventName: vi.fn(),\n30\t    setMeasure: vi.fn(),\n31\t    setGranularity: vi.fn(),\n32\t    setStartDate: vi.fn(),\n33\t    setEndDate: vi.fn(),\n34\t    setBreakdown: vi.fn(),\n35\t    setBreakdownLimit: vi.fn(),\n36\t  };\n37\t}\n38\t\n39\tconst sampleSchema = {\n40\t  event_names: [\"Page Viewed\", \"Purchase Completed\"],\n41\t  properties: {\n42\t    \"Purchase Completed\": {\n43\t      amount: \"numeric\" as const,\n44\t      currency: \"string\" as const,\n45\t    },\n46\t  },\n47\t};\n48\t\n49\tafterEach(() => {\n50\t  cleanup();\n51\t  vi.clearAllMocks();\n52\t});\n53\t\n54\t// ─── Tests ────────────────────────────────────────────────────────────────────\n55\t\n56\tdescribe(\"TrendsControls\", () => {\n57\t  describe(\"event name autocomplete\", () => {\n58\t    it(\"renders the event name autocomplete input\", () => {\n59\t      render(\n60\t        <TrendsControls\n61\t          schema={sampleSchema}\n62\t          controls={makeControls()}\n63\t          setters={makeSetters()}\n64\t          numericProperties={[]}\n65\t        />,\n66\t      );\n67\t      // Autocomplete renders a combobox\n68\t      const combos = screen.getAllByRole(\"combobox\");\n69\t      expect(combos.length).toBeGreaterThanOrEqual(1);\n70\t    });\n71\t\n72\t    it(\"renders with provided event names available as options\", () => {\n73\t      render(\n74\t        <TrendsControls\n75\t          schema={sampleSchema}\n76\t          controls={makeControls()}\n77\t          setters={makeSetters()}\n78\t          numericProperties={[]}\n79\t        />,\n80\t      );\n81\t      // Event name autocomplete should be present\n82\t      expect(screen.getAllByRole(\"combobox\").length).toBeGreaterThanOrEqual(1);\n83\t    });\n84\t\n85\t    it(\"renders without crashing when schema is null\", () => {\n86\t      render(\n87\t        <TrendsControls\n88\t          schema={null}\n89\t          controls={makeControls()}\n90\t          setters={makeSetters()}\n91\t          numericProperties={[]}\n92\t        />,\n93\t      );\n94\t      expect(screen.getAllByRole(\"combobox\").length).toBeGreaterThanOrEqual(1);\n95\t    });\n96\t  });\n97\t\n98\t  describe(\"measure selector\", () => {\n99\t    it(\"renders measure options including Count and Unique Users\", () => {\n100\t      render(\n101\t        <TrendsControls\n102\t          schema={sampleSchema}\n103\t          controls={makeControls()}\n104\t          setters={makeSetters()}\n105\t          numericProperties={[]}\n106\t        />,\n107\t      );\n108\t      expect(screen.getByText(\"Count\")).toBeTruthy();\n109\t      expect(screen.getByText(\"Unique Users\")).toBeTruthy();\n110\t    });\n111\t\n112\t    it(\"renders Sum of, Avg of, Min of, Max of measure options\", () => {\n113\t      render(\n114\t        <TrendsControls\n115\t          schema={sampleSchema}\n116\t          controls={makeControls()}\n117\t          setters={makeSetters()}\n118\t          numericProperties={[]}\n119\t        />,\n120\t      );\n121\t      expect(screen.getByText(\"Sum of\")).toBeTruthy();\n122\t      expect(screen.getByText(\"Avg of\")).toBeTruthy();\n123\t      expect(screen.getByText(\"Min of\")).toBeTruthy();\n124\t      expect(screen.getByText(\"Max of\")).toBeTruthy();\n125\t    });\n126\t\n127\t    it(\"does not show the property dropdown when measure is 'count'\", () => {\n128\t      render(\n129\t        <TrendsControls\n130\t          schema={sampleSchema}\n131\t          controls={makeControls({ measure: \"count\" })}\n132\t          setters={makeSetters()}\n133\t          numericProperties={[\"amount\"]}\n134\t        />,\n135\t      );\n136\t      // Property autocomplete should not be present for \"count\"\n137\t      expect(screen.queryByLabelText(\"Property\")).toBeNull();\n138\t      expect(screen.queryByTestId(\"measure-property-select\")).toBeNull();\n139\t    });\n140\t\n141\t    it(\"does not show the property dropdown when measure is 'unique_users'\", () => {\n142\t      render(\n143\t        <TrendsControls\n144\t          schema={sampleSchema}\n145\t          controls={makeControls({ measure: \"unique_users\" })}\n146\t          setters={makeSetters()}\n147\t          numericProperties={[\"amount\"]}\n148\t        />,\n149\t      );\n150\t      expect(screen.queryByLabelText(\"Property\")).toBeNull();\n151\t    });\n152\t\n153\t    it(\"shows property dropdown when measure starts with 'sum:'\", () => {\n154\t      render(\n155\t        <TrendsControls\n156\t          schema={sampleSchema}\n157\t          controls={makeControls({ measure: \"sum:amount\" })}\n158\t          setters={makeSetters()}\n159\t          numericProperties={[\"amount\"]}\n160\t        />,\n161\t      );\n162\t      expect(screen.getByLabelText(\"Property\")).toBeTruthy();\n163\t    });\n164\t\n165\t    it(\"shows property dropdown when measure starts with 'avg:'\", () => {\n166\t      render(\n167\t        <TrendsControls\n168\t          sch