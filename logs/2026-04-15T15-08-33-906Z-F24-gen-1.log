n (\n    <Box data-testid=\"step-builder\">\n      <Stack spacing={1.5}>\n        {steps.map((step, i) => (\n          <Box key={i} sx={{ display: \"flex\", alignItems: \"center\", gap: 1 }}>\n            <Typography\n              variant=\"body2\"\n              color=\"text.secondary\"\n              sx={{ minWidth: 24, textAlign: \"right\" }}\n            >\n              {i + 1}.\n            </Typography>\n            <Autocomplete\n              options={eventNames}\n              value={step || null}\n              onChange={(_, value) => onSetStep(i, value ?? \"\")}\n              renderInput={(params) => (\n                <TextField\n                  {...params}\n                  label={`Step ${i + 1}`}\n                  size=\"small\"\n                  placeholder=\"Select event…\"\n                />\n              )}\n              sx={{ flex: 1, minWidth: 220 }}\n            />\n            <IconButton\n              size=\"small\"\n              aria-label=\"Remove step\"\n              disabled={!canRemove}\n              onClick={() => onRemoveStep(i)}\n            >\n              ✕\n            </IconButton>\n          </Box>\n        ))}\n      </Stack>\n\n      <Box sx={{ mt: 1.5 }}>\n        <Button\n          size=\"small\"\n          variant=\"outlined\"\n          disabled={!canAdd}\n          onClick={onAddStep}\n        >\n          Add Step\n        </Button>\n      </Box>\n    </Box>\n  );\n}\n","structuredPatch":[{"oldStart":34,"oldLines":6,"newStart":34,"newLines":7,"lines":["     <Box data-testid=\"step-builder\">","       <Stack spacing={1.5}>","         {steps.map((step, i) => (","+          // biome-ignore lint/suspicious/noArrayIndexKey: steps are ordered user inputs that may be empty or identical","           <Box key={i} sx={{ display: \"flex\", alignItems: \"center\", gap: 1 }}>","             <Typography","               variant=\"body2\""]}],"userModified":false,"replaceAll":false}}
