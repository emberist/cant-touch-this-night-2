{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JtSY2rGJsTbZUPRFvAAF2f","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQueryFunnel } = vi.hoisted(() => ({\n6\t  mockQueryFunnel: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/funnels\", () => ({\n10\t  queryFunnel: mockQueryFunnel,\n11\t}));\n12\t\n13\timport { POST } from \"@/app/api/funnels/route\";\n14\t\n15\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n16\t\n17\tfunction makeRequest(body: unknown): Request {\n18\t  return new Request(\"http://localhost/api/funnels\", {\n19\t    method: \"POST\",\n20\t    body: JSON.stringify(body),\n21\t    headers: { \"Content-Type\": \"application/json\" },\n22\t  });\n23\t}\n24\t\n25\tfunction makeMalformedRequest(): Request {\n26\t  return new Request(\"http://localhost/api/funnels\", {\n27\t    method: \"POST\",\n28\t    body: \"{ this is not valid json !!!\",\n29\t    headers: { \"Content-Type\": \"application/json\" },\n30\t  });\n31\t}\n32\t\n33\tconst sampleResponse = {\n34\t  steps: [\n35\t    {\n36\t      name: \"Page Viewed\",\n37\t      users: 1000,\n38\t      conversion_from_prev: null,\n39\t      conversion_overall: 1.0,\n40\t    },\n41\t    {\n42\t      name: \"Signup Completed\",\n43\t      users: 320,\n44\t      conversion_from_prev: 0.32,\n45\t      conversion_overall: 0.32,\n46\t    },\n47\t  ],\n48\t};\n49\t\n50\tconst validBody = {\n51\t  steps: [\"Page Viewed\", \"Signup Completed\"],\n52\t  start: \"2026-04-01\",\n53\t  end: \"2026-04-15\",\n54\t};\n55\t\n56\t// ─── Tests ────────────────────────────────────────────────────────────────────\n57\t\n58\tbeforeEach(() => {\n59\t  mockQueryFunnel.mockResolvedValue(sampleResponse);\n60\t});\n61\t\n62\tafterEach(() => {\n63\t  vi.clearAllMocks();\n64\t});\n65\t\n66\tdescribe(\"POST /api/funnels\", () => {\n67\t  describe(\"validation errors — 400\", () => {\n68\t    it(\"returns 400 when body is not valid JSON\", async () => {\n69\t      const res = await POST(makeMalformedRequest());\n70\t\n71\t      expect(res.status).toBe(400);\n72\t      const body = await res.json();\n73\t      expect(body).toHaveProperty(\"error\");\n74\t    });\n75\t\n76\t    it(\"returns 400 when steps is missing\", async () => {\n77\t      const res = await POST(\n78\t        makeRequest({ start: \"2026-04-01\", end: \"2026-04-15\" }),\n79\t      );\n80\t\n81\t      expect(res.status).toBe(400);\n82\t      const body = await res.json();\n83\t      expect(body).toHaveProperty(\"error\");\n84\t    });\n85\t\n86\t    it(\"returns 400 when steps has fewer than 2 entries\", async () => {\n87\t      const res = await POST(\n88\t        makeRequest({\n89\t          steps: [\"Page Viewed\"],\n90\t          start: \"2026-04-01\",\n91\t          end: \"2026-04-15\",\n92\t        }),\n93\t      );\n94\t\n95\t      expect(res.status).toBe(400);\n96\t      const body = await res.json();\n97\t      expect(body).toHaveProperty(\"error\");\n98\t    });\n99\t\n100\t    it(\"returns 400 when steps has more than 5 entries\", async () => {\n101\t      const res = await POST(\n102\t        makeRequest({\n103\t          steps: [\"A\", \"B\", \"C\", \"D\", \"E\", \"F\"],\n104\t          start: \"2026-04-01\",\n105\t          end: \"2026-04-15\",\n106\t        }),\n107\t      );\n108\t\n109\t      expect(res.status).toBe(400);\n110\t      const body = await res.json();\n111\t      expect(body).toHaveProperty(\"error\");\n112\t    });\n113\t\n114\t    it(\"returns 400 when steps contains non-string entries\", async () => {\n115\t      const res = await POST(\n116\t        makeRequest({\n117\t          steps: [\"Page Viewed\", 42],\n118\t          start: \"2026-04-01\",\n119\t          end: \"2026-04-15\",\n120\t        }),\n121\t      );\n122\t\n123\t      expect(res.status).toBe(400);\n124\t      const body = await res.json();\n125\t      expect(body).toHaveProperty(\"error\");\n126\t    });\n127\t\n128\t    it(\"returns 400 when start is missing\", async () => {\n129\t      const res = await POST(\n130\t        makeRequest({\n131\t          steps: [\"Page Viewed\", \"Signup Completed\"],\n132\t          end: \"2026-04-15\",\n133\t        }),\n134\t      );\n135\t\n136\t      expect(res.status).toBe(400);\n137\t      const body = await res.json();\n138\t      expect(body).toHaveProperty(\"error\");\n139\t    });\n140\t\n141\t    it(\"returns 400 when end is missing\", async () => {\n142\t      const res = await POST(\n143\t        makeRequest({\n144\t          steps: [\"Page Viewed\", \"Signup Completed\"],\n145\t          start: \"2026-04-01\",\n146\t        }),\n147\t      );\n148\t\n149\t      expect(res.status).toBe(400);\n150\t      const body = await res.json();\n151\t      expect(body).toHaveProperty(\"error\");\n152\t    });\n153\t  });\n154\t\n155\t  describe(\"success — 200\", () => {\n156\t    it(\"returns 200 with steps array in response body\", async () => {\n157\t      const res = await POST(makeRequest(validBody));\n158\t\n159\t      expect(res.status).toBe(200);\n160\t      const body = await res.json();\n161\t      expect(body).toHaveProperty(\"steps\");\n162\t      expect(Array.isArray(body.steps)).toBe(true);\n163\t    });\n164\t\n165\t    it(\"forwards parsed params correctly to queryFunnel\", async () => {\n166\t      await POST(makeRequest(validBody));\n167\t\n168\t      expect(mockQueryFunnel).toHaveBeenCalledWith({\n169\t        steps: [\"Page Viewed\", \"Signup Completed\"],\n170\t        start: \"2026-04-01\",\n171\t        end: \"2026-04-15\",\n172\t      });\n173\t    });\n174\t  });\n175\t\n176\t  describe(\"error handling — 500\", () => {\n177\t    it(\"returns 500 when queryFunnel throws\", async () => {\n178\t      mockQueryFunnel.mockRejectedValue(\n179\t        new Error(\"ClickHouse connection failed\"),\n180\t      );\n181\t\n182\t      const res = await POST(makeRequest(validBody));\n183\t\n184\t      expect(res.status).toBe(500);\n185\t      const body = await res.json();\n186\t      expect(body).toHaveProperty(\"error\");\n187\t    });\n188\t  });\n189\t});\n190\t"}]},"parent_tool_use_id":"toolu_01NWeW8R45nb4Fb9vjB3jZJX","session_id":"0e7de277-607b-42d2-9d00-d4050492645c","uuid":"7590ecf9-dda9-45f2-ae0f-1fa1fc0d9322","timestamp":"2026-04-15T17:03:15.648Z"}
