le\n          onClick={() => handlePreset(30)}\n        />\n        <Chip\n          label=\"Last 90d\"\n          size=\"small\"\n          clickable\n          onClick={() => handlePreset(90)}\n        />\n      </Stack>\n      <Box sx={{ display: \"flex\", gap: 1 }}>\n        <TextField\n          label=\"Start\"\n          type=\"date\"\n          size=\"small\"\n          value={startDate}\n          onChange={(e) => onStartDateChange(e.target.value)}\n          slotProps={{ inputLabel: { shrink: true } }}\n        />\n        <TextField\n          label=\"End\"\n          type=\"date\"\n          size=\"small\"\n          value={endDate}\n          onChange={(e) => onEndDateChange(e.target.value)}\n          slotProps={{ inputLabel: { shrink: true } }}\n        />\n      </Box>\n    </Box>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":330,"cache_read_input_tokens":74330,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":330},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0e7de277-607b-42d2-9d00-d4050492645c","uuid":"b548c755-669d-410b-97ab-ebb81f8493ca"}
