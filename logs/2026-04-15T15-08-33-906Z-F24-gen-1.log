)\n      .finally(() => {\n        setLoading(false);\n      });\n  }, [steps, startDate, endDate]);\n\n  return {\n    schema,\n    steps,\n    startDate,\n    endDate,\n    addStep,\n    removeStep,\n    setStep,\n    setStartDate,\n    setEndDate,\n    runFunnel,\n    result,\n    loading,\n    error,\n  };\n}\n","structuredPatch":[],"originalFile":null}}
