{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KLmvUp2TDuiVNAPHMny2uy","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport { useCallback, useEffect, useMemo, useState } from \"react\";\n4\timport type { SchemaResponse } from \"@/lib/schema-cache\";\n5\timport type { Series } from \"@/lib/trends\";\n6\t\n7\t// ─── Types ────────────────────────────────────────────────────────────────────\n8\t\n9\texport interface UseTrendsControls {\n10\t  eventName: string | null;\n11\t  measure: string;\n12\t  granularity: \"day\" | \"week\";\n13\t  startDate: string;\n14\t  endDate: string;\n15\t  breakdown: string | null;\n16\t  breakdownLimit: number;\n17\t}\n18\t\n19\texport interface UseTrendsSetters {\n20\t  setEventName: (v: string | null) => void;\n21\t  setMeasure: (v: string) => void;\n22\t  setGranularity: (v: \"day\" | \"week\") => void;\n23\t  setStartDate: (v: string) => void;\n24\t  setEndDate: (v: string) => void;\n25\t  setBreakdown: (v: string | null) => void;\n26\t  setBreakdownLimit: (v: number) => void;\n27\t}\n28\t\n29\texport interface UseTrendsResult {\n30\t  schema: SchemaResponse | null;\n31\t  controls: UseTrendsControls;\n32\t  setters: UseTrendsSetters;\n33\t  series: Series[];\n34\t  numericProperties: string[];\n35\t  loading: boolean;\n36\t  error: string | null;\n37\t}\n38\t\n39\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n40\t\n41\tfunction todayISO(): string {\n42\t  return new Date().toISOString().slice(0, 10);\n43\t}\n44\t\n45\tfunction daysAgoISO(days: number): string {\n46\t  const d = new Date();\n47\t  d.setDate(d.getDate() - days);\n48\t  return d.toISOString().slice(0, 10);\n49\t}\n50\t\n51\t// ─── Hook ─────────────────────────────────────────────────────────────────────\n52\t\n53\texport function useTrends(): UseTrendsResult {\n54\t  const [schema, setSchema] = useState<SchemaResponse | null>(null);\n55\t  const [series, setSeries] = useState<Series[]>([]);\n56\t  const [loading, setLoading] = useState(false);\n57\t  const [error, setError] = useState<string | null>(null);\n58\t\n59\t  // Controls\n60\t  const [eventName, setEventName] = useState<string | null>(null);\n61\t  const [measure, setMeasure] = useState(\"count\");\n62\t  const [granularity, setGranularity] = useState<\"day\" | \"week\">(\"day\");\n63\t  const [startDate, setStartDate] = useState(daysAgoISO(30));\n64\t  const [endDate, setEndDate] = useState(todayISO);\n65\t  const [breakdown, setBreakdown] = useState<string | null>(null);\n66\t  const [breakdownLimit, setBreakdownLimit] = useState(10);\n67\t\n68\t  // Fetch schema once on mount\n69\t  useEffect(() => {\n70\t    setLoading(true);\n71\t    fetch(\"/api/schema\")\n72\t      .then((res) => res.json() as Promise<SchemaResponse>)\n73\t      .then((data) => {\n74\t        setSchema(data);\n75\t      })\n76\t      .catch(() => {\n77\t        // Schema stays null; controls still work\n78\t      })\n79\t      .finally(() => {\n80\t        setLoading(false);\n81\t      });\n82\t  }, []);\n83\t\n84\t  // Fetch trends whenever relevant controls change (only when eventName is set)\n85\t  const fetchTrends = useCallback(\n86\t    (\n87\t      name: string,\n88\t      opts: {\n89\t        measure: string;\n90\t        granularity: \"day\" | \"week\";\n91\t        startDate: string;\n92\t        endDate: string;\n93\t        breakdown: string | null;\n94\t        breakdownLimit: number;\n95\t      },\n96\t    ) => {\n97\t      const url = new URL(\"/api/trends\", window.location.origin);\n98\t      url.searchParams.set(\"event_name\", name);\n99\t      url.searchParams.set(\"measure\", opts.measure);\n100\t      url.searchParams.set(\"granularity\", opts.granularity);\n101\t      url.searchParams.set(\"start\", opts.startDate);\n102\t      url.searchParams.set(\"end\", opts.endDate);\n103\t      if (opts.breakdown) {\n104\t        url.searchParams.set(\"breakdown\", opts.breakdown);\n105\t        url.searchParams.set(\"breakdown_limit\", String(opts.breakdownLimit));\n106\t      }\n107\t\n108\t      setLoading(true);\n109\t      setError(null);\n110\t\n111\t      fetch(url.toString())\n112\t        .then((res) => res.json() as Promise<{ series: Series[] }>)\n113\t        .then((data) => {\n114\t          setSeries(data.series);\n115\t        })\n116\t        .catch((err: unknown) => {\n117\t          setError(err instanceof Error ? err.message : \"Unknown error\");\n118\t          setSeries([]);\n119\t        })\n120\t        .finally(() => {\n121\t          setLoading(false);\n122\t        });\n123\t    },\n124\t    [],\n125\t  );\n126\t\n127\t  useEffect(() => {\n128\t    if (!eventName) return;\n129\t    fetchTrends(eventName, {\n130\t      measure,\n131\t      granularity,\n132\t      startDate,\n133\t      endDate,\n134\t      breakdown,\n135\t      breakdownLimit,\n136\t    });\n137\t  }, [\n138\t    eventName,\n139\t    measure,\n140\t    granularity,\n141\t    startDate,\n142\t    endDate,\n143\t    breakdown,\n144\t    breakdownLimit,\n145\t    fetchTrends,\n146\t  ]);\n147\t\n148\t  // Derive numeric properties for the selected event from the schema\n149\t  const numericProperties = useMemo<string[]>(() => {\n150\t    if (!schema || !eventName) return [];\n151\t    const props = schema.properties[eventName] ?? {};\n152\t    return Object.entries(props)\n153\t      .filter(([, type]) => type === \"numeric\")\n154\t      .map(([name]) => name);\n155\t  }, [schema, eventName]);\n156\t\n157\t  const controls: UseTrendsControls = {\n158\t    eventName,\n159\t    measure,\n160\t    granularity,\n161\t    startDate,\n162\t    endDate,\n163\t    breakdown,\n164\t    breakdownLimit,\n165\t  };\n166\t\n167\t  const setters: UseTrendsSetters = {\n168\t    setEventName,\n169\t    setMeasure,\n170\t    setGranularity,\n171\t    setStartDate,\n172\t    setEndDate,\n173\t    setBreakdown,\n174\t    setBreakdownLimit,\n175\t  };\n176\t\n177\t  return {\n178\t    schema,\n179\t    controls,\n180\t    setters,\n181\t    series,\n182\t    numericProperties,\n183\t    loading,\n184\t    error,\n185\t  };\n186\t}\n187\t"}]},"parent_tool_use_id":null,"session_id":"0e7de277-607b-42d2-9d00-d4050492645c","uuid":"3ddfb21c-2413-4048-a27b-195ed35c91c5","timestamp":"2026-04-15T17:03:54.108Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/trends/useTrends.ts","content":"\"use client\";\n\nimport { useCallback, useEffect, useMemo, useState } from \"react\";\nimport type { SchemaResponse } from \"@/lib/schema-cache\";\nimport type { Series } from \"@/lib/trends\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface UseTrendsControls {\n  eventName: string | null;\n  measure: string;\n  granularity: \"day\" | \"week\";\n  startDate: string;\n  endDate: string;\n  breakdown: string | null;\n  breakdownLimit: number;\n}\n\nexport interface UseTrendsSetters {\n  setEventName: (v: string | null) => void;\n  setMeasure: (v: string) => void;\n  setGranularity: (v: \"day\" | \"week\") => void;\n  setStartDate: (v: string) => void;\n  setEndDate: (v: string) => void;\n  setBreakdown: (v: string | null) => void;\n  setBreakdownLimit: (v: number) => void;\n}\n\nexport interface UseTrendsResult {\n  schema: SchemaResponse | null;\n  controls: UseTrendsControls;\n  setters: UseTrendsSetters;\n  series: Series[];\n  numericProperties: string[];\n  loading: boolean;\n  error: string | null;\n}\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction todayISO(): string {\n  return new Date().toISOString().slice(0, 10);\n}\n\nfunction daysAgoISO(days: number): string {\n  const d = new Date();\n  d.setDate(d.getDate() - days);\n  return d.toISOString().slice(0, 10);\n}\n\n// ─── Hook ─────────────────────────────────────────────────────────────────────\n\nexport function useTrends(): UseTrendsResult {\n  const [schema, setSchema] = useState<SchemaResponse | null>(null);\n  const [series, setSeries] = useState<Series[]>([]);\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n\n  // Controls\n  const [eventName, setEventName] = useState<string | null>(null);\n  const [measure, setMeasure] = useState(\"count\");\n  const [granularity, setGranularity] = useState<\"day\" | \"week\">(\"day\");\n  const [startDate, setStartDate] = useState(daysAgoISO(30));\n  const [endDate, setEndDate] = useState(todayISO);\n  const [breakdown, setBreakdown] = useState<string | null>(null);\n  const [breakdownLimit, setBreakdownLimit] = useState(10);\n\n  // Fetch schema once on mount\n  useEffect(() => {\n    setLoading(true);\n    fetch(\"/api/schema\")\n      .then((res) => res.json() as Promise<SchemaResponse>)\n      .then((data) => {\n        setSchema(data);\n      })\n      .catch(() => {\n        // Schema stays null; controls still work\n      })\n      .finally(() => {\n        setLoading(false);\n      });\n  }, []);\n\n  // Fetch trends whenever relevant controls change (only when eventName is set)\n  const fetchTrends = useCallback(\n    (\n      name: string,\n      opts: {\n        measure: string;\n        granularity: \"day\" | \"week\";\n        startDate: string;\n        endDate: string;\n        breakdown: string | null;\n        breakdownLimit: number;\n      },\n    ) => {\n      const url = new URL(\"/api/trends\", window.location.origin);\n      url.searchParams.set(\"event_name\", name);\n      url.searchParams.set(\"measure\", opts.measure);\n      url.searchParams.set(\"granularity\", opts.granularity);\n      url.searchParams.set(\"start\", opts.startDate);\n      url.searchParams.set(\"end\", opts.endDate);\n      if (opts.breakdown) {\n        url.searchParams.set(\"breakdown\", opts.breakdown);\n        url.searchParams.set(\"breakdown_limit\", String(opts.breakdownLimit));\n      }\n\n      setLoading(true);\n      setError(null);\n\n      fetch(url.toString())\n        .then((res) => res.json() as Promise<{ series: Series[] }>)\n        .then((data) => {\n          setSeries(data.series);\n        })\n        .catch((err: unknown) => {\n          setError(err instanceof Error ? err.message : \"Unknown error\");\n          setSeries([]);\n        })\n        .finally(() => {\n          setLoading(false);\n        });\n    },\n    [],\n  );\n\n  useEffect(() => {\n    if (!eventName) return;\n    fetchTrends(eventName, {\n      measure,\n      granularity,\n      startDate,\n      endDate,\n      breakdown,\n      breakdownLimit,\n    });\n  }, [\n    eventName,\n    measure,\n    granularity,\n    startDate,\n    endDate,\n    breakdown,\n    breakdownLimit,\n    fetchTrends,\n  ]);\n\n  // Derive numeric properties for the selected event from the schema\n  const numericProperties = useMemo<string[]>(() => {\n    if (!schema || !eventName) return [];\n    const props = schema.properties[eventName] ?? {};\n    return Object.entries(props)\n      .filter(([, type]) => type === \"numeric\")\n      .map(([name]) => name);\n  }, [schema, eventName]);\n\n  const controls: UseTrendsControls = {\n    eventName,\n    measure,\n    granularity,\n    startDate,\n    endDate,\n    breakdown,\n    breakdownLimit,\n  };\n\n  const setters: UseTrendsSetters = {\n    setEventName,\n    setMeasure,\n    setGranularity,\n    setStartDate,\n    setEndDate,\n    setBreakdown,\n    setBreakdownLimit,\n  };\n\n  return {\n    schema,\n    controls,\n    setters,\n    series,\n    numericProperties,\n    loading,\n    error,\n  };\n}\n","numLines":187,"startLine":1,"totalLines":187}}}
