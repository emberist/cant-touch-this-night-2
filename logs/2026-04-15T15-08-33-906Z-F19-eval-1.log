");\n56\t    });\n57\t\n58\t    it(\"returns numeric values (not strings) for total_events and total_users\", async () => {\n59\t      const res = await GET();\n60\t\n61\t      const body = await res.json();\n62\t      expect(typeof body.total_events).toBe(\"number\");\n63\t      expect(typeof body.total_users).toBe(\"number\");\n64\t    });\n65\t\n66\t    it(\"converts ClickHouse string counts to correct numeric values\", async () => {\n67\t      const res = await GET();\n68\t\n69\t      const body = await res.json();\n70\t      expect(body.total_events).toBe(12000);\n71\t      expect(body.total_users).toBe(60);\n72\t    });\n73\t\n74\t    it(\"top_event_7d contains name (string) and count (number) when events exist\", async () => {\n75\t      const res = await GET();\n76\t\n77\t      const body = await res.json();\n78\t      expect(body.top_event_7d).not.toBeNull();\n79\t      expect(typeof body.top_event_7d.name).toBe(\"string\");\n80\t      expect(typeof body.top_event_7d.count).toBe(\"number\");\n81\t      expect(body.top_event_7d.name).toBe(\"Page Viewed\");\n82\t      expect(body.top_event_7d.count).toBe(4800);\n83\t    });\n84\t\n85\t    it(\"returns top_event_7d: null when no events exist in the last 7 days\", async () => {\n86\t      mockQuery.mockReset();\n87\t      mockQuery\n88\t        .mockResolvedValueOnce(makeCountResult(\"500\"))\n89\t        .mockResolvedValueOnce(makeCountResult(\"10\"))\n90\t        .mockResolvedValueOnce(makeTopEventResult([]));\n91\t\n92\t      const res = await GET();\n93\t\n94\t      expect(res.status).toBe(200);\n95\t      const body = await res.json();\n96\t      expect(body.top_event_7d).toBeNull();\n97\t    });\n98\t\n99\t    it(\"returns 0 for events and users when database is empty\", async () => {\n100\t      mockQuery.mockReset();\n101\t      mockQuery\n102\t        .mockResolvedValueOnce(makeCountResult(\"0\"))\n103\t        .mockResolvedValueOnce(makeCountResult(\"0\"))\n104\t        .mockResolvedValueOnce(makeTopEventResult([]));\n105\t\n106\t      const res = await GET();\n107\t\n108\t      expect(res.status).toBe(200);\n109\t      const body = await res.json();\n110\t      expect(body.total_events).toBe(0);\n111\t      expect(body.total_users).toBe(0);\n112\t      expect(body.top_event_7d).toBeNull();\n113\t    });\n114\t  });\n115\t\n116\t  describe(\"failure — 500\", () => {\n117\t    it(\"returns 500 with error message when ClickHouse query throws\", async () => {\n118\t      mockQuery.mockReset();\n119\t      mockQuery.mockRejectedValue(new Error(\"Connection refused\"));\n120\t\n121\t      const res = await GET();\n122\t\n123\t      expect(res.status).toBe(500);\n124\t      const body = await res.json();\n125\t      expect(body).toHaveProperty(\"error\");\n126\t      expect(body.error).toBe(\"Connection refused\");\n127\t    });\n128\t\n129\t    it(\"returns 500 with generic message for non-Error rejections\", async () => {\n130\t      mockQuery.mockReset();\n131\t      mockQuery.mockRejectedValue(\"unknown failure\");\n132\t\n133\t      const res = await GET();\n134\t\n135\t      expect(res.status).toBe(500);\n136\t      const body = await res.json();\n137\t      expect(body).toHaveProperty(\"error\");\n138\t      expect(body.error).toBe(\"Internal server error.\");\n139\t    });\n140\t  });\n141\t});\n142\t"}]},"parent_tool_use_id":null,"session_id":"c7974e27-f605-41f0-a94b-912f324b8c86","uuid":"caa6b546-5d8a-4581-9cc7-86f4270aed49","timestamp":"2026-04-15T16:21:33.758Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/dashboard/__tests__/route.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockQuery } = vi.hoisted(() => ({\n  mockQuery: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    query: mockQuery,\n  },\n}));\n\nimport { GET } from \"@/app/api/dashboard/route\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction makeCountResult(cnt: string): {\n  json: () => Promise<{ cnt: string }[]>;\n} {\n  return { json: () => Promise.resolve([{ cnt }]) };\n}\n\nfunction makeTopEventResult(rows: { event_name: string; cnt: string }[]): {\n  json: () => Promise<{ event_name: string; cnt: string }[]>;\n} {\n  return { json: () => Promise.resolve(rows) };\n}\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockQuery\n    .mockResolvedValueOnce(makeCountResult(\"12000\"))\n    .mockResolvedValueOnce(makeCountResult(\"60\"))\n    .mockResolvedValueOnce(\n      makeTopEventResult([{ event_name: \"Page Viewed\", cnt: \"4800\" }]),\n    );\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\ndescribe(\"GET /api/dashboard\", () => {\n  describe(\"success — 200\", () => {\n    it(\"returns 200 with total_events, total_users, and top_event_7d fields\", async () => {\n      const res = await GET();\n\n      expect(res.status).toBe(200);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"total_events\");\n      expect(body).toHaveProperty(\"total_users\");\n      expect(body).toHaveProperty(\"top_event_7d\");\n    });\n\n    it(\"returns numeric values (not strings) for total_events and total_users\", async () => {\n      const res = await GET();\n\n      const body = await res.json();\n      expect(typeof body.total_events).toBe(\"number\");\n      expect(typeof body.total_users).toBe(\"number\");\n    });\n\n    it(\"converts ClickHouse string counts to correct numeric values\", async () => {\n      const res = await GET();\n\n      const body = await res.json();\n      expect(body.total_events).toBe(12000);\n      expect(body.total_users).toBe(60);\n    });\n\n    it(\"top_event_7d contains name (string) and count (number) when events exist\", async () => {\n      const res = await GET();\n\n      const body = await res.json();\n      expect(body.top_event_7d).not.toBeNull();\n      expect(typeof body.top_event_7d.name).toBe(\"string\");\n      expect(typeof body.top_event_7d.count).toBe(\"number\");\n      expect(body.top_event_7d.name).toBe(\"Page Viewed\");\n      expect(body.top_event_7d.count).toBe(4800);\n    });\n\n    it(\"returns top_event_7d: null when no events exist in the last 7 days\", async () => {\n      mockQuery.mockReset();\n      mockQuery\n        .mockResolvedValueOnce(makeCountResult(\"500\"))\n        .mockResolvedValueOnce(makeCountResult(\"10\"))\n        .mockResolvedValueOnce(makeTopEventResult([]));\n\n      const res = await GET();\n\n      expect(res.status).toBe(200);\n      const body = await res.json();\n      expect(body.top_event_7d).toBeNull();\n    });\n\n    it(\"returns 0 for events and users when database is empty\", async () => {\n      mockQuery.mockReset();\n      mockQuery\n        .mockResolvedValueOnce(makeCountResult(\"0\"))\n        .mockResolvedValueOnce(makeCountResult(\"0\"))\n        .mockResolvedValueOnce(makeTopEventResult([]));\n\n      const res = await GET();\n\n      expect(res.status).toBe(200);\n      const body = await res.json();\n      expect(body.total_events).toBe(0);\n      expect(body.total_users).toBe(0);\n      expect(body.top_event_7d).toBeNull();\n    });\n  });\n\n  describe(\"failure — 500\", () => {\n    it(\"returns 500 with error message when ClickHouse query throws\", async () => {\n      mockQuery.mockReset();\n      mockQuery.mockRejectedValue(new Error(\"Connection refused\"));\n\n      const res = await GET();\n\n      expect(res.status).toBe(500);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n      expect(body.error).toBe(\"Connection refused\");\n    });\n\n    it(\"returns 500 with generic message for non-Error rejections\", async () => {\n      mockQuery.mockReset();\n      mockQuery.mockRejectedValue(\"unknown failure\");\n\n      const res = await GET();\n\n      expect(res.status).toBe(500);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n      expect(body.error).toBe(\"Internal server error.\");\n    });\n  });\n});\n","numLines":142,"startLine":1,"totalLines":142}}}
