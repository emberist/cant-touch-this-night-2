orEl}\n        onClose={() => setAnchorEl(null)}\n        anchorOrigin={{ vertical: \"bottom\", horizontal: \"left\" }}\n      >\n        <Box p={2}>\n          <Typography\n            component=\"pre\"\n            variant=\"body2\"\n            sx={{ fontFamily: \"monospace\", whiteSpace: \"pre-wrap\", m: 0 }}\n          >\n            {JSON.stringify(parsed, null, 2)}\n          </Typography>\n        </Box>\n      </Popover>\n    </>\n  );\n}\n","structuredPatch":[{"oldStart":48,"oldLines":7,"newStart":48,"newLines":7,"lines":["         onClose={() => setAnchorEl(null)}","         anchorOrigin={{ vertical: \"bottom\", horizontal: \"left\" }}","       >","-        <Box p={2}>","+        <Box sx={{ p: 2 }}>","           <Typography","             component=\"pre\"","             variant=\"body2\""]}],"userModified":false,"replaceAll":false}}
