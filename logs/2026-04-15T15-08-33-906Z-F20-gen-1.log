{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DvQGwbvM4Avu1Jq6G84osw","type":"tool_result","content":"1\timport { afterEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\tconst mockClient = {\n4\t  query: vi.fn(),\n5\t  insert: vi.fn(),\n6\t  command: vi.fn(),\n7\t  exec: vi.fn(),\n8\t  ping: vi.fn(),\n9\t  close: vi.fn(),\n10\t};\n11\t\n12\tconst mockCreateClient = vi.fn(() => mockClient);\n13\t\n14\tvi.mock(\"@clickhouse/client\", () => ({\n15\t  createClient: mockCreateClient,\n16\t}));\n17\t\n18\tdescribe(\"clickhouse singleton\", () => {\n19\t  afterEach(() => {\n20\t    vi.resetModules();\n21\t    mockCreateClient.mockClear();\n22\t  });\n23\t\n24\t  it(\"exports a defined clickhouse client\", async () => {\n25\t    const { clickhouse } = await import(\"@/lib/clickhouse\");\n26\t    expect(clickhouse).toBeDefined();\n27\t    expect(clickhouse).not.toBeNull();\n28\t  });\n29\t\n30\t  it(\"client has a query method\", async () => {\n31\t    const { clickhouse } = await import(\"@/lib/clickhouse\");\n32\t    expect(typeof clickhouse.query).toBe(\"function\");\n33\t  });\n34\t\n35\t  it(\"is a singleton — same instance on multiple imports within the same module load\", async () => {\n36\t    const { clickhouse: a } = await import(\"@/lib/clickhouse\");\n37\t    const { clickhouse: b } = await import(\"@/lib/clickhouse\");\n38\t    expect(a).toBe(b);\n39\t    expect(mockCreateClient).toHaveBeenCalledTimes(1);\n40\t  });\n41\t\n42\t  it(\"uses default values when env vars are absent\", async () => {\n43\t    const savedURL = process.env.CLICKHOUSE_URL;\n44\t    const savedDB = process.env.CLICKHOUSE_DB;\n45\t    const savedPW = process.env.CLICKHOUSE_PASSWORD;\n46\t    delete process.env.CLICKHOUSE_URL;\n47\t    delete process.env.CLICKHOUSE_DB;\n48\t    delete process.env.CLICKHOUSE_PASSWORD;\n49\t\n50\t    await import(\"@/lib/clickhouse\");\n51\t\n52\t    expect(mockCreateClient).toHaveBeenCalledWith({\n53\t      url: \"http://localhost:8123\",\n54\t      database: \"minipanel\",\n55\t      password: \"password\",\n56\t    });\n57\t\n58\t    if (savedURL !== undefined) process.env.CLICKHOUSE_URL = savedURL;\n59\t    if (savedDB !== undefined) process.env.CLICKHOUSE_DB = savedDB;\n60\t    if (savedPW !== undefined) process.env.CLICKHOUSE_PASSWORD = savedPW;\n61\t  });\n62\t\n63\t  it(\"reads custom values from env vars\", async () => {\n64\t    process.env.CLICKHOUSE_URL = \"http://custom-host:9000\";\n65\t    process.env.CLICKHOUSE_DB = \"custom_db\";\n66\t    process.env.CLICKHOUSE_PASSWORD = \"secret\";\n67\t\n68\t    await import(\"@/lib/clickhouse\");\n69\t\n70\t    expect(mockCreateClient).toHaveBeenCalledWith({\n71\t      url: \"http://custom-host:9000\",\n72\t      database: \"custom_db\",\n73\t      password: \"secret\",\n74\t    });\n75\t\n76\t    delete process.env.CLICKHOUSE_URL;\n77\t    delete process.env.CLICKHOUSE_DB;\n78\t    delete process.env.CLICKHOUSE_PASSWORD;\n79\t  });\n80\t});\n81\t"}]},"parent_tool_use_id":"toolu_01AEP6Kji4awJF9zuKzcU4yt","session_id":"b55bde5a-8012-4aca-b30e-7084df65edbe","uuid":"2c8dd0c5-5120-4361-a631-1cc8806fa2be","timestamp":"2026-04-15T16:25:04.344Z"}
