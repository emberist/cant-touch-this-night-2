    <TableHead>\n          <TableRow>\n            <TableCell>Timestamp</TableCell>\n            <TableCell>Event Name</TableCell>\n            <TableCell>Resolved Identity</TableCell>\n            <TableCell>Properties</TableCell>\n          </TableRow>\n        </TableHead>\n        <TableBody>\n          {events.map((event) => (\n            <TableRow key={event.event_id}>\n              <TableCell sx={{ whiteSpace: \"nowrap\" }}>\n                {new Date(event.timestamp).toLocaleString()}\n              </TableCell>\n              <TableCell>{event.event_name}</TableCell>\n              <TableCell>\n                <IdentityChip resolved_id={event.resolved_id} />\n              </TableCell>\n              <TableCell>\n                <JsonChip properties={event.properties} />\n              </TableCell>\n            </TableRow>\n          ))}\n          {loading && (\n            <TableRow>\n              <TableCell colSpan={4}>\n                <Skeleton variant=\"rectangular\" height={36} />\n              </TableCell>\n            </TableRow>\n          )}\n          {hasMore && !loading && (\n            <TableRow ref={sentinelRef} aria-hidden=\"true\">\n              <TableCell colSpan={4} sx={{ p: 0, border: 0 }} />\n            </TableRow>\n          )}\n        </TableBody>\n      </Table>\n    </TableContainer>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":431,"cache_read_input_tokens":76110,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":431},"output_tokens":69,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b55bde5a-8012-4aca-b30e-7084df65edbe","uuid":"13174dcd-3651-410e-8a63-6c09d3ff1f17"}
