 null, 2)}\n          </Typography>\n        </Box>\n      </Popover>\n    </>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":166,"cache_read_input_tokens":74865,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":166},"output_tokens":67,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b55bde5a-8012-4aca-b30e-7084df65edbe","uuid":"9586540f-b98f-4f94-a882-438413c69f89"}
