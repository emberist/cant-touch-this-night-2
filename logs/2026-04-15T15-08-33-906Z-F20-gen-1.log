not show the full stringified JSON in preview\n      expect(text).not.toContain('\"page\":\"/home\"');\n    });\n\n    it(\"chip preview includes the first key name\", () => {\n      render(<JsonChip properties='{\"amount\":49.99,\"currency\":\"USD\"}' />);\n      const chip = screen.getByRole(\"button\");\n      expect(chip.textContent).toContain(\"amount\");\n    });\n\n    it(\"does not render 'No properties' when properties are present\", () => {\n      render(<JsonChip properties='{\"x\":1}' />);\n      expect(screen.queryByText(\"No properties\")).toBeNull();\n    });\n  });\n\n  describe(\"expansion\", () => {\n    it(\"clicking the chip reveals the full JSON content\", () => {\n      render(<JsonChip properties='{\"page\":\"/home\",\"user\":\"alice\"}' />);\n      const chip = screen.getByRole(\"button\");\n      fireEvent.click(chip);\n      // After expansion, the formatted JSON should be visible in the document\n      const expanded = screen.getByText(/\\/home/);\n      expect(expanded).toBeTruthy();\n    });\n\n    it(\"full JSON is not visible before clicking\", () => {\n      render(<JsonChip properties='{\"secretKey\":\"hunter2\"}' />);\n      expect(screen.queryByText(/hunter2/)).toBeNull();\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01GHHG1ZW64SR3yhzbJDiMyS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01CZx8REtAbJACJfwgms9UZ5","name":"Write","input":{"file_path":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/ui/__tests__/IdentityChip.test.tsx","content":"// @vitest-environment jsdom\nimport { render, screen } from \"@testing-library/react\";\nimport { afterEach, describe, expect, it, vi } from \"vitest\";\n\n// Mock next/link to avoid Next.js router context requirement in tests\nvi.mock(\"next/link\", () => ({\n  default: ({\n    children,\n    href,\n    style,\n  }: {\n    children: React.ReactNode;\n    href: string;\n    style?: React.CSSProperties;\n  }) => (\n    <a href={href} style={style}>\n      {children}\n    </a>\n  ),\n}));\n\nimport { IdentityChip } from \"@/components/ui/IdentityChip\";\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\ndescribe(\"IdentityChip\", () => {\n  it(\"renders the resolved_id text\", () => {\n    render(<IdentityChip resolved_id=\"user@test.com\" />);\n    expect(screen.getByText(\"user@test.com\")).toBeTruthy();\n  });\n\n  it(\"wraps content in a link element\", () => {\n    render(<IdentityChip resolved_id=\"user@test.com\" />);\n    const link = screen.getByRole(\"link\");\n    expect(link).toBeTruthy();\n  });\n\n  it(\"links to /users/[percent-encoded id]\", () => {\n    render(<IdentityChip resolved_id=\"user@test.com\" />);\n    const link = screen.getByRole(\"link\");\n    // @ must be percent-encoded\n    expect(link.getAttribute(\"href\")).toBe(\n      `/users/${encodeURIComponent(\"user@test.com\")}`,\n    );\n  });\n\n  it(\"handles special characters in resolved_id (URL encoding)\", () => {\n    const id = \"user+special@example.com/path?q=1\";\n    render(<IdentityChip resolved_id={id} />);\n    const link = screen.getByRole(\"link\");\n    expect(link.getAttribute(\"href\")).toBe(`/users/${encodeURIComponent(id)}`);\n  });\n\n  it(\"renders the resolved_id as the chip label\", () => {\n    const id = \"device-abc-123\";\n    render(<IdentityChip resolved_id={id} />);\n    expect(screen.getByText(id)).toBeTruthy();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":918,"cache_read_input_tokens":70277,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":918},"output_tokens":69,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b55bde5a-8012-4aca-b30e-7084df65edbe","uuid":"d84731cc-ea2d-4f0e-a8a0-ea9301e210a9"}
