{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SMjTFJrcU3vZbnZqvvqre3","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQuery } = vi.hoisted(() => ({\n6\t  mockQuery: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: {\n11\t    query: mockQuery,\n12\t  },\n13\t}));\n14\t\n15\timport { getUserProfile, searchUsers } from \"@/lib/users\";\n16\t\n17\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n18\t\n19\tfunction mockQueryReturns(rows: unknown[]) {\n20\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n21\t}\n22\t\n23\tconst sampleUser = {\n24\t  resolved_id: \"user@test.com\",\n25\t  first_seen: \"2026-04-01T00:00:00.000Z\",\n26\t  last_seen: \"2026-04-15T00:00:00.000Z\",\n27\t  event_count: 42,\n28\t};\n29\t\n30\tconst sampleEvent = {\n31\t  event_id: \"uuid-1\",\n32\t  event_name: \"Page Viewed\",\n33\t  timestamp: \"2026-04-15T10:00:00.000Z\",\n34\t  device_id: \"dev-1\",\n35\t  user_id: null,\n36\t  properties: \"{}\",\n37\t  ingested_at: \"2026-04-15T10:00:00.100Z\",\n38\t  resolved_id: \"user@test.com\",\n39\t};\n40\t\n41\t// ─── Tests ────────────────────────────────────────────────────────────────────\n42\t\n43\tbeforeEach(() => {\n44\t  mockQueryReturns([]);\n45\t});\n46\t\n47\tafterEach(() => {\n48\t  vi.clearAllMocks();\n49\t});\n50\t\n51\t// ─── searchUsers ──────────────────────────────────────────────────────────────\n52\t\n53\tdescribe(\"searchUsers\", () => {\n54\t  it(\"returns users list with resolved_id, first_seen, last_seen, event_count\", async () => {\n55\t    mockQueryReturns([sampleUser]);\n56\t\n57\t    const result = await searchUsers({});\n58\t\n59\t    expect(result.users).toHaveLength(1);\n60\t    expect(result.users[0]).toMatchObject({\n61\t      resolved_id: \"user@test.com\",\n62\t      first_seen: \"2026-04-01T00:00:00.000Z\",\n63\t      last_seen: \"2026-04-15T00:00:00.000Z\",\n64\t      event_count: 42,\n65\t    });\n66\t  });\n67\t\n68\t  it(\"applies q filter (generates ILIKE condition in query)\", async () => {\n69\t    mockQueryReturns([]);\n70\t\n71\t    await searchUsers({ q: \"john\" });\n72\t\n73\t    const callArgs = mockQuery.mock.calls[0][0];\n74\t    expect(callArgs.query).toContain(\"ILIKE\");\n75\t    expect(callArgs.query_params.q).toBe(\"%john%\");\n76\t  });\n77\t\n78\t  it(\"respects limit parameter, caps at 200\", async () => {\n79\t    mockQueryReturns([]);\n80\t\n81\t    await searchUsers({ limit: 500 });\n82\t\n83\t    const callArgs = mockQuery.mock.calls[0][0];\n84\t    expect(Number(callArgs.query_params.limit)).toBe(200);\n85\t  });\n86\t\n87\t  it(\"applies cursor for pagination (generates condition in query)\", async () => {\n88\t    mockQueryReturns([]);\n89\t\n90\t    await searchUsers({ cursor: \"user@abc.com\" });\n91\t\n92\t    const callArgs = mockQuery.mock.calls[0][0];\n93\t    expect(callArgs.query).toContain(\"{cursor:String}\");\n94\t    expect(callArgs.query_params.cursor).toBe(\"user@abc.com\");\n95\t  });\n96\t\n97\t  it(\"returns next_cursor when result count equals limit\", async () => {\n98\t    const rows = [\n99\t      { ...sampleUser, resolved_id: \"a@test.com\" },\n100\t      { ...sampleUser, resolved_id: \"b@test.com\" },\n101\t    ];\n102\t    mockQueryReturns(rows);\n103\t\n104\t    const result = await searchUsers({ limit: 2 });\n105\t\n106\t    expect(result.next_cursor).toBe(\"b@test.com\");\n107\t  });\n108\t\n109\t  it(\"returns null next_cursor when result count is less than limit\", async () => {\n110\t    mockQueryReturns([sampleUser]);\n111\t\n112\t    const result = await searchUsers({ limit: 10 });\n113\t\n114\t    expect(result.next_cursor).toBeNull();\n115\t  });\n116\t\n117\t  it(\"returns empty array when no results\", async () => {\n118\t    mockQueryReturns([]);\n119\t\n120\t    const result = await searchUsers({});\n121\t\n122\t    expect(result.users).toEqual([]);\n123\t    expect(result.next_cursor).toBeNull();\n124\t  });\n125\t});\n126\t\n127\t// ─── getUserProfile ────────────────────────────────────────────────────────────\n128\t\n129\tdescribe(\"getUserProfile\", () => {\n130\t  it(\"returns profile with resolved_id, first_seen, last_seen, identity_cluster, events\", async () => {\n131\t    mockQuery\n132\t      .mockResolvedValueOnce({\n133\t        json: vi.fn().mockResolvedValue([\n134\t          {\n135\t            event_count: 5,\n136\t            first_seen: \"2026-04-01T00:00:00.000Z\",\n137\t            last_seen: \"2026-04-15T00:00:00.000Z\",\n138\t          },\n139\t        ]),\n140\t      })\n141\t      .mockResolvedValueOnce({\n142\t        json: vi\n143\t          .fn()\n144\t          .mockResolvedValue([\n145\t            { user_id: \"user@test.com\", device_id: \"dev-1\" },\n146\t          ]),\n147\t      })\n148\t      .mockResolvedValueOnce({\n149\t        json: vi.fn().mockResolvedValue([sampleEvent]),\n150\t      });\n151\t\n152\t    const result = await getUserProfile(\"user@test.com\");\n153\t\n154\t    expect(result).not.toBeNull();\n155\t    expect(result?.resolved_id).toBe(\"user@test.com\");\n156\t    expect(result?.first_seen).toBe(\"2026-04-01T00:00:00.000Z\");\n157\t    expect(result?.last_seen).toBe(\"2026-04-15T00:00:00.000Z\");\n158\t    expect(result?.identity_cluster).toBeDefined();\n159\t    expect(result?.events).toEqual([sampleEvent]);\n160\t  });\n161\t\n162\t  it(\"identity_cluster includes all associated user_ids and device_ids\", async () => {\n163\t    mockQuery\n164\t      .mockResolvedValueOnce({\n165\t        json: vi.fn().mockResolvedValue([\n166\t          {\n167\t            event_count: 3,\n168\t            first_seen: \"2026-04-01T00:00:00.000Z\",\n169\t            last_seen: \"2026-04-15T00:00:00.000Z\",\n170\t          },\n171\t        ]),\n172\t      })\n173\t      .mockResolvedValueOnce({\n174\t        json: vi.fn().mockResolvedValue([\n175\t          { user_id: \"user@test.com\", device_id: \"dev-1\" },\n176\t          { user_id: \"user@test.com\", device_id: \"dev-2\" },\n177\t          { user_id: null, device_id: \"dev-3\" },\n178\t        ]),\n179\t      })\n180\t      .mockResolvedValueOnce({\n181\t        json: vi.fn().mockResolvedValue([]),\n182\t      });\n183\t\n184\t    const result = await getUserProfile(\"user@test.com\");\n185\t\n186\t    expect(result?.identity_cluster.user_ids).toEqual([\"user@test.com\"]);\n187\t    expect(result?.identity_cluster.device_ids).toHaveLength(3);\n188\t    expect(result?.identity_cluster.device_ids).toContain(\"dev-1\");\n189\t    expect(result?.identity_cluster.device_ids).toContain(\"dev-2\");\n190\t    expect(result?.identity_cluster.device_ids).toContain(\"dev-3\");\n191\t  });\n192\t\n193\t  it(\"returns null when resolved_id not found\", async () => {\n194\t    // ClickHouse returns epoch for min(DateTime64) on empty set, not NULL.\n195\t    // We detect \"not found\" via event_count === 0.\n196\t    mockQuery.mockResolvedValueOnce({\n197\t      json: vi.fn().mockResolvedValue([\n198\t        {\n199\t          event_count: 0,\n200\t          first_seen: \"1970-01-01 00:00:00.000\",\n201\t          last_seen: \"1970-01-01 00:00:00.000\",\n202\t        },\n203\t      ]),\n204\t    });\n205\t\n206\t    const result = await getUserProfile(\"nonexistent@test.com\");\n207\t\n208\t    expect(result).toBeNull();\n209\t  });\n210\t});\n211\t"}]},"parent_tool_use_id":null,"session_id":"88b78d0f-2f5f-427a-9042-5c6a4a6b43d4","uuid":"4456f861-dac8-462d-9a6e-b8019050d6ba","timestamp":"2026-04-15T14:18:19.927Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/users.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockQuery } = vi.hoisted(() => ({\n  mockQuery: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    query: mockQuery,\n  },\n}));\n\nimport { getUserProfile, searchUsers } from \"@/lib/users\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction mockQueryReturns(rows: unknown[]) {\n  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n}\n\nconst sampleUser = {\n  resolved_id: \"user@test.com\",\n  first_seen: \"2026-04-01T00:00:00.000Z\",\n  last_seen: \"2026-04-15T00:00:00.000Z\",\n  event_count: 42,\n};\n\nconst sampleEvent = {\n  event_id: \"uuid-1\",\n  event_name: \"Page Viewed\",\n  timestamp: \"2026-04-15T10:00:00.000Z\",\n  device_id: \"dev-1\",\n  user_id: null,\n  properties: \"{}\",\n  ingested_at: \"2026-04-15T10:00:00.100Z\",\n  resolved_id: \"user@test.com\",\n};\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockQueryReturns([]);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\n// ─── searchUsers ──────────────────────────────────────────────────────────────\n\ndescribe(\"searchUsers\", () => {\n  it(\"returns users list with resolved_id, first_seen, last_seen, event_count\", async () => {\n    mockQueryReturns([sampleUser]);\n\n    const result = await searchUsers({});\n\n    expect(result.users).toHaveLength(1);\n    expect(result.users[0]).toMatchObject({\n      resolved_id: \"user@test.com\",\n      first_seen: \"2026-04-01T00:00:00.000Z\",\n      last_seen: \"2026-04-15T00:00:00.000Z\",\n      event_count: 42,\n    });\n  });\n\n  it(\"applies q filter (generates ILIKE condition in query)\", async () => {\n    mockQueryReturns([]);\n\n    await searchUsers({ q: \"john\" });\n\n    const callArgs = mockQuery.mock.calls[0][0];\n    expect(callArgs.query).toContain(\"ILIKE\");\n    expect(callArgs.query_params.q).toBe(\"%john%\");\n  });\n\n  it(\"respects limit parameter, caps at 200\", async () => {\n    mockQueryReturns([]);\n\n    await searchUsers({ limit: 500 });\n\n    const callArgs = mockQuery.mock.calls[0][0];\n    expect(Number(callArgs.query_params.limit)).toBe(200);\n  });\n\n  it(\"applies cursor for pagination (generates condition in query)\", async () => {\n    mockQueryReturns([]);\n\n    await searchUsers({ cursor: \"user@abc.com\" });\n\n    const callArgs = mockQuery.mock.calls[0][0];\n    expect(callArgs.query).toContain(\"{cursor:String}\");\n    expect(callArgs.query_params.cursor).toBe(\"user@abc.com\");\n  });\n\n  it(\"returns next_cursor when result count equals limit\", async () => {\n    const rows = [\n      { ...sampleUser, resolved_id: \"a@test.com\" },\n      { ...sampleUser, resolved_id: \"b@test.com\" },\n    ];\n    mockQueryReturns(rows);\n\n    const result = await searchUsers({ limit: 2 });\n\n    expect(result.next_cursor).toBe(\"b@test.com\");\n  });\n\n  it(\"returns null next_cursor when result count is less than limit\", async () => {\n    mockQueryReturns([sampleUser]);\n\n    const result = await searchUsers({ limit: 10 });\n\n    expect(result.next_cursor).toBeNull();\n  });\n\n  it(\"returns empty array when no results\", async () => {\n    mockQueryReturns([]);\n\n    const result = await searchUsers({});\n\n    expect(result.users).toEqual([]);\n    expect(result.next_cursor).toBeNull();\n  });\n});\n\n// ─── getUserProfile ────────────────────────────────────────────────────────────\n\ndescribe(\"getUserProfile\", () => {\n  it(\"returns profile with resolved_id, first_seen, last_seen, identity_cluster, events\", async () => {\n    mockQuery\n      .mockResolvedValueOnce({\n        json: vi.fn().mockResolvedValue([\n          {\n            event_count: 5,\n            first_seen: \"2026-04-01T00:00:00.000Z\",\n            last_seen: \"2026-04-15T00:00:00.000Z\",\n          },\n        ]),\n      })\n      .mockResolvedValueOnce({\n        json: vi\n          .fn()\n          .mockResolvedValue([\n            { user_id: \"user@test.com\", device_id: \"dev-1\" },\n          ]),\n      })\n      .mockResolvedValueOnce({\n        json: vi.fn().mockResolvedValue([sampleEvent]),\n      });\n\n    const result = await getUserProfile(\"user@test.com\");\n\n    expect(result).not.toBeNull();\n    expect(result?.resolved_id).toBe(\"user@test.com\");\n    expect(result?.first_seen).toBe(\"2026-04-01T00:00:00.000Z\");\n    expect(result?.last_seen).toBe(\"2026-04-15T00:00:00.000Z\");\n    expect(result?.identity_cluster).toBeDefined();\n    expect(result?.events).toEqual([sampleEvent]);\n  });\n\n  it(\"identity_cluster includes all associated user_ids and device_ids\", async () => {\n    mockQuery\n      .mockResolvedValueOnce({\n        json: vi.fn().mockResolvedValue([\n          {\n            event_count: 3,\n            first_seen: \"2026-04-01T00:00:00.000Z\",\n            last_seen: \"2026-04-15T00:00:00.000Z\",\n          },\n        ]),\n      })\n      .mockResolvedValueOnce({\n        json: vi.fn().mockResolvedValue([\n          { user_id: \"user@test.com\", device_id: \"dev-1\" },\n          { user_id: \"user@test.com\", device_id: \"dev-2\" },\n          { user_id: null, device_id: \"dev-3\" },\n        ]),\n      })\n      .mockResolvedValueOnce({\n        json: vi.fn().mockResolvedValue([]),\n      });\n\n    const result = await getUserProfile(\"user@test.com\");\n\n    expect(result?.identity_cluster.user_ids).toEqual([\"user@test.com\"]);\n    expect(result?.identity_cluster.device_ids).toHaveLength(3);\n    expect(result?.identity_cluster.device_ids).toContain(\"dev-1\");\n    expect(result?.identity_cluster.device_ids).toContain(\"dev-2\");\n    expect(result?.identity_cluster.device_ids).toContain(\"dev-3\");\n  });\n\n  it(\"returns null when resolved_id not found\", async () => {\n    // ClickHouse returns epoch for min(DateTime64) on empty set, not NULL.\n    // We detect \"not found\" via event_count === 0.\n    mockQuery.mockResolvedValueOnce({\n      json: vi.fn().mockResolvedValue([\n        {\n          event_count: 0,\n          first_seen: \"1970-01-01 00:00:00.000\",\n          last_seen: \"1970-01-01 00:00:00.000\",\n        },\n      ]),\n    });\n\n    const result = await getUserProfile(\"nonexistent@test.com\");\n\n    expect(result).toBeNull();\n  });\n});\n","numLines":211,"startLine":1,"totalLines":211}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Jpj6WNBVTPuWfBJjUeBi9h","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LhY5pwvJhUjD9LKowLeuyB","name":"Read","input":{"file_path":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/users.integration.test.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3755,"cache_read_input_tokens":37538,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3755},"output_tokens":30,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"88b78d0f-2f5f-427a-9042-5c6a4a6b43d4","uuid":"042cc0f9-21fa-4b5c-a9c8-dc72ac145671"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LhY5pwvJhUjD9LKowLeuyB","type":"tool_result","content":"1\t/**\n2\t * Integration tests for searchUsers and getUserProfile (F13).\n3\t * Requires a running ClickHouse server at localhost:8123 (or CLICKHOUSE_URL).\n4\t * Uses a dedicated `minipanel_test` database — never touches `minipanel`.\n5\t *\n6\t * Run with: pnpm test (requires ./clickhouse server -- --path=.clickhouse)\n7\t */\n8\t\n9\timport { createClient } from \"@clickhouse/client\";\n10\timport { afterAll, afterEach, beforeAll, describe, expect, it } from \"vitest\";\n11\timport { getUserProfile, searchUsers } from \"@/lib/users\";\n12\t\n13\tconst CLICKHOUSE_URL = process.env.CLICKHOUSE_URL ?? \"http://localhost:8123\";\n14\tconst TEST_DB = \"minipanel_test\";\n15\t\n16\tasync function isClickHouseReachable(): Promise<boolean> {\n17\t  try {\n18\t    const res = await fetch(`${CLICKHOUSE_URL}/ping`, {\n19\t      signal: AbortSignal.timeout(2000),\n20\t    });\n21\t    return res.ok;\n22\t  } catch {\n23\t    return false;\n24\t  }\n25\t}\n26\t\n27\tconst testClient = createClient({\n28\t  url: CLICKHOUSE_URL,\n29\t  database: TEST_DB,\n30\t  password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n31\t});\n32\t\n33\tdescribe.skipIf(!(await isClickHouseReachable()))(\n34\t  \"users integration — real ClickHouse (minipanel_test)\",\n35\t  () => {\n36\t    beforeAll(async () => {\n37\t      const adminClient = createClient({\n38\t        url: CLICKHOUSE_URL,\n39\t        password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n40\t      });\n41\t\n42\t      await adminClient.command({\n43\t        query: `CREATE DATABASE IF NOT EXISTS ${TEST_DB}`,\n44\t      });\n45\t\n46\t      await adminClient.command({\n47\t        query: `\n48\t          CREATE TABLE IF NOT EXISTS ${TEST_DB}.events\n49\t          (\n50\t            event_id    UUID                     DEFAULT generateUUIDv4(),\n51\t            event_name  LowCardinality(String),\n52\t            timestamp   DateTime64(3, 'UTC'),\n53\t            device_id   Nullable(String),\n54\t            user_id     Nullable(String),\n55\t            properties  String,\n56\t            ingested_at DateTime64(3, 'UTC')     DEFAULT now64()\n57\t          )\n58\t          ENGINE = MergeTree()\n59\t          ORDER BY (timestamp, event_id)\n60\t          PARTITION BY toYYYYMM(timestamp)\n61\t        `,\n62\t      });\n63\t\n64\t      await adminClient.command({\n65\t        query: `\n66\t          CREATE TABLE IF NOT EXISTS ${TEST_DB}.identity_mappings\n67\t          (\n68\t            device_id  String,\n69\t            user_id    String,\n70\t            created_at DateTime64(3, 'UTC') DEFAULT now64()\n71\t          )\n72\t          ENGINE = ReplacingMergeTree(created_at)\n73\t          ORDER BY (device_id)\n74\t        `,\n75\t      });\n76\t\n77\t      await adminClient.close();\n78\t    });\n79\t\n80\t    afterAll(async () => {\n81\t      await testClient.close();\n82\t    });\n83\t\n84\t    afterEach(async () => {\n85\t      await testClient.command({ query: \"TRUNCATE TABLE events\" });\n86\t      await testClient.command({ query: \"TRUNCATE TABLE identity_mappings\" });\n87\t    });\n88\t\n89\t    // Helper: insert a minimal event row directly\n90\t    async function insertRawEvent(\n91\t      eventName: string,\n92\t      userId: string | null,\n93\t      deviceId: string | null,\n94\t      ts = \"2026-04-10T10:00:00.000Z\",\n95\t    ) {\n96\t      await testClient.insert({\n97\t        table: \"events\",\n98\t        values: [\n99\t          {\n100\t            event_name: eventName,\n101\t            timestamp: ts,\n102\t            device_id: deviceId,\n103\t            user_id: userId,\n104\t            properties: \"{}\",\n105\t          },\n106\t        ],\n107\t        format: \"JSONEachRow\",\n108\t      });\n109\t    }\n110\t\n111\t    // ─── searchUsers ──────────────────────────────────────────────────────────\n112\t\n113\t    describe(\"searchUsers\", () => {\n114\t      it(\"returns identified user from events\", async () => {\n115\t        await insertRawEvent(\"Page Viewed\", \"u1@test.com\", \"dev-u1\");\n116\t\n117\t        const { users } = await searchUsers({}, testClient);\n118\t\n119\t        const match = users.find((u) => u.resolved_id === \"u1@test.com\");\n120\t        expect(match).toBeDefined();\n121\t        expect(match?.event_count).toBeGreaterThanOrEqual(1);\n122\t        expect(match?.first_seen).toBeTruthy();\n123\t        expect(match?.last_seen).toBeTruthy();\n124\t      });\n125\t\n126\t      it(\"filters users by q (substring match)\", async () => {\n127\t        await insertRawEvent(\"Page Viewed\", \"alice@test.com\", \"dev-alice\");\n128\t        await insertRawEvent(\"Page Viewed\", \"bob@test.com\", \"dev-bob\");\n129\t\n130\t        const { users } = await searchUsers({ q: \"alice\" }, testClient);\n131\t\n132\t        expect(users.some((u) => u.resolved_id === \"alice@test.com\")).toBe(\n133\t          true,\n134\t        );\n135\t        expect(users.some((u) => u.resolved_id === \"bob@test.com\")).toBe(false);\n136\t      });\n137\t\n138\t      it(\"returns empty array when q matches nothing\", async () => {\n139\t        await insertRawEvent(\"Page Viewed\", \"charlie@test.com\", \"dev-charlie\");\n140\t\n141\t        const { users, next_cursor } = await searchUsers(\n142\t          { q: \"nonexistent_xyz_qqa\" },\n143\t          testClient,\n144\t        );\n145\t\n146\t        expect(users).toEqual([]);\n147\t        expect(next_cursor).toBeNull();\n148\t      });\n149\t\n150\t      it(\"cursor pagination: next page starts after cursor\", async () => {\n151\t        // Insert 3 users with predictable resolved_ids sorted lexicographically\n152\t        await insertRawEvent(\"Page Viewed\", \"aa@test.com\", \"dev-aa\");\n153\t        await insertRawEvent(\"Page Viewed\", \"bb@test.com\", \"dev-bb\");\n154\t        await insertRawEvent(\"Page Viewed\", \"cc@test.com\", \"dev-cc\");\n155\t\n156\t        // Page 1: limit 2\n157\t        const page1 = await searchUsers({ limit: 2 }, testClient);\n158\t        expect(page1.users.length).toBe(2);\n159\t        expect(page1.next_cursor).toBeTruthy();\n160\t\n161\t        // Page 2: provide cursor from page 1\n162\t        const cursor1 = page1.next_cursor ?? undefined;\n163\t        const page2 = await searchUsers(\n164\t          { limit: 2, cursor: cursor1 },\n165\t          testClient,\n166\t        );\n167\t        // Must not repeat any resolved_id from page 1\n168\t        const page1Ids = new Set(page1.users.map((u) => u.resolved_id));\n169\t        for (const u of page2.users) {\n170\t          expect(page1Ids.has(u.resolved_id)).toBe(false);\n171\t        }\n172\t      });\n173\t\n174\t      it(\"uses resolved identity (device events attributed to mapped user)\", async () => {\n175\t        // Insert anonymous event for device-anon\n176\t        await insertRawEvent(\"Page Viewed\", null, \"device-anon\");\n177\t        // Map device-anon → user-mapped via identity_mappings\n178\t        await testClient.insert({\n179\t          table: \"identity_mappings\",\n180\t          values: [{ device_id: \"device-anon\", user_id: \"mapped@test.com\" }],\n181\t          format: \"JSONEachRow\",\n182\t        });\n183\t        // Optimize forces deduplication of ReplacingMergeTree\n184\t        await testClient.command({\n185\t          query: \"OPTIMIZE TABLE identity_mappings FINAL\",\n186\t        });\n187\t\n188\t        const { users } = await searchUsers(\n189\t          { q: \"mapped@test.com\" },\n190\t          testClient,\n191\t        );\n192\t\n193\t        expect(users.some((u) => u.resolved_id === \"mapped@test.com\")).toBe(\n194\t          true,\n195\t        );\n196\t      });\n197\t    });\n198\t\n199\t    // ─── getUserProfile ────────────────────────────────────────────────────────\n200\t\n201\t    describe(\"getUserProfile\", () => {\n202\t      it(\"returns null when no events exist for resolved_id\", async () => {\n203\t        const result = await getUserProfile(\"ghost@test.com\", testClient);\n204\t        expect(result).toBeNull();\n205\t      });\n206\t\n207\t      it(\"returns profile with correct fields when user exists\", async () => {\n208\t        await insertRawEvent(\n209\t          \"Page Viewed\",\n210\t          \"profiled@test.com\",\n211\t          \"dev-profiled\",\n212\t          \"2026-04-10T10:00:00.000Z\",\n213\t        );\n214\t        await insertRawEvent(\n215\t          \"Purchase Completed\",\n216\t          \"profiled@test.com\",\n217\t          \"dev-profiled\",\n218\t          \"2026-04-11T12:00:00.000Z\",\n219\t        );\n220\t\n221\t        const profile = await getUserProfile(\"profiled@test.com\", testClient);\n222\t\n223\t        expect(profile).not.toBeNull();\n224\t        expect(profile?.resolved_id).toBe(\"profiled@test.com\");\n225\t        expect(profile?.first_seen).toBeTruthy();\n226\t        expect(profile?.last_seen).toBeTruthy();\n227\t        expect(profile?.identity_cluster).toBeDefined();\n228\t        expect(profile?.events.length).toBeGreaterThanOrEqual(2);\n229\t      });\n230\t\n231\t      it(\"identity_cluster includes device_id associated with the user\", async () => {\n232\t        await insertRawEvent(\"Page Viewed\", \"cluster@test.com\", \"dev-cluster\");\n233\t\n234\t        const profile = await getUserProfile(\"cluster@test.com\", testClient);\n235\t\n236\t        expect(profile?.identity_cluster.user_ids).toContain(\n237\t          \"cluster@test.com\",\n238\t        );\n239\t        expect(profile?.identity_cluster.device_ids).toContain(\"dev-cluster\");\n240\t      });\n241\t\n242\t      it(\"events are returned newest first\", async () => {\n243\t        await insertRawEvent(\n244\t          \"Page Viewed\",\n245\t          \"ordered@test.com\",\n246\t          null,\n247\t          \"2026-04-01T00:00:00.000Z\",\n248\t        );\n249\t        await insertRawEvent(\n250\t          \"Purchase Completed\",\n251\t          \"ordered@test.com\",\n252\t          null,\n253\t          \"2026-04-15T00:00:00.000Z\",\n254\t        );\n255\t\n256\t        const profile = await getUserProfile(\"ordered@test.com\", testClient);\n257\t\n258\t        expect(profile?.events.length).toBe(2);\n259\t        // First event in array should be the more recent one\n260\t        expect(profile?.events[0].event_name).toBe(\"Purchase Completed\");\n261\t        expect(profile?.events[1].event_name).toBe(\"Page Viewed\");\n262\t      });\n263\t    });\n264\t  },\n265\t);\n266\t"}]},"parent_tool_use_id":null,"session_id":"88b78d0f-2f5f-427a-9042-5c6a4a6b43d4","uuid":"36ebe6f9-1c93-4025-8ecd-a5452ba393d8","timestamp":"2026-04-15T14:18:20.454Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/users.integration.test.ts","content":"/**\n * Integration tests for searchUsers and getUserProfile (F13).\n * Requires a running ClickHouse server at localhost:8123 (or CLICKHOUSE_URL).\n * Uses a dedicated `minipanel_test` database — never touches `minipanel`.\n *\n * Run with: pnpm test (requires ./clickhouse server -- --path=.clickhouse)\n */\n\nimport { createClient } from \"@clickhouse/client\";\nimport { afterAll, afterEach, beforeAll, describe, expect, it } from \"vitest\";\nimport { getUserProfile, searchUsers } from \"@/lib/users\";\n\nconst CLICKHOUSE_URL = process.env.CLICKHOUSE_URL ?? \"http://localhost:8123\";\nconst TEST_DB = \"minipanel_test\";\n\nasync function isClickHouseReachable(): Promise<boolean> {\n  try {\n    const res = await fetch(`${CLICKHOUSE_URL}/ping`, {\n      signal: AbortSignal.timeout(2000),\n    });\n    return res.ok;\n  } catch {\n    return false;\n  }\n}\n\nconst testClient = createClient({\n  url: CLICKHOUSE_URL,\n  database: TEST_DB,\n  password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n});\n\ndescribe.skipIf(!(await isClickHouseReachable()))(\n  \"users integration — real ClickHouse (minipanel_test)\",\n  () => {\n    beforeAll(async () => {\n      const adminClient = createClient({\n        url: CLICKHOUSE_URL,\n        password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n      });\n\n      await adminClient.command({\n        query: `CREATE DATABASE IF NOT EXISTS ${TEST_DB}`,\n      });\n\n      await adminClient.command({\n        query: `\n          CREATE TABLE IF NOT EXISTS ${TEST_DB}.events\n          (\n            event_id    UUID                     DEFAULT generateUUIDv4(),\n            event_name  LowCardinality(String),\n            timestamp   DateTime64(3, 'UTC'),\n            device_id   Nullable(String),\n            user_id     Nullable(String),\n            properties  String,\n            ingested_at DateTime64(3, 'UTC')     DEFAULT now64()\n          )\n          ENGINE = MergeTree()\n          ORDER BY (timestamp, event_id)\n          PARTITION BY toYYYYMM(timestamp)\n        `,\n      });\n\n      await adminClient.command({\n        query: `\n          CREATE TABLE IF NOT EXISTS ${TEST_DB}.identity_mappings\n          (\n            device_id  String,\n            user_id    String,\n            created_at DateTime64(3, 'UTC') DEFAULT now64()\n          )\n          ENGINE = ReplacingMergeTree(created_at)\n          ORDER BY (device_id)\n        `,\n      });\n\n      await adminClient.close();\n    });\n\n    afterAll(async () => {\n      await testClient.close();\n    });\n\n    afterEach(async () => {\n      await testClient.command({ query: \"TRUNCATE TABLE events\" });\n      await testClient.command({ query: \"TRUNCATE TABLE identity_mappings\" });\n    });\n\n    // Helper: insert a minimal event row directly\n    async function insertRawEvent(\n      eventName: string,\n      userId: string | null,\n      deviceId: string | null,\n      ts = \"2026-04-10T10:00:00.000Z\",\n    ) {\n      await testClient.insert({\n        table: \"events\",\n        values: [\n          {\n            event_name: eventName,\n            timestamp: ts,\n            device_id: deviceId,\n            user_id: userId,\n            properties: \"{}\",\n          },\n        ],\n        format: \"JSONEachRow\",\n      });\n    }\n\n    // ─── searchUsers ──────────────────────────────────────────────────────────\n\n    describe(\"searchUsers\", () => {\n      it(\"returns identified user from events\", async () => {\n        await insertRawEvent(\"Page Viewed\", \"u1@test.com\", \"dev-u1\");\n\n        const { users } = await searchUsers({}, testClient);\n\n        const match = users.find((u) => u.resolved_id === \"u1@test.com\");\n        expect(match).toBeDefined();\n        expect(match?.event_count).toBeGreaterThanOrEqual(1);\n        expect(match?.first_seen).toBeTruthy();\n        expect(match?.last_seen).toBeTruthy();\n      });\n\n      it(\"filters users by q (substring match)\", async () => {\n        await insertRawEvent(\"Page Viewed\", \"alice@test.com\", \"dev-alice\");\n        await insertRawEvent(\"Page Viewed\", \"bob@test.com\", \"dev-bob\");\n\n        const { users } = await searchUsers({ q: \"alice\" }, testClient);\n\n        expect(users.some((u) => u.resolved_id === \"alice@test.com\")).toBe(\n          true,\n        );\n        expect(users.some((u) => u.resolved_id === \"bob@test.com\")).toBe(false);\n      });\n\n      it(\"returns empty array when q matches nothing\", async () => {\n        await insertRawEvent(\"Page Viewed\", \"charlie@test.com\", \"dev-charlie\");\n\n        const { users, next_cursor } = await searchUsers(\n          { q: \"nonexistent_xyz_qqa\" },\n          testClient,\n        );\n\n        expect(users).toEqual([]);\n        expect(next_cursor).toBeNull();\n      });\n\n      it(\"cursor pagination: next page starts after cursor\", async () => {\n        // Insert 3 users with predictable resolved_ids sorted lexicographically\n        await insertRawEvent(\"Page Viewed\", \"aa@test.com\", \"dev-aa\");\n        await insertRawEvent(\"Page Viewed\", \"bb@test.com\", \"dev-bb\");\n        await insertRawEvent(\"Page Viewed\", \"cc@test.com\", \"dev-cc\");\n\n        // Page 1: limit 2\n        const page1 = await searchUsers({ limit: 2 }, testClient);\n        expect(page1.users.length).toBe(2);\n        expect(page1.next_cursor).toBeTruthy();\n\n        // Page 2: provide cursor from page 1\n        const cursor1 = page1.next_cursor ?? undefined;\n        const page2 = await searchUsers(\n          { limit: 2, cursor: cursor1 },\n          testClient,\n        );\n        // Must not repeat any resolved_id from page 1\n        const page1Ids = new Set(page1.users.map((u) => u.resolved_id));\n        for (const u of page2.users) {\n          expect(page1Ids.has(u.resolved_id)).toBe(false);\n        }\n      });\n\n      it(\"uses resolved identity (device events attributed to mapped user)\", async () => {\n        // Insert anonymous event for device-anon\n        await insertRawEvent(\"Page Viewed\", null, \"device-anon\");\n        // Map device-anon → user-mapped via identity_mappings\n        await testClient.insert({\n          table: \"identity_mappings\",\n          values: [{ device_id: \"device-anon\", user_id: \"mapped@test.com\" }],\n          format: \"JSONEachRow\",\n        });\n        // Optimize forces deduplication of ReplacingMergeTree\n        await testClient.command({\n          query: \"OPTIMIZE TABLE identity_mappings FINAL\",\n        });\n\n        const { users } = await searchUsers(\n          { q: \"mapped@test.com\" },\n          testClient,\n        );\n\n        expect(users.some((u) => u.resolved_id === \"mapped@test.com\")).toBe(\n          true,\n        );\n      });\n    });\n\n    // ─── getUserProfile ────────────────────────────────────────────────────────\n\n    describe(\"getUserProfile\", () => {\n      it(\"returns null when no events exist for resolved_id\", async () => {\n        const result = await getUserProfile(\"ghost@test.com\", testClient);\n        expect(result).toBeNull();\n      });\n\n      it(\"returns profile with correct fields when user exists\", async () => {\n        await insertRawEvent(\n          \"Page Viewed\",\n          \"profiled@test.com\",\n          \"dev-profiled\",\n          \"2026-04-10T10:00:00.000Z\",\n        );\n        await insertRawEvent(\n          \"Purchase Completed\",\n          \"profiled@test.com\",\n          \"dev-profiled\",\n          \"2026-04-11T12:00:00.000Z\",\n        );\n\n        const profile = await getUserProfile(\"profiled@test.com\", testClient);\n\n        expect(profile).not.toBeNull();\n        expect(profile?.resolved_id).toBe(\"profiled@test.com\");\n        expect(profile?.first_seen).toBeTruthy();\n        expect(profile?.last_seen).toBeTruthy();\n        expect(profile?.identity_cluster).toBeDefined();\n        expect(profile?.events.length).toBeGreaterThanOrEqual(2);\n      });\n\n      it(\"identity_cluster includes device_id associated with the user\", async () => {\n        await insertRawEvent(\"Page Viewed\", \"cluster@test.com\", \"dev-cluster\");\n\n        const profile = await getUserProfile(\"cluster@test.com\", testClient);\n\n        expect(profile?.identity_cluster.user_ids).toContain(\n          \"cluster@test.com\",\n        );\n        expect(profile?.identity_cluster.device_ids).toContain(\"dev-cluster\");\n      });\n\n      it(\"events are returned newest first\", async () => {\n        await insertRawEvent(\n          \"Page Viewed\",\n          \"ordered@test.com\",\n          null,\n          \"2026-04-01T00:00:00.000Z\",\n        );\n        await insertRawEvent(\n          \"Purchase Completed\",\n          \"ordered@test.com\",\n          null,\n          \"2026-04-15T00:00:00.000Z\",\n        );\n\n        const profile = await getUserProfile(\"ordered@test.com\", testClient);\n\n        expect(profile?.events.length).toBe(2);\n        // First event in array should be the more recent one\n        expect(profile?.events[0].event_name).toBe(\"Purchase Completed\");\n        expect(profile?.events[1].event_name).toBe(\"Page Viewed\");\n      });\n    });\n  },\n);\n","numLines":266,"startLine":1,"totalLines":266}}}
