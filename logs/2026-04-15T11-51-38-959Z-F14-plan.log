ons.push(\"resolved_id ILIKE {q:String}\");\n62\t    params.q = `%${q}%`;\n63\t  }\n64\t\n65\t  if (cursor) {\n66\t    conditions.push(\"resolved_id > {cursor:String}\");\n67\t    params.cursor = cursor;\n68\t  }\n69\t\n70\t  const having =\n71\t    conditions.length > 0 ? `HAVING ${conditions.join(\" AND \")}` : \"\";\n72\t\n73\t  const result = await client.query({\n74\t    query: `\n75\t      SELECT\n76\t        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id,\n77\t        min(e.timestamp) AS first_seen,\n78\t        max(e.timestamp) AS last_seen,\n79\t        count() AS event_count\n80\t      FROM events e\n81\t      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n82\t        ON e.device_id = m.device_id\n83\t      GROUP BY resolved_id\n84\t      ${having}\n85\t      ORDER BY resolved_id ASC\n86\t      LIMIT {limit:UInt64}\n87\t    `,\n88\t    query_params: params,\n89\t    format: \"JSONEachRow\",\n90\t  });\n91\t\n92\t  const rows = await result.json<\n93\t    Omit<UserListItem, \"event_count\"> & { event_count: number | string }\n94\t  >();\n95\t\n96\t  const users: UserListItem[] = rows.map((row) => ({\n97\t    resolved_id: row.resolved_id,\n98\t    first_seen: row.first_seen,\n99\t    last_seen: row.last_seen,\n100\t    event_count: Number(row.event_count),\n101\t  }));\n102\t\n103\t  const next_cursor =\n104\t    users.length === limit ? users[users.length - 1].resolved_id : null;\n105\t\n106\t  return { users, next_cursor };\n107\t}\n108\t\n109\t// ─── getUserProfile ────────────────────────────────────────────────────────────\n110\t\n111\t/**\n112\t * Returns a full user profile for a given resolved_id, including:\n113\t * - first_seen / last_seen timestamps\n114\t * - identity_cluster: all user_ids and device_ids associated with this identity\n115\t * - recent events (up to 200, newest first)\n116\t *\n117\t * Returns null if no events are found for the given resolved_id.\n118\t */\n119\texport async function getUserProfile(\n120\t  resolved_id: string,\n121\t  client: ClickHouseClientLike = clickhouse,\n122\t): Promise<UserProfile | null> {\n123\t  // ── Query 1: stats ──────────────────────────────────────────────────────────\n124\t\n125\t  const statsResult = await client.query({\n126\t    query: `\n127\t      SELECT\n128\t        count() AS event_count,\n129\t        min(e.timestamp) AS first_seen,\n130\t        max(e.timestamp) AS last_seen\n131\t      FROM events e\n132\t      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n133\t        ON e.device_id = m.device_id\n134\t      WHERE coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\n135\t    `,\n136\t    query_params: { resolved_id },\n137\t    format: \"JSONEachRow\",\n138\t  });\n139\t\n140\t  const statsRows = await statsResult.json<{\n141\t    event_count: number | string;\n142\t    first_seen: string;\n143\t    last_seen: string;\n144\t  }>();\n145\t\n146\t  if (statsRows.length === 0 || Number(statsRows[0].event_count) === 0) {\n147\t    return null;\n148\t  }\n149\t\n150\t  const { first_seen, last_seen } = statsRows[0];\n151\t\n152\t  // ── Query 2: identity cluster ───────────────────────────────────────────────\n153\t\n154\t  const clusterResult = await client.query({\n155\t    query: `\n156\t      SELECT DISTINCT\n157\t        e.user_id,\n158\t        e.device_id\n159\t      FROM events e\n160\t      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n161\t        ON e.device_id = m.device_id\n162\t      WHERE coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\n163\t    `,\n164\t    query_params: { resolved_id },\n165\t    format: \"JSONEachRow\",\n166\t  });\n167\t\n168\t  const clusterRows = await clusterResult.json<{\n169\t    user_id: string | null;\n170\t    device_id: string | null;\n171\t  }>();\n172\t\n173\t  const user_ids = [\n174\t    ...new Set(\n175\t      clusterRows\n176\t        .map((r) => r.user_id)\n177\t        .filter((id)