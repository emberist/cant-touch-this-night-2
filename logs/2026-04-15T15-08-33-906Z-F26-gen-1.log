ssage : \"Unknown error\");\n      } finally {\n        if (!cancelled) {\n          setLoading(false);\n        }\n      }\n    }\n\n    fetchProfile();\n\n    return () => {\n      cancelled = true;\n    };\n  }, [resolved_id]);\n\n  return { profile, loading, error };\n}\n","structuredPatch":[],"originalFile":null}}
