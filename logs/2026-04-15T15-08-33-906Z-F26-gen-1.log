{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011XR1mKToAUdgbXtz1YQwcR","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport Paper from \"@mui/material/Paper\";\n4\timport Skeleton from \"@mui/material/Skeleton\";\n5\timport Table from \"@mui/material/Table\";\n6\timport TableBody from \"@mui/material/TableBody\";\n7\timport TableCell from \"@mui/material/TableCell\";\n8\timport TableContainer from \"@mui/material/TableContainer\";\n9\timport TableHead from \"@mui/material/TableHead\";\n10\timport TableRow from \"@mui/material/TableRow\";\n11\timport { useEffect, useRef } from \"react\";\n12\timport { IdentityChip } from \"@/components/ui/IdentityChip\";\n13\timport { JsonChip } from \"@/components/ui/JsonChip\";\n14\timport type { EventRow } from \"@/lib/identity\";\n15\t\n16\tinterface EventTableProps {\n17\t  events: EventRow[];\n18\t  loading: boolean;\n19\t  hasMore: boolean;\n20\t  onLoadMore: () => void;\n21\t  emptyMessage?: string;\n22\t}\n23\t\n24\texport function EventTable({\n25\t  events,\n26\t  loading,\n27\t  hasMore,\n28\t  onLoadMore,\n29\t  emptyMessage = \"No events found.\",\n30\t}: EventTableProps): React.JSX.Element {\n31\t  const sentinelRef = useRef<HTMLTableRowElement>(null);\n32\t  // Keep a stable ref to onLoadMore to avoid re-attaching observer on every render\n33\t  const onLoadMoreRef = useRef(onLoadMore);\n34\t  onLoadMoreRef.current = onLoadMore;\n35\t\n36\t  useEffect(() => {\n37\t    if (!hasMore) return;\n38\t    const sentinel = sentinelRef.current;\n39\t    if (!sentinel) return;\n40\t\n41\t    const observer = new IntersectionObserver(\n42\t      (entries) => {\n43\t        if (entries[0]?.isIntersecting) {\n44\t          onLoadMoreRef.current();\n45\t        }\n46\t      },\n47\t      { rootMargin: \"100px\" },\n48\t    );\n49\t\n50\t    observer.observe(sentinel);\n51\t    return () => observer.disconnect();\n52\t  }, [hasMore]);\n53\t\n54\t  return (\n55\t    <TableContainer component={Paper} data-testid=\"event-table\">\n56\t      <Table size=\"small\">\n57\t        <TableHead>\n58\t          <TableRow>\n59\t            <TableCell>Timestamp</TableCell>\n60\t            <TableCell>Event Name</TableCell>\n61\t            <TableCell>Resolved Identity</TableCell>\n62\t            <TableCell>Properties</TableCell>\n63\t          </TableRow>\n64\t        </TableHead>\n65\t        <TableBody>\n66\t          {events.map((event) => (\n67\t            <TableRow key={event.event_id}>\n68\t              <TableCell sx={{ whiteSpace: \"nowrap\" }}>\n69\t                {new Date(event.timestamp).toLocaleString()}\n70\t              </TableCell>\n71\t              <TableCell>{event.event_name}</TableCell>\n72\t              <TableCell>\n73\t                <IdentityChip resolved_id={event.resolved_id} />\n74\t              </TableCell>\n75\t              <TableCell>\n76\t                <JsonChip properties={event.properties} />\n77\t              </TableCell>\n78\t            </TableRow>\n79\t          ))}\n80\t          {events.length === 0 && !loading && (\n81\t            <TableRow>\n82\t              <TableCell\n83\t                colSpan={4}\n84\t                sx={{ color: \"text.secondary\", py: 4, textAlign: \"center\" }}\n85\t              >\n86\t                {emptyMessage}\n87\t              </TableCell>\n88\t            </TableRow>\n89\t          )}\n90\t          {loading && (\n91\t            <TableRow>\n92\t              <TableCell colSpan={4}>\n93\t                <Skeleton variant=\"rectangular\" height={36} />\n94\t              </TableCell>\n95\t            </TableRow>\n96\t          )}\n97\t          {hasMore && !loading && (\n98\t            <TableRow ref={sentinelRef} aria-hidden=\"true\">\n99\t              <TableCell colSpan={4} sx={{ p: 0, border: 0 }} />\n100\t            </TableRow>\n101\t          )}\n102\t        </TableBody>\n103\t      </Table>\n104\t    </TableContainer>\n105\t  );\n106\t}\n107\t"}]},"parent_tool_use_id":nu