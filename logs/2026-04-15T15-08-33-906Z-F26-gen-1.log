n variant=\"text\" width={300} height={40} sx={{ mb: 2 }} />\n        <Skeleton variant=\"rectangular\" height={80} sx={{ mb: 2 }} />\n        <Skeleton variant=\"rectangular\" height={200} />\n      </Box>\n    );\n  }\n\n  if (error) {\n    return (\n      <Box data-testid=\"user-profile\">\n        <Typography color=\"error\">{error}</Typography>\n      </Box>\n    );\n  }\n\n  if (!profile) {\n    return (\n      <Box data-testid=\"user-profile\">\n        <Typography color=\"text.secondary\">User not found.</Typography>\n      </Box>\n    );\n  }\n\n  return (\n    <Box data-testid=\"user-profile\">\n      <Typography variant=\"h4\" component=\"h1\" gutterBottom>\n        {profile.resolved_id}\n      </Typography>\n\n      <Stack direction=\"row\" spacing={4} sx={{ mb: 3 }}>\n        <Box>\n          <Typography variant=\"caption\" color=\"text.secondary\">\n            First seen\n          </Typography>\n          <Typography variant=\"body2\">\n            {formatDate(profile.first_seen)}\n          </Typography>\n        </Box>\n        <Box>\n          <Typography variant=\"caption\" color=\"text.secondary\">\n            Last seen\n          </Typography>\n          <Typography variant=\"body2\">\n            {formatDate(profile.last_seen)}\n          </Typography>\n        </Box>\n      </Stack>\n\n      <Box data-testid=\"identity-cluster\" sx={{ mb: 3 }}>\n        <Typography variant=\"subtitle1\" gutterBottom>\n          Identity Cluster\n        </Typography>\n\n        {profile.identity_cluster.user_ids.length > 0 && (\n          <Box sx={{ mb: 1 }}>\n            <Typography variant=\"caption\" color=\"text.secondary\" sx={{ mr: 1 }}>\n              User IDs\n            </Typography>\n            <Stack direction=\"row\" flexWrap=\"wrap\" gap={0.5} component=\"span\">\n              {profile.identity_cluster.user_ids.map((uid) => (\n                <Chip\n                  key={uid}\n                  label={uid}\n                  size=\"small\"\n                  color=\"primary\"\n                  variant=\"outlined\"\n                />\n              ))}\n            </Stack>\n          </Box>\n        )}\n\n        {profile.identity_cluster.device_ids.length > 0 && (\n          <Box>\n            <Typography variant=\"caption\" color=\"text.secondary\" sx={{ mr: 1 }}>\n              Device IDs\n            </Typography>\n            <Stack direction=\"row\" flexWrap=\"wrap\" gap={0.5} component=\"span\">\n              {profile.identity_cluster.device_ids.map((did) => (\n                <Chip key={did} label={did} size=\"small\" variant=\"outlined\" />\n              ))}\n            </Stack>\n          </Box>\n        )}\n      </Box>\n\n      <Divider sx={{ mb: 2 }} />\n\n      <Typography variant=\"subtitle1\" gutterBottom>\n        Event Timeline ({profile.events.length} events)\n      </Typography>\n\n      <UserTimeline events={profile.events} />\n    </Box>\n  );\n}\n","structuredPatch":[{"oldStart":87,"oldLines":7,"newStart":87,"newLines":7,"lines":["             <Typography variant=\"caption\" color=\"text.secondary\" sx={{ mr: 1 }}>","               User IDs","             </Typography>","-            <Stack direction=\"row\" flexWrap=\"wrap\" gap={0.5} component=\"span\">","+            <Stack direction=\"row\" sx={{ flexWrap: \"wrap\", gap: 0.5 }} component=\"span\">","               {profile.identity_cluster.user_ids.map((uid) => (","                 <Chip","                   key={uid}"]},{"oldStart":106,"oldLines":7,"newStart":106,"newLines":7,"lines":["             <Typography variant=\"caption\" color=\"text.secondary\" sx={{ mr: 1 }}>","               Device IDs","             </Typography>","-            <Stack direction=\"row\" flexWrap=\"wrap\" gap={0.5} component=\"span\">","+            <Stack direction=\"row\" sx={{ flexWrap: \"wrap\", gap: 0.5 }} component=\"span\">","               {profile.identity_cluster.device_ids.map((did) => (","                 <Chip key={did} label={di