{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UqQmirvwQZ1VdLuWzT6iQ8","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\t// Hoist all mock refs AND the error class so they're available inside vi.mock factory\n6\tconst { mockInsertEvent, MockIdentityConflictError } = vi.hoisted(() => {\n7\t  class HoistedConflictError extends Error {\n8\t    readonly status = 409 as const;\n9\t    constructor(msg = \"Device conflict\") {\n10\t      super(msg);\n11\t      this.name = \"IdentityConflictError\";\n12\t      Object.setPrototypeOf(this, HoistedConflictError.prototype);\n13\t    }\n14\t  }\n15\t\n16\t  return {\n17\t    mockInsertEvent: vi.fn(),\n18\t    MockIdentityConflictError: HoistedConflictError,\n19\t  };\n20\t});\n21\t\n22\tvi.mock(\"@/lib/identity\", () => ({\n23\t  insertEvent: mockInsertEvent,\n24\t  IdentityConflictError: MockIdentityConflictError,\n25\t}));\n26\t\n27\timport { POST } from \"@/app/api/events/batch/route\";\n28\t\n29\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n30\t\n31\tfunction makeRequest(body: unknown): Request {\n32\t  return new Request(\"http://localhost/api/events/batch\", {\n33\t    method: \"POST\",\n34\t    body: JSON.stringify(body),\n35\t    headers: { \"Content-Type\": \"application/json\" },\n36\t  });\n37\t}\n38\t\n39\tfunction makeMalformedRequest(): Request {\n40\t  return new Request(\"http://localhost/api/events/batch\", {\n41\t    method: \"POST\",\n42\t    body: \"{ this is not valid json !!!\",\n43\t    headers: { \"Content-Type\": \"application/json\" },\n44\t  });\n45\t}\n46\t\n47\tfunction makeSampleRow(overrides: Record<string, unknown> = {}) {\n48\t  return {\n49\t    event_id: \"uuid-1234\",\n50\t    event_name: \"Page Viewed\",\n51\t    timestamp: \"2026-04-15T10:00:00.000Z\",\n52\t    device_id: \"dev-1\",\n53\t    user_id: null,\n54\t    properties: \"{}\",\n55\t    ingested_at: \"2026-04-15T10:00:00.100Z\",\n56\t    resolved_id: \"dev-1\",\n57\t    ...overrides,\n58\t  };\n59\t}\n60\t\n61\t// ─── Tests ────────────────────────────────────────────────────────────────────\n62\t\n63\tbeforeEach(() => {\n64\t  mockInsertEvent.mockResolvedValue(makeSampleRow());\n65\t});\n66\t\n67\tafterEach(() => {\n68\t  vi.clearAllMocks();\n69\t});\n70\t\n71\tdescribe(\"POST /api/events/batch\", () => {\n72\t  describe(\"all events valid — 200\", () => {\n73\t    it(\"returns { ok: N, errors: [] } for N valid events\", async () => {\n74\t      mockInsertEvent\n75\t        .mockResolvedValueOnce(makeSampleRow({ event_id: \"id-1\" }))\n76\t        .mockResolvedValueOnce(makeSampleRow({ event_id: \"id-2\" }))\n77\t        .mockResolvedValueOnce(makeSampleRow({ event_id: \"id-3\" }));\n78\t\n79\t      const res = await POST(\n80\t        makeRequest([\n81\t          { event_name: \"Page Viewed\", device_id: \"dev-1\" },\n82\t          { event_name: \"Button Clicked\", device_id: \"dev-2\" },\n83\t          { event_name: \"Purchase Completed\", user_id: \"user@test.com\" },\n84\t        ]),\n85\t      );\n86\t\n87\t      expect(res.status).toBe(200);\n88\t      const body = await res.json();\n89\t      expect(body).toEqual({ ok: 3, errors: [] });\n90\t    });\n91\t\n92\t    it(\"calls insertEvent for each item in the array\", async () => {\n93\t      const events = [\n94\t        { event_name: \"Page Viewed\", device_id: \"dev-1\" },\n95\t        { event_name: \"Button Clicked\", device_id: \"dev-2\" },\n96\t      ];\n97\t\n98\t      await POST(makeRequest(events));\n99\t\n100\t      expect(mockInsertEvent).toHaveBeenCalledTimes(2);\n101\t      expect(mockInsertEvent).toHaveBeenNthCalledWith(1, events[0]);\n102\t      expect(mockInsertEvent).toHaveBeenNthCalledWith(2, events[1]);\n103\t    });\n104\t  });\n105\t\n106\t  describe(\"empty array — 200\", () => {\n107\t    it(\"returns { ok: 0, errors: [] } for empty array\", async () => {\n108\t      const res = await POST(makeRequest([]));\n109\t\n110\t      expect(res.status).toBe(200);\n111\t      const body = await res.json();\n112\t      expect(body).toEqual({ ok: 0, errors: [] });\n113\t      expect(mockInsertEvent).not.toHaveBeenCalled();\n114\t    });\n115\t  });\n116\t\n117\t  describe(\"mixed valid/invalid events — 200 with errors\", () => {\n118\t    it(\"returns correct ok count and errors array for mixed batch\", async () => {\n119\t      mockInsertEvent\n120\t        .mockResolvedValueOnce(makeSampleRow()) // index 0 — success\n121\t        .mockRejectedValueOnce(\n122\t          new Error(\"event_name is required and must be a non-empty string.\"),\n123\t        ) // index 1 — invalid\n124\t        .mockResolvedValueOnce(makeSampleRow({ event_id: \"id-3\" })); // index 2 — success\n125\t\n126\t      const res = await POST(\n127\t        makeRequest([\n128\t          { event_name: \"Page Viewed\", device_id: \"dev-1\" },\n129\t          { device_id: \"dev-2\" }, // missing event_name\n130\t          { event_name: \"Signup Completed\", user_id: \"user@test.com\" },\n131\t        ]),\n132\t      );\n133\t\n134\t      expect(res.status).toBe(200);\n135\t      const body = await res.json();\n136\t      expect(body.ok).toBe(2);\n137\t      expect(body.errors).toHaveLength(1);\n138\t      expect(body.errors[0]).toMatchObject({\n139\t        index: 1,\n140\t        error: \"event_name is required and must be a non-empty string.\",\n141\t      });\n142\t    });\n143\t\n144\t    it(\"reports correct index for each error in a mixed batch\", async () => {\n145\t      mockInsertEvent\n146\t        .mockRejectedValueOnce(new Error(\"error at index 0\"))\n147\t        .mockResolvedValueOnce(makeSampleRow())\n148\t        .mockRejectedValueOnce(new Error(\"error at index 2\"));\n149\t\n150\t      const res = await POST(\n151\t        makeRequest([\n152\t          { device_id: \"dev-1\" }, // index 0 — invalid\n153\t          { event_name: \"Page Viewed\", device_id: \"dev-2\" }, // index 1 — success\n154\t          { event_name: \"\" }, // index 2 — invalid\n155\t        ]),\n156\t      );\n157\t\n158\t      expect(res.status).toBe(200);\n159\t      const body = await res.json();\n160\t      expect(body.ok).toBe(1);\n161\t      expect(body.errors).toHaveLength(2);\n162\t      expect(body.errors[0]).toMatchObject({\n163\t        index: 0,\n164\t        error: \"error at index 0\",\n165\t      });\n166\t      expect(body.errors[1]).toMatchObject({\n167\t        index: 2,\n168\t        error: \"error at index 2\",\n169\t      });\n170\t    });\n171\t  });\n172\t\n173\t  describe(\"identity conflict — 200 with conflict in errors\", () => {\n174\t    it(\"puts conflicting event in errors with its message; other events still succeed\", async () => {\n175\t      mockInsertEvent\n176\t        .mockResolvedValueOnce(makeSampleRow()) // index 0 — success\n177\t        .mockRejectedValueOnce(\n178\t          new MockIdentityConflictError(\"Device already mapped\"),\n179\t        ) // index 1 — conflict\n180\t        .mockResolvedValueOnce(makeSampleRow({ event_id: \"id-3\" })); // index 2 — success\n181\t\n182\t      const res = await POST(\n183\t        makeRequest([\n184\t          { event_name: \"Page Viewed\", device_id: \"dev-1\" },\n185\t          {\n186\t            event_name: \"Signup Completed\",\n187\t            device_id: \"dev-conflict\",\n188\t            user_id: \"user2@test.com\",\n189\t          },\n190\t          { event_name: \"Purchase Completed\", user_id: \"user@test.com\" },\n191\t        ]),\n192\t      );\n193\t\n194\t      expect(res.status).toBe(200);\n195\t      const body = await res.json();\n196\t      expect(body.ok).toBe(2);\n197\t      expect(body.errors).toHaveLength(1);\n198\t      expect(body.errors[0]).toMatchObject({\n199\t        index: 1,\n200\t        error: \"Device already mapped\",\n201\t      });\n202\t    });\n203\t  });\n204\t\n205\t  describe(\"invalid top-level body — 400\", () => {\n206\t    it(\"returns 400 with error when body is a plain object (not array)\", async () => {\n207\t      const res = await POST(\n208\t        makeRequest({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n209\t      );\n210\t\n211\t      expect(res.status).toBe(400);\n212\t      const body = await res.json();\n213\t      expect(body).toHaveProperty(\"error\");\n214\t      expect(typeof body.error).toBe(\"string\");\n215\t    });\n216\t\n217\t    it(\"returns 400 with error when body is a string\", async () => {\n218\t      const res = await POST(makeRequest(\"not-an-array\"));\n219\t\n220\t      expect(res.status).toBe(400);\n221\t      const body = await res.json();\n222\t      expect(body).toHaveProperty(\"error\");\n223\t    });\n224\t\n225\t    it(\"returns 400 with error when body is not valid JSON\", async () => {\n226\t      const res = await POST(makeMalformedRequest());\n227\t\n228\t      expect(res.status).toBe(400);\n229\t      const body = await res.json();\n230\t      expect(body).toHaveProperty(\"error\");\n231\t    });\n232\t  });\n233\t});\n234\t"}]},"parent_tool_use_id":null,"session_id":"8a6e4bc0-b987-4228-9222-5a0f06858663","uuid":"2282b0bb-46ea-45c8-96b8-d6b0865fdbea","timestamp":"2026-04-15T12:33:17.422Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/events/batch/__tests__/route.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\n// Hoist all mock refs AND the error class so they're available inside vi.mock factory\nconst { mockInsertEvent, MockIdentityConflictError } = vi.hoisted(() => {\n  class HoistedConflictError extends Error {\n    readonly status = 409 as const;\n    constructor(msg = \"Device conflict\") {\n      super(msg);\n      this.name = \"IdentityConflictError\";\n      Object.setPrototypeOf(this, HoistedConflictError.prototype);\n    }\n  }\n\n  return {\n    mockInsertEvent: vi.fn(),\n    MockIdentityConflictError: HoistedConflictError,\n  };\n});\n\nvi.mock(\"@/lib/identity\", () => ({\n  insertEvent: mockInsertEvent,\n  IdentityConflictError: MockIdentityConflictError,\n}));\n\nimport { POST } from \"@/app/api/events/batch/route\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction makeRequest(body: unknown): Request {\n  return new Request(\"http://localhost/api/events/batch\", {\n    method: \"POST\",\n    body: JSON.stringify(body),\n    headers: { \"Content-Type\": \"application/json\" },\n  });\n}\n\nfunction makeMalformedRequest(): Request {\n  return new Request(\"http://localhost/api/events/batch\", {\n    method: \"POST\",\n    body: \"{ this is not valid json !!!\",\n    headers: { \"Content-Type\": \"application/json\" },\n  });\n}\n\nfunction makeSampleRow(overrides: Record<string, unknown> = {}) {\n  return {\n    event_id: \"uuid-1234\",\n    event_name: \"Page Viewed\",\n    timestamp: \"2026-04-15T10:00:00.000Z\",\n    device_id: \"dev-1\",\n    user_id: null,\n    properties: \"{}\",\n    ingested_at: \"2026-04-15T10:00:00.100Z\",\n    resolved_id: \"dev-1\",\n    ...overrides,\n  };\n}\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockInsertEvent.mockResolvedValue(makeSampleRow());\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\ndescribe(\"POST /api/events/batch\", () => {\n  describe(\"all events valid — 200\", () => {\n    it(\"returns { ok: N, errors: [] } for N valid events\", async () => {\n      mockInsertEvent\n        .mockResolvedValueOnce(makeSampleRow({ event_id: \"id-1\" }))\n        .mockResolvedValueOnce(makeSampleRow({ event_id: \"id-2\" }))\n        .mockResolvedValueOnce(makeSampleRow({ event_id: \"id-3\" }));\n\n      const res = await POST(\n        makeRequest([\n          { event_name: \"Page Viewed\", device_id: \"dev-1\" },\n          { event_name: \"Button Clicked\", device_id: \"dev-2\" },\n          { event_name: \"Purchase Completed\", user_id: \"user@test.com\" },\n        ]),\n      );\n\n      expect(res.status).toBe(200);\n      const body = await res.json();\n      expect(body).toEqual({ ok: 3, errors: [] });\n    });\n\n    it(\"calls insertEvent for each item in the array\", async () => {\n      const events = [\n        { event_name: \"Page Viewed\", device_id: \"dev-1\" },\n        { event_name: \"Button Clicked\", device_id: \"dev-2\" },\n      ];\n\n      await POST(makeRequest(events));\n\n      expect(mockInsertEvent).toHaveBeenCalledTimes(2);\n      expect(mockInsertEvent).toHaveBeenNthCalledWith(1, events[0]);\n      expect(mockInsertEvent).toHaveBeenNthCalledWith(2, events[1]);\n    });\n  });\n\n  describe(\"empty array — 200\", () => {\n    it(\"returns { ok: 0, errors: [] } for empty array\", async () => {\n      const res = await POST(makeRequest([]));\n\n      expect(res.status).toBe(200);\n      const body = await res.json();\n      expect(body).toEqual({ ok: 0, errors: [] });\n      expect(mockInsertEvent).not.toHaveBeenCalled();\n    });\n  });\n\n  describe(\"mixed valid/invalid events — 200 with errors\", () => {\n    it(\"returns correct ok count and errors array for mixed batch\", async () => {\n      mockInsertEvent\n        .mockResolvedValueOnce(makeSampleRow()) // index 0 — success\n        .mockRejectedValueOnce(\n          new Error(\"event_name is required and must be a non-empty string.\"),\n        ) // index 1 — invalid\n        .mockResolvedValueOnce(makeSampleRow({ event_id: \"id-3\" })); // index 2 — success\n\n      const res = await POST(\n        makeRequest([\n          { event_name: \"Page Viewed\", device_id: \"dev-1\" },\n          { device_id: \"dev-2\" }, // missing event_name\n          { event_name: \"Signup Completed\", user_id: \"user@test.com\" },\n        ]),\n      );\n\n      expect(res.status).toBe(200);\n      const body = await res.json();\n      expect(body.ok).toBe(2);\n      expect(body.errors).toHaveLength(1);\n      expect(body.errors[0]).toMatchObject({\n        index: 1,\n        error: \"event_name is required and must be a non-empty string.\",\n      });\n    });\n\n    it(\"reports correct index for each error in a mixed batch\", async () => {\n      mockInsertEvent\n        .mockRejectedValueOnce(new Error(\"error at index 0\"))\n        .mockResolvedValueOnce(makeSampleRow())\n        .mockRejectedValueOnce(new Error(\"error at index 2\"));\n\n      const res = await POST(\n        makeRequest([\n          { device_id: \"dev-1\" }, // index 0 — invalid\n          { event_name: \"Page Viewed\", device_id: \"dev-2\" }, // index 1 — success\n          { event_name: \"\" }, // index 2 — invalid\n        ]),\n      );\n\n      expect(res.status).toBe(200);\n      const body = await res.json();\n      expect(body.ok).toBe(1);\n      expect(body.errors).toHaveLength(2);\n      expect(body.errors[0]).toMatchObject({\n        index: 0,\n        error: \"error at index 0\",\n      });\n      expect(body.errors[1]).toMatchObject({\n        index: 2,\n        error: \"error at index 2\",\n      });\n    });\n  });\n\n  describe(\"identity conflict — 200 with conflict in errors\", () => {\n    it(\"puts conflicting event in errors with its message; other events still succeed\", async () => {\n      mockInsertEvent\n        .mockResolvedValueOnce(makeSampleRow()) // index 0 — success\n        .mockRejectedValueOnce(\n          new MockIdentityConflictError(\"Device already mapped\"),\n        ) // index 1 — conflict\n        .mockResolvedValueOnce(makeSampleRow({ event_id: \"id-3\" })); // index 2 — success\n\n      const res = await POST(\n        makeRequest([\n          { event_name: \"Page Viewed\", device_id: \"dev-1\" },\n          {\n            event_name: \"Signup Completed\",\n            device_id: \"dev-conflict\",\n            user_id: \"user2@test.com\",\n          },\n          { event_name: \"Purchase Completed\", user_id: \"user@test.com\" },\n        ]),\n      );\n\n      expect(res.status).toBe(200);\n      const body = await res.json();\n      expect(body.ok).toBe(2);\n      expect(body.errors).toHaveLength(1);\n      expect(body.errors[0]).toMatchObject({\n        index: 1,\n        error: \"Device already mapped\",\n      });\n    });\n  });\n\n  describe(\"invalid top-level body — 400\", () => {\n    it(\"returns 400 with error when body is a plain object (not array)\", async () => {\n      const res = await POST(\n        makeRequest({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n      );\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n      expect(typeof body.error).toBe(\"string\");\n    });\n\n    it(\"returns 400 with error when body is a string\", async () => {\n      const res = await POST(makeRequest(\"not-an-array\"));\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n    });\n\n    it(\"returns 400 with error when body is not valid JSON\", async () => {\n      const res = await POST(makeMalformedRequest());\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n    });\n  });\n});\n","numLines":234,"startLine":1,"totalLines":234}}}
