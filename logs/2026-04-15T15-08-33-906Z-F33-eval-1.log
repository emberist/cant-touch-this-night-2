{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XECfGAndwyC1wyAC6E5D9i","type":"tool_result","content":"1\timport { expect, test } from \"@playwright/test\";\n2\t\n3\t/**\n4\t * Integration tests for the Funnels page (/funnels).\n5\t *\n6\t * Structural tests run without seeded data.\n7\t * Data-driven tests (AC #4) require ClickHouse + seed data.\n8\t *\n9\t * Pre-conditions: Next.js dev server running at baseURL (playwright.config.ts).\n10\t */\n11\t\n12\ttest.describe(\"Funnels page (/funnels)\", () => {\n13\t  test(\"page heading shows 'Funnels'\", async ({ page }) => {\n14\t    await page.goto(\"/funnels\");\n15\t    await expect(page.getByRole(\"heading\", { name: \"Funnels\" })).toBeVisible();\n16\t  });\n17\t\n18\t  test(\"step-builder container is visible\", async ({ page }) => {\n19\t    await page.goto(\"/funnels\");\n20\t    await expect(page.getByTestId(\"step-builder\")).toBeVisible();\n21\t  });\n22\t\n23\t  test(\"funnel-date-range container is visible\", async ({ page }) => {\n24\t    await page.goto(\"/funnels\");\n25\t    await expect(page.getByTestId(\"funnel-date-range\")).toBeVisible();\n26\t  });\n27\t\n28\t  test(\"funnel-chart container is visible\", async ({ page }) => {\n29\t    await page.goto(\"/funnels\");\n30\t    await expect(page.getByTestId(\"funnel-chart\")).toBeVisible();\n31\t  });\n32\t\n33\t  test(\"step-builder renders exactly 2 comboboxes by default\", async ({\n34\t    page,\n35\t  }) => {\n36\t    await page.goto(\"/funnels\");\n37\t    const combos = page.getByTestId(\"step-builder\").getByRole(\"combobox\");\n38\t    await expect(combos).toHaveCount(2);\n39\t  });\n40\t\n41\t  test(\"Add Step button is visible and not disabled\", async ({ page }) => {\n42\t    await page.goto(\"/funnels\");\n43\t    const addBtn = page.getByRole(\"button\", { name: /add step/i });\n44\t    await expect(addBtn).toBeVisible();\n45\t    await expect(addBtn).toBeEnabled();\n46\t  });\n47\t\n48\t  test(\"clicking Add Step adds a third combobox\", async ({ page }) => {\n49\t    await page.goto(\"/funnels\");\n50\t    await page.getByRole(\"button\", { name: /add step/i }).click();\n51\t    const combos = page.getByTestId(\"step-builder\").getByRole(\"combobox\");\n52\t    await expect(combos).toHaveCount(3);\n53\t  });\n54\t\n55\t  test(\"Run Funnel button is visible\", async ({ page }) => {\n56\t    await page.goto(\"/funnels\");\n57\t    await expect(\n58\t      page.getByRole(\"button\", { name: /run funnel/i }),\n59\t    ).toBeVisible();\n60\t  });\n61\t});\n62\t\n63\ttest.describe(\"Funnels page — data-driven (requires ClickHouse + seed data)\", () => {\n64\t  test.beforeAll(async ({ request }) => {\n65\t    const res = await request.post(\"/api/seed\", { timeout: 60000 });\n66\t    expect(res.ok()).toBeTruthy();\n67\t  });\n68\t\n69\t  test(\"3-step funnel shows chart with non-zero conversion rates (AC #4)\", async ({\n70\t    page,\n71\t  }) => {\n72\t    await page.goto(\"/funnels\");\n73\t\n74\t    const stepBuilder = page.getByTestId(\"step-builder\");\n75\t\n76\t    // Step 1: Page Viewed\n77\t    const step1 = stepBuilder.getByRole(\"combobox\").nth(0);\n78\t    await step1.click();\n79\t    await step1.fill(\"Page Viewed\");\n80\t    await page.getByRole(\"option\", { name: \"Page Viewed\" }).click();\n81\t\n82\t    // Step 2: Signup Completed\n83\t    const step2 = stepBuilder.getByRole(\"combobox\").nth(1);\n84\t    await step2.click();\n85\t    await step2.fill(\"Signup Completed\");\n86\t    await page.getByRole(\"option\", { name: \"Signup Completed\" }).click();\n87\t\n88\t    // Add a third step\n89\t    await page.getByRole(\"button\", { name: /add step/i }).click();\n90\t\n91\t    // Step 3: Purchase Completed\n92\t    const step3 = stepBuilder.getByRole(\"combobox\").nth(2);\n93\t    await step3.click();\n94\t    await step3.fill(\"Purchase Completed\");\n95\t    await page.getByRole(\"option\", { name: \"Purchase Completed\" }).click();\n96\t\n97\t    // Run the funnel\n98\t    await page.getByRole(\"button\", { name: /run funnel/i }).click();\n99\t\n100\t    // funnel-chart-steps renders when there are results with at least one step\n101\t    await expect(page.getByTestId(\"funnel-chart-steps\")).toBeVisible({\n102\t      timeout: 15000,\n103\t    });\n104\t\n105\t    // Drop-off annotations are rendered between steps (non-zero conversion means\n106\t    // at least one drop-off element is present)\n107\t    await expect(page.getByTestId(\"funnel-dropoff\").first()).toBeVisible();\n108\t  });\n109\t});\n110\t"}]},"parent_tool_use_id":null,"session_id":"0d6b6401-0816-449d-a818-1e9e6cd1e8cf","uuid":"b924d187-65f2-4120-817b-878c4de9986f","timestamp":"2026-04-15T19:49:50.484Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/playwright_tests/funnels.spec.ts","content":"import { expect, test } from \"@playwright/test\";\n\n/**\n * Integration tests for the Funnels page (/funnels).\n *\n * Structural tests run without seeded data.\n * Data-driven tests (AC #4) require ClickHouse + seed data.\n *\n * Pre-conditions: Next.js dev server running at baseURL (playwright.config.ts).\n */\n\ntest.describe(\"Funnels page (/funnels)\", () => {\n  test(\"page heading shows 'Funnels'\", async ({ page }) => {\n    await page.goto(\"/funnels\");\n    await expect(page.getByRole(\"heading\", { name: \"Funnels\" })).toBeVisible();\n  });\n\n  test(\"step-builder container is visible\", async ({ page }) => {\n    await page.goto(\"/funnels\");\n    await expect(page.getByTestId(\"step-builder\")).toBeVisible();\n  });\n\n  test(\"funnel-date-range container is visible\", async ({ page }) => {\n    await page.goto(\"/funnels\");\n    await expect(page.getByTestId(\"funnel-date-range\")).toBeVisible();\n  });\n\n  test(\"funnel-chart container is visible\", async ({ page }) => {\n    await page.goto(\"/funnels\");\n    await expect(page.getByTestId(\"funnel-chart\")).toBeVisible();\n  });\n\n  test(\"step-builder renders exactly 2 comboboxes by default\", async ({\n    page,\n  }) => {\n    await page.goto(\"/funnels\");\n    const combos = page.getByTestId(\"step-builder\").getByRole(\"combobox\");\n    await expect(combos).toHaveCount(2);\n  });\n\n  test(\"Add Step button is visible and not disabled\", async ({ page }) => {\n    await page.goto(\"/funnels\");\n    const addBtn = page.getByRole(\"button\", { name: /add step/i });\n    await expect(addBtn).toBeVisible();\n    await expect(addBtn).toBeEnabled();\n  });\n\n  test(\"clicking Add Step adds a third combobox\", async ({ page }) => {\n    await page.goto(\"/funnels\");\n    await page.getByRole(\"button\", { name: /add step/i }).click();\n    const combos = page.getByTestId(\"step-builder\").getByRole(\"combobox\");\n    await expect(combos).toHaveCount(3);\n  });\n\n  test(\"Run Funnel button is visible\", async ({ page }) => {\n    await page.goto(\"/funnels\");\n    await expect(\n      page.getByRole(\"button\", { name: /run funnel/i }),\n    ).toBeVisible();\n  });\n});\n\ntest.describe(\"Funnels page — data-driven (requires ClickHouse + seed data)\", () => {\n  test.beforeAll(async ({ request }) => {\n    const res = await request.post(\"/api/seed\", { timeout: 60000 });\n    expect(res.ok()).toBeTruthy();\n  });\n\n  test(\"3-step funnel shows chart with non-zero conversion rates (AC #4)\", async ({\n    page,\n  }) => {\n    await page.goto(\"/funnels\");\n\n    const stepBuilder = page.getByTestId(\"step-builder\");\n\n    // Step 1: Page Viewed\n    const step1 = stepBuilder.getByRole(\"combobox\").nth(0);\n    await step1.click();\n    await step1.fill(\"Page Viewed\");\n    await page.getByRole(\"option\", { name: \"Page Viewed\" }).click();\n\n    // Step 2: Signup Completed\n    const step2 = stepBuilder.getByRole(\"combobox\").nth(1);\n    await step2.click();\n    await step2.fill(\"Signup Completed\");\n    await page.getByRole(\"option\", { name: \"Signup Completed\" }).click();\n\n    // Add a third step\n    await page.getByRole(\"button\", { name: /add step/i }).click();\n\n    // Step 3: Purchase Completed\n    const step3 = stepBuilder.getByRole(\"combobox\").nth(2);\n    await step3.click();\n    await step3.fill(\"Purchase Completed\");\n    await page.getByRole(\"option\", { name: \"Purchase Completed\" }).click();\n\n    // Run the funnel\n    await page.getByRole(\"button\", { name: /run funnel/i }).click();\n\n    // funnel-chart-steps renders when there are results with at least one step\n    await expect(page.getByTestId(\"funnel-chart-steps\")).toBeVisible({\n      timeout: 15000,\n    });\n\n    // Drop-off annotations are rendered between steps (non-zero conversion means\n    // at least one drop-off element is present)\n    await expect(page.getByTestId(\"funnel-dropoff\").first()).toBeVisible();\n  });\n});\n","numLines":110,"startLine":1,"totalLines":110}}}
