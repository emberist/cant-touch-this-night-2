{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013iVod3Fn6btAU1HWeebDBu","type":"tool_result","content":"1\timport { expect, test } from \"@playwright/test\";\n2\t\n3\t/**\n4\t * E2e tests for identity resolution flows.\n5\t *\n6\t * AC #5: identity.spec.ts exists and tests the anonymous → identify flow.\n7\t * AC #6 (BR-101 Scenario 1): 4 anonymous events + 1 identify → user profile\n8\t *   shows all 5 events under the resolved user identity.\n9\t * AC #7 (BR-101 Scenario 2): two devices linked to same user → both device\n10\t *   IDs appear in the user's identity cluster.\n11\t *\n12\t * Pre-conditions: Next.js dev server + ClickHouse running.\n13\t *\n14\t * Notes on device IDs:\n15\t *   The Testing page's \"Anonymous Page View\" button generates a NEW random\n16\t *   device_id on each click. Only the LAST device_id is stored as lastDeviceId\n17\t *   and used by \"Identify User\". Therefore, the BR-101 Scenario 1 flow (4×\n18\t *   anon + identify → 5 events) is exercised via the API directly to control\n19\t *   which device_id is used. A separate UI smoke-test verifies the button flow.\n20\t */\n21\t\n22\ttest.describe(\"Identity resolution — API-level verification\", () => {\n23\t  test(\"AC #5/#6 — 4 anonymous events + identify → user profile shows 5 events\", async ({\n24\t    page,\n25\t    request,\n26\t  }) => {\n27\t    const deviceId = `pw-anon-${Date.now()}`;\n28\t    const userId = `pw-user-${Date.now()}@example.com`;\n29\t\n30\t    // Insert 4 anonymous Page Viewed events for the same device\n31\t    for (let i = 0; i < 4; i++) {\n32\t      const res = await request.post(\"/api/events\", {\n33\t        data: {\n34\t          event_name: \"Page Viewed\",\n35\t          device_id: deviceId,\n36\t          properties: { page: `/page${i}` },\n37\t        },\n38\t      });\n39\t      expect(res.status()).toBe(201);\n40\t    }\n41\t\n42\t    // Insert the identity-link event (device_id + user_id → creates mapping)\n43\t    const identifyRes = await request.post(\"/api/events\", {\n44\t      data: {\n45\t        event_name: \"Identify\",\n46\t        device_id: deviceId,\n47\t        user_id: userId,\n48\t      },\n49\t    });\n50\t    expect(identifyRes.status()).toBe(201);\n51\t\n52\t    // Navigate to the user profile (Server Component; queries ClickHouse at\n53\t    // request time, so the mapping is immediately visible via FINAL)\n54\t    await page.goto(`/users/${encodeURIComponent(userId)}`);\n55\t\n56\t    // Profile container must be present\n57\t    await expect(page.getByTestId(\"user-profile\")).toBeVisible();\n58\t\n59\t    // Identity cluster should list userId as a user ID chip\n60\t    const cluster = page.getByTestId(\"identity-cluster\");\n61\t    await expect(cluster).toBeVisible();\n62\t    await expect(cluster.getByText(userId)).toBeVisible({ timeout: 10000 });\n63\t\n64\t    // The deviceId should also appear in the cluster (mapped device)\n65\t    await expect(cluster.getByText(deviceId)).toBeVisible();\n66\t\n67\t    // Event Timeline heading shows the count: \"Event Timeline (5 events)\"\n68\t    await expect(page.getByText(/event timeline \\(5 events\\)/i)).toBeVisible();\n69\t  });\n70\t\n71\t  test(\"AC #7 (BR-101 Scenario 2) — two devices linked to same user appear in identity cluster\", async ({\n72\t    page,\n73\t    request,\n74\t  }) => {\n75\t    const ts = Date.now();\n76\t    const deviceA = `pw-device-a-${ts}`;\n77\t    const deviceB = `pw-device-b-${ts + 1}`;\n78\t    const userId = `pw-two-devices-${ts}@example.com`;\n79\t\n80\t    // Link device-A to userId\n81\t    const resA = await request.post(\"/api/events\", {\n82\t      data: {\n83\t        event_name: \"Page Viewed\",\n84\t        device_id: deviceA,\n85\t        user_id: userId,\n86\t        properties: { page: \"/from-device-a\" },\n87\t      },\n88\t    });\n89\t    expect(resA.status()).toBe(201);\n90\t\n91\t    // Link device-B to the same userId (one user → many devices is valid)\n92\t    const resB = await request.post(\"/api/events\", {\n93\t      data: {\n94\t        event_name: \"Page Viewed\",\n95\t        device_id: deviceB,\n96\t        user_id: userId,\n97\t        properties: { page: \"/from-device-b\" },\n98\t      },\n99\t    });\n100\t    expect(resB.status()).toBe(201);\n101\t\n102\t    // Navigate to the user profile\n103\t    await page.goto(`/users/${encodeURIComponent(userId)}`);\n104\t\n105\t    const cluster = page.getByTestId(\"identity-cluster\");\n106\t    await expect(cluster).toBeVisible({ timeout: 10000 });\n107\t\n108\t    // Both device IDs should appear as chips in the identity cluster\n109\t    await expect(cluster.getByText(deviceA)).toBeVisible();\n110\t    await expect(cluster.getByText(deviceB)).toBeVisible();\n111\t  });\n112\t});\n113\t\n114\ttest.describe(\"Identity resolution — UI smoke-test (Testing page)\", () => {\n115\t  test(\"AC #5 — Anonymous Page View then Identify User buttons work end-to-end\", async ({\n116\t    page,\n117\t  }) => {\n118\t    await page.goto(\"/test\");\n119\t    await expect(page.getByTestId(\"quick-fire-buttons\")).toBeVisible();\n120\t\n121\t    // Fire one anonymous page view to establish lastDeviceId in the hook\n122\t    await page.getByRole(\"button\", { name: \"Anonymous Page View\" }).click();\n123\t    await expect(page.getByText(\"Sent\").first()).toBeVisible({\n124\t      timeout: 10000,\n125\t    });\n126\t\n127\t    // Link that device to test@example.com\n128\t    await page.getByRole(\"button\", { name: \"Identify User\" }).click();\n129\t    await expect(page.getByText(\"Sent\").first()).toBeVisible({\n130\t      timeout: 10000,\n131\t    });\n132\t\n133\t    // Navigate to the user profile — it should exist with identity cluster visible\n134\t    await page.goto(\"/users/test%40example.com\");\n135\t\n136\t    await expect(page.getByTestId(\"user-profile\")).toBeVisible();\n137\t\n138\t    const cluster = page.getByTestId(\"identity-cluster\");\n139\t    await expect(cluster).toBeVisible();\n140\t    await expect(cluster.getByText(\"test@example.com\")).toBeVisible({\n141\t      timeout: 10000,\n142\t    });\n143\t  });\n144\t});\n145\t"}]},"parent_tool_use_id":null,"session_id":"0d6b6401-0816-449d-a818-1e9e6cd1e8cf","uuid":"f1b683b2-1d88-4d6d-8e68-c27caa7be800","timestamp":"2026-04-15T19:49:45.206Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/playwright_tests/identity.spec.ts","content":"import { expect, test } from \"@playwright/test\";\n\n/**\n * E2e tests for identity resolution flows.\n *\n * AC #5: identity.spec.ts exists and tests the anonymous → identify flow.\n * AC #6 (BR-101 Scenario 1): 4 anonymous events + 1 identify → user profile\n *   shows all 5 events under the resolved user identity.\n * AC #7 (BR-101 Scenario 2): two devices linked to same user → both device\n *   IDs appear in the user's identity cluster.\n *\n * Pre-conditions: Next.js dev server + ClickHouse running.\n *\n * Notes on device IDs:\n *   The Testing page's \"Anonymous Page View\" button generates a NEW random\n *   device_id on each click. Only the LAST device_id is stored as lastDeviceId\n *   and used by \"Identify User\". Therefore, the BR-101 Scenario 1 flow (4×\n *   anon + identify → 5 events) is exercised via the API directly to control\n *   which device_id is used. A separate UI smoke-test verifies the button flow.\n */\n\ntest.describe(\"Identity resolution — API-level verification\", () => {\n  test(\"AC #5/#6 — 4 anonymous events + identify → user profile shows 5 events\", async ({\n    page,\n    request,\n  }) => {\n    const deviceId = `pw-anon-${Date.now()}`;\n    const userId = `pw-user-${Date.now()}@example.com`;\n\n    // Insert 4 anonymous Page Viewed events for the same device\n    for (let i = 0; i < 4; i++) {\n      const res = await request.post(\"/api/events\", {\n        data: {\n          event_name: \"Page Viewed\",\n          device_id: deviceId,\n          properties: { page: `/page${i}` },\n        },\n      });\n      expect(res.status()).toBe(201);\n    }\n\n    // Insert the identity-link event (device_id + user_id → creates mapping)\n    const identifyRes = await request.post(\"/api/events\", {\n      data: {\n        event_name: \"Identify\",\n        device_id: deviceId,\n        user_id: userId,\n      },\n    });\n    expect(identifyRes.status()).toBe(201);\n\n    // Navigate to the user profile (Server Component; queries ClickHouse at\n    // request time, so the mapping is immediately visible via FINAL)\n    await page.goto(`/users/${encodeURIComponent(userId)}`);\n\n    // Profile container must be present\n    await expect(page.getByTestId(\"user-profile\")).toBeVisible();\n\n    // Identity cluster should list userId as a user ID chip\n    const cluster = page.getByTestId(\"identity-cluster\");\n    await expect(cluster).toBeVisible();\n    await expect(cluster.getByText(userId)).toBeVisible({ timeout: 10000 });\n\n    // The deviceId should also appear in the cluster (mapped device)\n    await expect(cluster.getByText(deviceId)).toBeVisible();\n\n    // Event Timeline heading shows the count: \"Event Timeline (5 events)\"\n    await expect(page.getByText(/event timeline \\(5 events\\)/i)).toBeVisible();\n  });\n\n  test(\"AC #7 (BR-101 Scenario 2) — two devices linked to same user appear in identity cluster\", async ({\n    page,\n    request,\n  }) => {\n    const ts = Date.now();\n    const deviceA = `pw-device-a-${ts}`;\n    const deviceB = `pw-device-b-${ts + 1}`;\n    const userId = `pw-two-devices-${ts}@example.com`;\n\n    // Link device-A to userId\n    const resA = await request.post(\"/api/events\", {\n      data: {\n        event_name: \"Page Viewed\",\n        device_id: deviceA,\n        user_id: userId,\n        properties: { page: \"/from-device-a\" },\n      },\n    });\n    expect(resA.status()).toBe(201);\n\n    // Link device-B to the same userId (one user → many devices is valid)\n    const resB = await request.post(\"/api/events\", {\n      data: {\n        event_name: \"Page Viewed\",\n        device_id: deviceB,\n        user_id: userId,\n        properties: { page: \"/from-device-b\" },\n      },\n    });\n    expect(resB.status()).toBe(201);\n\n    // Navigate to the user profile\n    await page.goto(`/users/${encodeURIComponent(userId)}`);\n\n    const cluster = page.getByTestId(\"identity-cluster\");\n    await expect(cluster).toBeVisible({ timeout: 10000 });\n\n    // Both device IDs should appear as chips in the identity cluster\n    await expect(cluster.getByText(deviceA)).toBeVisible();\n    await expect(cluster.getByText(deviceB)).toBeVisible();\n  });\n});\n\ntest.describe(\"Identity resolution — UI smoke-test (Testing page)\", () => {\n  test(\"AC #5 — Anonymous Page View then Identify User buttons work end-to-end\", async ({\n    page,\n  }) => {\n    await page.goto(\"/test\");\n    await expect(page.getByTestId(\"quick-fire-buttons\")).toBeVisible();\n\n    // Fire one anonymous page view to establish lastDeviceId in the hook\n    await page.getByRole(\"button\", { name: \"Anonymous Page View\" }).click();\n    await expect(page.getByText(\"Sent\").first()).toBeVisible({\n      timeout: 10000,\n    });\n\n    // Link that device to test@example.com\n    await page.getByRole(\"button\", { name: \"Identify User\" }).click();\n    await expect(page.getByText(\"Sent\").first()).toBeVisible({\n      timeout: 10000,\n    });\n\n    // Navigate to the user profile — it should exist with identity cluster visible\n    await page.goto(\"/users/test%40example.com\");\n\n    await expect(page.getByTestId(\"user-profile\")).toBeVisible();\n\n    const cluster = page.getByTestId(\"identity-cluster\");\n    await expect(cluster).toBeVisible();\n    await expect(cluster.getByText(\"test@example.com\")).toBeVisible({\n      timeout: 10000,\n    });\n  });\n});\n","numLines":145,"startLine":1,"totalLines":145}}}
