{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0185D2UErHTcQ94xtuzCEFXQ","type":"tool_result","content":"1\timport { expect, test } from \"@playwright/test\";\n2\t\n3\t/**\n4\t * Integration tests for the Trends page (/trends).\n5\t *\n6\t * Structural tests run without seeded data.\n7\t * Data-driven tests (AC #3) require ClickHouse + seed data.\n8\t *\n9\t * Pre-conditions: Next.js dev server running at baseURL (playwright.config.ts).\n10\t */\n11\t\n12\ttest.describe(\"Trends page (/trends)\", () => {\n13\t  test(\"page title contains 'Trends'\", async ({ page }) => {\n14\t    await page.goto(\"/trends\");\n15\t    await expect(page).toHaveTitle(/Trends/i);\n16\t  });\n17\t\n18\t  test(\"controls container is visible\", async ({ page }) => {\n19\t    await page.goto(\"/trends\");\n20\t    await expect(page.getByTestId(\"trends-controls\")).toBeVisible();\n21\t  });\n22\t\n23\t  test(\"chart container is visible\", async ({ page }) => {\n24\t    await page.goto(\"/trends\");\n25\t    await expect(page.getByTestId(\"trend-chart\")).toBeVisible();\n26\t  });\n27\t\n28\t  test(\"page heading shows 'Trends'\", async ({ page }) => {\n29\t    await page.goto(\"/trends\");\n30\t    await expect(page.getByRole(\"heading\", { name: \"Trends\" })).toBeVisible();\n31\t  });\n32\t});\n33\t\n34\ttest.describe(\"Trends page — data-driven (requires ClickHouse + seed data)\", () => {\n35\t  test.beforeAll(async ({ request }) => {\n36\t    const res = await request.post(\"/api/seed\", { timeout: 60000 });\n37\t    expect(res.ok()).toBeTruthy();\n38\t  });\n39\t\n40\t  test(\"selecting 'Page Viewed' event renders chart with data (AC #3)\", async ({\n41\t    page,\n42\t  }) => {\n43\t    await page.goto(\"/trends\");\n44\t\n45\t    // Wait for the schema to load so the autocomplete has options\n46\t    await expect(page.getByTestId(\"trends-controls\")).toBeVisible();\n47\t\n48\t    // Select \"Page Viewed\" from the event-name autocomplete\n49\t    const eventInput = page.getByLabel(\"Event name\");\n50\t    await eventInput.click();\n51\t    await eventInput.fill(\"Page Viewed\");\n52\t    await page.getByRole(\"option\", { name: \"Page Viewed\" }).click();\n53\t\n54\t    // useTrends fires a fetch as soon as eventName is set.\n55\t    // Wait for the skeleton (loading indicator) to disappear.\n56\t    await expect(page.getByTestId(\"trend-chart-skeleton\")).not.toBeVisible({\n57\t      timeout: 15000,\n58\t    });\n59\t\n60\t    // Chart should now show real data, not the empty-state placeholder\n61\t    await expect(page.getByTestId(\"trend-chart-empty\")).not.toBeVisible();\n62\t  });\n63\t});\n64\t"}]},"parent_tool_use_id":null,"session_id":"0d6b6401-0816-449d-a818-1e9e6cd1e8cf","uuid":"ee06feea-d6dd-4c26-96aa-1cde87e94be3","timestamp":"2026-04-15T19:49:50.271Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/playwright_tests/trends.spec.ts","content":"import { expect, test } from \"@playwright/test\";\n\n/**\n * Integration tests for the Trends page (/trends).\n *\n * Structural tests run without seeded data.\n * Data-driven tests (AC #3) require ClickHouse + seed data.\n *\n * Pre-conditions: Next.js dev server running at baseURL (playwright.config.ts).\n */\n\ntest.describe(\"Trends page (/trends)\", () => {\n  test(\"page title contains 'Trends'\", async ({ page }) => {\n    await page.goto(\"/trends\");\n    await expect(page).toHaveTitle(/Trends/i);\n  });\n\n  test(\"controls container is visible\", async ({ page }) => {\n    await page.goto(\"/trends\");\n    await expect(page.getByTestId(\"trends-controls\")).toBeVisible();\n  });\n\n  test(\"chart container is visible\", async ({ page }) => {\n    await page.goto(\"/trends\");\n    await expect(page.getByTestId(\"trend-chart\")).toBeVisible();\n  });\n\n  test(\"page heading shows 'Trends'\", async ({ page }) => {\n    await page.goto(\"/trends\");\n    await expect(page.getByRole(\"heading\", { name: \"Trends\" })).toBeVisible();\n  });\n});\n\ntest.describe(\"Trends page — data-driven (requires ClickHouse + seed data)\", () => {\n  test.beforeAll(async ({ request }) => {\n    const res = await request.post(\"/api/seed\", { timeout: 60000 });\n    expect(res.ok()).toBeTruthy();\n  });\n\n  test(\"selecting 'Page Viewed' event renders chart with data (AC #3)\", async ({\n    page,\n  }) => {\n    await page.goto(\"/trends\");\n\n    // Wait for the schema to load so the autocomplete has options\n    await expect(page.getByTestId(\"trends-controls\")).toBeVisible();\n\n    // Select \"Page Viewed\" from the event-name autocomplete\n    const eventInput = page.getByLabel(\"Event name\");\n    await eventInput.click();\n    await eventInput.fill(\"Page Viewed\");\n    await page.getByRole(\"option\", { name: \"Page Viewed\" }).click();\n\n    // useTrends fires a fetch as soon as eventName is set.\n    // Wait for the skeleton (loading indicator) to disappear.\n    await expect(page.getByTestId(\"trend-chart-skeleton\")).not.toBeVisible({\n      timeout: 15000,\n    });\n\n    // Chart should now show real data, not the empty-state placeholder\n    await expect(page.getByTestId(\"trend-chart-empty\")).not.toBeVisible();\n  });\n});\n","numLines":64,"startLine":1,"totalLines":64}}}
