{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QyfCZuxPe5dNeXtBs87Ctj","type":"tool_result","content":"1\t/** Cached schema response shape (matches GET /api/schema response). */\n2\texport interface SchemaResponse {\n3\t  event_names: string[];\n4\t  properties: Record<string, Record<string, \"numeric\" | \"string\">>;\n5\t}\n6\t\n7\tconst TTL_MS = 60_000; // 60 seconds\n8\t\n9\tinterface CacheEntry {\n10\t  value: SchemaResponse;\n11\t  cachedAt: number;\n12\t}\n13\t\n14\tlet entry: CacheEntry | null = null;\n15\t\n16\t/** Returns the cached schema if it exists and is within TTL, otherwise null. */\n17\texport function getCachedSchema(): SchemaResponse | null {\n18\t  if (entry === null) return null;\n19\t  if (Date.now() - entry.cachedAt >= TTL_MS) {\n20\t    entry = null;\n21\t    return null;\n22\t  }\n23\t  return entry.value;\n24\t}\n25\t\n26\t/** Stores a new schema response in the cache with the current timestamp. */\n27\texport function setCachedSchema(value: SchemaResponse): void {\n28\t  entry = { value, cachedAt: Date.now() };\n29\t}\n30\t\n31\t/** Clears the cache. Used in tests and when data changes. */\n32\texport function invalidateSchemaCache(): void {\n33\t  entry = null;\n34\t}\n35\t"}]},"parent_tool_use_id":null,"session_id":"cda6f915-37ec-4ede-b4a3-17e09f1601dd","uuid":"3273f065-0b0c-42a3-8f09-8b30178bdc38","timestamp":"2026-04-15T12:53:53.757Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/schema-cache.ts","content":"/** Cached schema response shape (matches GET /api/schema response). */\nexport interface SchemaResponse {\n  event_names: string[];\n  properties: Record<string, Record<string, \"numeric\" | \"string\">>;\n}\n\nconst TTL_MS = 60_000; // 60 seconds\n\ninterface CacheEntry {\n  value: SchemaResponse;\n  cachedAt: number;\n}\n\nlet entry: CacheEntry | null = null;\n\n/** Returns the cached schema if it exists and is within TTL, otherwise null. */\nexport function getCachedSchema(): SchemaResponse | null {\n  if (entry === null) return null;\n  if (Date.now() - entry.cachedAt >= TTL_MS) {\n    entry = null;\n    return null;\n  }\n  return entry.value;\n}\n\n/** Stores a new schema response in the cache with the current timestamp. */\nexport function setCachedSchema(value: SchemaResponse): void {\n  entry = { value, cachedAt: Date.now() };\n}\n\n/** Clears the cache. Used in tests and when data changes. */\nexport function invalidateSchemaCache(): void {\n  entry = null;\n}\n","numLines":35,"startLine":1,"totalLines":35}}}
