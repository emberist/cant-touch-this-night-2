{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014TmvfHUvDDjCWuFHtxLQKb","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\t\n3\t// ─── Types ────────────────────────────────────────────────────────────────────\n4\t\n5\texport interface EventInput {\n6\t  event_name: string;\n7\t  device_id?: string;\n8\t  user_id?: string;\n9\t  timestamp?: string;\n10\t  properties?: Record<string, unknown>;\n11\t}\n12\t\n13\texport interface EventRow {\n14\t  event_id: string;\n15\t  event_name: string;\n16\t  timestamp: string;\n17\t  device_id: string | null;\n18\t  user_id: string | null;\n19\t  properties: string;\n20\t  ingested_at: string;\n21\t  resolved_id: string;\n22\t}\n23\t\n24\texport interface QueryEventsOptions {\n25\t  event_name?: string;\n26\t  resolved_id?: string;\n27\t  /** ISO timestamp cursor — return events strictly before this time */\n28\t  before?: string;\n29\t  limit?: number;\n30\t}\n31\t\n32\t// ─── Error ────────────────────────────────────────────────────────────────────\n33\t\n34\texport class IdentityConflictError extends Error {\n35\t  readonly status = 409 as const;\n36\t\n37\t  constructor(\n38\t    device_id: string,\n39\t    existing_user_id: string,\n40\t    new_user_id: string,\n41\t  ) {\n42\t    super(\n43\t      `Device \"${device_id}\" is already mapped to user \"${existing_user_id}\". Cannot remap to \"${new_user_id}\".`,\n44\t    );\n45\t    this.name = \"IdentityConflictError\";\n46\t    // Maintain correct prototype chain in transpiled environments\n47\t    Object.setPrototypeOf(this, new.target.prototype);\n48\t  }\n49\t}\n50\t\n51\t// ─── Type alias for the ClickHouse client ─────────────────────────────────────\n52\t\n53\ttype ClickHouseClientLike = typeof clickhouse;\n54\t\n55\t// ─── validateEvent ────────────────────────────────────────────────────────────\n56\t\n57\t/**\n58\t * Validates a raw event input object. Throws an Error if invalid.\n59\t * After this call returns, callers may safely treat the input as EventInput.\n60\t */\n61\texport function validateEvent(input: unknown): asserts input is EventInput {\n62\t  if (typeof input !== \"object\" || input === null) {\n63\t    throw new Error(\"Event must be a non-null object.\");\n64\t  }\n65\t  const evt = input as Record<string, unknown>;\n66\t\n67\t  if (typeof evt.event_name !== \"string\" || evt.event_name.trim() === \"\") {\n68\t    throw new Error(\"event_name is required and must be a non-empty string.\");\n69\t  }\n70\t\n71\t  if (!evt.device_id && !evt.user_id) {\n72\t    throw new Error(\"At least one of device_id or user_id must be present.\");\n73\t  }\n74\t}\n75\t\n76\t// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n77\t\n78\t/**\n79\t * Checks identity_mappings FINAL for an existing device → user mapping and:\n80\t * - Inserts a new mapping if none exists.\n81\t * - No-ops if the same mapping already exists (idempotent).\n82\t * - Throws IdentityConflictError (status 409) if the device is mapped to a\n83\t *   different user.\n84\t */\n85\texport async function resolveIdentityMapping(\n86\t  device_id: string,\n87\t  user_id: string,\n88\t  client: ClickHouseClientLike = clickhouse,\n89\t): Promise<void> {\n90\t  const result = await client.query({\n91\t    query:\n92\t      \"SELECT user_id FROM identity_mappings FINAL WHERE device_id = {device_id:String} LIMIT 1\",\n93\t    query_params: { device_id },\n94\t    format: \"JSONEachRow\",\n95\t  });\n96\t\n97\t  const rows = await result.json<{ user_id: string }>();\n98\t\n99\t  if (rows.length === 0) {\n100\t    // No existing mapping — insert\n101\t    await client.insert({\n102\t      table: \"identity_mappings\",\n103\t      values: [{ device_id, user_id }],\n104\t      format: \"JSONEachRow\",\n105\t    });\n106\t    return;\n107\t  }\n108\t\n109\t  const existingUserId = rows[0].user_id;\n110\t\n111\t  if (existingUserId === user_id) {\n112\t    // Same mapping — no-op (idempotent)\n113\t    return;\n114\t  }\n115\t\n116\t  // Different user — conflict\n117\t  throw new IdentityConflictError(device_id, existingUserId, user_id);\n118\t}\n119\t\n120\t// ─── insertEvent ──────────────────────────────────────────────────────────────\n121\t\n122\t/**\n123\t * Validates, timestamps, and inserts a single event. If both device_id and\n124\t * user_id are provided, also writes (or verifies) the identity mapping.\n125\t *\n126\t * Throws IdentityConflictError (status 409) if the device_id is already\n127\t * associated with a different user_id.\n128\t */\n129\texport async function insertEvent(\n130\t  input: unknown,\n131\t  client: ClickHouseClientLike = clickhouse,\n132\t): Promise<EventRow> {\n133\t  validateEvent(input);\n134\t\n135\t  const timestamp = input.timestamp ?? new Date().toISOString();\n136\t  const properties = input.properties ? JSON.stringify(input.properties) : \"{}\";\n137\t  const event_id = crypto.randomUUID();\n138\t  const ingested_at = new Date().toISOString();\n139\t\n140\t  await client.insert({\n141\t    table: \"events\",\n142\t    values: [\n143\t      {\n144\t        event_id,\n145\t        event_name: input.event_name,\n146\t        timestamp,\n147\t        device_id: input.device_id ?? null,\n148\t        user_id: input.user_id ?? null,\n149\t        properties,\n150\t      },\n151\t    ],\n152\t    format: \"JSONEachRow\",\n153\t  });\n154\t\n155\t  if (input.device_id && input.user_id) {\n156\t    await resolveIdentityMapping(input.device_id, input.user_id, client);\n157\t  }\n158\t\n159\t  const resolved_id = input.user_id ?? input.device_id ?? \"\";\n160\t\n161\t  return {\n162\t    event_id,\n163\t    event_name: input.event_name,\n164\t    timestamp,\n165\t    device_id: input.device_id ?? null,\n166\t    user_id: input.user_id ?? null,\n167\t    properties,\n168\t    ingested_at,\n169\t    resolved_id,\n170\t  };\n171\t}\n172\t\n173\t// ─── queryEventsWithResolvedId ────────────────────────────────────────────────\n174\t\n175\t/**\n176\t * Returns events joined with identity_mappings FINAL, with resolved_id\n177\t * computed as coalesce(e.user_id, m.user_id, e.device_id).\n178\t *\n179\t * Optional filters: event_name, resolved_id, before (cursor), limit (max 200).\n180\t */\n181\texport async function queryEventsWithResolvedId(\n182\t  options: QueryEventsOptions = {},\n183\t  client: ClickHouseClientLike = clickhouse,\n184\t): Promise<EventRow[]> {\n185\t  const { event_name, resolved_id, before, limit = 50 } = options;\n186\t\n187\t  const conditions: string[] = [];\n188\t  const params: Record<string, string | number> = {\n189\t    limit: Math.min(limit, 200),\n190\t  };\n191\t\n192\t  if (event_name) {\n193\t    conditions.push(\"e.event_name = {event_name:String}\");\n194\t    params.event_name = event_name;\n195\t  }\n196\t\n197\t  if (before) {\n198\t    conditions.push(\"e.timestamp < {before:String}\");\n199\t    params.before = before;\n200\t  }\n201\t\n202\t  if (resolved_id) {\n203\t    conditions.push(\n204\t      \"coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\",\n205\t    );\n206\t    params.resolved_id = resolved_id;\n207\t  }\n208\t\n209\t  const where =\n210\t    conditions.length > 0 ? `WHERE ${conditions.join(\" AND \")}` : \"\";\n211\t\n212\t  const result = await client.query({\n213\t    query: `\n214\t      SELECT\n215\t        e.event_id,\n216\t        e.event_name,\n217\t        e.timestamp,\n218\t        e.device_id,\n219\t        e.user_id,\n220\t        e.properties,\n221\t        e.ingested_at,\n222\t        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id\n223\t      FROM events e\n224\t      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n225\t        ON e.device_id = m.device_id\n226\t      ${where}\n227\t      ORDER BY e.timestamp DESC, e.event_id DESC\n228\t      LIMIT {limit:UInt64}\n229\t    `,\n230\t    query_params: params,\n231\t    format: \"JSONEachRow\",\n232\t  });\n233\t\n234\t  return result.json<EventRow>();\n235\t}\n236\t\n237\t// ─── getEventsByResolvedId ────────────────────────────────────────────────────\n238\t\n239\t/**\n240\t * Convenience wrapper: returns all events (up to 200) attributed to a given\n241\t * resolved identity (user_id or device_id).\n242\t */\n243\texport async function getEventsByResolvedId(\n244\t  resolved_id: string,\n245\t  client: ClickHouseClientLike = clickhouse,\n246\t): Promise<EventRow[]> {\n247\t  return queryEventsWithResolvedId({ resolved_id, limit: 200 }, client);\n248\t}\n249\t"}]},"parent_tool_use_id":null,"session_id":"555cbb0a-8ca3-4fc2-a2ff-19b5c3d3f176","uuid":"816e024d-cea6-4fdc-bc00-5e0879ca6258","timestamp":"2026-04-15T12:20:01.012Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/identity.ts","content":"import { clickhouse } from \"@/lib/clickhouse\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface EventInput {\n  event_name: string;\n  device_id?: string;\n  user_id?: string;\n  timestamp?: string;\n  properties?: Record<string, unknown>;\n}\n\nexport interface EventRow {\n  event_id: string;\n  event_name: string;\n  timestamp: string;\n  device_id: string | null;\n  user_id: string | null;\n  properties: string;\n  ingested_at: string;\n  resolved_id: string;\n}\n\nexport interface QueryEventsOptions {\n  event_name?: string;\n  resolved_id?: string;\n  /** ISO timestamp cursor — return events strictly before this time */\n  before?: string;\n  limit?: number;\n}\n\n// ─── Error ────────────────────────────────────────────────────────────────────\n\nexport class IdentityConflictError extends Error {\n  readonly status = 409 as const;\n\n  constructor(\n    device_id: string,\n    existing_user_id: string,\n    new_user_id: string,\n  ) {\n    super(\n      `Device \"${device_id}\" is already mapped to user \"${existing_user_id}\". Cannot remap to \"${new_user_id}\".`,\n    );\n    this.name = \"IdentityConflictError\";\n    // Maintain correct prototype chain in transpiled environments\n    Object.setPrototypeOf(this, new.target.prototype);\n  }\n}\n\n// ─── Type alias for the ClickHouse client ─────────────────────────────────────\n\ntype ClickHouseClientLike = typeof clickhouse;\n\n// ─── validateEvent ────────────────────────────────────────────────────────────\n\n/**\n * Validates a raw event input object. Throws an Error if invalid.\n * After this call returns, callers may safely treat the input as EventInput.\n */\nexport function validateEvent(input: unknown): asserts input is EventInput {\n  if (typeof input !== \"object\" || input === null) {\n    throw new Error(\"Event must be a non-null object.\");\n  }\n  const evt = input as Record<string, unknown>;\n\n  if (typeof evt.event_name !== \"string\" || evt.event_name.trim() === \"\") {\n    throw new Error(\"event_name is required and must be a non-empty string.\");\n  }\n\n  if (!evt.device_id && !evt.user_id) {\n    throw new Error(\"At least one of device_id or user_id must be present.\");\n  }\n}\n\n// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n\n/**\n * Checks identity_mappings FINAL for an existing device → user mapping and:\n * - Inserts a new mapping if none exists.\n * - No-ops if the same mapping already exists (idempotent).\n * - Throws IdentityConflictError (status 409) if the device is mapped to a\n *   different user.\n */\nexport async function resolveIdentityMapping(\n  device_id: string,\n  user_id: string,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<void> {\n  const result = await client.query({\n    query:\n      \"SELECT user_id FROM identity_mappings FINAL WHERE device_id = {device_id:String} LIMIT 1\",\n    query_params: { device_id },\n    format: \"JSONEachRow\",\n  });\n\n  const rows = await result.json<{ user_id: string }>();\n\n  if (rows.length === 0) {\n    // No existing mapping — insert\n    await client.insert({\n      table: \"identity_mappings\",\n      values: [{ device_id, user_id }],\n      format: \"JSONEachRow\",\n    });\n    return;\n  }\n\n  const existingUserId = rows[0].user_id;\n\n  if (existingUserId === user_id) {\n    // Same mapping — no-op (idempotent)\n    return;\n  }\n\n  // Different user — conflict\n  throw new IdentityConflictError(device_id, existingUserId, user_id);\n}\n\n// ─── insertEvent ──────────────────────────────────────────────────────────────\n\n/**\n * Validates, timestamps, and inserts a single event. If both device_id and\n * user_id are provided, also writes (or verifies) the identity mapping.\n *\n * Throws IdentityConflictError (status 409) if the device_id is already\n * associated with a different user_id.\n */\nexport async function insertEvent(\n  input: unknown,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<EventRow> {\n  validateEvent(input);\n\n  const timestamp = input.timestamp ?? new Date().toISOString();\n  const properties = input.properties ? JSON.stringify(input.properties) : \"{}\";\n  const event_id = crypto.randomUUID();\n  const ingested_at = new Date().toISOString();\n\n  await client.insert({\n    table: \"events\",\n    values: [\n      {\n        event_id,\n        event_name: input.event_name,\n        timestamp,\n        device_id: input.device_id ?? null,\n        user_id: input.user_id ?? null,\n        properties,\n      },\n    ],\n    format: \"JSONEachRow\",\n  });\n\n  if (input.device_id && input.user_id) {\n    await resolveIdentityMapping(input.device_id, input.user_id, client);\n  }\n\n  const resolved_id = input.user_id ?? input.device_id ?? \"\";\n\n  return {\n    event_id,\n    event_name: input.event_name,\n    timestamp,\n    device_id: input.device_id ?? null,\n    user_id: input.user_id ?? null,\n    properties,\n    ingested_at,\n    resolved_id,\n  };\n}\n\n// ─── queryEventsWithResolvedId ────────────────────────────────────────────────\n\n/**\n * Returns events joined with identity_mappings FINAL, with resolved_id\n * computed as coalesce(e.user_id, m.user_id, e.device_id).\n *\n * Optional filters: event_name, resolved_id, before (cursor), limit (max 200).\n */\nexport async function queryEventsWithResolvedId(\n  options: QueryEventsOptions = {},\n  client: ClickHouseClientLike = clickhouse,\n): Promise<EventRow[]> {\n  const { event_name, resolved_id, before, limit = 50 } = options;\n\n  const conditions: string[] = [];\n  const params: Record<string, string | number> = {\n    limit: Math.min(limit, 200),\n  };\n\n  if (event_name) {\n    conditions.push(\"e.event_name = {event_name:String}\");\n    params.event_name = event_name;\n  }\n\n  if (before) {\n    conditions.push(\"e.timestamp < {before:String}\");\n    params.before = before;\n  }\n\n  if (resolved_id) {\n    conditions.push(\n      \"coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\",\n    );\n    params.resolved_id = resolved_id;\n  }\n\n  const where =\n    conditions.length > 0 ? `WHERE ${conditions.join(\" AND \")}` : \"\";\n\n  const result = await client.query({\n    query: `\n      SELECT\n        e.event_id,\n        e.event_name,\n        e.timestamp,\n        e.device_id,\n        e.user_id,\n        e.properties,\n        e.ingested_at,\n        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id\n      FROM events e\n      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n        ON e.device_id = m.device_id\n      ${where}\n      ORDER BY e.timestamp DESC, e.event_id DESC\n      LIMIT {limit:UInt64}\n    `,\n    query_params: params,\n    format: \"JSONEachRow\",\n  });\n\n  return result.json<EventRow>();\n}\n\n// ─── getEventsByResolvedId ────────────────────────────────────────────────────\n\n/**\n * Convenience wrapper: returns all events (up to 200) attributed to a given\n * resolved identity (user_id or device_id).\n */\nexport async function getEventsByResolvedId(\n  resolved_id: string,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<EventRow[]> {\n  return queryEventsWithResolvedId({ resolved_id, limit: 200 }, client);\n}\n","numLines":249,"startLine":1,"totalLines":249}}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01MwDc4QvTHz3vA6f87EUZbG","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EGK6ELJ1uhFDVMp4Utx8Ay","name":"Read","input":{"file_path":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/identity.test.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":22388,"cache_read_input_tokens":11937,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":22388},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"555cbb0a-8ca3-4fc2-a2ff-19b5c3d3f176","uuid":"b064557b-51af-4d42-bffe-aa507e0a7127"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EGK6ELJ1uhFDVMp4Utx8Ay","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// Hoist mock refs so vi.mock factory can reference them\n4\tconst { mockQuery, mockInsert } = vi.hoisted(() => ({\n5\t  mockQuery: vi.fn(),\n6\t  mockInsert: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: {\n11\t    query: mockQuery,\n12\t    insert: mockInsert,\n13\t  },\n14\t}));\n15\t\n16\timport {\n17\t  IdentityConflictError,\n18\t  insertEvent,\n19\t  resolveIdentityMapping,\n20\t  validateEvent,\n21\t} from \"@/lib/identity\";\n22\t\n23\t// Helper: set up mockQuery to return a given rows array\n24\tfunction mockQueryReturns(rows: unknown[]) {\n25\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n26\t}\n27\t\n28\tbeforeEach(() => {\n29\t  // Default: no existing identity mapping, inserts succeed\n30\t  mockQueryReturns([]);\n31\t  mockInsert.mockResolvedValue(undefined);\n32\t});\n33\t\n34\tafterEach(() => {\n35\t  vi.clearAllMocks();\n36\t});\n37\t\n38\t// ─── validateEvent ────────────────────────────────────────────────────────────\n39\t\n40\tdescribe(\"validateEvent\", () => {\n41\t  it(\"rejects when both device_id and user_id are missing\", () => {\n42\t    expect(() => validateEvent({ event_name: \"Page Viewed\" })).toThrow();\n43\t  });\n44\t\n45\t  it(\"rejects when event_name is missing\", () => {\n46\t    expect(() => validateEvent({ device_id: \"dev-1\" })).toThrow();\n47\t  });\n48\t\n49\t  it(\"rejects when event_name is empty string\", () => {\n50\t    expect(() =>\n51\t      validateEvent({ event_name: \"\", device_id: \"dev-1\" }),\n52\t    ).toThrow();\n53\t  });\n54\t\n55\t  it(\"rejects when event_name is whitespace only\", () => {\n56\t    expect(() =>\n57\t      validateEvent({ event_name: \"  \", device_id: \"dev-1\" }),\n58\t    ).toThrow();\n59\t  });\n60\t\n61\t  it(\"accepts event with only device_id\", () => {\n62\t    expect(() =>\n63\t      validateEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n64\t    ).not.toThrow();\n65\t  });\n66\t\n67\t  it(\"accepts event with only user_id\", () => {\n68\t    expect(() =>\n69\t      validateEvent({ event_name: \"Page Viewed\", user_id: \"user@test.com\" }),\n70\t    ).not.toThrow();\n71\t  });\n72\t\n73\t  it(\"accepts event with both device_id and user_id\", () => {\n74\t    expect(() =>\n75\t      validateEvent({\n76\t        event_name: \"Signup Completed\",\n77\t        device_id: \"dev-1\",\n78\t        user_id: \"user@test.com\",\n79\t      }),\n80\t    ).not.toThrow();\n81\t  });\n82\t});\n83\t\n84\t// ─── insertEvent ──────────────────────────────────────────────────────────────\n85\t\n86\tdescribe(\"insertEvent\", () => {\n87\t  it(\"defaults timestamp to current time when not provided\", async () => {\n88\t    const before = Date.now();\n89\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n90\t    const after = Date.now();\n91\t\n92\t    const insertCall = mockInsert.mock.calls[0][0];\n93\t    const insertedTs = new Date(insertCall.values[0].timestamp).getTime();\n94\t    expect(insertedTs).toBeGreaterThanOrEqual(before);\n95\t    expect(insertedTs).toBeLessThanOrEqual(after);\n96\t  });\n97\t\n98\t  it(\"preserves caller-provided timestamp\", async () => {\n99\t    const ts = \"2026-01-15T10:30:00.000Z\";\n100\t    await insertEvent({\n101\t      event_name: \"Page Viewed\",\n102\t      device_id: \"dev-1\",\n103\t      timestamp: ts,\n104\t    });\n105\t\n106\t    const insertCall = mockInsert.mock.calls[0][0];\n107\t    expect(insertCall.values[0].timestamp).toBe(ts);\n108\t  });\n109\t\n110\t  it(\"inserts event into the events table\", async () => {\n111\t    await insertEvent({\n112\t      event_name: \"Purchase Completed\",\n113\t      user_id: \"user@test.com\",\n114\t      properties: { amount: 49.99 },\n115\t    });\n116\t\n117\t    expect(mockInsert).toHaveBeenCalledWith(\n118\t      expect.objectContaining({ table: \"events\" }),\n119\t    );\n120\t  });\n121\t\n122\t  it(\"stores event_name correctly in the inserted row\", async () => {\n123\t    await insertEvent({ event_name: \"Button Clicked\", device_id: \"dev-2\" });\n124\t\n125\t    const insertCall = mockInsert.mock.calls[0][0];\n126\t    expect(insertCall.values[0].event_name).toBe(\"Button Clicked\");\n127\t  });\n128\t\n129\t  it(\"serialises properties as a JSON string\", async () => {\n130\t    await insertEvent({\n131\t      event_name: \"Page Viewed\",\n132\t      device_id: \"dev-1\",\n133\t      properties: { page: \"/home\", count: 3 },\n134\t    });\n135\t\n136\t    const insertCall = mockInsert.mock.calls[0][0];\n137\t    expect(insertCall.values[0].properties).toBe(\n138\t      JSON.stringify({ page: \"/home\", count: 3 }),\n139\t    );\n140\t  });\n141\t\n142\t  it(\"defaults properties to '{}' when not provided\", async () => {\n143\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n144\t\n145\t    const insertCall = mockInsert.mock.calls[0][0];\n146\t    expect(insertCall.values[0].properties).toBe(\"{}\");\n147\t  });\n148\t\n149\t  it(\"calls resolveIdentityMapping (queries mappings) when both device_id and user_id are present\", async () => {\n150\t    await insertEvent({\n151\t      event_name: \"Signup Completed\",\n152\t      device_id: \"dev-1\",\n153\t      user_id: \"user@test.com\",\n154\t    });\n155\t\n156\t    // resolveIdentityMapping does a SELECT on identity_mappings\n157\t    expect(mockQuery).toHaveBeenCalled();\n158\t  });\n159\t\n160\t  it(\"does NOT call resolveIdentityMapping when only device_id is present\", async () => {\n161\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n162\t\n163\t    expect(mockQuery).not.toHaveBeenCalled();\n164\t  });\n165\t\n166\t  it(\"does NOT call resolveIdentityMapping when only user_id is present\", async () => {\n167\t    await insertEvent({\n168\t      event_name: \"Purchase Completed\",\n169\t      user_id: \"user@test.com\",\n170\t    });\n171\t\n172\t    expect(mockQuery).not.toHaveBeenCalled();\n173\t  });\n174\t\n175\t  it(\"returns an EventRow with resolved_id set to user_id when user_id is present\", async () => {\n176\t    const result = await insertEvent({\n177\t      event_name: \"Purchase Completed\",\n178\t      device_id: \"dev-1\",\n179\t      user_id: \"user@test.com\",\n180\t    });\n181\t\n182\t    expect(result.resolved_id).toBe(\"user@test.com\");\n183\t  });\n184\t\n185\t  it(\"returns an EventRow with resolved_id set to device_id when only device_id is present\", async () => {\n186\t    const result = await insertEvent({\n187\t      event_name: \"Page Viewed\",\n188\t      device_id: \"dev-1\",\n189\t    });\n190\t\n191\t    expect(result.resolved_id).toBe(\"dev-1\");\n192\t  });\n193\t});\n194\t\n195\t// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n196\t\n197\tdescribe(\"resolveIdentityMapping\", () => {\n198\t  it(\"inserts a new mapping when no existing mapping is found\", async () => {\n199\t    mockQueryReturns([]); // no existing mapping\n200\t\n201\t    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n202\t\n203\t    expect(mockInsert).toHaveBeenCalledWith(\n204\t      expect.objectContaining({\n205\t        table: \"identity_mappings\",\n206\t        values: [{ device_id: \"dev-1\", user_id: \"user@test.com\" }],\n207\t      }),\n208\t    );\n209\t  });\n210\t\n211\t  it(\"is a no-op when existing mapping has the same user_id\", async () => {\n212\t    mockQueryReturns([{ user_id: \"user@test.com\" }]); // same user already mapped\n213\t\n214\t    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n215\t\n216\t    expect(mockInsert).not.toHaveBeenCalled();\n217\t  });\n218\t\n219\t  it(\"throws IdentityConflictError when existing mapping has a different user_id\", async () => {\n220\t    mockQueryReturns([{ user_id: \"other@test.com\" }]); // different user already mapped\n221\t\n222\t    await expect(\n223\t      resolveIdentityMapping(\"dev-1\", \"user@test.com\"),\n224\t    ).rejects.toThrow(IdentityConflictError);\n225\t  });\n226\t\n227\t  it(\"IdentityConflictError has status 409\", async () => {\n228\t    mockQueryReturns([{ user_id: \"other@test.com\" }]);\n229\t\n230\t    try {\n231\t      await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n232\t      expect.fail(\"should have thrown\");\n233\t    } catch (err) {\n234\t      expect(err).toBeInstanceOf(IdentityConflictError);\n235\t      expect((err as IdentityConflictError).status).toBe(409);\n236\t    }\n237\t  });\n238\t});\n239\t"}]},"parent_tool_use_id":null,"session_id":"555cbb0a-8ca3-4fc2-a2ff-19b5c3d3f176","uuid":"f538607b-3e58-4e8f-830a-04bcc8c79556","timestamp":"2026-04-15T12:20:01.728Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/identity.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// Hoist mock refs so vi.mock factory can reference them\nconst { mockQuery, mockInsert } = vi.hoisted(() => ({\n  mockQuery: vi.fn(),\n  mockInsert: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    query: mockQuery,\n    insert: mockInsert,\n  },\n}));\n\nimport {\n  IdentityConflictError,\n  insertEvent,\n  resolveIdentityMapping,\n  validateEvent,\n} from \"@/lib/identity\";\n\n// Helper: set up mockQuery to return a given rows array\nfunction mockQueryReturns(rows: unknown[]) {\n  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n}\n\nbeforeEach(() => {\n  // Default: no existing identity mapping, inserts succeed\n  mockQueryReturns([]);\n  mockInsert.mockResolvedValue(undefined);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\n// ─── validateEvent ────────────────────────────────────────────────────────────\n\ndescribe(\"validateEvent\", () => {\n  it(\"rejects when both device_id and user_id are missing\", () => {\n    expect(() => validateEvent({ event_name: \"Page Viewed\" })).toThrow();\n  });\n\n  it(\"rejects when event_name is missing\", () => {\n    expect(() => validateEvent({ device_id: \"dev-1\" })).toThrow();\n  });\n\n  it(\"rejects when event_name is empty string\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"\", device_id: \"dev-1\" }),\n    ).toThrow();\n  });\n\n  it(\"rejects when event_name is whitespace only\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"  \", device_id: \"dev-1\" }),\n    ).toThrow();\n  });\n\n  it(\"accepts event with only device_id\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n    ).not.toThrow();\n  });\n\n  it(\"accepts event with only user_id\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"Page Viewed\", user_id: \"user@test.com\" }),\n    ).not.toThrow();\n  });\n\n  it(\"accepts event with both device_id and user_id\", () => {\n    expect(() =>\n      validateEvent({\n        event_name: \"Signup Completed\",\n        device_id: \"dev-1\",\n        user_id: \"user@test.com\",\n      }),\n    ).not.toThrow();\n  });\n});\n\n// ─── insertEvent ──────────────────────────────────────────────────────────────\n\ndescribe(\"insertEvent\", () => {\n  it(\"defaults timestamp to current time when not provided\", async () => {\n    const before = Date.now();\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n    const after = Date.now();\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    const insertedTs = new Date(insertCall.values[0].timestamp).getTime();\n    expect(insertedTs).toBeGreaterThanOrEqual(before);\n    expect(insertedTs).toBeLessThanOrEqual(after);\n  });\n\n  it(\"preserves caller-provided timestamp\", async () => {\n    const ts = \"2026-01-15T10:30:00.000Z\";\n    await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n      timestamp: ts,\n    });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].timestamp).toBe(ts);\n  });\n\n  it(\"inserts event into the events table\", async () => {\n    await insertEvent({\n      event_name: \"Purchase Completed\",\n      user_id: \"user@test.com\",\n      properties: { amount: 49.99 },\n    });\n\n    expect(mockInsert).toHaveBeenCalledWith(\n      expect.objectContaining({ table: \"events\" }),\n    );\n  });\n\n  it(\"stores event_name correctly in the inserted row\", async () => {\n    await insertEvent({ event_name: \"Button Clicked\", device_id: \"dev-2\" });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].event_name).toBe(\"Button Clicked\");\n  });\n\n  it(\"serialises properties as a JSON string\", async () => {\n    await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n      properties: { page: \"/home\", count: 3 },\n    });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].properties).toBe(\n      JSON.stringify({ page: \"/home\", count: 3 }),\n    );\n  });\n\n  it(\"defaults properties to '{}' when not provided\", async () => {\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].properties).toBe(\"{}\");\n  });\n\n  it(\"calls resolveIdentityMapping (queries mappings) when both device_id and user_id are present\", async () => {\n    await insertEvent({\n      event_name: \"Signup Completed\",\n      device_id: \"dev-1\",\n      user_id: \"user@test.com\",\n    });\n\n    // resolveIdentityMapping does a SELECT on identity_mappings\n    expect(mockQuery).toHaveBeenCalled();\n  });\n\n  it(\"does NOT call resolveIdentityMapping when only device_id is present\", async () => {\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n\n    expect(mockQuery).not.toHaveBeenCalled();\n  });\n\n  it(\"does NOT call resolveIdentityMapping when only user_id is present\", async () => {\n    await insertEvent({\n      event_name: \"Purchase Completed\",\n      user_id: \"user@test.com\",\n    });\n\n    expect(mockQuery).not.toHaveBeenCalled();\n  });\n\n  it(\"returns an EventRow with resolved_id set to user_id when user_id is present\", async () => {\n    const result = await insertEvent({\n      event_name: \"Purchase Completed\",\n      device_id: \"dev-1\",\n      user_id: \"user@test.com\",\n    });\n\n    expect(result.resolved_id).toBe(\"user@test.com\");\n  });\n\n  it(\"returns an EventRow with resolved_id set to device_id when only device_id is present\", async () => {\n    const result = await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n    });\n\n    expect(result.resolved_id).toBe(\"dev-1\");\n  });\n});\n\n// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n\ndescribe(\"resolveIdentityMapping\", () => {\n  it(\"inserts a new mapping when no existing mapping is found\", async () => {\n    mockQueryReturns([]); // no existing mapping\n\n    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n\n    expect(mockInsert).toHaveBeenCalledWith(\n      expect.objectContaining({\n        table: \"identity_mappings\",\n        values: [{ device_id: \"dev-1\", user_id: \"user@test.com\" }],\n      }),\n    );\n  });\n\n  it(\"is a no-op when existing mapping has the same user_id\", async () => {\n    mockQueryReturns([{ user_id: \"user@test.com\" }]); // same user already mapped\n\n    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n\n    expect(mockInsert).not.toHaveBeenCalled();\n  });\n\n  it(\"throws IdentityConflictError when existing mapping has a different user_id\", async () => {\n    mockQueryReturns([{ user_id: \"other@test.com\" }]); // different user already mapped\n\n    await expect(\n      resolveIdentityMapping(\"dev-1\", \"user@test.com\"),\n    ).rejects.toThrow(IdentityConflictError);\n  });\n\n  it(\"IdentityConflictError has status 409\", async () => {\n    mockQueryReturns([{ user_id: \"other@test.com\" }]);\n\n    try {\n      await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n      expect.fail(\"should have thrown\");\n    } catch (err) {\n      expect(err).toBeInstanceOf(IdentityConflictError);\n      expect((err as IdentityConflictError).status).toBe(409);\n    }\n  });\n});\n","numLines":239,"startLine":1,"totalLines":239}}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01MwDc4QvTHz3vA6f87EUZbG","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GKBVNqbcyGgtMX9m6iF7nx","name":"Read","input":{"file_path":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/identity.integration.test.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":22388,"cache_read_input_tokens":11937,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":22388},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"555cbb0a-8ca3-4fc2-a2ff-19b5c3d3f176","uuid":"84001140-463d-480a-a4f6-4cc714364d87"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GKBVNqbcyGgtMX9m6iF7nx","type":"tool_result","content":"1\t/**\n2\t * Integration tests for identity resolution (BR-101).\n3\t * Requires a running ClickHouse server at localhost:8123 (or CLICKHOUSE_URL).\n4\t * Uses a dedicated `minipanel_test` database — never touches `minipanel`.\n5\t *\n6\t * Run with: pnpm test (requires ./clickhouse server -- --path=.clickhouse)\n7\t */\n8\t\n9\timport { createClient } from \"@clickhouse/client\";\n10\timport { afterAll, afterEach, beforeAll, describe, expect, it } from \"vitest\";\n11\timport {\n12\t  getEventsByResolvedId,\n13\t  IdentityConflictError,\n14\t  insertEvent,\n15\t  queryEventsWithResolvedId,\n16\t} from \"@/lib/identity\";\n17\t\n18\tconst CLICKHOUSE_URL = process.env.CLICKHOUSE_URL ?? \"http://localhost:8123\";\n19\tconst TEST_DB = \"minipanel_test\";\n20\t\n21\tasync function isClickHouseReachable(): Promise<boolean> {\n22\t  try {\n23\t    const res = await fetch(`${CLICKHOUSE_URL}/ping`, {\n24\t      signal: AbortSignal.timeout(2000),\n25\t    });\n26\t    return res.ok;\n27\t  } catch {\n28\t    return false;\n29\t  }\n30\t}\n31\t\n32\t// Test-scoped client — always uses minipanel_test\n33\tconst testClient = createClient({\n34\t  url: CLICKHOUSE_URL,\n35\t  database: TEST_DB,\n36\t  password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n37\t});\n38\t\n39\tdescribe.skipIf(!(await isClickHouseReachable()))(\n40\t  \"identity integration — real ClickHouse (minipanel_test)\",\n41\t  () => {\n42\t    beforeAll(async () => {\n43\t      // Create test database and tables (idempotent)\n44\t      const adminClient = createClient({\n45\t        url: CLICKHOUSE_URL,\n46\t        password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n47\t      });\n48\t\n49\t      await adminClient.command({\n50\t        query: `CREATE DATABASE IF NOT EXISTS ${TEST_DB}`,\n51\t      });\n52\t\n53\t      await adminClient.command({\n54\t        query: `\n55\t          CREATE TABLE IF NOT EXISTS ${TEST_DB}.events\n56\t          (\n57\t            event_id    UUID                     DEFAULT generateUUIDv4(),\n58\t            event_name  LowCardinality(String),\n59\t            timestamp   DateTime64(3, 'UTC'),\n60\t            device_id   Nullable(String),\n61\t            user_id     Nullable(String),\n62\t            properties  String,\n63\t            ingested_at DateTime64(3, 'UTC')     DEFAULT now64()\n64\t          )\n65\t          ENGINE = MergeTree()\n66\t          ORDER BY (timestamp, event_id)\n67\t          PARTITION BY toYYYYMM(timestamp)\n68\t        `,\n69\t      });\n70\t\n71\t      await adminClient.command({\n72\t        query: `\n73\t          CREATE TABLE IF NOT EXISTS ${TEST_DB}.identity_mappings\n74\t          (\n75\t            device_id  String,\n76\t            user_id    String,\n77\t            created_at DateTime64(3, 'UTC') DEFAULT now64()\n78\t          )\n79\t          ENGINE = ReplacingMergeTree(created_at)\n80\t          ORDER BY (device_id)\n81\t        `,\n82\t      });\n83\t\n84\t      await adminClient.close();\n85\t    });\n86\t\n87\t    afterAll(async () => {\n88\t      await testClient.close();\n89\t    });\n90\t\n91\t    afterEach(async () => {\n92\t      // Truncate after every test to keep isolation\n93\t      await testClient.command({ query: \"TRUNCATE TABLE events\" });\n94\t      await testClient.command({ query: \"TRUNCATE TABLE identity_mappings\" });\n95\t    });\n96\t\n97\t    // ── BR-101 Scenario 1 ─────────────────────────────────────────────────────\n98\t    it(\"BR-101 S1: anonymous event followed by identify event → all events attributed to user (retroactive merge)\", async () => {\n99\t      // Anonymous event (device only)\n100\t      await insertEvent(\n101\t        { event_name: \"Page Viewed\", device_id: \"dev-s1\" },\n102\t        testClient,\n103\t      );\n104\t\n105\t      // Identify event (links device to user)\n106\t      await insertEvent(\n107\t        {\n108\t          event_name: \"Signup Completed\",\n109\t          device_id: \"dev-s1\",\n110\t          user_id: \"user-s1@test.com\",\n111\t        },\n112\t        testClient,\n113\t      );\n114\t\n115\t      // Query by user's resolved_id — should return BOTH events\n116\t      const events = await queryEventsWithResolvedId(\n117\t        { resolved_id: \"user-s1@test.com\", limit: 50 },\n118\t        testClient,\n119\t      );\n120\t\n121\t      expect(events.length).toBe(2);\n122\t      expect(events.every((e) => e.resolved_id === \"user-s1@test.com\")).toBe(\n123\t        true,\n124\t      );\n125\t    });\n126\t\n127\t    // ── BR-101 Scenario 2 ─────────────────────────────────────────────────────\n128\t    it(\"BR-101 S2: two devices linked to same user → events from both devices returned\", async () => {\n129\t      await insertEvent(\n130\t        {\n131\t          event_name: \"Page Viewed\",\n132\t          device_id: \"dev-s2a\",\n133\t          user_id: \"user-s2@test.com\",\n134\t        },\n135\t        testClient,\n136\t      );\n137\t\n138\t      await insertEvent(\n139\t        {\n140\t          event_name: \"Button Clicked\",\n141\t          device_id: \"dev-s2b\",\n142\t          user_id: \"user-s2@test.com\",\n143\t        },\n144\t        testClient,\n145\t      );\n146\t\n147\t      const events = await getEventsByResolvedId(\n148\t        \"user-s2@test.com\",\n149\t        testClient,\n150\t      );\n151\t\n152\t      expect(events.length).toBe(2);\n153\t      const deviceIds = events.map((e) => e.device_id);\n154\t      expect(deviceIds).toContain(\"dev-s2a\");\n155\t      expect(deviceIds).toContain(\"dev-s2b\");\n156\t    });\n157\t\n158\t    // ── BR-101 Scenario 3 ─────────────────────────────────────────────────────\n159\t    it(\"BR-101 S3: device mapped to two different users → second mapping throws IdentityConflictError (409)\", async () => {\n160\t      // First mapping\n161\t      await insertEvent(\n162\t        {\n163\t          event_name: \"Signup Completed\",\n164\t          device_id: \"dev-s3\",\n165\t          user_id: \"user-s3a@test.com\",\n166\t        },\n167\t        testClient,\n168\t      );\n169\t\n170\t      // Second mapping to a different user — must reject\n171\t      await expect(\n172\t        insertEvent(\n173\t          {\n174\t            event_name: \"Purchase Completed\",\n175\t            device_id: \"dev-s3\",\n176\t            user_id: \"user-s3b@test.com\",\n177\t          },\n178\t          testClient,\n179\t        ),\n180\t      ).rejects.toThrow(IdentityConflictError);\n181\t    });\n182\t\n183\t    it(\"BR-101 S3: IdentityConflictError has status 409\", async () => {\n184\t      await insertEvent(\n185\t        {\n186\t          event_name: \"Signup Completed\",\n187\t          device_id: \"dev-s3x\",\n188\t          user_id: \"user-s3x-a@test.com\",\n189\t        },\n190\t        testClient,\n191\t      );\n192\t\n193\t      try {\n194\t        await insertEvent(\n195\t          {\n196\t            event_name: \"Page Viewed\",\n197\t            device_id: \"dev-s3x\",\n198\t            user_id: \"user-s3x-b@test.com\",\n199\t          },\n200\t          testClient,\n201\t        );\n202\t        expect.fail(\"should have thrown\");\n203\t      } catch (err) {\n204\t        expect(err).toBeInstanceOf(IdentityConflictError);\n205\t        expect((err as IdentityConflictError).status).toBe(409);\n206\t      }\n207\t    });\n208\t\n209\t    // ── BR-101 Scenario 4 ─────────────────────────────────────────────────────\n210\t    it(\"BR-101 S4: same device + same user sent twice → second call succeeds (idempotent)\", async () => {\n211\t      await insertEvent(\n212\t        {\n213\t          event_name: \"Signup Completed\",\n214\t          device_id: \"dev-s4\",\n215\t          user_id: \"user-s4@test.com\",\n216\t        },\n217\t        testClient,\n218\t      );\n219\t\n220\t      // Identical mapping — must not throw\n221\t      await expect(\n222\t        insertEvent(\n223\t          {\n224\t            event_name: \"Page Viewed\",\n225\t            device_id: \"dev-s4\",\n226\t            user_id: \"user-s4@test.com\",\n227\t          },\n228\t          testClient,\n229\t        ),\n230\t      ).resolves.not.toThrow();\n231\t\n232\t      // Both events inserted\n233\t      const events = await getEventsByResolvedId(\n234\t        \"user-s4@test.com\",\n235\t        testClient,\n236\t      );\n237\t      expect(events.length).toBe(2);\n238\t    });\n239\t  },\n240\t);\n241\t"}]},"parent_tool_use_id":null,"session_id":"555cbb0a-8ca3-4fc2-a2ff-19b5c3d3f176","uuid":"b8f75b00-b7e3-4641-ad17-68b5a218a0d3","timestamp":"2026-04-15T12:20:02.052Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/identity.integration.test.ts","content":"/**\n * Integration tests for identity resolution (BR-101).\n * Requires a running ClickHouse server at localhost:8123 (or CLICKHOUSE_URL).\n * Uses a dedicated `minipanel_test` database — never touches `minipanel`.\n *\n * Run with: pnpm test (requires ./clickhouse server -- --path=.clickhouse)\n */\n\nimport { createClient } from \"@clickhouse/client\";\nimport { afterAll, afterEach, beforeAll, describe, expect, it } from \"vitest\";\nimport {\n  getEventsByResolvedId,\n  IdentityConflictError,\n  insertEvent,\n  queryEventsWithResolvedId,\n} from \"@/lib/identity\";\n\nconst CLICKHOUSE_URL = process.env.CLICKHOUSE_URL ?? \"http://localhost:8123\";\nconst TEST_DB = \"minipanel_test\";\n\nasync function isClickHouseReachable(): Promise<boolean> {\n  try {\n    const res = await fetch(`${CLICKHOUSE_URL}/ping`, {\n      signal: AbortSignal.timeout(2000),\n    });\n    return res.ok;\n  } catch {\n    return false;\n  }\n}\n\n// Test-scoped client — always uses minipanel_test\nconst testClient = createClient({\n  url: CLICKHOUSE_URL,\n  database: TEST_DB,\n  password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n});\n\ndescribe.skipIf(!(await isClickHouseReachable()))(\n  \"identity integration — real ClickHouse (minipanel_test)\",\n  () => {\n    beforeAll(async () => {\n      // Create test database and tables (idempotent)\n      const adminClient = createClient({\n        url: CLICKHOUSE_URL,\n        password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n      });\n\n      await adminClient.command({\n        query: `CREATE DATABASE IF NOT EXISTS ${TEST_DB}`,\n      });\n\n      await adminClient.command({\n        query: `\n          CREATE TABLE IF NOT EXISTS ${TEST_DB}.events\n          (\n            event_id    UUID                     DEFAULT generateUUIDv4(),\n            event_name  LowCardinality(String),\n            timestamp   DateTime64(3, 'UTC'),\n            device_id   Nullable(String),\n            user_id     Nullable(String),\n            properties  String,\n            ingested_at DateTime64(3, 'UTC')     DEFAULT now64()\n          )\n          ENGINE = MergeTree()\n          ORDER BY (timestamp, event_id)\n          PARTITION BY toYYYYMM(timestamp)\n        `,\n      });\n\n      await adminClient.command({\n        query: `\n          CREATE TABLE IF NOT EXISTS ${TEST_DB}.identity_mappings\n          (\n            device_id  String,\n            user_id    String,\n            created_at DateTime64(3, 'UTC') DEFAULT now64()\n          )\n          ENGINE = ReplacingMergeTree(created_at)\n          ORDER BY (device_id)\n        `,\n      });\n\n      await adminClient.close();\n    });\n\n    afterAll(async () => {\n      await testClient.close();\n    });\n\n    afterEach(async () => {\n      // Truncate after every test to keep isolation\n      await testClient.command({ query: \"TRUNCATE TABLE events\" });\n      await testClient.command({ query: \"TRUNCATE TABLE identity_mappings\" });\n    });\n\n    // ── BR-101 Scenario 1 ─────────────────────────────────────────────────────\n    it(\"BR-101 S1: anonymous event followed by identify event → all events attributed to user (retroactive merge)\", async () => {\n      // Anonymous event (device only)\n      await insertEvent(\n        { event_name: \"Page Viewed\", device_id: \"dev-s1\" },\n        testClient,\n      );\n\n      // Identify event (links device to user)\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s1\",\n          user_id: \"user-s1@test.com\",\n        },\n        testClient,\n      );\n\n      // Query by user's resolved_id — should return BOTH events\n      const events = await queryEventsWithResolvedId(\n        { resolved_id: \"user-s1@test.com\", limit: 50 },\n        testClient,\n      );\n\n      expect(events.length).toBe(2);\n      expect(events.every((e) => e.resolved_id === \"user-s1@test.com\")).toBe(\n        true,\n      );\n    });\n\n    // ── BR-101 Scenario 2 ─────────────────────────────────────────────────────\n    it(\"BR-101 S2: two devices linked to same user → events from both devices returned\", async () => {\n      await insertEvent(\n        {\n          event_name: \"Page Viewed\",\n          device_id: \"dev-s2a\",\n          user_id: \"user-s2@test.com\",\n        },\n        testClient,\n      );\n\n      await insertEvent(\n        {\n          event_name: \"Button Clicked\",\n          device_id: \"dev-s2b\",\n          user_id: \"user-s2@test.com\",\n        },\n        testClient,\n      );\n\n      const events = await getEventsByResolvedId(\n        \"user-s2@test.com\",\n        testClient,\n      );\n\n      expect(events.length).toBe(2);\n      const deviceIds = events.map((e) => e.device_id);\n      expect(deviceIds).toContain(\"dev-s2a\");\n      expect(deviceIds).toContain(\"dev-s2b\");\n    });\n\n    // ── BR-101 Scenario 3 ─────────────────────────────────────────────────────\n    it(\"BR-101 S3: device mapped to two different users → second mapping throws IdentityConflictError (409)\", async () => {\n      // First mapping\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s3\",\n          user_id: \"user-s3a@test.com\",\n        },\n        testClient,\n      );\n\n      // Second mapping to a different user — must reject\n      await expect(\n        insertEvent(\n          {\n            event_name: \"Purchase Completed\",\n            device_id: \"dev-s3\",\n            user_id: \"user-s3b@test.com\",\n          },\n          testClient,\n        ),\n      ).rejects.toThrow(IdentityConflictError);\n    });\n\n    it(\"BR-101 S3: IdentityConflictError has status 409\", async () => {\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s3x\",\n          user_id: \"user-s3x-a@test.com\",\n        },\n        testClient,\n      );\n\n      try {\n        await insertEvent(\n          {\n            event_name: \"Page Viewed\",\n            device_id: \"dev-s3x\",\n            user_id: \"user-s3x-b@test.com\",\n          },\n          testClient,\n        );\n        expect.fail(\"should have thrown\");\n      } catch (err) {\n        expect(err).toBeInstanceOf(IdentityConflictError);\n        expect((err as IdentityConflictError).status).toBe(409);\n      }\n    });\n\n    // ── BR-101 Scenario 4 ─────────────────────────────────────────────────────\n    it(\"BR-101 S4: same device + same user sent twice → second call succeeds (idempotent)\", async () => {\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s4\",\n          user_id: \"user-s4@test.com\",\n        },\n        testClient,\n      );\n\n      // Identical mapping — must not throw\n      await expect(\n        insertEvent(\n          {\n            event_name: \"Page Viewed\",\n            device_id: \"dev-s4\",\n            user_id: \"user-s4@test.com\",\n          },\n          testClient,\n        ),\n      ).resolves.not.toThrow();\n\n      // Both events inserted\n      const events = await getEventsByResolvedId(\n        \"user-s4@test.com\",\n        testClient,\n      );\n      expect(events.length).toBe(2);\n    });\n  },\n);\n","numLines":241,"startLine":1,"totalLines":241}}}
