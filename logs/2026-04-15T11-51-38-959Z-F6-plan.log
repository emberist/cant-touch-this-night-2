{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W7ZVqsAtgSHe7v63LtWa4m","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\t\n3\t// ─── Types ────────────────────────────────────────────────────────────────────\n4\t\n5\texport interface EventInput {\n6\t  event_name: string;\n7\t  device_id?: string;\n8\t  user_id?: string;\n9\t  timestamp?: string;\n10\t  properties?: Record<string, unknown>;\n11\t}\n12\t\n13\texport interface EventRow {\n14\t  event_id: string;\n15\t  event_name: string;\n16\t  timestamp: string;\n17\t  device_id: string | null;\n18\t  user_id: string | null;\n19\t  properties: string;\n20\t  ingested_at: string;\n21\t  resolved_id: string;\n22\t}\n23\t\n24\texport interface QueryEventsOptions {\n25\t  event_name?: string;\n26\t  resolved_id?: string;\n27\t  /** ISO timestamp cursor — return events strictly before this time */\n28\t  before?: string;\n29\t  limit?: number;\n30\t}\n31\t\n32\t// ─── Error ────────────────────────────────────────────────────────────────────\n33\t\n34\texport class IdentityConflictError extends Error {\n35\t  readonly status = 409 as const;\n36\t\n37\t  constructor(\n38\t    device_id: string,\n39\t    existing_user_id: string,\n40\t    new_user_id: string,\n41\t  ) {\n42\t    super(\n43\t      `Device \"${device_id}\" is already mapped to user \"${existing_user_id}\". Cannot remap to \"${new_user_id}\".`,\n44\t    );\n45\t    this.name = \"IdentityConflictError\";\n46\t    // Maintain correct prototype chain in transpiled environments\n47\t    Object.setPrototypeOf(this, new.target.prototype);\n48\t  }\n49\t}\n50\t\n51\t// ─── Type alias for the ClickHouse client ─────────────────────────────────────\n52\t\n53\ttype ClickHouseClientLike = typeof clickhouse;\n54\t\n55\t// ─── validateEvent ────────────────────────────────────────────────────────────\n56\t\n57\t/**\n58\t * Validates a raw event input object. Throws an Error if invalid.\n59\t * After this call returns, callers may safely treat the input as EventInput.\n60\t */\n61\texport function validateEvent(input: unknown): asserts input is EventInput {\n62\t  if (typeof input !== \"object\" || input === null) {\n63\t    throw new Error(\"Event must be a non-null object.\");\n64\t  }\n65\t  const evt = input as Record<string, unknown>;\n66\t\n67\t  if (typeof evt.event_name !== \"string\" || evt.event_name.trim() === \"\") {\n68\t    throw new Error(\"event_name is required and must be a non-empty string.\");\n69\t  }\n70\t\n71\t  if (!evt.device_id && !evt.user_id) {\n72\t    throw new Error(\"At least one of device_id or user_id must be present.\");\n73\t  }\n74\t}\n75\t\n76\t// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n77\t\n78\t/**\n79\t * Checks identity_mappings FINAL for an existing device → user mapping and:\n80\t * - Inserts a new mapping if none exists.\n81\t * - No-ops if the same mapping already exists (idempotent).\n82\t * - Throws IdentityConflictError (status 409) if the device is mapped to a\n83\t *   different user.\n84\t */\n85\texport async function resolveIdentityMapping(\n86\t  device_id: string,\n87\t  user_id: string,\n88\t  client: ClickHouseClientLike = clickhouse,\n89\t): Promise<void> {\n90\t  const result = await client.query({\n91\t    query:\n92\t      \"SELECT user_id FROM identity_mappings FINAL WHERE device_id = {device_id:String} LIMIT 1\",\n93\t    query_params: { device_id },\n94\t    format: \"JSONEachRow\",\n95\t  });\n96\t\n97\t  const rows = await result.json<{ user_id: string }>();\n98\t\n99\t  if (rows.length === 0) {\n100\t    // No existing mapping — insert\n101\t    await client.insert({\n102\t      table: \"identity_mappings\",\n103\t      values: [{ device_id, user_id }],\n104\t      format: \"JSONEachRow\",\n105\t    });\n106\t    return;\n107\t  }\n108\t\n109\t  const existingUserId = rows[0].user_id;\n110\t\n111\t  if (existingUserId === user_id) {\n112\t    // Same mapping — no-op (idempotent)\n113\t    return;\n114\t  }\n115\t\n116\t  // Different user — conflict\n117\t  throw new IdentityConflictError(device_id, existingUserId, user_id);\n118\t}\n119\t\n120\t// ─── insertEvent ──────────────────────────────────────────────────────────────\n121\t\n122\t/**\n123\t * Validates, timestamps, and inserts a single event. If both device_id and\n124\t * user_id are provided, also writes (or verifies) the identity mapping.\n125\t *\n126\t * Throws IdentityConflictError (status 409) if the device_id is already\n127\t * associated with a different user_id.\n128\t */\n129\texport async function insertEvent(\n130\t  input: unknown,\n131\t  client: ClickHouseClientLike = clickhouse,\n132\t): Promise<EventRow> {\n133\t  validateEvent(input);\n134\t\n135\t  const timestamp = input.timestamp ?? new Date().toISOString();\n136\t  const properties = input.properties ? JSON.stringify(input.properties) : \"{}\";\n137\t  const event_id = crypto.randomUUID();\n138\t  const ingested_at = new Date().toISOString();\n139\t\n140\t  await client.insert({\n141\t    table: \"events\",\n142\t    values: [\n143\t      {\n144\t        event_id,\n145\t        event_name: input.event_name,\n146\t        timestamp,\n147\t        device_id: input.device_id ?? null,\n148\t        user_id: input.user_id ?? null,\n149\t        properties,\n150\t      },\n151\t    ],\n152\t    format: \"JSONEachRow\",\n153\t  });\n154\t\n155\t  if (input.device_id && input.user_id) {\n156\t    await resolveIdentityMapping(input.device_id, input.user_id, client);\n157\t  }\n158\t\n159\t  const resolved_id = input.user_id ?? input.device_id ?? \"\";\n160\t\n161\t  return {\n162\t    event_id,\n163\t    event_name: input.event_name,\n164\t    timestamp,\n165\t    device_id: input.device_id ?? null,\n166\t    user_id: input.user_id ?? null,\n167\t    properties,\n168\t    ingested_at,\n169\t    resolved_id,\n170\t  };\n171\t}\n172\t\n173\t// ─── queryEventsWithResolvedId ────────────────────────────────────────────────\n174\t\n175\t/**\n176\t * Returns events joined with identity_mappings FINAL, with resolved_id\n177\t * computed as coalesce(e.user_id, m.user_id, e.device_id).\n178\t *\n179\t * Optional filters: event_name, resolved_id, before (cursor), limit (max 200).\n180\t */\n181\texport async function queryEventsWithResolvedId(\n182\t  options: QueryEventsOptions = {},\n183\t  client: ClickHouseClientLike = clickhouse,\n184\t): Promise<EventRow[]> {\n185\t  const { event_name, resolved_id, before, limit = 50 } = options;\n186\t\n187\t  const conditions: string[] = [];\n188\t  const params: Record<string, string | number> = {\n189\t    limit: Math.min(limit, 200),\n190\t  };\n191\t\n192\t  if (event_name) {\n193\t    conditions.push(\"e.event_name = {event_name:String}\");\n194\t    params.event_name = event_name;\n195\t  }\n196\t\n197\t  if (before) {\n198\t    conditions.push(\"e.timestamp < {before:String}\");\n199\t    params.before = before;\n200\t  }\n201\t\n202\t  if (resolved_id) {\n203\t    conditions.push(\n204\t      \"coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\",\n205\t    );\n206\t    params.resolved_id = resolved_id;\n207\t  }\n208\t\n209\t  const where =\n210\t    conditions.length > 0 ? `WHERE ${conditions.join(\" AND \")}` : \"\";\n211\t\n212\t  const result = await client.query({\n213\t    query: `\n214\t      SELECT\n215\t        e.event_id,\n216\t        e.event_name,\n217\t        e.timestamp,\n218\t        e.device_id,\n219\t        e.user_id,\n220\t        e.properties,\n221\t        e.ingested_at,\n222\t        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id\n223\t      FROM events e\n224\t      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n225\t        ON e.device_id = m.device_id\n226\t      ${where}\n227\t      ORDER BY e.timestamp DESC, e.event_id DESC\n228\t      LIMIT {limit:UInt64}\n229\t    `,\n230\t    query_params: params,\n231\t    format: \"JSONEachRow\",\n232\t  });\n233\t\n234\t  return result.json<EventRow>();\n235\t}\n236\t\n237\t// ─── getEventsByResolvedId ────────────────────────────────────────────────────\n238\t\n239\t/**\n240\t * Convenience wrapper: returns all events (up to 200) attributed to a given\n241\t * resolved identity (user_id or device_id).\n242\t */\n243\texport async function getEventsByResolvedId(\n244\t  resolved_id: string,\n245\t  client: ClickHouseClientLike = clickhouse,\n246\t): Promise<EventRow[]> {\n247\t  return queryEventsWithResolvedId({ resolved_id, limit: 200 }, client);\n248\t}\n249\t"}]},"parent_tool_use_id":null,"session_id":"44011601-b82e-4ff5-898e-b50c6e22e2be","uuid":"161b3806-2ee6-456a-81bc-7b8e4b2dadc2","timestamp":"2026-04-15T12:30:14.624Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/identity.ts","content":"import { clickhouse } from \"@/lib/clickhouse\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface EventInput {\n  event_name: string;\n  device_id?: string;\n  user_id?: string;\n  timestamp?: string;\n  properties?: Record<string, unknown>;\n}\n\nexport interface EventRow {\n  event_id: string;\n  event_name: string;\n  timestamp: string;\n  device_id: string | null;\n  user_id: string | null;\n  properties: string;\n  ingested_at: string;\n  resolved_id: string;\n}\n\nexport interface QueryEventsOptions {\n  event_name?: string;\n  resolved_id?: string;\n  /** ISO timestamp cursor — return events strictly before this time */\n  before?: string;\n  limit?: number;\n}\n\n// ─── Error ────────────────────────────────────────────────────────────────────\n\nexport class IdentityConflictError extends Error {\n  readonly status = 409 as const;\n\n  constructor(\n    device_id: string,\n    existing_user_id: string,\n    new_user_id: string,\n  ) {\n    super(\n      `Device \"${device_id}\" is already mapped to user \"${existing_user_id}\". Cannot remap to \"${new_user_id}\".`,\n    );\n    this.name = \"IdentityConflictError\";\n    // Maintain correct prototype chain in transpiled environments\n    Object.setPrototypeOf(this, new.target.prototype);\n  }\n}\n\n// ─── Type alias for the ClickHouse client ─────────────────────────────────────\n\ntype ClickHouseClientLike = typeof clickhouse;\n\n// ─── validateEvent ────────────────────────────────────────────────────────────\n\n/**\n * Validates a raw event input object. Throws an Error if invalid.\n * After this call returns, callers may safely treat the input as EventInput.\n */\nexport function validateEvent(input: unknown): asserts input is EventInput {\n  if (typeof input !== \"object\" || input === null) {\n    throw new Error(\"Event must be a non-null object.\");\n  }\n  const evt = input as Record<string, unknown>;\n\n  if (typeof evt.event_name !== \"string\" || evt.event_name.trim() === \"\") {\n    throw new Error(\"event_name is required and must be a non-empty string.\");\n  }\n\n  if (!evt.device_id && !evt.user_id) {\n    throw new Error(\"At least one of device_id or user_id must be present.\");\n  }\n}\n\n// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n\n/**\n * Checks identity_mappings FINAL for an existing device → user mapping and:\n * - Inserts a new mapping if none exists.\n * - No-ops if the same mapping already exists (idempotent).\n * - Throws IdentityConflictError (status 409) if the device is mapped to a\n *   different user.\n */\nexport async function resolveIdentityMapping(\n  device_id: string,\n  user_id: string,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<void> {\n  const result = await client.query({\n    query:\n      \"SELECT user_id FROM identity_mappings FINAL WHERE device_id = {device_id:String} LIMIT 1\",\n    query_params: { device_id },\n    format: \"JSONEachRow\",\n  });\n\n  const rows = await result.json<{ user_id: string }>();\n\n  if (rows.length === 0) {\n    // No existing mapping — insert\n    await client.insert({\n      table: \"identity_mappings\",\n      values: [{ device_id, user_id }],\n      format: \"JSONEachRow\",\n    });\n    return;\n  }\n\n  const existingUserId = rows[0].user_id;\n\n  if (existingUserId === user_id) {\n    // Same mapping — no-op (idempotent)\n    return;\n  }\n\n  // Different user — conflict\n  throw new IdentityConflictError(device_id, existingUserId, user_id);\n}\n\n// ─── insertEvent ──────────────────────────────────────────────────────────────\n\n/**\n * Validates, timestamps, and inserts a single event. If both device_id and\n * user_id are provided, also writes (or verifies) the identity mapping.\n *\n * Throws IdentityConflictError (status 409) if the device_id is already\n * associated with a different user_id.\n */\nexport async function insertEvent(\n  input: unknown,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<EventRow> {\n  validateEvent(input);\n\n  const timestamp = input.timestamp ?? new Date().toISOString();\n  const properties = input.properties ? JSON.stringify(input.properties) : \"{}\";\n  const event_id = crypto.randomUUID();\n  const ingested_at = new Date().toISOString();\n\n  await client.insert({\n    table: \"events\",\n    values: [\n      {\n        event_id,\n        event_name: input.event_name,\n        timestamp,\n        device_id: input.device_id ?? null,\n        user_id: input.user_id ?? null,\n        properties,\n      },\n    ],\n    format: \"JSONEachRow\",\n  });\n\n  if (input.device_id && input.user_id) {\n    await resolveIdentityMapping(input.device_id, input.user_id, client);\n  }\n\n  const resolved_id = input.user_id ?? input.device_id ?? \"\";\n\n  return {\n    event_id,\n    event_name: input.event_name,\n    timestamp,\n    device_id: input.device_id ?? null,\n    user_id: input.user_id ?? null,\n    properties,\n    ingested_at,\n    resolved_id,\n  };\n}\n\n// ─── queryEventsWithResolvedId ────────────────────────────────────────────────\n\n/**\n * Returns events joined with identity_mappings FINAL, with resolved_id\n * computed as coalesce(e.user_id, m.user_id, e.device_id).\n *\n * Optional filters: event_name, resolved_id, before (cursor), limit (max 200).\n */\nexport async function queryEventsWithResolvedId(\n  options: QueryEventsOptions = {},\n  client: ClickHouseClientLike = clickhouse,\n): Promise<EventRow[]> {\n  const { event_name, resolved_id, before, limit = 50 } = options;\n\n  const conditions: string[] = [];\n  const params: Record<string, string | number> = {\n    limit: Math.min(limit, 200),\n  };\n\n  if (event_name) {\n    conditions.push(\"e.event_name = {event_name:String}\");\n    params.event_name = event_name;\n  }\n\n  if (before) {\n    conditions.push(\"e.timestamp < {before:String}\");\n    params.before = before;\n  }\n\n  if (resolved_id) {\n    conditions.push(\n      \"coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\",\n    );\n    params.resolved_id = resolved_id;\n  }\n\n  const where =\n    conditions.length > 0 ? `WHERE ${conditions.join(\" AND \")}` : \"\";\n\n  const result = await client.query({\n    query: `\n      SELECT\n        e.event_id,\n        e.event_name,\n        e.timestamp,\n        e.device_id,\n        e.user_id,\n        e.properties,\n        e.ingested_at,\n        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id\n      FROM events e\n      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n        ON e.device_id = m.device_id\n      ${where}\n      ORDER BY e.timestamp DESC, e.event_id DESC\n      LIMIT {limit:UInt64}\n    `,\n    query_params: params,\n    format: \"JSONEachRow\",\n  });\n\n  return result.json<EventRow>();\n}\n\n// ─── getEventsByResolvedId ────────────────────────────────────────────────────\n\n/**\n * Convenience wrapper: returns all events (up to 200) attributed to a given\n * resolved identity (user_id or device_id).\n */\nexport async function getEventsByResolvedId(\n  resolved_id: string,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<EventRow[]> {\n  return queryEventsWithResolvedId({ resolved_id, limit: 200 }, client);\n}\n","numLines":249,"startLine":1,"totalLines":249}}}
