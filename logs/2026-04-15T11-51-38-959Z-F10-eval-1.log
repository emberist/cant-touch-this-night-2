{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GpYaHEusi2Y12dbrFuLyvR","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\t\n3\t// ─── Types ────────────────────────────────────────────────────────────────────\n4\t\n5\texport interface TrendsParams {\n6\t  event_name: string;\n7\t  /** \"count\" | \"unique_users\" | \"sum:<prop>\" | \"avg:<prop>\" | \"min:<prop>\" | \"max:<prop>\" */\n8\t  measure: string;\n9\t  granularity: \"day\" | \"week\";\n10\t  /** ISO date string (YYYY-MM-DD) — inclusive lower bound */\n11\t  start: string;\n12\t  /** ISO date string (YYYY-MM-DD) — inclusive upper bound */\n13\t  end: string;\n14\t  breakdown?: string;\n15\t  breakdown_limit?: number;\n16\t}\n17\t\n18\texport interface SeriesPoint {\n19\t  date: string;\n20\t  value: number;\n21\t}\n22\t\n23\texport interface Series {\n24\t  label: string;\n25\t  data: SeriesPoint[];\n26\t}\n27\t\n28\texport interface TrendsResponse {\n29\t  series: Series[];\n30\t}\n31\t\n32\texport interface TrendsQuerySpec {\n33\t  query: string;\n34\t  query_params: Record<string, string>;\n35\t}\n36\t\n37\t// ─── Type alias for the ClickHouse client ────────────────────────────────────\n38\t\n39\ttype ClickHouseClientLike = typeof clickhouse;\n40\t\n41\t// ─── Internal helpers ─────────────────────────────────────────────────────────\n42\t\n43\t/** Returns the exclusive upper bound timestamp for the given ISO date. */\n44\tfunction computeEndExclusive(end: string): string {\n45\t  const [y, m, d] = end.split(\"-\").map(Number);\n46\t  return new Date(Date.UTC(y, m - 1, d + 1)).toISOString();\n47\t}\n48\t\n49\t/** Builds the SQL aggregate expression for the given measure. */\n50\tfunction buildAggregateExpr(measure: string): string {\n51\t  if (measure === \"count\") return \"count()\";\n52\t  if (measure === \"unique_users\") {\n53\t    return \"uniqExact(coalesce(e.user_id, m.user_id, e.device_id))\";\n54\t  }\n55\t  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n56\t  if (match) {\n57\t    const fn = match[1];\n58\t    const prop = match[2];\n59\t    return `${fn}(JSONExtractFloat(e.properties, '${prop}'))`;\n60\t  }\n61\t  // Fallback — should be unreachable after route-level validation\n62\t  return \"count()\";\n63\t}\n64\t\n65\t/** Builds the SQL date-bucket expression for the given granularity. */\n66\tfunction buildBucketExpr(granularity: \"day\" | \"week\"): string {\n67\t  return granularity === \"week\"\n68\t    ? \"toMonday(e.timestamp)\"\n69\t    : \"toDate(e.timestamp)\";\n70\t}\n71\t\n72\t// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n73\t\n74\t/**\n75\t * Constructs the ClickHouse SQL query and bound parameters for a trends\n76\t * request. Exported for unit testing of SQL correctness.\n77\t */\n78\texport function buildTrendsQuery(params: TrendsParams): TrendsQuerySpec {\n79\t  const { event_name, measure, granularity, start, end, breakdown } = params;\n80\t\n81\t  const aggregateExpr = buildAggregateExpr(measure);\n82\t  const bucketExpr = buildBucketExpr(granularity);\n83\t  const needsJoin = measure === \"unique_users\";\n84\t\n85\t  const joinClause = needsJoin\n86\t    ? \"LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\\n      ON e.device_id = m.device_id\"\n87\t    : \"\";\n88\t\n89\t  const query_params: Record<string, string> = {\n90\t    event_name,\n91\t    start: `${start}T00:00:00.000Z`,\n92\t    end_exclusive: computeEndExclusive(end),\n93\t  };\n94\t\n95\t  if (breakdown) {\n96\t    const query = `\n97\t      SELECT\n98\t        ${bucketExpr} AS bucket,\n99\t        JSONExtractString(e.properties, '${breakdown}') AS breakdown_val,\n100\t        ${aggregateExpr} AS value\n101\t      FROM events e\n102\t      ${joinClause}\n103\t      WHERE e.event_name = {event_name:String}\n104\t        AND e.timestamp >= {start:String}\n105\t        AND e.timestamp < {end_exclusive:String}\n106\t      GROUP BY bucket, breakdown_val\n107\t      ORDER BY bucket ASC\n108\t    `.trim();\n109\t    return { query, query_params };\n110\t  }\n111\t\n112\t  const query = `\n113\t    SELECT\n114\t      ${bucketExpr} AS bucket,\n115\t      ${aggregateExpr} AS value\n116\t    FROM events e\n117\t    ${joinClause}\n118\t    WHERE e.event_name = {event_name:String}\n119\t      AND e.timestamp >= {start:String}\n120\t      AND e.timestamp < {end_exclusive:String}\n121\t    GROUP BY bucket\n122\t    ORDER BY bucket ASC\n123\t  `.trim();\n124\t\n125\t  return { query, query_params };\n126\t}\n127\t\n128\t// ─── queryTrends ──────────────────────────────────────────────────────────────\n129\t\n130\tinterface TrendsRow {\n131\t  bucket: string;\n132\t  value: number | string;\n133\t  breakdown_val?: string;\n134\t}\n135\t\n136\t/**\n137\t * Executes the trends query and transforms the raw ClickHouse rows into the\n138\t * series response shape.\n139\t *\n140\t * Without breakdown: returns a single series labelled with event_name.\n141\t * With breakdown:    returns one series per top-N breakdown value, with the\n142\t *                    remainder merged into an \"Other\" series.\n143\t */\n144\texport async function queryTrends(\n145\t  params: TrendsParams,\n146\t  client: ClickHouseClientLike = clickhouse,\n147\t): Promise<TrendsResponse> {\n148\t  const { event_name, breakdown, breakdown_limit = 10 } = params;\n149\t  const { query, query_params } = buildTrendsQuery(params);\n150\t\n151\t  const result = await client.query({\n152\t    query,\n153\t    query_params,\n154\t    format: \"JSONEachRow\",\n155\t  });\n156\t\n157\t  const rows = await result.json<TrendsRow>();\n158\t\n159\t  if (rows.length === 0) {\n160\t    return { series: [] };\n161\t  }\n162\t\n163\t  // ── No breakdown: single series ─────────────────────────────────────────────\n164\t\n165\t  if (!breakdown) {\n166\t    const data: SeriesPoint[] = rows.map((r) => ({\n167\t      date: r.bucket,\n168\t      value: Number(r.value),\n169\t    }));\n170\t    return { series: [{ label: event_name, data }] };\n171\t  }\n172\t\n173\t  // ── With breakdown: group rows by breakdown_val ───────────────────────────\n174\t\n175\t  const seriesMap = new Map<string, SeriesPoint[]>();\n176\t  const totalsByLabel = new Map<string, number>();\n177\t\n178\t  for (const row of rows) {\n179\t    const label = row.breakdown_val ?? \"\";\n180\t    const value = Number(row.value);\n181\t\n182\t    let points = seriesMap.get(label);\n183\t    if (points === undefined) {\n184\t      points = [];\n185\t      seriesMap.set(label, points);\n186\t      totalsByLabel.set(label, 0);\n187\t    }\n188\t    points.push({ date: row.bucket, value });\n189\t    totalsByLabel.set(label, (totalsByLabel.get(label) ?? 0) + value);\n190\t  }\n191\t\n192\t  // Sort by total descending to determine top-N\n193\t  const sorted = Array.from(totalsByLabel.entries()).sort(\n194\t    ([, a], [, b]) => b - a,\n195\t  );\n196\t\n197\t  const series: Series[] = [];\n198\t\n199\t  // Add top-N individual series\n200\t  for (const [label] of sorted.slice(0, breakdown_limit)) {\n201\t    series.push({ label, data: seriesMap.get(label) ?? [] });\n202\t  }\n203\t\n204\t  // Merge remaining values into \"Other\"\n205\t  const restEntries = sorted.slice(breakdown_limit);\n206\t  if (restEntries.length > 0) {\n207\t    const otherMap = new Map<string, number>();\n208\t    for (const [otherLabel] of restEntries) {\n209\t      for (const point of seriesMap.get(otherLabel) ?? []) {\n210\t        otherMap.set(point.date, (otherMap.get(point.date) ?? 0) + point.value);\n211\t      }\n212\t    }\n213\t    const otherData = Array.from(otherMap.entries())\n214\t      .sort(([a], [b]) => a.localeCompare(b))\n215\t      .map(([date, value]) => ({ date, value }));\n216\t    series.push({ label: \"Other\", data: otherData });\n217\t  }\n218\t\n219\t  return { series };\n220\t}\n221\t"}]},"parent_tool_use_id":null,"session_id":"09fd6134-5b9f-4b7d-bc24-5ed377ea7936","uuid":"82055c74-5dc9-47ec-9a75-580af7600fbe","timestamp":"2026-04-15T13:09:27.134Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/trends.ts","content":"import { clickhouse } from \"@/lib/clickhouse\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface TrendsParams {\n  event_name: string;\n  /** \"count\" | \"unique_users\" | \"sum:<prop>\" | \"avg:<prop>\" | \"min:<prop>\" | \"max:<prop>\" */\n  measure: string;\n  granularity: \"day\" | \"week\";\n  /** ISO date string (YYYY-MM-DD) — inclusive lower bound */\n  start: string;\n  /** ISO date string (YYYY-MM-DD) — inclusive upper bound */\n  end: string;\n  breakdown?: string;\n  breakdown_limit?: number;\n}\n\nexport interface SeriesPoint {\n  date: string;\n  value: number;\n}\n\nexport interface Series {\n  label: string;\n  data: SeriesPoint[];\n}\n\nexport interface TrendsResponse {\n  series: Series[];\n}\n\nexport interface TrendsQuerySpec {\n  query: string;\n  query_params: Record<string, string>;\n}\n\n// ─── Type alias for the ClickHouse client ────────────────────────────────────\n\ntype ClickHouseClientLike = typeof clickhouse;\n\n// ─── Internal helpers ─────────────────────────────────────────────────────────\n\n/** Returns the exclusive upper bound timestamp for the given ISO date. */\nfunction computeEndExclusive(end: string): string {\n  const [y, m, d] = end.split(\"-\").map(Number);\n  return new Date(Date.UTC(y, m - 1, d + 1)).toISOString();\n}\n\n/** Builds the SQL aggregate expression for the given measure. */\nfunction buildAggregateExpr(measure: string): string {\n  if (measure === \"count\") return \"count()\";\n  if (measure === \"unique_users\") {\n    return \"uniqExact(coalesce(e.user_id, m.user_id, e.device_id))\";\n  }\n  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n  if (match) {\n    const fn = match[1];\n    const prop = match[2];\n    return `${fn}(JSONExtractFloat(e.properties, '${prop}'))`;\n  }\n  // Fallback — should be unreachable after route-level validation\n  return \"count()\";\n}\n\n/** Builds the SQL date-bucket expression for the given granularity. */\nfunction buildBucketExpr(granularity: \"day\" | \"week\"): string {\n  return granularity === \"week\"\n    ? \"toMonday(e.timestamp)\"\n    : \"toDate(e.timestamp)\";\n}\n\n// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n\n/**\n * Constructs the ClickHouse SQL query and bound parameters for a trends\n * request. Exported for unit testing of SQL correctness.\n */\nexport function buildTrendsQuery(params: TrendsParams): TrendsQuerySpec {\n  const { event_name, measure, granularity, start, end, breakdown } = params;\n\n  const aggregateExpr = buildAggregateExpr(measure);\n  const bucketExpr = buildBucketExpr(granularity);\n  const needsJoin = measure === \"unique_users\";\n\n  const joinClause = needsJoin\n    ? \"LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\\n      ON e.device_id = m.device_id\"\n    : \"\";\n\n  const query_params: Record<string, string> = {\n    event_name,\n    start: `${start}T00:00:00.000Z`,\n    end_exclusive: computeEndExclusive(end),\n  };\n\n  if (breakdown) {\n    const query = `\n      SELECT\n        ${bucketExpr} AS bucket,\n        JSONExtractString(e.properties, '${breakdown}') AS breakdown_val,\n        ${aggregateExpr} AS value\n      FROM events e\n      ${joinClause}\n      WHERE e.event_name = {event_name:String}\n        AND e.timestamp >= {start:String}\n        AND e.timestamp < {end_exclusive:String}\n      GROUP BY bucket, breakdown_val\n      ORDER BY bucket ASC\n    `.trim();\n    return { query, query_params };\n  }\n\n  const query = `\n    SELECT\n      ${bucketExpr} AS bucket,\n      ${aggregateExpr} AS value\n    FROM events e\n    ${joinClause}\n    WHERE e.event_name = {event_name:String}\n      AND e.timestamp >= {start:String}\n      AND e.timestamp < {end_exclusive:String}\n    GROUP BY bucket\n    ORDER BY bucket ASC\n  `.trim();\n\n  return { query, query_params };\n}\n\n// ─── queryTrends ──────────────────────────────────────────────────────────────\n\ninterface TrendsRow {\n  bucket: string;\n  value: number | string;\n  breakdown_val?: string;\n}\n\n/**\n * Executes the trends query and transforms the raw ClickHouse rows into the\n * series response shape.\n *\n * Without breakdown: returns a single series labelled with event_name.\n * With breakdown:    returns one series per top-N breakdown value, with the\n *                    remainder merged into an \"Other\" series.\n */\nexport async function queryTrends(\n  params: TrendsParams,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<TrendsResponse> {\n  const { event_name, breakdown, breakdown_limit = 10 } = params;\n  const { query, query_params } = buildTrendsQuery(params);\n\n  const result = await client.query({\n    query,\n    query_params,\n    format: \"JSONEachRow\",\n  });\n\n  const rows = await result.json<TrendsRow>();\n\n  if (rows.length === 0) {\n    return { series: [] };\n  }\n\n  // ── No breakdown: single series ─────────────────────────────────────────────\n\n  if (!breakdown) {\n    const data: SeriesPoint[] = rows.map((r) => ({\n      date: r.bucket,\n      value: Number(r.value),\n    }));\n    return { series: [{ label: event_name, data }] };\n  }\n\n  // ── With breakdown: group rows by breakdown_val ───────────────────────────\n\n  const seriesMap = new Map<string, SeriesPoint[]>();\n  const totalsByLabel = new Map<string, number>();\n\n  for (const row of rows) {\n    const label = row.breakdown_val ?? \"\";\n    const value = Number(row.value);\n\n    let points = seriesMap.get(label);\n    if (points === undefined) {\n      points = [];\n      seriesMap.set(label, points);\n      totalsByLabel.set(label, 0);\n    }\n    points.push({ date: row.bucket, value });\n    totalsByLabel.set(label, (totalsByLabel.get(label) ?? 0) + value);\n  }\n\n  // Sort by total descending to determine top-N\n  const sorted = Array.from(totalsByLabel.entries()).sort(\n    ([, a], [, b]) => b - a,\n  );\n\n  const series: Series[] = [];\n\n  // Add top-N individual series\n  for (const [label] of sorted.slice(0, breakdown_limit)) {\n    series.push({ label, data: seriesMap.get(label) ?? [] });\n  }\n\n  // Merge remaining values into \"Other\"\n  const restEntries = sorted.slice(breakdown_limit);\n  if (restEntries.length > 0) {\n    const otherMap = new Map<string, number>();\n    for (const [otherLabel] of restEntries) {\n      for (const point of seriesMap.get(otherLabel) ?? []) {\n        otherMap.set(point.date, (otherMap.get(point.date) ?? 0) + point.value);\n      }\n    }\n    const otherData = Array.from(otherMap.entries())\n      .sort(([a], [b]) => a.localeCompare(b))\n      .map(([date, value]) => ({ date, value }));\n    series.push({ label: \"Other\", data: otherData });\n  }\n\n  return { series };\n}\n","numLines":221,"startLine":1,"totalLines":221}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HABoCen2aTc5zdz6T1RUJK","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQuery } = vi.hoisted(() => ({\n6\t  mockQuery: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: {\n11\t    query: mockQuery,\n12\t  },\n13\t}));\n14\t\n15\timport { buildTrendsQuery, queryTrends } from \"@/lib/trends\";\n16\t\n17\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n18\t\n19\tfunction mockQueryReturns(rows: unknown[]) {\n20\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n21\t}\n22\t\n23\tconst baseParams = {\n24\t  event_name: \"Page Viewed\",\n25\t  measure: \"count\",\n26\t  granularity: \"day\" as const,\n27\t  start: \"2026-04-01\",\n28\t  end: \"2026-04-15\",\n29\t};\n30\t\n31\t// ─── Tests ────────────────────────────────────────────────────────────────────\n32\t\n33\tbeforeEach(() => {\n34\t  mockQueryReturns([]);\n35\t});\n36\t\n37\tafterEach(() => {\n38\t  vi.clearAllMocks();\n39\t});\n40\t\n41\t// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n42\t\n43\tdescribe(\"buildTrendsQuery\", () => {\n44\t  describe(\"measure expressions\", () => {\n45\t    it(\"uses count() for measure=count\", () => {\n46\t      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n47\t      expect(query).toContain(\"count()\");\n48\t    });\n49\t\n50\t    it(\"uses uniqExact and identity_mappings FINAL for measure=unique_users\", () => {\n51\t      const { query } = buildTrendsQuery({\n52\t        ...baseParams,\n53\t        measure: \"unique_users\",\n54\t      });\n55\t      expect(query).toContain(\"uniqExact\");\n56\t      expect(query).toContain(\"identity_mappings FINAL\");\n57\t    });\n58\t\n59\t    it(\"does not include identity_mappings JOIN for measure=count\", () => {\n60\t      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n61\t      expect(query).not.toContain(\"identity_mappings\");\n62\t    });\n63\t\n64\t    it(\"uses sum(JSONExtractFloat) for measure=sum:amount\", () => {\n65\t      const { query } = buildTrendsQuery({\n66\t        ...baseParams,\n67\t        measure: \"sum:amount\",\n68\t      });\n69\t      expect(query).toContain(\"sum(JSONExtractFloat\");\n70\t      expect(query).toContain(\"'amount'\");\n71\t    });\n72\t\n73\t    it(\"uses avg(JSONExtractFloat) for measure=avg:amount\", () => {\n74\t      const { query } = buildTrendsQuery({\n75\t        ...baseParams,\n76\t        measure: \"avg:amount\",\n77\t      });\n78\t      expect(query).toContain(\"avg(JSONExtractFloat\");\n79\t      expect(query).toContain(\"'amount'\");\n80\t    });\n81\t\n82\t    it(\"uses min(JSONExtractFloat) for measure=min:amount\", () => {\n83\t      const { query } = buildTrendsQuery({\n84\t        ...baseParams,\n85\t        measure: \"min:amount\",\n86\t      });\n87\t      expect(query).toContain(\"min(JSONExtractFloat\");\n88\t    });\n89\t\n90\t    it(\"uses max(JSONExtractFloat) for measure=max:amount\", () => {\n91\t      const { query } = buildTrendsQuery({\n92\t        ...baseParams,\n93\t        measure: \"max:amount\",\n94\t      });\n95\t      expect(query).toContain(\"max(JSONExtractFloat\");\n96\t    });\n97\t  });\n98\t\n99\t  describe(\"granularity\", () => {\n100\t    it(\"groups by toDate for granularity=day\", () => {\n101\t      const { query } = buildTrendsQuery({\n102\t        ...baseParams,\n103\t        granularity: \"day\",\n104\t      });\n105\t      expect(query).toContain(\"toDate(\");\n106\t    });\n107\t\n108\t    it(\"groups by toMonday for granularity=week\", () => {\n109\t      const { query } = buildTrendsQuery({\n110\t        ...baseParams,\n111\t        granularity: \"week\",\n112\t      });\n113\t      expect(query).toContain(\"toMonday(\");\n114\t    });\n115\t  });\n116\t\n117\t  describe(\"date range\", () => {\n118\t    it(\"includes start and end_exclusive in query params\", () => {\n119\t      const { query_params } = buildTrendsQuery({\n120\t        ...baseParams,\n121\t        start: \"2026-04-01\",\n122\t        end: \"2026-04-15\",\n123\t      });\n124\t      expect(query_params).toHaveProperty(\"start\");\n125\t      expect(query_params).toHaveProperty(\"end_exclusive\");\n126\t      expect(query_params.start).toContain(\"2026-04-01\");\n127\t      expect(query_params.end_exclusive).toContain(\"2026-04-16\");\n128\t    });\n129\t\n130\t    it(\"references start and end_exclusive params in the WHERE clause\", () => {\n131\t      const { query } = buildTrendsQuery(baseParams);\n132\t      expect(query).toContain(\"{start:String}\");\n133\t      expect(query).toContain(\"{end_exclusive:String}\");\n134\t    });\n135\t\n136\t    it(\"includes event_name in query params\", () => {\n137\t      const { query_params } = buildTrendsQuery({\n138\t        ...baseParams,\n139\t        event_name: \"Purchase Completed\",\n140\t      });\n141\t      expect(query_params.event_name).toBe(\"Purchase Completed\");\n142\t    });\n143\t  });\n144\t\n145\t  describe(\"breakdown\", () => {\n146\t    it(\"does not include breakdown_val column when no breakdown is given\", () => {\n147\t      const { query } = buildTrendsQuery(baseParams);\n148\t      expect(query).not.toContain(\"breakdown_val\");\n149\t    });\n150\t\n151\t    it(\"includes JSONExtractString and breakdown_val when breakdown is provided\", () => {\n152\t      const { query } = buildTrendsQuery({\n153\t        ...baseParams,\n154\t        breakdown: \"country\",\n155\t      });\n156\t      expect(query).toContain(\"JSONExtractString\");\n157\t      expect(query).toContain(\"breakdown_val\");\n158\t      expect(query).toContain(\"'country'\");\n159\t    });\n160\t\n161\t    it(\"groups by breakdown_val in addition to bucket when breakdown is provided\", () => {\n162\t      const { query } = buildTrendsQuery({\n163\t        ...baseParams,\n164\t        breakdown: \"country\",\n165\t      });\n166\t      expect(query).toContain(\"GROUP BY bucket, breakdown_val\");\n167\t    });\n168\t  });\n169\t});\n170\t\n171\t// ─── queryTrends ──────────────────────────────────────────────────────────────\n172\t\n173\tdescribe(\"queryTrends\", () => {\n174\t  describe(\"without breakdown\", () => {\n175\t    it(\"returns a single series with label = event_name\", async () => {\n176\t      mockQueryReturns([\n177\t        { bucket: \"2026-04-01\", value: 5 },\n178\t        { bucket: \"2026-04-02\", value: 3 },\n179\t      ]);\n180\t\n181\t      const result = await queryTrends({\n182\t        ...baseParams,\n183\t        event_name: \"Page Viewed\",\n184\t      });\n185\t\n186\t      expect(result.series).toHaveLength(1);\n187\t      expect(result.series[0].label).toBe(\"Page Viewed\");\n188\t    });\n189\t\n190\t    it(\"maps rows to { date, value } data points\", async () => {\n191\t      mockQueryReturns([\n192\t        { bucket: \"2026-04-01\", value: 5 },\n193\t        { bucket: \"2026-04-02\", value: 3 },\n194\t      ]);\n195\t\n196\t      const result = await queryTrends(baseParams);\n197\t\n198\t      expect(result.series[0].data).toEqual([\n199\t        { date: \"2026-04-01\", value: 5 },\n200\t        { date: \"2026-04-02\", value: 3 },\n201\t      ]);\n202\t    });\n203\t\n204\t    it(\"coerces string values returned by ClickHouse to numbers\", async () => {\n205\t      mockQueryReturns([{ bucket: \"2026-04-01\", value: \"42\" }]);\n206\t\n207\t      const result = await queryTrends(baseParams);\n208\t\n209\t      expect(result.series[0].data[0].value).toBe(42);\n210\t      expect(typeof result.series[0].data[0].value).toBe(\"number\");\n211\t    });\n212\t\n213\t    it(\"returns { series: [] } when ClickHouse returns no rows\", async () => {\n214\t      mockQueryReturns([]);\n215\t\n216\t      const result = await queryTrends(baseParams);\n217\t\n218\t      expect(result.series).toEqual([]);\n219\t    });\n220\t  });\n221\t\n222\t  describe(\"with breakdown\", () => {\n223\t    it(\"returns one series per distinct breakdown value\", async () => {\n224\t      mockQueryReturns([\n225\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n226\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n227\t        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n228\t      ]);\n229\t\n230\t      const result = await queryTrends({\n231\t        ...baseParams,\n232\t        breakdown: \"country\",\n233\t      });\n234\t\n235\t      const labels = result.series.map((s) => s.label);\n236\t      expect(labels).toContain(\"US\");\n237\t      expect(labels).toContain(\"DE\");\n238\t    });\n239\t\n240\t    it(\"orders data points within each series chronologically\", async () => {\n241\t      mockQueryReturns([\n242\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n243\t        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n244\t      ]);\n245\t\n246\t      const result = await queryTrends({\n247\t        ...baseParams,\n248\t        breakdown: \"country\",\n249\t      });\n250\t\n251\t      const usSeries = result.series.find((s) => s.label === \"US\");\n252\t      expect(usSeries?.data[0].date).toBe(\"2026-04-01\");\n253\t      expect(usSeries?.data[1].date).toBe(\"2026-04-02\");\n254\t    });\n255\t\n256\t    it(\"respects breakdown_limit and groups remaining values as Other\", async () => {\n257\t      mockQueryReturns([\n258\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n259\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n260\t        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n261\t      ]);\n262\t\n263\t      const result = await queryTrends({\n264\t        ...baseParams,\n265\t        breakdown: \"country\",\n266\t        breakdown_limit: 2,\n267\t      });\n268\t\n269\t      expect(result.series).toHaveLength(3); // US, DE, Other\n270\t      const labels = result.series.map((s) => s.label);\n271\t      expect(labels).toContain(\"US\");\n272\t      expect(labels).toContain(\"DE\");\n273\t      expect(labels).toContain(\"Other\");\n274\t      expect(labels).not.toContain(\"FR\");\n275\t    });\n276\t\n277\t    it(\"Other series aggregates values of non-top breakdown values by date\", async () => {\n278\t      mockQueryReturns([\n279\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n280\t        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n281\t        { bucket: \"2026-04-01\", breakdown_val: \"JP\", value: 7 },\n282\t      ]);\n283\t\n284\t      const result = await queryTrends({\n285\t        ...baseParams,\n286\t        breakdown: \"country\",\n287\t        breakdown_limit: 1,\n288\t      });\n289\t\n290\t      const otherSeries = result.series.find((s) => s.label === \"Other\");\n291\t      expect(otherSeries).toBeDefined();\n292\t      // FR (10) + JP (7) = 17\n293\t      expect(otherSeries?.data[0].value).toBe(17);\n294\t    });\n295\t\n296\t    it(\"does not add Other series when all values are within the limit\", async () => {\n297\t      mockQueryReturns([\n298\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n299\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n300\t      ]);\n301\t\n302\t      const result = await queryTrends({\n303\t        ...baseParams,\n304\t        breakdown: \"country\",\n305\t        breakdown_limit: 10,\n306\t      });\n307\t\n308\t      const labels = result.series.map((s) => s.label);\n309\t      expect(labels).not.toContain(\"Other\");\n310\t    });\n311\t\n312\t    it(\"sorts series by total value descending (top values first)\", async () => {\n313\t      mockQueryReturns([\n314\t        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n315\t        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n316\t        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 25 },\n317\t      ]);\n318\t\n319\t      const result = await queryTrends({\n320\t        ...baseParams,\n321\t        breakdown: \"country\",\n322\t        breakdown_limit: 10,\n323\t      });\n324\t\n325\t      expect(result.series[0].label).toBe(\"US\");\n326\t      expect(result.series[1].label).toBe(\"DE\");\n327\t      expect(result.series[2].label).toBe(\"FR\");\n328\t    });\n329\t  });\n330\t});\n331\t"}]},"parent_tool_use_id":null,"session_id":"09fd6134-5b9f-4b7d-bc24-5ed377ea7936","uuid":"4cd32fdd-ad64-4ede-ab30-dee72274abec","timestamp":"2026-04-15T13:09:27.432Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/trends.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockQuery } = vi.hoisted(() => ({\n  mockQuery: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    query: mockQuery,\n  },\n}));\n\nimport { buildTrendsQuery, queryTrends } from \"@/lib/trends\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction mockQueryReturns(rows: unknown[]) {\n  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n}\n\nconst baseParams = {\n  event_name: \"Page Viewed\",\n  measure: \"count\",\n  granularity: \"day\" as const,\n  start: \"2026-04-01\",\n  end: \"2026-04-15\",\n};\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockQueryReturns([]);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\n// ─── buildTrendsQuery ─────────────────────────────────────────────────────────\n\ndescribe(\"buildTrendsQuery\", () => {\n  describe(\"measure expressions\", () => {\n    it(\"uses count() for measure=count\", () => {\n      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n      expect(query).toContain(\"count()\");\n    });\n\n    it(\"uses uniqExact and identity_mappings FINAL for measure=unique_users\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"unique_users\",\n      });\n      expect(query).toContain(\"uniqExact\");\n      expect(query).toContain(\"identity_mappings FINAL\");\n    });\n\n    it(\"does not include identity_mappings JOIN for measure=count\", () => {\n      const { query } = buildTrendsQuery({ ...baseParams, measure: \"count\" });\n      expect(query).not.toContain(\"identity_mappings\");\n    });\n\n    it(\"uses sum(JSONExtractFloat) for measure=sum:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"sum:amount\",\n      });\n      expect(query).toContain(\"sum(JSONExtractFloat\");\n      expect(query).toContain(\"'amount'\");\n    });\n\n    it(\"uses avg(JSONExtractFloat) for measure=avg:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"avg:amount\",\n      });\n      expect(query).toContain(\"avg(JSONExtractFloat\");\n      expect(query).toContain(\"'amount'\");\n    });\n\n    it(\"uses min(JSONExtractFloat) for measure=min:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"min:amount\",\n      });\n      expect(query).toContain(\"min(JSONExtractFloat\");\n    });\n\n    it(\"uses max(JSONExtractFloat) for measure=max:amount\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        measure: \"max:amount\",\n      });\n      expect(query).toContain(\"max(JSONExtractFloat\");\n    });\n  });\n\n  describe(\"granularity\", () => {\n    it(\"groups by toDate for granularity=day\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        granularity: \"day\",\n      });\n      expect(query).toContain(\"toDate(\");\n    });\n\n    it(\"groups by toMonday for granularity=week\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        granularity: \"week\",\n      });\n      expect(query).toContain(\"toMonday(\");\n    });\n  });\n\n  describe(\"date range\", () => {\n    it(\"includes start and end_exclusive in query params\", () => {\n      const { query_params } = buildTrendsQuery({\n        ...baseParams,\n        start: \"2026-04-01\",\n        end: \"2026-04-15\",\n      });\n      expect(query_params).toHaveProperty(\"start\");\n      expect(query_params).toHaveProperty(\"end_exclusive\");\n      expect(query_params.start).toContain(\"2026-04-01\");\n      expect(query_params.end_exclusive).toContain(\"2026-04-16\");\n    });\n\n    it(\"references start and end_exclusive params in the WHERE clause\", () => {\n      const { query } = buildTrendsQuery(baseParams);\n      expect(query).toContain(\"{start:String}\");\n      expect(query).toContain(\"{end_exclusive:String}\");\n    });\n\n    it(\"includes event_name in query params\", () => {\n      const { query_params } = buildTrendsQuery({\n        ...baseParams,\n        event_name: \"Purchase Completed\",\n      });\n      expect(query_params.event_name).toBe(\"Purchase Completed\");\n    });\n  });\n\n  describe(\"breakdown\", () => {\n    it(\"does not include breakdown_val column when no breakdown is given\", () => {\n      const { query } = buildTrendsQuery(baseParams);\n      expect(query).not.toContain(\"breakdown_val\");\n    });\n\n    it(\"includes JSONExtractString and breakdown_val when breakdown is provided\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n      expect(query).toContain(\"JSONExtractString\");\n      expect(query).toContain(\"breakdown_val\");\n      expect(query).toContain(\"'country'\");\n    });\n\n    it(\"groups by breakdown_val in addition to bucket when breakdown is provided\", () => {\n      const { query } = buildTrendsQuery({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n      expect(query).toContain(\"GROUP BY bucket, breakdown_val\");\n    });\n  });\n});\n\n// ─── queryTrends ──────────────────────────────────────────────────────────────\n\ndescribe(\"queryTrends\", () => {\n  describe(\"without breakdown\", () => {\n    it(\"returns a single series with label = event_name\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", value: 5 },\n        { bucket: \"2026-04-02\", value: 3 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        event_name: \"Page Viewed\",\n      });\n\n      expect(result.series).toHaveLength(1);\n      expect(result.series[0].label).toBe(\"Page Viewed\");\n    });\n\n    it(\"maps rows to { date, value } data points\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", value: 5 },\n        { bucket: \"2026-04-02\", value: 3 },\n      ]);\n\n      const result = await queryTrends(baseParams);\n\n      expect(result.series[0].data).toEqual([\n        { date: \"2026-04-01\", value: 5 },\n        { date: \"2026-04-02\", value: 3 },\n      ]);\n    });\n\n    it(\"coerces string values returned by ClickHouse to numbers\", async () => {\n      mockQueryReturns([{ bucket: \"2026-04-01\", value: \"42\" }]);\n\n      const result = await queryTrends(baseParams);\n\n      expect(result.series[0].data[0].value).toBe(42);\n      expect(typeof result.series[0].data[0].value).toBe(\"number\");\n    });\n\n    it(\"returns { series: [] } when ClickHouse returns no rows\", async () => {\n      mockQueryReturns([]);\n\n      const result = await queryTrends(baseParams);\n\n      expect(result.series).toEqual([]);\n    });\n  });\n\n  describe(\"with breakdown\", () => {\n    it(\"returns one series per distinct breakdown value\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n\n      const labels = result.series.map((s) => s.label);\n      expect(labels).toContain(\"US\");\n      expect(labels).toContain(\"DE\");\n    });\n\n    it(\"orders data points within each series chronologically\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n        { bucket: \"2026-04-02\", breakdown_val: \"US\", value: 8 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n      });\n\n      const usSeries = result.series.find((s) => s.label === \"US\");\n      expect(usSeries?.data[0].date).toBe(\"2026-04-01\");\n      expect(usSeries?.data[1].date).toBe(\"2026-04-02\");\n    });\n\n    it(\"respects breakdown_limit and groups remaining values as Other\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 2,\n      });\n\n      expect(result.series).toHaveLength(3); // US, DE, Other\n      const labels = result.series.map((s) => s.label);\n      expect(labels).toContain(\"US\");\n      expect(labels).toContain(\"DE\");\n      expect(labels).toContain(\"Other\");\n      expect(labels).not.toContain(\"FR\");\n    });\n\n    it(\"Other series aggregates values of non-top breakdown values by date\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 10 },\n        { bucket: \"2026-04-01\", breakdown_val: \"JP\", value: 7 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 1,\n      });\n\n      const otherSeries = result.series.find((s) => s.label === \"Other\");\n      expect(otherSeries).toBeDefined();\n      // FR (10) + JP (7) = 17\n      expect(otherSeries?.data[0].value).toBe(17);\n    });\n\n    it(\"does not add Other series when all values are within the limit\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 10 },\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 5 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 10,\n      });\n\n      const labels = result.series.map((s) => s.label);\n      expect(labels).not.toContain(\"Other\");\n    });\n\n    it(\"sorts series by total value descending (top values first)\", async () => {\n      mockQueryReturns([\n        { bucket: \"2026-04-01\", breakdown_val: \"DE\", value: 50 },\n        { bucket: \"2026-04-01\", breakdown_val: \"US\", value: 100 },\n        { bucket: \"2026-04-01\", breakdown_val: \"FR\", value: 25 },\n      ]);\n\n      const result = await queryTrends({\n        ...baseParams,\n        breakdown: \"country\",\n        breakdown_limit: 10,\n      });\n\n      expect(result.series[0].label).toBe(\"US\");\n      expect(result.series[1].label).toBe(\"DE\");\n      expect(result.series[2].label).toBe(\"FR\");\n    });\n  });\n});\n","numLines":331,"startLine":1,"totalLines":331}}}
