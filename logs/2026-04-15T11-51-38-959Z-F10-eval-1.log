{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FCFcSkBYGeDj53XJkweuF5","type":"tool_result","content":"1\timport { queryTrends } from \"@/lib/trends\";\n2\t\n3\t// ─── Validation helpers ───────────────────────────────────────────────────────\n4\t\n5\tconst VALID_MEASURES = new Set([\"count\", \"unique_users\"]);\n6\tconst VALID_GRANULARITIES = new Set([\"day\", \"week\"]);\n7\t\n8\t/**\n9\t * Returns an error string if the measure is invalid, otherwise null.\n10\t * Valid forms: \"count\", \"unique_users\", \"sum:<prop>\", \"avg:<prop>\",\n11\t * \"min:<prop>\", \"max:<prop>\" where <prop> is a non-empty string.\n12\t */\n13\tfunction validateMeasure(measure: string): string | null {\n14\t  if (VALID_MEASURES.has(measure)) return null;\n15\t  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n16\t  if (match) return null;\n17\t  return `Invalid measure \"${measure}\". Must be count, unique_users, sum:<prop>, avg:<prop>, min:<prop>, or max:<prop>.`;\n18\t}\n19\t\n20\t// ─── Route handler ────────────────────────────────────────────────────────────\n21\t\n22\t/**\n23\t * GET /api/trends\n24\t *\n25\t * Query params:\n26\t *   event_name   (required)\n27\t *   measure      default \"count\"\n28\t *   granularity  default \"day\"\n29\t *   start        (required) ISO date YYYY-MM-DD\n30\t *   end          (required) ISO date YYYY-MM-DD\n31\t *   breakdown    (optional) property name\n32\t *   breakdown_limit (optional) default 10\n33\t */\n34\texport async function GET(request: Request): Promise<Response> {\n35\t  const { searchParams } = new URL(request.url);\n36\t\n37\t  const event_name = searchParams.get(\"event_name\");\n38\t  const measure = searchParams.get(\"measure\") ?? \"count\";\n39\t  const granularity = searchParams.get(\"granularity\") ?? \"day\";\n40\t  const start = searchParams.get(\"start\");\n41\t  const end = searchParams.get(\"end\");\n42\t  const breakdown = searchParams.get(\"breakdown\") ?? undefined;\n43\t  const breakdownLimitRaw = searchParams.get(\"breakdown_limit\");\n44\t\n45\t  // ── Required param checks ─────────────────────────────────────────────────\n46\t\n47\t  if (!event_name) {\n48\t    return Response.json({ error: \"event_name is required.\" }, { status: 400 });\n49\t  }\n50\t\n51\t  if (!start) {\n52\t    return Response.json({ error: \"start is required.\" }, { status: 400 });\n53\t  }\n54\t\n55\t  if (!end) {\n56\t    return Response.json({ error: \"end is required.\" }, { status: 400 });\n57\t  }\n58\t\n59\t  // ── Optional param validation ─────────────────────────────────────────────\n60\t\n61\t  const measureError = validateMeasure(measure);\n62\t  if (measureError) {\n63\t    return Response.json({ error: measureError }, { status: 400 });\n64\t  }\n65\t\n66\t  if (!VALID_GRANULARITIES.has(granularity)) {\n67\t    return Response.json(\n68\t      {\n69\t        error: `Invalid granularity \"${granularity}\". Must be \"day\" or \"week\".`,\n70\t      },\n71\t      { status: 400 },\n72\t    );\n73\t  }\n74\t\n75\t  let breakdown_limit = 10;\n76\t  if (breakdownLimitRaw !== null) {\n77\t    const parsed = Number(breakdownLimitRaw);\n78\t    if (Number.isFinite(parsed) && parsed > 0) {\n79\t      breakdown_limit = Math.floor(parsed);\n80\t    }\n81\t  }\n82\t\n83\t  // ── Execute query ─────────────────────────────────────────────────────────\n84\t\n85\t  try {\n86\t    const response = await queryTrends({\n87\t      event_name,\n88\t      measure,\n89\t      granularity: granularity as \"day\" | \"week\",\n90\t      start,\n91\t      end,\n92\t      breakdown,\n93\t      breakdown_limit,\n94\t    });\n95\t    return Response.json(response);\n96\t  } catch (err) {\n97\t    const message =\n98\t      err instanceof Error ? err.message : \"Internal server error.\";\n99\t    return Response.json({ error: message }, { status: 500 });\n100\t  }\n101\t}\n102\t"}]},"parent_tool_use_id":null,"session_id":"09fd6134-5b9f-4b7d-bc24-5ed377ea7936","uuid":"2cb3aa81-6faf-4d47-b136-7ba7a1968377","timestamp":"2026-04-15T13:09:30.673Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/trends/route.ts","content":"import { queryTrends } from \"@/lib/trends\";\n\n// ─── Validation helpers ───────────────────────────────────────────────────────\n\nconst VALID_MEASURES = new Set([\"count\", \"unique_users\"]);\nconst VALID_GRANULARITIES = new Set([\"day\", \"week\"]);\n\n/**\n * Returns an error string if the measure is invalid, otherwise null.\n * Valid forms: \"count\", \"unique_users\", \"sum:<prop>\", \"avg:<prop>\",\n * \"min:<prop>\", \"max:<prop>\" where <prop> is a non-empty string.\n */\nfunction validateMeasure(measure: string): string | null {\n  if (VALID_MEASURES.has(measure)) return null;\n  const match = measure.match(/^(sum|avg|min|max):(.+)$/);\n  if (match) return null;\n  return `Invalid measure \"${measure}\". Must be count, unique_users, sum:<prop>, avg:<prop>, min:<prop>, or max:<prop>.`;\n}\n\n// ─── Route handler ────────────────────────────────────────────────────────────\n\n/**\n * GET /api/trends\n *\n * Query params:\n *   event_name   (required)\n *   measure      default \"count\"\n *   granularity  default \"day\"\n *   start        (required) ISO date YYYY-MM-DD\n *   end          (required) ISO date YYYY-MM-DD\n *   breakdown    (optional) property name\n *   breakdown_limit (optional) default 10\n */\nexport async function GET(request: Request): Promise<Response> {\n  const { searchParams } = new URL(request.url);\n\n  const event_name = searchParams.get(\"event_name\");\n  const measure = searchParams.get(\"measure\") ?? \"count\";\n  const granularity = searchParams.get(\"granularity\") ?? \"day\";\n  const start = searchParams.get(\"start\");\n  const end = searchParams.get(\"end\");\n  const breakdown = searchParams.get(\"breakdown\") ?? undefined;\n  const breakdownLimitRaw = searchParams.get(\"breakdown_limit\");\n\n  // ── Required param checks ─────────────────────────────────────────────────\n\n  if (!event_name) {\n    return Response.json({ error: \"event_name is required.\" }, { status: 400 });\n  }\n\n  if (!start) {\n    return Response.json({ error: \"start is required.\" }, { status: 400 });\n  }\n\n  if (!end) {\n    return Response.json({ error: \"end is required.\" }, { status: 400 });\n  }\n\n  // ── Optional param validation ─────────────────────────────────────────────\n\n  const measureError = validateMeasure(measure);\n  if (measureError) {\n    return Response.json({ error: measureError }, { status: 400 });\n  }\n\n  if (!VALID_GRANULARITIES.has(granularity)) {\n    return Response.json(\n      {\n        error: `Invalid granularity \"${granularity}\". Must be \"day\" or \"week\".`,\n      },\n      { status: 400 },\n    );\n  }\n\n  let breakdown_limit = 10;\n  if (breakdownLimitRaw !== null) {\n    const parsed = Number(breakdownLimitRaw);\n    if (Number.isFinite(parsed) && parsed > 0) {\n      breakdown_limit = Math.floor(parsed);\n    }\n  }\n\n  // ── Execute query ─────────────────────────────────────────────────────────\n\n  try {\n    const response = await queryTrends({\n      event_name,\n      measure,\n      granularity: granularity as \"day\" | \"week\",\n      start,\n      end,\n      breakdown,\n      breakdown_limit,\n    });\n    return Response.json(response);\n  } catch (err) {\n    const message =\n      err instanceof Error ? err.message : \"Internal server error.\";\n    return Response.json({ error: message }, { status: 500 });\n  }\n}\n","numLines":102,"startLine":1,"totalLines":102}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WgknCxQexZV1W2LybyqY9K","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQueryTrends } = vi.hoisted(() => ({\n6\t  mockQueryTrends: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/trends\", () => ({\n10\t  queryTrends: mockQueryTrends,\n11\t}));\n12\t\n13\timport { GET } from \"@/app/api/trends/route\";\n14\t\n15\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n16\t\n17\tfunction makeRequest(params: Record<string, string> = {}): Request {\n18\t  const url = new URL(\"http://localhost/api/trends\");\n19\t  for (const [k, v] of Object.entries(params)) {\n20\t    url.searchParams.set(k, v);\n21\t  }\n22\t  return new Request(url.toString());\n23\t}\n24\t\n25\tconst sampleResponse = {\n26\t  series: [\n27\t    {\n28\t      label: \"Page Viewed\",\n29\t      data: [{ date: \"2026-04-01\", value: 5 }],\n30\t    },\n31\t  ],\n32\t};\n33\t\n34\t// ─── Tests ────────────────────────────────────────────────────────────────────\n35\t\n36\tbeforeEach(() => {\n37\t  mockQueryTrends.mockResolvedValue(sampleResponse);\n38\t});\n39\t\n40\tafterEach(() => {\n41\t  vi.clearAllMocks();\n42\t});\n43\t\n44\tdescribe(\"GET /api/trends\", () => {\n45\t  describe(\"success — 200\", () => {\n46\t    it(\"returns 200 with series response shape\", async () => {\n47\t      const res = await GET(\n48\t        makeRequest({\n49\t          event_name: \"Page Viewed\",\n50\t          start: \"2026-04-01\",\n51\t          end: \"2026-04-15\",\n52\t        }),\n53\t      );\n54\t\n55\t      expect(res.status).toBe(200);\n56\t      const body = await res.json();\n57\t      expect(body).toHaveProperty(\"series\");\n58\t      expect(Array.isArray(body.series)).toBe(true);\n59\t    });\n60\t\n61\t    it(\"returns the series data from queryTrends in the response body\", async () => {\n62\t      const res = await GET(\n63\t        makeRequest({\n64\t          event_name: \"Page Viewed\",\n65\t          start: \"2026-04-01\",\n66\t          end: \"2026-04-15\",\n67\t        }),\n68\t      );\n69\t      const body = await res.json();\n70\t\n71\t      expect(body.series).toEqual(sampleResponse.series);\n72\t    });\n73\t  });\n74\t\n75\t  describe(\"validation errors — 400\", () => {\n76\t    it(\"returns 400 when event_name is missing\", async () => {\n77\t      const res = await GET(\n78\t        makeRequest({ start: \"2026-04-01\", end: \"2026-04-15\" }),\n79\t      );\n80\t\n81\t      expect(res.status).toBe(400);\n82\t      const body = await res.json();\n83\t      expect(body).toHaveProperty(\"error\");\n84\t      expect(typeof body.error).toBe(\"string\");\n85\t    });\n86\t\n87\t    it(\"returns 400 when start is missing\", async () => {\n88\t      const res = await GET(\n89\t        makeRequest({ event_name: \"Page Viewed\", end: \"2026-04-15\" }),\n90\t      );\n91\t\n92\t      expect(res.status).toBe(400);\n93\t      const body = await res.json();\n94\t      expect(body).toHaveProperty(\"error\");\n95\t    });\n96\t\n97\t    it(\"returns 400 when end is missing\", async () => {\n98\t      const res = await GET(\n99\t        makeRequest({ event_name: \"Page Viewed\", start: \"2026-04-01\" }),\n100\t      );\n101\t\n102\t      expect(res.status).toBe(400);\n103\t      const body = await res.json();\n104\t      expect(body).toHaveProperty(\"error\");\n105\t    });\n106\t\n107\t    it(\"returns 400 for invalid measure format (sum: with no property)\", async () => {\n108\t      const res = await GET(\n109\t        makeRequest({\n110\t          event_name: \"Page Viewed\",\n111\t          start: \"2026-04-01\",\n112\t          end: \"2026-04-15\",\n113\t          measure: \"sum:\",\n114\t        }),\n115\t      );\n116\t\n117\t      expect(res.status).toBe(400);\n118\t      const body = await res.json();\n119\t      expect(body).toHaveProperty(\"error\");\n120\t    });\n121\t\n122\t    it(\"returns 400 for unknown measure\", async () => {\n123\t      const res = await GET(\n124\t        makeRequest({\n125\t          event_name: \"Page Viewed\",\n126\t          start: \"2026-04-01\",\n127\t          end: \"2026-04-15\",\n128\t          measure: \"unknown\",\n129\t        }),\n130\t      );\n131\t\n132\t      expect(res.status).toBe(400);\n133\t      const body = await res.json();\n134\t      expect(body).toHaveProperty(\"error\");\n135\t    });\n136\t\n137\t    it(\"returns 400 for invalid granularity\", async () => {\n138\t      const res = await GET(\n139\t        makeRequest({\n140\t          event_name: \"Page Viewed\",\n141\t          start: \"2026-04-01\",\n142\t          end: \"2026-04-15\",\n143\t          granularity: \"month\",\n144\t        }),\n145\t      );\n146\t\n147\t      expect(res.status).toBe(400);\n148\t      const body = await res.json();\n149\t      expect(body).toHaveProperty(\"error\");\n150\t    });\n151\t  });\n152\t\n153\t  describe(\"defaults\", () => {\n154\t    it(\"defaults measure to count when not provided\", async () => {\n155\t      await GET(\n156\t        makeRequest({\n157\t          event_name: \"Page Viewed\",\n158\t          start: \"2026-04-01\",\n159\t          end: \"2026-04-15\",\n160\t        }),\n161\t      );\n162\t\n163\t      expect(mockQueryTrends).toHaveBeenCalledWith(\n164\t        expect.objectContaining({ measure: \"count\" }),\n165\t      );\n166\t    });\n167\t\n168\t    it(\"defaults granularity to day when not provided\", async () => {\n169\t      await GET(\n170\t        makeRequest({\n171\t          event_name: \"Page Viewed\",\n172\t          start: \"2026-04-01\",\n173\t          end: \"2026-04-15\",\n174\t        }),\n175\t      );\n176\t\n177\t      expect(mockQueryTrends).toHaveBeenCalledWith(\n178\t        expect.objectContaining({ granularity: \"day\" }),\n179\t      );\n180\t    });\n181\t\n182\t    it(\"defaults breakdown_limit to 10 when not provided\", async () => {\n183\t      await GET(\n184\t        makeRequest({\n185\t          event_name: \"Page Viewed\",\n186\t          start: \"2026-04-01\",\n187\t          end: \"2026-04-15\",\n188\t        }),\n189\t      );\n190\t\n191\t      expect(mockQueryTrends).toHaveBeenCalledWith(\n192\t        expect.objectContaining({ breakdown_limit: 10 }),\n193\t      );\n194\t    });\n195\t  });\n196\t\n197\t  describe(\"query params forwarding\", () => {\n198\t    it(\"forwards all parsed params correctly to queryTrends\", async () => {\n199\t      await GET(\n200\t        makeRequest({\n201\t          event_name: \"Purchase Completed\",\n202\t          measure: \"sum:amount\",\n203\t          granularity: \"week\",\n204\t          start: \"2026-03-01\",\n205\t          end: \"2026-04-01\",\n206\t          breakdown: \"plan\",\n207\t          breakdown_limit: \"5\",\n208\t        }),\n209\t      );\n210\t\n211\t      expect(mockQueryTrends).toHaveBeenCalledWith({\n212\t        event_name: \"Purchase Completed\",\n213\t        measure: \"sum:amount\",\n214\t        granularity: \"week\",\n215\t        start: \"2026-03-01\",\n216\t        end: \"2026-04-01\",\n217\t        breakdown: \"plan\",\n218\t        breakdown_limit: 5,\n219\t      });\n220\t    });\n221\t\n222\t    it(\"passes breakdown as undefined when not provided\", async () => {\n223\t      await GET(\n224\t        makeRequest({\n225\t          event_name: \"Page Viewed\",\n226\t          start: \"2026-04-01\",\n227\t          end: \"2026-04-15\",\n228\t        }),\n229\t      );\n230\t\n231\t      expect(mockQueryTrends).toHaveBeenCalledWith(\n232\t        expect.objectContaining({ breakdown: undefined }),\n233\t      );\n234\t    });\n235\t  });\n236\t\n237\t  describe(\"valid measure variants\", () => {\n238\t    it.each([\n239\t      \"count\",\n240\t      \"unique_users\",\n241\t      \"sum:amount\",\n242\t      \"avg:amount\",\n243\t      \"min:price\",\n244\t      \"max:price\",\n245\t    ])(\"accepts measure=%s and returns 200\", async (measure) => {\n246\t      const res = await GET(\n247\t        makeRequest({\n248\t          event_name: \"Page Viewed\",\n249\t          start: \"2026-04-01\",\n250\t          end: \"2026-04-15\",\n251\t          measure,\n252\t        }),\n253\t      );\n254\t\n255\t      expect(res.status).toBe(200);\n256\t    });\n257\t  });\n258\t});\n259\t"}]},"parent_tool_use_id":null,"session_id":"09fd6134-5b9f-4b7d-bc24-5ed377ea7936","uuid":"e7113309-8d7d-479c-bcdf-ecb645b2ceff","timestamp":"2026-04-15T13:09:30.677Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/trends/__tests__/route.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockQueryTrends } = vi.hoisted(() => ({\n  mockQueryTrends: vi.fn(),\n}));\n\nvi.mock(\"@/lib/trends\", () => ({\n  queryTrends: mockQueryTrends,\n}));\n\nimport { GET } from \"@/app/api/trends/route\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction makeRequest(params: Record<string, string> = {}): Request {\n  const url = new URL(\"http://localhost/api/trends\");\n  for (const [k, v] of Object.entries(params)) {\n    url.searchParams.set(k, v);\n  }\n  return new Request(url.toString());\n}\n\nconst sampleResponse = {\n  series: [\n    {\n      label: \"Page Viewed\",\n      data: [{ date: \"2026-04-01\", value: 5 }],\n    },\n  ],\n};\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockQueryTrends.mockResolvedValue(sampleResponse);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\ndescribe(\"GET /api/trends\", () => {\n  describe(\"success — 200\", () => {\n    it(\"returns 200 with series response shape\", async () => {\n      const res = await GET(\n        makeRequest({\n          event_name: \"Page Viewed\",\n          start: \"2026-04-01\",\n          end: \"2026-04-15\",\n        }),\n      );\n\n      expect(res.status).toBe(200);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"series\");\n      expect(Array.isArray(body.series)).toBe(true);\n    });\n\n    it(\"returns the series data from queryTrends in the response body\", async () => {\n      const res = await GET(\n        makeRequest({\n          event_name: \"Page Viewed\",\n          start: \"2026-04-01\",\n          end: \"2026-04-15\",\n        }),\n      );\n      const body = await res.json();\n\n      expect(body.series).toEqual(sampleResponse.series);\n    });\n  });\n\n  describe(\"validation errors — 400\", () => {\n    it(\"returns 400 when event_name is missing\", async () => {\n      const res = await GET(\n        makeRequest({ start: \"2026-04-01\", end: \"2026-04-15\" }),\n      );\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n      expect(typeof body.error).toBe(\"string\");\n    });\n\n    it(\"returns 400 when start is missing\", async () => {\n      const res = await GET(\n        makeRequest({ event_name: \"Page Viewed\", end: \"2026-04-15\" }),\n      );\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n    });\n\n    it(\"returns 400 when end is missing\", async () => {\n      const res = await GET(\n        makeRequest({ event_name: \"Page Viewed\", start: \"2026-04-01\" }),\n      );\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n    });\n\n    it(\"returns 400 for invalid measure format (sum: with no property)\", async () => {\n      const res = await GET(\n        makeRequest({\n          event_name: \"Page Viewed\",\n          start: \"2026-04-01\",\n          end: \"2026-04-15\",\n          measure: \"sum:\",\n        }),\n      );\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n    });\n\n    it(\"returns 400 for unknown measure\", async () => {\n      const res = await GET(\n        makeRequest({\n          event_name: \"Page Viewed\",\n          start: \"2026-04-01\",\n          end: \"2026-04-15\",\n          measure: \"unknown\",\n        }),\n      );\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n    });\n\n    it(\"returns 400 for invalid granularity\", async () => {\n      const res = await GET(\n        makeRequest({\n          event_name: \"Page Viewed\",\n          start: \"2026-04-01\",\n          end: \"2026-04-15\",\n          granularity: \"month\",\n        }),\n      );\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n    });\n  });\n\n  describe(\"defaults\", () => {\n    it(\"defaults measure to count when not provided\", async () => {\n      await GET(\n        makeRequest({\n          event_name: \"Page Viewed\",\n          start: \"2026-04-01\",\n          end: \"2026-04-15\",\n        }),\n      );\n\n      expect(mockQueryTrends).toHaveBeenCalledWith(\n        expect.objectContaining({ measure: \"count\" }),\n      );\n    });\n\n    it(\"defaults granularity to day when not provided\", async () => {\n      await GET(\n        makeRequest({\n          event_name: \"Page Viewed\",\n          start: \"2026-04-01\",\n          end: \"2026-04-15\",\n        }),\n      );\n\n      expect(mockQueryTrends).toHaveBeenCalledWith(\n        expect.objectContaining({ granularity: \"day\" }),\n      );\n    });\n\n    it(\"defaults breakdown_limit to 10 when not provided\", async () => {\n      await GET(\n        makeRequest({\n          event_name: \"Page Viewed\",\n          start: \"2026-04-01\",\n          end: \"2026-04-15\",\n        }),\n      );\n\n      expect(mockQueryTrends).toHaveBeenCalledWith(\n        expect.objectContaining({ breakdown_limit: 10 }),\n      );\n    });\n  });\n\n  describe(\"query params forwarding\", () => {\n    it(\"forwards all parsed params correctly to queryTrends\", async () => {\n      await GET(\n        makeRequest({\n          event_name: \"Purchase Completed\",\n          measure: \"sum:amount\",\n          granularity: \"week\",\n          start: \"2026-03-01\",\n          end: \"2026-04-01\",\n          breakdown: \"plan\",\n          breakdown_limit: \"5\",\n        }),\n      );\n\n      expect(mockQueryTrends).toHaveBeenCalledWith({\n        event_name: \"Purchase Completed\",\n        measure: \"sum:amount\",\n        granularity: \"week\",\n        start: \"2026-03-01\",\n        end: \"2026-04-01\",\n        breakdown: \"plan\",\n        breakdown_limit: 5,\n      });\n    });\n\n    it(\"passes breakdown as undefined when not provided\", async () => {\n      await GET(\n        makeRequest({\n          event_name: \"Page Viewed\",\n          start: \"2026-04-01\",\n          end: \"2026-04-15\",\n        }),\n      );\n\n      expect(mockQueryTrends).toHaveBeenCalledWith(\n        expect.objectContaining({ breakdown: undefined }),\n      );\n    });\n  });\n\n  describe(\"valid measure variants\", () => {\n    it.each([\n      \"count\",\n      \"unique_users\",\n      \"sum:amount\",\n      \"avg:amount\",\n      \"min:price\",\n      \"max:price\",\n    ])(\"accepts measure=%s and returns 200\", async (measure) => {\n      const res = await GET(\n        makeRequest({\n          event_name: \"Page Viewed\",\n          start: \"2026-04-01\",\n          end: \"2026-04-15\",\n          measure,\n        }),\n      );\n\n      expect(res.status).toBe(200);\n    });\n  });\n});\n","numLines":259,"startLine":1,"totalLines":259}}}
