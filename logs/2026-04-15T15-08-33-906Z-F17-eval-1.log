{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UwAKv9mLBrkYUdZTf9NcZY","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockQueryNewEvents } = vi.hoisted(() => ({\n6\t  mockQueryNewEvents: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/live\", () => ({\n10\t  queryNewEvents: mockQueryNewEvents,\n11\t}));\n12\t\n13\timport { GET } from \"@/app/api/live/route\";\n14\t\n15\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n16\t\n17\tconst sampleEvent = {\n18\t  event_id: \"evt-1\",\n19\t  event_name: \"Page Viewed\",\n20\t  timestamp: \"2026-04-15 12:00:00.000\",\n21\t  device_id: \"device-abc\",\n22\t  user_id: null,\n23\t  properties: \"{}\",\n24\t  ingested_at: \"2026-04-15 12:00:01.000\",\n25\t  resolved_id: \"device-abc\",\n26\t};\n27\t\n28\t// ─── Tests ────────────────────────────────────────────────────────────────────\n29\t\n30\tbeforeEach(() => {\n31\t  mockQueryNewEvents.mockResolvedValue([]);\n32\t  vi.useFakeTimers();\n33\t});\n34\t\n35\tafterEach(() => {\n36\t  vi.useRealTimers();\n37\t  vi.clearAllMocks();\n38\t});\n39\t\n40\tdescribe(\"GET /api/live\", () => {\n41\t  it(\"returns status 200\", async () => {\n42\t    const res = await GET();\n43\t    expect(res.status).toBe(200);\n44\t    res.body?.cancel();\n45\t  });\n46\t\n47\t  it(\"returns Content-Type: text/event-stream\", async () => {\n48\t    const res = await GET();\n49\t    expect(res.headers.get(\"Content-Type\")).toContain(\"text/event-stream\");\n50\t    res.body?.cancel();\n51\t  });\n52\t\n53\t  it(\"returns Cache-Control: no-cache\", async () => {\n54\t    const res = await GET();\n55\t    expect(res.headers.get(\"Cache-Control\")).toBe(\"no-cache\");\n56\t    res.body?.cancel();\n57\t  });\n58\t\n59\t  it(\"returns a non-null body stream\", async () => {\n60\t    const res = await GET();\n61\t    expect(res.body).not.toBeNull();\n62\t    res.body?.cancel();\n63\t  });\n64\t\n65\t  it(\"emits data: <JSON>\\\\n\\\\n for each event returned by queryNewEvents\", async () => {\n66\t    mockQueryNewEvents\n67\t      .mockResolvedValueOnce([sampleEvent])\n68\t      .mockResolvedValue([]);\n69\t\n70\t    const res = await GET();\n71\t    expect(res.body).not.toBeNull();\n72\t    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n73\t    const decoder = new TextDecoder();\n74\t\n75\t    // Advance clock 1 second to trigger the first polling tick\n76\t    await vi.advanceTimersByTimeAsync(1000);\n77\t\n78\t    const { value } = await reader.read();\n79\t    const text = decoder.decode(value);\n80\t\n81\t    expect(text).toContain(`data: ${JSON.stringify(sampleEvent)}\\n\\n`);\n82\t\n83\t    reader.cancel();\n84\t  });\n85\t\n86\t  it(\"does not emit data: lines when queryNewEvents returns an empty array\", async () => {\n87\t    mockQueryNewEvents.mockResolvedValue([]);\n88\t\n89\t    const res = await GET();\n90\t    expect(res.body).not.toBeNull();\n91\t    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n92\t\n93\t    // Advance clock to trigger the polling tick\n94\t    await vi.advanceTimersByTimeAsync(1000);\n95\t\n96\t    // Confirm the tick ran\n97\t    expect(mockQueryNewEvents).toHaveBeenCalledOnce();\n98\t\n99\t    // Start a read — it should stay pending since nothing was enqueued\n100\t    let didResolve = false;\n101\t    const readPromise = reader.read().then(() => {\n102\t      didResolve = true;\n103\t    });\n104\t\n105\t    // Flush microtasks — any immediately-enqueued data would resolve here\n106\t    await Promise.resolve();\n107\t    await Promise.resolve();\n108\t\n109\t    expect(didResolve).toBe(false);\n110\t\n111\t    // Cleanup: cancel the stream (this will eventually resolve the pending read)\n112\t    reader.cancel();\n113\t    await readPromise.catch(() => {});\n114\t  });\n115\t});\n116\t"}]},"parent_tool_use_id":null,"session_id":"a5aaa11d-67a7-4ffc-9b3b-2cb42566b1cb","uuid":"66ac76f8-d63d-4115-b3b0-36f2aaf284ed","timestamp":"2026-04-15T15:59:44.299Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/live/__tests__/route.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockQueryNewEvents } = vi.hoisted(() => ({\n  mockQueryNewEvents: vi.fn(),\n}));\n\nvi.mock(\"@/lib/live\", () => ({\n  queryNewEvents: mockQueryNewEvents,\n}));\n\nimport { GET } from \"@/app/api/live/route\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nconst sampleEvent = {\n  event_id: \"evt-1\",\n  event_name: \"Page Viewed\",\n  timestamp: \"2026-04-15 12:00:00.000\",\n  device_id: \"device-abc\",\n  user_id: null,\n  properties: \"{}\",\n  ingested_at: \"2026-04-15 12:00:01.000\",\n  resolved_id: \"device-abc\",\n};\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockQueryNewEvents.mockResolvedValue([]);\n  vi.useFakeTimers();\n});\n\nafterEach(() => {\n  vi.useRealTimers();\n  vi.clearAllMocks();\n});\n\ndescribe(\"GET /api/live\", () => {\n  it(\"returns status 200\", async () => {\n    const res = await GET();\n    expect(res.status).toBe(200);\n    res.body?.cancel();\n  });\n\n  it(\"returns Content-Type: text/event-stream\", async () => {\n    const res = await GET();\n    expect(res.headers.get(\"Content-Type\")).toContain(\"text/event-stream\");\n    res.body?.cancel();\n  });\n\n  it(\"returns Cache-Control: no-cache\", async () => {\n    const res = await GET();\n    expect(res.headers.get(\"Cache-Control\")).toBe(\"no-cache\");\n    res.body?.cancel();\n  });\n\n  it(\"returns a non-null body stream\", async () => {\n    const res = await GET();\n    expect(res.body).not.toBeNull();\n    res.body?.cancel();\n  });\n\n  it(\"emits data: <JSON>\\\\n\\\\n for each event returned by queryNewEvents\", async () => {\n    mockQueryNewEvents\n      .mockResolvedValueOnce([sampleEvent])\n      .mockResolvedValue([]);\n\n    const res = await GET();\n    expect(res.body).not.toBeNull();\n    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n    const decoder = new TextDecoder();\n\n    // Advance clock 1 second to trigger the first polling tick\n    await vi.advanceTimersByTimeAsync(1000);\n\n    const { value } = await reader.read();\n    const text = decoder.decode(value);\n\n    expect(text).toContain(`data: ${JSON.stringify(sampleEvent)}\\n\\n`);\n\n    reader.cancel();\n  });\n\n  it(\"does not emit data: lines when queryNewEvents returns an empty array\", async () => {\n    mockQueryNewEvents.mockResolvedValue([]);\n\n    const res = await GET();\n    expect(res.body).not.toBeNull();\n    const reader = (res.body as ReadableStream<Uint8Array>).getReader();\n\n    // Advance clock to trigger the polling tick\n    await vi.advanceTimersByTimeAsync(1000);\n\n    // Confirm the tick ran\n    expect(mockQueryNewEvents).toHaveBeenCalledOnce();\n\n    // Start a read — it should stay pending since nothing was enqueued\n    let didResolve = false;\n    const readPromise = reader.read().then(() => {\n      didResolve = true;\n    });\n\n    // Flush microtasks — any immediately-enqueued data would resolve here\n    await Promise.resolve();\n    await Promise.resolve();\n\n    expect(didResolve).toBe(false);\n\n    // Cleanup: cancel the stream (this will eventually resolve the pending read)\n    reader.cancel();\n    await readPromise.catch(() => {});\n  });\n});\n","numLines":116,"startLine":1,"totalLines":116}}}
