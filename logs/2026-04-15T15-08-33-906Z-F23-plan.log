{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SGy3iHrWFUKiipXtHvrKBx","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { cleanup, fireEvent, render, screen } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport { TrendChart } from \"@/components/TrendChart\";\n5\timport type { Series } from \"@/lib/trends\";\n6\t\n7\t// ─── Mock recharts ─────────────────────────────────────────────────────────────\n8\t// Recharts needs ResizeObserver and real DOM dimensions to render.\n9\t// jsdom has zero-size containers, so we stub the chart components.\n10\t\n11\tvi.mock(\"recharts\", () => ({\n12\t  ResponsiveContainer: ({ children }: { children: React.ReactNode }) => (\n13\t    <div>{children}</div>\n14\t  ),\n15\t  LineChart: ({ children }: { children: React.ReactNode }) => (\n16\t    <div data-testid=\"recharts-line-chart\">{children}</div>\n17\t  ),\n18\t  BarChart: ({ children }: { children: React.ReactNode }) => (\n19\t    <div data-testid=\"recharts-bar-chart\">{children}</div>\n20\t  ),\n21\t  AreaChart: ({ children }: { children: React.ReactNode }) => (\n22\t    <div data-testid=\"recharts-area-chart\">{children}</div>\n23\t  ),\n24\t  Line: () => null,\n25\t  Bar: () => null,\n26\t  Area: () => null,\n27\t  XAxis: () => null,\n28\t  YAxis: () => null,\n29\t  CartesianGrid: () => null,\n30\t  Tooltip: () => null,\n31\t  Legend: () => null,\n32\t}));\n33\t\n34\t// ─── Fixtures ─────────────────────────────────────────────────────────────────\n35\t\n36\tfunction makeSeries(numPoints: number): Series[] {\n37\t  const data = Array.from({ length: numPoints }, (_, i) => ({\n38\t    date: `2026-04-${String(i + 1).padStart(2, \"0\")}`,\n39\t    value: i * 10,\n40\t  }));\n41\t  return [{ label: \"Page Viewed\", data }];\n42\t}\n43\t\n44\tfunction makeMultiSeries(numPoints: number): Series[] {\n45\t  const data = Array.from({ length: numPoints }, (_, i) 