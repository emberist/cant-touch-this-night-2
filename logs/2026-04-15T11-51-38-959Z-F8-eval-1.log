{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UvKpcGS1mWeeAkpLWpGzca","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\timport {\n4\t  getCachedSchema,\n5\t  invalidateSchemaCache,\n6\t  setCachedSchema,\n7\t} from \"@/lib/schema-cache\";\n8\t\n9\tconst sampleSchema = {\n10\t  event_names: [\"Page Viewed\", \"Purchase Completed\"],\n11\t  properties: {\n12\t    \"Purchase Completed\": {\n13\t      amount: \"numeric\" as const,\n14\t      currency: \"string\" as const,\n15\t    },\n16\t  },\n17\t};\n18\t\n19\tbeforeEach(() => {\n20\t  vi.useFakeTimers();\n21\t  invalidateSchemaCache();\n22\t});\n23\t\n24\tafterEach(() => {\n25\t  vi.useRealTimers();\n26\t});\n27\t\n28\tdescribe(\"schema cache\", () => {\n29\t  it(\"returns null when cache is empty (never set)\", () => {\n30\t    expect(getCachedSchema()).toBeNull();\n31\t  });\n32\t\n33\t  it(\"returns the cached value within the TTL window\", () => {\n34\t    setCachedSchema(sampleSchema);\n35\t\n36\t    // Advance by 59 seconds — still within 60-second TTL\n37\t    vi.advanceTimersByTime(59_000);\n38\t\n39\t    expect(getCachedSchema()).toEqual(sampleSchema);\n40\t  });\n41\t\n42\t  it(\"returns null after TTL expires\", () => {\n43\t    setCachedSchema(sampleSchema);\n44\t\n45\t    // Advance by exactly 60 seconds — TTL expired\n46\t    vi.advanceTimersByTime(60_000);\n47\t\n48\t    expect(getCachedSchema()).toBeNull();\n49\t  });\n50\t\n51\t  it(\"returns null after TTL expires (well past expiry)\", () => {\n52\t    setCachedSchema(sampleSchema);\n53\t\n54\t    // Advance well past TTL\n55\t    vi.advanceTimersByTime(120_000);\n56\t\n57\t    expect(getCachedSchema()).toBeNull();\n58\t  });\n59\t\n60\t  it(\"returns null after manual invalidation\", () => {\n61\t    setCachedSchema(sampleSchema);\n62\t    invalidateSchemaCache();\n63\t\n64\t    expect(getCachedSchema()).toBeNull();\n65\t  });\n66\t\n67\t  it(\"returns freshly set value after invalidation and re-set\", () => {\n68\t    setCachedSchema(sampleSchema);\n69\t    invalidateSchemaCache();\n70\t\n71\t    const newSchema = {\n72\t      event_names: [\"Button Clicked\"],\n73\t      properties: {},\n74\t    };\n75\t    setCachedSchema(newSchema);\n76\t\n77\t    expect(getCachedSchema()).toEqual(newSchema);\n78\t  });\n79\t\n80\t  it(\"returns the last set value when set multiple times\", () => {\n81\t    setCachedSchema(sampleSchema);\n82\t\n83\t    const updated = {\n84\t      event_names: [\"Page Viewed\"],\n85\t      properties: {},\n86\t    };\n87\t    setCachedSchema(updated);\n88\t\n89\t    expect(getCachedSchema()).toEqual(updated);\n90\t  });\n91\t});\n92\t"}]},"parent_tool_use_id":null,"session_id":"bf5c5d54-f5be-4f7e-81c9-7cee309979d4","uuid":"d193ebc8-adc5-4114-9df4-9e32c9089e8c","timestamp":"2026-04-15T12:46:41.356Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/schema-cache.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\nimport {\n  getCachedSchema,\n  invalidateSchemaCache,\n  setCachedSchema,\n} from \"@/lib/schema-cache\";\n\nconst sampleSchema = {\n  event_names: [\"Page Viewed\", \"Purchase Completed\"],\n  properties: {\n    \"Purchase Completed\": {\n      amount: \"numeric\" as const,\n      currency: \"string\" as const,\n    },\n  },\n};\n\nbeforeEach(() => {\n  vi.useFakeTimers();\n  invalidateSchemaCache();\n});\n\nafterEach(() => {\n  vi.useRealTimers();\n});\n\ndescribe(\"schema cache\", () => {\n  it(\"returns null when cache is empty (never set)\", () => {\n    expect(getCachedSchema()).toBeNull();\n  });\n\n  it(\"returns the cached value within the TTL window\", () => {\n    setCachedSchema(sampleSchema);\n\n    // Advance by 59 seconds — still within 60-second TTL\n    vi.advanceTimersByTime(59_000);\n\n    expect(getCachedSchema()).toEqual(sampleSchema);\n  });\n\n  it(\"returns null after TTL expires\", () => {\n    setCachedSchema(sampleSchema);\n\n    // Advance by exactly 60 seconds — TTL expired\n    vi.advanceTimersByTime(60_000);\n\n    expect(getCachedSchema()).toBeNull();\n  });\n\n  it(\"returns null after TTL expires (well past expiry)\", () => {\n    setCachedSchema(sampleSchema);\n\n    // Advance well past TTL\n    vi.advanceTimersByTime(120_000);\n\n    expect(getCachedSchema()).toBeNull();\n  });\n\n  it(\"returns null after manual invalidation\", () => {\n    setCachedSchema(sampleSchema);\n    invalidateSchemaCache();\n\n    expect(getCachedSchema()).toBeNull();\n  });\n\n  it(\"returns freshly set value after invalidation and re-set\", () => {\n    setCachedSchema(sampleSchema);\n    invalidateSchemaCache();\n\n    const newSchema = {\n      event_names: [\"Button Clicked\"],\n      properties: {},\n    };\n    setCachedSchema(newSchema);\n\n    expect(getCachedSchema()).toEqual(newSchema);\n  });\n\n  it(\"returns the last set value when set multiple times\", () => {\n    setCachedSchema(sampleSchema);\n\n    const updated = {\n      event_names: [\"Page Viewed\"],\n      properties: {},\n    };\n    setCachedSchema(updated);\n\n    expect(getCachedSchema()).toEqual(updated);\n  });\n});\n","numLines":92,"startLine":1,"totalLines":92}}}
