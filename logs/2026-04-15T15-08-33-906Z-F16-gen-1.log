y.events).toBe(0);\n      expect(body.users).toBe(0);\n    });\n  });\n\n  describe(\"failure — 500\", () => {\n    it(\"returns 500 with error message when ClickHouse query throws\", async () => {\n      vi.clearAllMocks();\n      mockQuery.mockRejectedValue(new Error(\"Connection refused\"));\n\n      const res = await GET();\n\n      expect(res.status).toBe(500);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n      expect(body.error).toBe(\"Connection refused\");\n    });\n\n    it(\"returns 500 with generic message for non-Error rejections\", async () => {\n      vi.clearAllMocks();\n      mockQuery.mockRejectedValue(\"unknown failure\");\n\n      const res = await GET();\n\n      expect(res.status).toBe(500);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n      expect(body.error).toBe(\"Internal server error.\");\n    });\n  });\n});\n","structuredPatch":[{"oldStart":76,"oldLines":7,"newStart":76,"newLines":7,"lines":[" ","   describe(\"failure — 500\", () => {","     it(\"returns 500 with error message when ClickHouse query throws\", async () => {","-      vi.clearAllMocks();","+      mockQuery.mockReset();","       mockQuery.mockRejectedValue(new Error(\"Connection refused\"));"," ","       const res = await GET();"]},{"oldStart":88,"oldLines":7,"newStart":88,"newLines":7,"lines":["     });"," ","     it(\"returns 500 with generic message for non-Error rejections\", async () => {","-      vi.clearAllMocks();","+      mockQuery.mockReset();","       mockQuery.mockRejectedValue(\"unknown failure\");"," ","       const res = await GET();"]}],"userModified":false,"replaceAll":false}}
