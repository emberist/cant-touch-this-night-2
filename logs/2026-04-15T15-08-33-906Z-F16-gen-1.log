{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q4KNhu4S8XxmaKJmBc62jE","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\t// Hoist all mock refs AND the error class so they're available inside vi.mock factory\n6\tconst { mockInsertEvent, MockIdentityConflictError } = vi.hoisted(() => {\n7\t  class HoistedConflictError extends Error {\n8\t    readonly status = 409 as const;\n9\t    constructor(msg = \"Device conflict\") {\n10\t      super(msg);\n11\t      this.name = \"IdentityConflictError\";\n12\t      Object.setPrototypeOf(this, HoistedConflictError.prototype);\n13\t    }\n14\t  }\n15\t\n16\t  return {\n17\t    mockInsertEvent: vi.fn(),\n18\t    MockIdentityConflictError: HoistedConflictError,\n19\t  };\n20\t});\n21\t\n22\tvi.mock(\"@/lib/identity\", () => ({\n23\t  insertEvent: mockInsertEvent,\n24\t  IdentityConflictError: MockIdentityConflictError,\n25\t}));\n26\t\n27\timport { POST } from \"@/app/api/events/route\";\n28\t\n29\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n30\t\n31\tfunction makeRequest(body: unknown): Request {\n32\t  return new Request(\"http://localhost/api/events\", {\n33\t    method: \"POST\",\n34\t    body: JSON.stringify(body),\n35\t    headers: { \"Content-Type\": \"application/json\" },\n36\t  });\n37\t}\n38\t\n39\tfunction makeMalformedRequest(): Request {\n40\t  return new Request(\"http://localhost/api/events\", {\n41\t    method: \"POST\",\n42\t    body: \"{ this is not valid json !!!\",\n43\t    headers: { \"Content-Type\": \"application/json\" },\n44\t  });\n45\t}\n46\t\n47\tconst sampleRow = {\n48\t  event_id: \"uuid-1234\",\n49\t  event_name: \"Page Viewed\",\n50\t  timestamp: \"2026-04-15T10:00:00.000Z\",\n51\t  device_id: \"dev-1\",\n52\t  user_id: null,\n53\t  properties: \"{}\",\n54\t  ingested_at: \"2026-04-15T10:00:00.100Z\",\n55\t  resolved_id: \"dev-1\",\n56\t};\n57\t\n58\t// ─── Tests ────────────────────────────────────────────────────────────────────\n59\t\n60\tbeforeEach(() => {\n61\t  mockInsertEvent.mockResolvedValue(sampleRow);\n62\t});\n63\t\n64\tafterEach(() => {\n65\t  vi.clearAllMocks();\n66\t});\n67\t\n68\tdescribe(\"POST /api/events\", () => {\n69\t  describe(\"success — 201\", () => {\n70\t    it(\"returns 201 with event_id, event_name, resolved_id for device_id-only event\", async () => {\n71\t      const res = await POST(\n72\t        makeRequest({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n73\t      );\n74\t\n75\t      expect(res.status).toBe(201);\n76\t      const body = await res.json();\n77\t      expect(body).toMatchObject({\n78\t        event_id: sampleRow.event_id,\n79\t        event_name: sampleRow.event_name,\n80\t        resolved_id: sampleRow.resolved_id,\n81\t      });\n82\t    });\n83\t\n84\t    it(\"returns 201 for user_id-only event\", async () => {\n85\t      const userRow = {\n86\t        ...sampleRow,\n87\t        device_id: null,\n88\t        user_id: \"user@test.com\",\n89\t        resolved_id: \"user@test.com\",\n90\t      };\n91\t      mockInsertEvent.mockResolvedValue(userRow);\n92\t\n93\t      const res = await POST(\n94\t        makeRequest({\n95\t          event_name: \"Purchase Completed\",\n96\t          user_id: \"user@test.com\",\n97\t        }),\n98\t      );\n99\t\n100\t      expect(res.status).toBe(201);\n101\t    });\n102\t\n103\t    it(\"returns 201 for event with both device_id and user_id\", async () => {\n104\t      const bothRow = {\n105\t        ...sampleRow,\n106\t        user_id: \"user@test.com\",\n107\t        resolved_id: \"user@test.com\",\n108\t      };\n109\t      mockInsertEvent.mockResolvedValue(bothRow);\n110\t\n111\t      const res = await POST(\n112\t        makeRequest({\n113\t          event_name: \"Signup Completed\",\n114\t          device_id: \"dev-1\",\n115\t          user_id: \"user@test.com\",\n116\t        }),\n117\t      );\n118\t\n119\t      expect(res.status).toBe(201);\n120\t    });\n121\t\n122\t    it(\"preserves caller-provided timestamp in the returned row\", async () => {\n123\t      const ts = \"2026-01-15T10:30:00.000Z\";\n124\t      const rowWithTs = { ...sampleRow, timestamp: ts };\n125\t      mockInsertEvent.mockResolvedValue(rowWithTs);\n126\t\n127\t      const res = await POST(\n128\t        makeRequest({\n129\t          event_name: \"Page Viewed\",\n130\t          device_id: \"dev-1\",\n131\t          timestamp: ts,\n132\t        }),\n133\t      );\n134\t\n135\t      expect(res.status).toBe(201);\n136\t      const body = await res.json();\n137\t      expect(body.timestamp).toBe(ts);\n138\t    });\n139\t\n140\t    it(\"passes the parsed body to insertEvent\", async () => {\n141\t      const input = { event_name: \"Button Clicked\", device_id: \"dev-2\" };\n142\t      await POST(makeRequest(input));\n143\t\n144\t      expect(mockInsertEvent).toHaveBeenCalledWith(input);\n145\t    });\n146\t  });\n147\t\n148\t  describe(\"validation errors — 400\", () => {\n149\t    it(\"returns 400 with error when event_name is missing\", async () => {\n150\t      mockInsertEvent.mockRejectedValue(\n151\t        new Error(\"event_name is required and must be a non-empty string.\"),\n152\t      );\n153\t\n154\t      const res = await POST(makeRequest({ device_id: \"dev-1\" }));\n155\t\n156\t      expect(res.status).toBe(400);\n157\t      const body = await res.json();\n158\t      expect(body).toHaveProperty(\"error\");\n159\t      expect(typeof body.error).toBe(\"string\");\n160\t    });\n161\t\n162\t    it(\"returns 400 with error when both device_id and user_id are missing\", async () => {\n163\t      mockInsertEvent.mockRejectedValue(\n164\t        new Error(\"At least one of device_id or user_id must be present.\"),\n165\t      );\n166\t\n167\t      const res = await POST(makeRequest({ event_name: \"Page Viewed\" }));\n168\t\n169\t      expect(res.status).toBe(400);\n170\t      const body = await res.json();\n171\t      expect(body).toHaveProperty(\"error\");\n172\t    });\n173\t\n174\t    it(\"returns 400 when request body is not valid JSON\", async () => {\n175\t      const res = await POST(makeMalformedRequest());\n176\t\n177\t      expect(res.status).toBe(400);\n178\t      const body = await res.json();\n179\t      expect(body).toHaveProperty(\"error\");\n180\t    });\n181\t  });\n182\t\n183\t  describe(\"identity conflict — 409\", () => {\n184\t    it(\"returns 409 with error when IdentityConflictError is thrown\", async () => {\n185\t      mockInsertEvent.mockRejectedValue(\n186\t        new MockIdentityConflictError(\"Device conflict\"),\n187\t      );\n188\t\n189\t      const res = await POST(\n190\t        makeRequest({\n191\t          event_name: \"Signup Completed\",\n192\t          device_id: \"dev-1\",\n193\t          user_id: \"user@test.com\",\n194\t        }),\n195\t      );\n196\t\n197\t      expect(res.status).toBe(409);\n198\t      const body = await res.json();\n199\t      expect(body).toHaveProperty(\"error\");\n200\t      expect(typeof body.error).toBe(\"string\");\n201\t    });\n202\t  });\n203\t});\n204\t"}]},"parent_tool_use_id":null,"session_id":"154b1bb3-2180-48a3-9fc4-525491cd885a","uuid":"ba97857c-7fb4-4185-b06e-77918b2579d5","timestamp":"2026-04-15T15:09:55.407Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/events/__tests__/route.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\n// Hoist all mock refs AND the error class so they're available inside vi.mock factory\nconst { mockInsertEvent, MockIdentityConflictError } = vi.hoisted(() => {\n  class HoistedConflictError extends Error {\n    readonly status = 409 as const;\n    constructor(msg = \"Device conflict\") {\n      super(msg);\n      this.name = \"IdentityConflictError\";\n      Object.setPrototypeOf(this, HoistedConflictError.prototype);\n    }\n  }\n\n  return {\n    mockInsertEvent: vi.fn(),\n    MockIdentityConflictError: HoistedConflictError,\n  };\n});\n\nvi.mock(\"@/lib/identity\", () => ({\n  insertEvent: mockInsertEvent,\n  IdentityConflictError: MockIdentityConflictError,\n}));\n\nimport { POST } from \"@/app/api/events/route\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction makeRequest(body: unknown): Request {\n  return new Request(\"http://localhost/api/events\", {\n    method: \"POST\",\n    body: JSON.stringify(body),\n    headers: { \"Content-Type\": \"application/json\" },\n  });\n}\n\nfunction makeMalformedRequest(): Request {\n  return new Request(\"http://localhost/api/events\", {\n    method: \"POST\",\n    body: \"{ this is not valid json !!!\",\n    headers: { \"Content-Type\": \"application/json\" },\n  });\n}\n\nconst sampleRow = {\n  event_id: \"uuid-1234\",\n  event_name: \"Page Viewed\",\n  timestamp: \"2026-04-15T10:00:00.000Z\",\n  device_id: \"dev-1\",\n  user_id: null,\n  properties: \"{}\",\n  ingested_at: \"2026-04-15T10:00:00.100Z\",\n  resolved_id: \"dev-1\",\n};\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockInsertEvent.mockResolvedValue(sampleRow);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\ndescribe(\"POST /api/events\", () => {\n  describe(\"success — 201\", () => {\n    it(\"returns 201 with event_id, event_name, resolved_id for device_id-only event\", async () => {\n      const res = await POST(\n        makeRequest({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n      );\n\n      expect(res.status).toBe(201);\n      const body = await res.json();\n      expect(body).toMatchObject({\n        event_id: sampleRow.event_id,\n        event_name: sampleRow.event_name,\n        resolved_id: sampleRow.resolved_id,\n      });\n    });\n\n    it(\"returns 201 for user_id-only event\", async () => {\n      const userRow = {\n        ...sampleRow,\n        device_id: null,\n        user_id: \"user@test.com\",\n        resolved_id: \"user@test.com\",\n      };\n      mockInsertEvent.mockResolvedValue(userRow);\n\n      const res = await POST(\n        makeRequest({\n          event_name: \"Purchase Completed\",\n          user_id: \"user@test.com\",\n        }),\n      );\n\n      expect(res.status).toBe(201);\n    });\n\n    it(\"returns 201 for event with both device_id and user_id\", async () => {\n      const bothRow = {\n        ...sampleRow,\n        user_id: \"user@test.com\",\n        resolved_id: \"user@test.com\",\n      };\n      mockInsertEvent.mockResolvedValue(bothRow);\n\n      const res = await POST(\n        makeRequest({\n          event_name: \"Signup Completed\",\n          device_id: \"dev-1\",\n          user_id: \"user@test.com\",\n        }),\n      );\n\n      expect(res.status).toBe(201);\n    });\n\n    it(\"preserves caller-provided timestamp in the returned row\", async () => {\n      const ts = \"2026-01-15T10:30:00.000Z\";\n      const rowWithTs = { ...sampleRow, timestamp: ts };\n      mockInsertEvent.mockResolvedValue(rowWithTs);\n\n      const res = await POST(\n        makeRequest({\n          event_name: \"Page Viewed\",\n          device_id: \"dev-1\",\n          timestamp: ts,\n        }),\n      );\n\n      expect(res.status).toBe(201);\n      const body = await res.json();\n      expect(body.timestamp).toBe(ts);\n    });\n\n    it(\"passes the parsed body to insertEvent\", async () => {\n      const input = { event_name: \"Button Clicked\", device_id: \"dev-2\" };\n      await POST(makeRequest(input));\n\n      expect(mockInsertEvent).toHaveBeenCalledWith(input);\n    });\n  });\n\n  describe(\"validation errors — 400\", () => {\n    it(\"returns 400 with error when event_name is missing\", async () => {\n      mockInsertEvent.mockRejectedValue(\n        new Error(\"event_name is required and must be a non-empty string.\"),\n      );\n\n      const res = await POST(makeRequest({ device_id: \"dev-1\" }));\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n      expect(typeof body.error).toBe(\"string\");\n    });\n\n    it(\"returns 400 with error when both device_id and user_id are missing\", async () => {\n      mockInsertEvent.mockRejectedValue(\n        new Error(\"At least one of device_id or user_id must be present.\"),\n      );\n\n      const res = await POST(makeRequest({ event_name: \"Page Viewed\" }));\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n    });\n\n    it(\"returns 400 when request body is not valid JSON\", async () => {\n      const res = await POST(makeMalformedRequest());\n\n      expect(res.status).toBe(400);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n    });\n  });\n\n  describe(\"identity conflict — 409\", () => {\n    it(\"returns 409 with error when IdentityConflictError is thrown\", async () => {\n      mockInsertEvent.mockRejectedValue(\n        new MockIdentityConflictError(\"Device conflict\"),\n      );\n\n      const res = await POST(\n        makeRequest({\n          event_name: \"Signup Completed\",\n          device_id: \"dev-1\",\n          user_id: \"user@test.com\",\n        }),\n      );\n\n      expect(res.status).toBe(409);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n      expect(typeof body.error).toBe(\"string\");\n    });\n  });\n});\n","numLines":204,"startLine":1,"totalLines":204}}}
