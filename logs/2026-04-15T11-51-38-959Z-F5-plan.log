{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012VRVQtrpYijADU4NEv5BRA","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// Hoist mock refs so vi.mock factory can reference them\n4\tconst { mockQuery, mockInsert } = vi.hoisted(() => ({\n5\t  mockQuery: vi.fn(),\n6\t  mockInsert: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: {\n11\t    query: mockQuery,\n12\t    insert: mockInsert,\n13\t  },\n14\t}));\n15\t\n16\timport {\n17\t  IdentityConflictError,\n18\t  insertEvent,\n19\t  resolveIdentityMapping,\n20\t  validateEvent,\n21\t} from \"@/lib/identity\";\n22\t\n23\t// Helper: set up mockQuery to return a given rows array\n24\tfunction mockQueryReturns(rows: unknown[]) {\n25\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n26\t}\n27\t\n28\tbeforeEach(() => {\n29\t  // Default: no existing identity mapping, inserts succeed\n30\t  mockQueryReturns([]);\n31\t  mockInsert.mockResolvedValue(undefined);\n32\t});\n33\t\n34\tafterEach(() => {\n35\t  vi.clearAllMocks();\n36\t});\n37\t\n38\t// ─── validateEvent ────────────────────────────────────────────────────────────\n39\t\n40\tdescribe(\"validateEvent\", () => {\n41\t  it(\"rejects when both device_id and user_id are missing\", () => {\n42\t    expect(() => validateEvent({ event_name: \"Page Viewed\" })).toThrow();\n43\t  });\n44\t\n45\t  it(\"rejects when event_name is missing\", () => {\n46\t    expect(() => validateEvent({ device_id: \"dev-1\" })).toThrow();\n47\t  });\n48\t\n49\t  it(\"rejects when event_name is empty string\", () => {\n50\t    expect(() =>\n51\t      validateEvent({ event_name: \"\", device_id: \"dev-1\" }),\n52\t    ).toThrow();\n53\t  });\n54\t\n55\t  it(\"rejects when event_name is whitespace only\", () => {\n56\t    expect(() =>\n57\t      validateEvent({ event_name: \"  \", device_id: \"dev-1\" }),\n58\t    ).toThrow();\n59\t  });\n60\t\n61\t  it(\"accepts event with only device_id\", () => {\n62\t    expect(() =>\n63\t      validateEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n64\t    ).not.toThrow();\n65\t  });\n66\t\n67\t  it(\"accepts event with only user_id\", () => {\n68\t    expect(() =>\n69\t      validateEvent({ event_name: \"Page Viewed\", user_id: \"user@test.com\" }),\n70\t    ).not.toThrow();\n71\t  });\n72\t\n73\t  it(\"accepts event with both device_id and user_id\", () => {\n74\t    expect(() =>\n75\t      validateEvent({\n76\t        event_name: \"Signup Completed\",\n77\t        device_id: \"dev-1\",\n78\t        user_id: \"user@test.com\",\n79\t      }),\n80\t    ).not.toThrow();\n81\t  });\n82\t});\n83\t\n84\t// ─── insertEvent ──────────────────────────────────────────────────────────────\n85\t\n86\tdescribe(\"insertEvent\", () => {\n87\t  it(\"defaults timestamp to current time when not provided\", async () => {\n88\t    const before = Date.now();\n89\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n90\t    const after = Date.now();\n91\t\n92\t    const insertCall = mockInsert.mock.calls[0][0];\n93\t    const insertedTs = new Date(insertCall.values[0].timestamp).getTime();\n94\t    expect(insertedTs).toBeGreaterThanOrEqual(before);\n95\t    expect(insertedTs).toBeLessThanOrEqual(after);\n96\t  });\n97\t\n98\t  it(\"preserves caller-provided timestamp\", async () => {\n99\t    const ts = \"2026-01-15T10:30:00.000Z\";\n100\t    await insertEvent({\n101\t      event_name: \"Page Viewed\",\n102\t      device_id: \"dev-1\",\n103\t      timestamp: ts,\n104\t    });\n105\t\n106\t    const insertCall = mockInsert.mock.calls[0][0];\n107\t    expect(insertCall.values[0].timestamp).toBe(ts);\n108\t  });\n109\t\n110\t  it(\"inserts event into the events table\", async () => {\n111\t    await insertEvent({\n112\t      event_name: \"Purchase Completed\",\n113\t      user_id: \"user@test.com\",\n114\t      properties: { amount: 49.99 },\n115\t    });\n116\t\n117\t    expect(mockInsert).toHaveBeenCalledWith(\n118\t      expect.objectContaining({ table: \"events\" }),\n119\t    );\n120\t  });\n121\t\n122\t  it(\"stores event_name correctly in the inserted row\", async () => {\n123\t    await insertEvent({ event_name: \"Button Clicked\", device_id: \"dev-2\" });\n124\t\n125\t    const insertCall = mockInsert.mock.calls[0][0];\n126\t    expect(insertCall.values[0].event_name).toBe(\"Button Clicked\");\n127\t  });\n128\t\n129\t  it(\"serialises properties as a JSON string\", async () => {\n130\t    await insertEvent({\n131\t      event_name: \"Page Viewed\",\n132\t      device_id: \"dev-1\",\n133\t      properties: { page: \"/home\", count: 3 },\n134\t    });\n135\t\n136\t    const insertCall = mockInsert.mock.calls[0][0];\n137\t    expect(insertCall.values[0].properties).toBe(\n138\t      JSON.stringify({ page: \"/home\", count: 3 }),\n139\t    );\n140\t  });\n141\t\n142\t  it(\"defaults properties to '{}' when not provided\", async () => {\n143\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n144\t\n145\t    const insertCall = mockInsert.mock.calls[0][0];\n146\t    expect(insertCall.values[0].properties).toBe(\"{}\");\n147\t  });\n148\t\n149\t  it(\"calls resolveIdentityMapping (queries mappings) when both device_id and user_id are present\", async () => {\n150\t    await insertEvent({\n151\t      event_name: \"Signup Completed\",\n152\t      device_id: \"dev-1\",\n153\t      user_id: \"user@test.com\",\n154\t    });\n155\t\n156\t    // resolveIdentityMapping does a SELECT on identity_mappings\n157\t    expect(mockQuery).toHaveBeenCalled();\n158\t  });\n159\t\n160\t  it(\"does NOT call resolveIdentityMapping when only device_id is present\", async () => {\n161\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n162\t\n163\t    expect(mockQuery).not.toHaveBeenCalled();\n164\t  });\n165\t\n166\t  it(\"does NOT call resolveIdentityMapping when only user_id is present\", async () => {\n167\t    await insertEvent({\n168\t      event_name: \"Purchase Completed\",\n169\t      user_id: \"user@test.com\",\n170\t    });\n171\t\n172\t    expect(mockQuery).not.toHaveBeenCalled();\n173\t  });\n174\t\n175\t  it(\"returns an EventRow with resolved_id set to user_id when user_id is present\", async () => {\n176\t    const result = await insertEvent({\n177\t      event_name: \"Purchase Completed\",\n178\t      device_id: \"dev-1\",\n179\t      user_id: \"user@test.com\",\n180\t    });\n181\t\n182\t    expect(result.resolved_id).toBe(\"user@test.com\");\n183\t  });\n184\t\n185\t  it(\"returns an EventRow with resolved_id set to device_id when only device_id is present\", async () => {\n186\t    const result = await insertEvent({\n187\t      event_name: \"Page Viewed\",\n188\t      device_id: \"dev-1\",\n189\t    });\n190\t\n191\t    expect(result.resolved_id).toBe(\"dev-1\");\n192\t  });\n193\t});\n194\t\n195\t// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n196\t\n197\tdescribe(\"resolveIdentityMapping\", () => {\n198\t  it(\"inserts a new mapping when no existing mapping is found\", async () => {\n199\t    mockQueryReturns([]); // no existing mapping\n200\t\n201\t    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n202\t\n203\t    expect(mockInsert).toHaveBeenCalledWith(\n204\t      expect.objectContaining({\n205\t        table: \"identity_mappings\",\n206\t        values: [{ device_id: \"dev-1\", user_id: \"user@test.com\" }],\n207\t      }),\n208\t    );\n209\t  });\n210\t\n211\t  it(\"is a no-op when existing mapping has the same user_id\", async () => {\n212\t    mockQueryReturns([{ user_id: \"user@test.com\" }]); // same user already mapped\n213\t\n214\t    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n215\t\n216\t    expect(mockInsert).not.toHaveBeenCalled();\n217\t  });\n218\t\n219\t  it(\"throws IdentityConflictError when existing mapping has a different user_id\", async () => {\n220\t    mockQueryReturns([{ user_id: \"other@test.com\" }]); // different user already mapped\n221\t\n222\t    await expect(\n223\t      resolveIdentityMapping(\"dev-1\", \"user@test.com\"),\n224\t    ).rejects.toThrow(IdentityConflictError);\n225\t  });\n226\t\n227\t  it(\"IdentityConflictError has status 409\", async () => {\n228\t    mockQueryReturns([{ user_id: \"other@test.com\" }]);\n229\t\n230\t    try {\n231\t      await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n232\t      expect.fail(\"should have thrown\");\n233\t    } catch (err) {\n234\t      expect(err).toBeInstanceOf(IdentityConflictError);\n235\t      expect((err as IdentityConflictError).status).toBe(409);\n236\t    }\n237\t  });\n238\t});\n239\t"}]},"parent_tool_use_id":null,"session_id":"c6dbe08c-c429-4f5e-a754-e6e96b09fdc5","uuid":"629d1942-ea3b-4ce5-883b-22b2390d2a91","timestamp":"2026-04-15T12:22:56.027Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/identity.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// Hoist mock refs so vi.mock factory can reference them\nconst { mockQuery, mockInsert } = vi.hoisted(() => ({\n  mockQuery: vi.fn(),\n  mockInsert: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    query: mockQuery,\n    insert: mockInsert,\n  },\n}));\n\nimport {\n  IdentityConflictError,\n  insertEvent,\n  resolveIdentityMapping,\n  validateEvent,\n} from \"@/lib/identity\";\n\n// Helper: set up mockQuery to return a given rows array\nfunction mockQueryReturns(rows: unknown[]) {\n  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n}\n\nbeforeEach(() => {\n  // Default: no existing identity mapping, inserts succeed\n  mockQueryReturns([]);\n  mockInsert.mockResolvedValue(undefined);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\n// ─── validateEvent ────────────────────────────────────────────────────────────\n\ndescribe(\"validateEvent\", () => {\n  it(\"rejects when both device_id and user_id are missing\", () => {\n    expect(() => validateEvent({ event_name: \"Page Viewed\" })).toThrow();\n  });\n\n  it(\"rejects when event_name is missing\", () => {\n    expect(() => validateEvent({ device_id: \"dev-1\" })).toThrow();\n  });\n\n  it(\"rejects when event_name is empty string\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"\", device_id: \"dev-1\" }),\n    ).toThrow();\n  });\n\n  it(\"rejects when event_name is whitespace only\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"  \", device_id: \"dev-1\" }),\n    ).toThrow();\n  });\n\n  it(\"accepts event with only device_id\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n    ).not.toThrow();\n  });\n\n  it(\"accepts event with only user_id\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"Page Viewed\", user_id: \"user@test.com\" }),\n    ).not.toThrow();\n  });\n\n  it(\"accepts event with both device_id and user_id\", () => {\n    expect(() =>\n      validateEvent({\n        event_name: \"Signup Completed\",\n        device_id: \"dev-1\",\n        user_id: \"user@test.com\",\n      }),\n    ).not.toThrow();\n  });\n});\n\n// ─── insertEvent ──────────────────────────────────────────────────────────────\n\ndescribe(\"insertEvent\", () => {\n  it(\"defaults timestamp to current time when not provided\", async () => {\n    const before = Date.now();\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n    const after = Date.now();\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    const insertedTs = new Date(insertCall.values[0].timestamp).getTime();\n    expect(insertedTs).toBeGreaterThanOrEqual(before);\n    expect(insertedTs).toBeLessThanOrEqual(after);\n  });\n\n  it(\"preserves caller-provided timestamp\", async () => {\n    const ts = \"2026-01-15T10:30:00.000Z\";\n    await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n      timestamp: ts,\n    });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].timestamp).toBe(ts);\n  });\n\n  it(\"inserts event into the events table\", async () => {\n    await insertEvent({\n      event_name: \"Purchase Completed\",\n      user_id: \"user@test.com\",\n      properties: { amount: 49.99 },\n    });\n\n    expect(mockInsert).toHaveBeenCalledWith(\n      expect.objectContaining({ table: \"events\" }),\n    );\n  });\n\n  it(\"stores event_name correctly in the inserted row\", async () => {\n    await insertEvent({ event_name: \"Button Clicked\", device_id: \"dev-2\" });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].event_name).toBe(\"Button Clicked\");\n  });\n\n  it(\"serialises properties as a JSON string\", async () => {\n    await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n      properties: { page: \"/home\", count: 3 },\n    });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].properties).toBe(\n      JSON.stringify({ page: \"/home\", count: 3 }),\n    );\n  });\n\n  it(\"defaults properties to '{}' when not provided\", async () => {\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].properties).toBe(\"{}\");\n  });\n\n  it(\"calls resolveIdentityMapping (queries mappings) when both device_id and user_id are present\", async () => {\n    await insertEvent({\n      event_name: \"Signup Completed\",\n      device_id: \"dev-1\",\n      user_id: \"user@test.com\",\n    });\n\n    // resolveIdentityMapping does a SELECT on identity_mappings\n    expect(mockQuery).toHaveBeenCalled();\n  });\n\n  it(\"does NOT call resolveIdentityMapping when only device_id is present\", async () => {\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n\n    expect(mockQuery).not.toHaveBeenCalled();\n  });\n\n  it(\"does NOT call resolveIdentityMapping when only user_id is present\", async () => {\n    await insertEvent({\n      event_name: \"Purchase Completed\",\n      user_id: \"user@test.com\",\n    });\n\n    expect(mockQuery).not.toHaveBeenCalled();\n  });\n\n  it(\"returns an EventRow with resolved_id set to user_id when user_id is present\", async () => {\n    const result = await insertEvent({\n      event_name: \"Purchase Completed\",\n      device_id: \"dev-1\",\n      user_id: \"user@test.com\",\n    });\n\n    expect(result.resolved_id).toBe(\"user@test.com\");\n  });\n\n  it(\"returns an EventRow with resolved_id set to device_id when only device_id is present\", async () => {\n    const result = await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n    });\n\n    expect(result.resolved_id).toBe(\"dev-1\");\n  });\n});\n\n// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n\ndescribe(\"resolveIdentityMapping\", () => {\n  it(\"inserts a new mapping when no existing mapping is found\", async () => {\n    mockQueryReturns([]); // no existing mapping\n\n    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n\n    expect(mockInsert).toHaveBeenCalledWith(\n      expect.objectContaining({\n        table: \"identity_mappings\",\n        values: [{ device_id: \"dev-1\", user_id: \"user@test.com\" }],\n      }),\n    );\n  });\n\n  it(\"is a no-op when existing mapping has the same user_id\", async () => {\n    mockQueryReturns([{ user_id: \"user@test.com\" }]); // same user already mapped\n\n    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n\n    expect(mockInsert).not.toHaveBeenCalled();\n  });\n\n  it(\"throws IdentityConflictError when existing mapping has a different user_id\", async () => {\n    mockQueryReturns([{ user_id: \"other@test.com\" }]); // different user already mapped\n\n    await expect(\n      resolveIdentityMapping(\"dev-1\", \"user@test.com\"),\n    ).rejects.toThrow(IdentityConflictError);\n  });\n\n  it(\"IdentityConflictError has status 409\", async () => {\n    mockQueryReturns([{ user_id: \"other@test.com\" }]);\n\n    try {\n      await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n      expect.fail(\"should have thrown\");\n    } catch (err) {\n      expect(err).toBeInstanceOf(IdentityConflictError);\n      expect((err as IdentityConflictError).status).toBe(409);\n    }\n  });\n});\n","numLines":239,"startLine":1,"totalLines":239}}}
