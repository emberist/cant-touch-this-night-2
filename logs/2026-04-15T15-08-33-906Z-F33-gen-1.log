6\t  async function handleSubmit(e: React.FormEvent): Promise<void> {\n57\t    e.preventDefault();\n58\t    if (!eventName.trim() || propertiesError) return;\n59\t\n60\t    const payload: EventPayload = { event_name: eventName.trim() };\n61\t    if (deviceId.trim()) payload.device_id = deviceId.trim();\n62\t    if (userId.trim()) payload.user_id = userId.trim();\n63\t    if (timestamp.trim()) payload.timestamp = timestamp.trim();\n64\t    if (propertiesRaw.trim()) {\n65\t      try {\n66\t        payload.properties = JSON.parse(propertiesRaw) as Record<\n67\t          string,\n68\t          unknown\n69\t        >;\n70\t      } catch {\n71\t        setPropertiesError(true);\n72\t        return;\n73\t      }\n74\t    }\n75\t\n76\t    setLoading(true);\n77\t    setFeedback(null);\n78\t    const result = await sendEvent(payload);\n79\t    setLoading(false);\n80\t    setFeedback(\n81\t      result.success\n82\t        ? { type: \"success\", message: \"Sent\" }\n83\t        : { type: \"error\", message: result.error ?? \"Error\" },\n84\t    );\n85\t  }\n86\t\n87\t  return (\n88\t    <Box data-testid=\"custom-event-form\">\n89\t      <Button\n90\t        variant=\"outlined\"\n91\t        size=\"small\"\n92\t        onClick={() => setOpen((v) => !v)}\n93\t        fullWidth\n94\t      >\n95\t        Custom Event\n96\t      </Button>\n97\t\n98\t      {open && (\n99\t        <Box\n100\t          component=\"form\"\n101\t          onSubmit={(e) => void handleSubmit(e)}\n102\t          sx={{ mt: 1 }}\n103\t        >\n104\t          <Stack spacing={1}>\n105\t            <TextField\n106\t              label=\"Event Name\"\n107\t              value={eventName}\n108\t              onChange={(e) => setEventName(e.target.value)}\n109\t              size=\"small\"\n110\t              required\n111\t              fullWidth\n112\t            />\n113\t            <TextField\n114\t              label=\"Device ID\"\n115\t              value={deviceId}\n116\t              onChange={(e) => set