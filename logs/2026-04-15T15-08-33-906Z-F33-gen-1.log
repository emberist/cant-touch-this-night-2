();\n61\t\n62\t  // Build a lookup: label → date → value\n63\t  const lookup = new Map<string, Map<string, number>>();\n64\t  for (const s of series) {\n65\t    const byDate = new Map<string, number>();\n66\t    for (const p of s.data) {\n67\t      byDate.set(p.date, p.value);\n68\t    }\n69\t    lookup.set(s.label, byDate);\n70\t  }\n71\t\n72\t  return (\n73\t    <Table size=\"small\">\n74\t      <TableHead>\n75\t        <TableRow>\n76\t          <TableCell>Date</TableCell>\n77\t          {series.map((s) => (\n78\t            <TableCell key={s.label} align=\"right\">\n79\t              {s.label}\n80\t            </TableCell>\n81\t          ))}\n82\t        </TableRow>\n83\t      </TableHead>\n84\t      <TableBody>\n85\t        {allDates.map((date) => (\n86\t          <TableRow key={date}>\n87\t            <TableCell>{date}</TableCell>\n88\t            {series.map((s) => (\n89\t              <TableCell key={s.label} align=\"right\">\n90\t                {lookup.get(s.label)?.get(date) ?? \"-\"}\n91\t              </TableCell>\n92\t            ))}\n93\t          </TableRow>\n94\t        ))}\n95\t      </TableBody>\n96\t    </Table>\n97\t  );\n98\t}\n99\t\n100\t// ─── Recharts data shape ──────────────────────────────────────────────────────\n101\t\n102\t/** Transform series into a flat array usable by Recharts (one row per date). */\n103\tfunction toRechartsData(series: Series[]): Record<string, string | number>[] {\n104\t  const allDates = Array.from(\n105\t    new Set(series.flatMap((s) => s.data.map((p) => p.date))),\n106\t  ).sort();\n107\t\n108\t  return allDates.map((date) => {\n109\t    const row: Record<string, string | number> = { date };\n110\t    for (const s of series) {\n111\t      const point = s.data.find((p) => p.date === date);\n112\t      row[s.label] = point?.value ?? 0;\n113\t    }\n114\t    return row;\n115\t  });\n116\t}\n117\t\n118\t// ─── Component ────────────────────────────────────────────────────────────────\n119\t\n120\texport function TrendChart({\n121\t  series,\n122\t  loading,\n123\t}: TrendChartProps): React.JSX.Element {\n124\t  // Determine initial chart type: if only 1 data bucket across all series → bar\n125\t  const isSingleBucket =\n126\t    series.length > 0 && series.every((s) => s.data.length === 1);\n127\t\n128\t  const [chartType, setChartType] = useState<ChartType>(\n129\t    isSingleBucket ? \"bar\" : \"line\",\n130\t  );\n131\t\n132\t  // Re-evaluate auto-switch when series changes\n133\t  useEffect(() => {\n134\t    if (series.length === 0) return;\n135\t    const single = series.every((s) => s.data.length === 1);\n136\t    setChartType(single ? \"bar\" : \"line\");\n137\t  }, [series]);\n138\t\n139\t  const data = toRechartsData(series);\n140\t  const hasData = series.length > 0;\n141\t\n142\t  return (\n143\t    <Box data-testid=\"trend-chart\">\n144\t      {/* ── Chart type toggle ──────────────────────────────────────────────── */}\n145\t      <Box sx={{ mb: 2 }}>\n146\t        <ToggleButtonGroup\n147\t          exclusive\n148\t          size=\"small\"\n149\t          value={chartType}\n150\t          onChange={(_, v: ChartType | null) => {\n151\t            if (v) setChartType(v);\n152\t          }}\n153\t        >\n154\t          <ToggleButton value=\"line\">Line</ToggleButton>\n155\t          <ToggleButton value=\"bar\">Bar</ToggleButton>\n156\t          <ToggleButton value=\"area\">Area</ToggleButton>\n157\t          <ToggleButton value=\"table\">Table</ToggleButton>\n158\t        </ToggleButtonGroup>\n159\t      </Box>\n160\t\n161\t      {/* ── Content area ──────────────────────────────────────────────────── */}\n162\t      {loading && (\n163\t        <Box data-testid=\"trend-chart-skeleton\">\n164\t          <Skeleton variant=\"rectangular\" height={300} />\n165\t        </Box>\n166\t      )}\n167\t\n168\t      {!loading && !hasData && (\n169\t        <Box\n170\t          data-testid=\"trend-chart-empty\"\n171\t          sx={{\n172\t            display: \"flex\",\n173\t            alignItems: \"center\",\n174\t            justifyContent: \"center\",\n175\t            height: 300,\n176\t            border: 1,\n177\t            borderColor: \"divider\",\n178\t            borderRadius: 1,\n179\t          }}\n180\t        >\n181\t          <Typography color=\"text.secondary\">No data</Typography>\n182\t        </Box>\n183\t      )}\n184\t\n185\t      {!loading && hasData && chartType === \"table\" && (\n186\t        <TableView series={series} />\n187\t      )}\n188\t\n189\t      {!loading && hasData && chartType === \"line\" && (\n190\t        <ResponsiveContainer width=\"100%\" height={300}>\n191\t          <LineChart data={data}>\n192\t            <CartesianGrid strokeDasharray=\"3 3\" />\n193\t            <XAxis dataKey=\"date\" />\n194\t            <YAxis />\n195\t            <Tooltip />\n196\t            <Legend />\n197\t            {series.map((s, i) => (\n198\t              <Line\n199\t                key={s.label}\n200\t                type=\"monotone\"\n201\t                dataKey={s.label}\n202\t                stroke={COLORS[i % COLORS.length]}\n203\t                dot={false}\n204\t              />\n205\t            ))}\n206\t          </LineChart>\n207\t        </ResponsiveContainer>\n208\t      )}\n209\t\n210\t      {!loading && hasData && chartType === \"bar\" && (\n211\t        <ResponsiveContainer width=\"100%\" height={300}>\n212\t          <BarChart data={data}>\n213\t            <CartesianGrid strokeDasharray=\"3 3\" />\n214\t            <XAxis dataKey=\"date\" />\n215\t            <YAxis />\n216\t            <Tooltip />\n217\t            <Legend />\n218\t            {series.map((s, i) => (\n219\t              <Bar\n220\t                key={s.label}\n221\t                dataKey={s.label}\n222\t                fill={COLORS[i % COLORS.length]}\n223\t              />\n224\t            ))}\n225\t          </BarChart>\n226\t        </ResponsiveContainer>\n227\t      )}\n228\t\n229\t      {!loading && hasData && chartType === \"area\" && (\n230\t        <ResponsiveContainer width=\"100%\" height={300}>\n231\t          <AreaChart data={data}>\n232\t            <CartesianGrid strokeDasharray=\"3 3\" />\n233\t            <XAxis dataKey=\"date\" />\n234\t            <YAxis />\n235\t            <Tooltip />\n236\t            <Legend />\n237\t            {series.map((s, i) => (\n238\t              <Area\n239\t                key={s.label}\n240\t                type=\"monotone\"\n241\t                dataKey={s.label}\n242\t                stroke={COLORS[i % COLORS.length]}\n243\t                fill={COLORS[i % COLORS.length]}\n244\t                fillOpacity={0.3}\n245\t              />\n246\t            ))}\n247\t          </AreaChart>\n248\t        </ResponsiveContainer>\n249\t      )}\n250\t    </Box>\n251\t  );\n252\t}\n253\t"}]},"parent_tool_use_id":null,"session_id":"eb1717ec-5d87-4414-9ed1-88e4656c8afb","uuid":"e6bb169c-b599-4715-96b0-ae49dc4dfb39","timestamp":"2026-04-15T19:39:55.060Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/TrendChart.tsx","content":"\"use client\";\n\nimport Box from \"@mui/material/Box\";\nimport Skeleton from \"@mui/material/Skeleton\";\nimport Table from \"@mui/material/Table\";\nimport TableBody from \"@mui/material/TableBody\";\nimport TableCell from \"@mui/material/TableCell\";\nimport TableHead from \"@mui/material/TableHead\";\nimport TableRow from \"@mui/material/TableRow\";\nimport ToggleButton from \"@mui/material/ToggleButton\";\nimport ToggleButtonGroup from \"@mui/material/ToggleButtonGroup\";\nimport Typography from \"@mui/material/Typography\";\nimport { useEffect, useState } from \"react\";\nimport {\n  Area,\n  AreaChart,\n  Bar,\n  BarChart,\n  CartesianGrid,\n  Legend,\n  Line,\n  LineChart,\n  ResponsiveContainer,\n  Tooltip,\n  XAxis,\n  YAxis,\n} from \"recharts\";\nimport type { Series } from \"@/lib/trends\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\ntype ChartType = \"line\" | \"bar\" | \"area\" | \"table\";\n\ninterface TrendChartProps {\n  series: Series[];\n  loading: boolean;\n}\n\n// ─── Colors ───────────────────────────────────────────────────────────────────\n\nconst COLORS = [\n  \"#1976d2\",\n  \"#e91e63\",\n  \"#4caf50\",\n  \"#ff9800\",\n  \"#9c27b0\",\n  \"#00bcd4\",\n  \"#f44336\",\n  \"#607d8b\",\n];\n\n// ─── Table view ───────────────────────────────────────────────────────────────\n\nfunction TableView({ series }: { series: Series[] }): React.JSX.Element {\n  if (series.length === 0) return <></>;\n\n  // Collect all unique dates across all series\n  const allDates = Array.from(\n    new Set(series.flatMap((s) => s.data.map((p) => p.date))),\n  ).sort();\n\n  // Build a lookup: label → date → value\n  const lookup = new Map<string, Map<string, number>>();\n  for (const s of series) {\n    const byDate = new Map<string, number>();\n    for (const p of s.data) {\n      byDate.set(p.date, p.value);\n    }\n    lookup.set(s.label, byDate);\n  }\n\n  return (\n    <Table size=\"small\">\n      <TableHead>\n        <TableRow>\n          <TableCell>Date</TableCell>\n          {series.map((s) => (\n            <TableCell key={s.label} align=\"right\">\n              {s.label}\n            </TableCell>\n          ))}\n        </TableRow>\n      </TableHead>\n      <TableBody>\n        {allDates.map((date) => (\n          <TableRow key={date}>\n            <TableCell>{date}</TableCell>\n            {series.map((s) => (\n              <TableCell key={s.label} align=\"right\">\n                {lookup.get(s.label)?.get(date) ?? \"-\"}\n              </TableCell>\n            ))}\n          </TableRow>\n        ))}\n      </TableBody>\n    </Table>\n  );\n}\n\n// ─── Recharts data shape ──────────────────────────────────────────────────────\n\n/** Transform series into a flat array usable by Recharts (one row per date). */\nfunction toRechartsData(series: Series[]): Record<string, string | number>[] {\n  const allDates = Array.from(\n    new Set(series.flatMap((s) => s.data.map((p) => p.date))),\n  ).sort();\n\n  return allDates.map((date) => {\n    const row: Record<string, string | number> = { date };\n    for (const s of series) {\n      const point = s.data.find((p) => p.date === date);\n      row[s.label] = point?.value ?? 0;\n    }\n    return row;\n  });\n}\n\n// ─── Component ────────────────────────────────────────────────────────────────\n\nexport function TrendChart({\n  series,\n  loading,\n}: TrendChartProps): React.JSX.Element {\n  // Determine initial chart type: if only 1 data bucket across all series → bar\n  const isSingleBucket =\n    series.length > 0 && series.every((s) => s.data.length === 1);\n\n  const [chartType, setChartType] = useState<ChartType>(\n    isSingleBucket ? \"bar\" : \"line\",\n  );\n\n  // Re-evaluate auto-switch when series changes\n  useEffect(() => {\n    if (series.length === 0) return;\n    const single = series.every((s) => s.data.length === 1);\n    setChartType(single ? \"bar\" : \"line\");\n  }, [series]);\n\n  const data = toRechartsData(series);\n  const hasData = series.length > 0;\n\n  return (\n    <Box data-testid=\"trend-chart\">\n      {/* ── Chart type toggle ──────────────────────────────────────────────── */}\n      <Box sx={{ mb: 2 }}>\n        <ToggleButtonGroup\n          exclusive\n          size=\"small\"\n          value={chartType}\n          onChange={(_, v: ChartType | null) => {\n            if (v) setChartType(v);\n          }}\n        >\n          <ToggleButton value=\"line\">Line</ToggleButton>\n          <ToggleButton value=\"bar\">Bar</ToggleButton>\n          <ToggleButton value=\"area\">Area</ToggleButton>\n          <ToggleButton value=\"table\">Table</ToggleButton>\n        </ToggleButtonGroup>\n      </Box>\n\n      {/* ── Content area ──────────────────────────────────────────────────── */}\n      {loading && (\n        <Box data-testid=\"trend-chart-skeleton\">\n          <Skeleton variant=\"rectangular\" height={300} />\n        </Box>\n      )}\n\n      {!loading && !hasData && (\n        <Box\n          data-testid=\"trend-chart-empty\"\n          sx={{\n            display: \"flex\",\n            alignItems: \"center\",\n            justifyContent: \"center\",\n            height: 300,\n            border: 1,\n            borderColor: \"divider\",\n            borderRadius: 1,\n          }}\n        >\n          <Typography color=\"text.secondary\">No data</Typography>\n        </Box>\n      )}\n\n      {!loading && hasData && chartType === \"table\" && (\n        <TableView series={series} />\n      )}\n\n      {!loading && hasData && chartType === \"line\" && (\n        <ResponsiveContainer width=\"100%\" height={300}>\n          <LineChart data={data}>\n            <CartesianGrid strokeDasharray=\"3 3\" />\n            <XAxis dataKey=\"date\" />\n            <YAxis />\n            <Tooltip />\n            <Legend />\n            {series.map((s, i) => (\n              <Line\n                key={s.label}\n                type=\"monotone\"\n                dataKey={s.label}\n                stroke={COLORS[i % COLORS.length]}\n                dot={false}\n              />\n            ))}\n          </LineChart>\n        </ResponsiveContainer>\n      )}\n\n      {!loading && hasData && chartType === \"bar\" && (\n        <ResponsiveContainer width=\"100%\" height={300}>\n          <BarChart data={data}>\n            <CartesianGrid strokeDasharray=\"3 3\" />\n            <XAxis dataKey=\"date\" />\n            <YAxis />\n            <Tooltip />\n            <Legend />\n            {series.map((s, i) => (\n              <Bar\n                key={s.label}\n                dataKey={s.label}\n                fill={COLORS[i % COLORS.length]}\n              />\n            ))}\n          </BarChart>\n        </ResponsiveContainer>\n      )}\n\n      {!loading && hasData && chartType === \"area\" && (\n        <ResponsiveContainer width=\"100%\" height={300}>\n          <AreaChart data={data}>\n            <CartesianGrid strokeDasharray=\"3 3\" />\n            <XAxis dataKey=\"date\" />\n            <YAxis />\n            <Tooltip />\n            <Legend />\n            {series.map((s, i) => (\n              <Area\n                key={s.label}\n                type=\"monotone\"\n                dataKey={s.label}\n                stroke={COLORS[i % COLORS.length]}\n                fill={COLORS[i % COLORS.length]}\n                fillOpacity={0.3}\n              />\n            ))}\n          </AreaChart>\n        </ResponsiveContainer>\n      )}\n    </Box>\n  );\n}\n","numLines":253,"startLine":1,"totalLines":253}}}
