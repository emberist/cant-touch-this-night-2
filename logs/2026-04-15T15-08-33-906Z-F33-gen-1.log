ers.setStartDate(e.target.value)}\n202\t              slotProps={{ inputLabel: { shrink: true } }}\n203\t            />\n204\t            <TextField\n205\t              label=\"End\"\n206\t              type=\"date\"\n207\t              size=\"small\"\n208\t              value={controls.endDate}\n209\t              onChange={(e) => setters.setEndDate(e.target.value)}\n210\t              slotProps={{ inputLabel: { shrink: true } }}\n211\t            />\n212\t          </Box>\n213\t        </Box>\n214\t\n215\t        {/* ── Breakdown ───────────────────────────────────────────────────── */}\n216\t        <Box\n217\t          sx={{\n218\t            display: \"flex\",\n219\t            flexDirection: \"row\",\n220\t            gap: 1,\n221\t            alignItems: \"center\",\n222\t          }}\n223\t        >\n224\t          <Autocomplete\n225\t            options={\n226\t              controls.eventName\n227\t                ? Object.keys(schema?.properties[controls.eventName] ?? {})\n228\t                : []\n229\t            }\n230\t            value={controls.breakdown}\n231\t            onChange={(_, value) => setters.setBreakdown(value)}\n232\t            renderInput={(params) => (\n233\t              <TextField {...params} label=\"Breakdown by\" size=\"small\" />\n234\t            )}\n235\t            sx={{ minWidth: 200 }}\n236\t          />\n237\t          {controls.breakdown && (\n238\t            <TextField\n239\t              label=\"Limit\"\n240\t              type=\"number\"\n241\t              size=\"small\"\n242\t              value={controls.breakdownLimit}\n243\t              onChange={(e) =>\n244\t                setters.setBreakdownLimit(Number(e.target.value))\n245\t              }\n246\t              sx={{ width: 80 }}\n247\t              slotProps={{ htmlInput: { min: 1, max: 50 } }}\n248\t            />\n249\t          )}\n250\t        </Box>\n251\t      </Stack>\n252\t    </Box>\n253\t  );\n254\t}\n255\t"}]},"parent_tool_use_id":null,"session