     Select steps and run the funnel to see results.\n60\t          </Typography>\n61\t        </Box>\n62\t      )}\n63\t\n64\t      {/* ── Results ──────────────────────────────────────────────────────── */}\n65\t      {!loading && steps.length > 0 && (\n66\t        <Box data-testid=\"funnel-chart-steps\">\n67\t          {/* Step annotations (name, users, conversion, drop-off) */}\n68\t          <Box sx={{ mb: 3 }}>\n69\t            {steps.map((step, i) => (\n70\t              <Box key={step.name}>\n71\t                {/* Drop-off indicator between steps */}\n72\t                {i > 0 && (\n73\t                  <Box\n74\t                    data-testid=\"funnel-dropoff\"\n75\t                    sx={{\n76\t                      display: \"flex\",\n77\t                      alignItems: \"center\",\n78\t                      gap: 1,\n79\t                      ml: 1,\n80\t                      my: 0.5,\n81\t                    }}\n82\t                  >\n83\t                    <Typography variant=\"caption\" color=\"error\">\n84\t                      ↓{\" \"}\n85\t                      {((1 - (step.conversion_from_prev ?? 1)) * 100).toFixed(\n86\t                        1,\n87\t                      )}\n88\t                      % drop-off\n89\t                    </Typography>\n90\t                    <Typography variant=\"caption\" color=\"text.secondary\">\n91\t                      ({((step.conversion_from_prev ?? 0) * 100).toFixed(1)}%\n92\t                      converted)\n93\t                    </Typography>\n94\t                  </Box>\n95\t                )}\n96\t\n97\t                {/* Step row */}\n98\t                <Box\n99\t                  sx={{\n100\t                    display: \"flex\",\n101\t                    alignItems: \"center\",\n102\t                    gap: 2,\n103\t                    p: 1,\n104\t                    borderRadius: 1,\n105\t                    bgcolor: \"action.hover\",\n106\t                  }}\n107\t                >\n108\t                  <Typography\n109\t                    variant=\"body2\"\n110\t                    sx={{ minWidth: 24, color: \"text.secondary\" }}\n111\t                  >\n112\t                    {i + 1}.\n113\t                  </Typography>\n114\t                  <Typography variant=\"body2\" sx={{ flex: 1 }}>\n115\t                    {step.name}\n116\t                  </Typography>\n117\t                  <Typography variant=\"body2\" sx={{ fontWeight: \"bold\" }}>\n118\t                    {step.users.toLocaleString(\"en-US\")}\n119\t                  </Typography>\n120\t                  {i > 0 && step.conversion_from_prev !== null && (\n121\t                    <Typography variant=\"caption\" color=\"text.secondary\">\n122\t                      {(step.conversion_from_prev * 100).toFixed(1)}%\n123\t                    </Typography>\n124\t                  )}\n125\t                </Box>\n126\t              </Box>\n127\t            ))}\n128\t          </Box>\n129\t\n130\t          {/* Recharts horizontal bar chart */}\n131\t          <ResponsiveContainer\n132\t            width=\"100%\"\n133\t            height={Math.max(200, steps.length * 56)}\n134\t          >\n135\t            <BarChart\n136\t              layout=\"vertical\"\n137\t              data={steps.map((s) => ({ name: s.name, users: s.users }))}\n138\t              margin={{ top: 4, right: 40, left: 120, bottom: 4 }}\n139\t            >\n140\t              <CartesianGrid strokeDasharray=\"3 3\" horizontal={false} />\n141\t              <XAxis type=\"number\" />\n142\t              <YAxis\n143\t                type=\"category\"\n144\t                dataKey=\"name\"\n145\t                width={110}\n146\t                tick={{ fontSize: 12 }}\n147\t              />\n148\t              <Tooltip\n149\t                formatter={(value) => [\n150\t                  Number(value).toLocaleString(\"en-US\"),\n151\t                  \"Users\",\n152\t                ]}\n153\t              />\n154\t              <Bar dataKey=\"users\" radius={[0, 4, 4, 0]}>\n155\t                {steps.map((step, i) => (\n156\t                  <Cell\n157\t                    key={step.name}\n158\t                    fill={BAR_COLOR}\n159\t                    fillOpacity={1 - i * (0.15 / Math.max(steps.length - 1, 1))}\n160\t                  />\n161\t                ))}\n162\t              </Bar>\n163\t            </BarChart>\n164\t          </ResponsiveContainer>\n165\t        </Box>\n166\t      )}\n167\t    </Box>\n168\t  );\n169\t}\n170\t"}]},"parent_tool_use_id":null,"session_id":"eb1717ec-5d87-4414-9ed1-88e4656c8afb","uuid":"029dcb9c-ffcc-4f24-8936-3d38893d108d","timestamp":"2026-04-15T19:39:58.735Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/FunnelChart.tsx","content":"\"use client\";\n\nimport Box from \"@mui/material/Box\";\nimport Skeleton from \"@mui/material/Skeleton\";\nimport Typography from \"@mui/material/Typography\";\nimport {\n  Bar,\n  BarChart,\n  CartesianGrid,\n  Cell,\n  ResponsiveContainer,\n  Tooltip,\n  XAxis,\n  YAxis,\n} from \"recharts\";\nimport type { FunnelStepResult } from \"@/lib/funnels\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\ninterface FunnelChartProps {\n  steps: FunnelStepResult[];\n  loading: boolean;\n}\n\n// ─── Colors ───────────────────────────────────────────────────────────────────\n\nconst BAR_COLOR = \"#1976d2\";\n\n// ─── Component ────────────────────────────────────────────────────────────────\n\nexport function FunnelChart({\n  steps,\n  loading,\n}: FunnelChartProps): React.JSX.Element {\n  return (\n    <Box data-testid=\"funnel-chart\">\n      {/* ── Loading ──────────────────────────────────────────────────────── */}\n      {loading && (\n        <Box data-testid=\"funnel-chart-skeleton\">\n          <Skeleton variant=\"rectangular\" height={300} />\n        </Box>\n      )}\n\n      {/* ── Empty state ──────────────────────────────────────────────────── */}\n      {!loading && steps.length === 0 && (\n        <Box\n          data-testid=\"funnel-chart-empty\"\n          sx={{\n            display: \"flex\",\n            alignItems: \"center\",\n            justifyContent: \"center\",\n            height: 300,\n            border: 1,\n            borderColor: \"divider\",\n            borderRadius: 1,\n          }}\n        >\n          <Typography color=\"text.secondary\">\n            Select steps and run the funnel to see results.\n          </Typography>\n        </Box>\n      )}\n\n      {/* ── Results ──────────────────────────────────────────────────────── */}\n      {!loading && steps.length > 0 && (\n        <Box data-testid=\"funnel-chart-steps\">\n          {/* Step annotations (name, users, conversion, drop-off) */}\n          <Box sx={{ mb: 3 }}>\n            {steps.map((step, i) => (\n              <Box key={step.name}>\n                {/* Drop-off indicator between steps */}\n                {i > 0 && (\n                  <Box\n                    data-testid=\"funnel-dropoff\"\n                    sx={{\n                      display: \"flex\",\n                      alignItems: \"center\",\n                      gap: 1,\n                      ml: 1,\n                      my: 0.5,\n                    }}\n                  >\n                    <Typography variant=\"caption\" color=\"error\">\n                      ↓{\" \"}\n                      {((1 - (step.conversion_from_prev ?? 1)) * 100).toFixed(\n                        1,\n                      )}\n                      % drop-off\n                    </Typography>\n                    <Typography variant=\"caption\" color=\"text.secondary\">\n                      ({((step.conversion_from_prev ?? 0) * 100).toFixed(1)}%\n                      converted)\n                    </Typography>\n                  </Box>\n                )}\n\n                {/* Step row */}\n                <Box\n                  sx={{\n                    display: \"flex\",\n                    alignItems: \"center\",\n                    gap: 2,\n                    p: 1,\n                    borderRadius: 1,\n                    bgcolor: \"action.hover\",\n                  }}\n                >\n                  <Typography\n                    variant=\"body2\"\n                    sx={{ minWidth: 24, color: \"text.secondary\" }}\n                  >\n                    {i + 1}.\n                  </Typography>\n                  <Typography variant=\"body2\" sx={{ flex: 1 }}>\n                    {step.name}\n                  </Typography>\n                  <Typography variant=\"body2\" sx={{ fontWeight: \"bold\" }}>\n                    {step.users.toLocaleString(\"en-US\")}\n                  </Typography>\n                  {i > 0 && step.conversion_from_prev !== null && (\n                    <Typography variant=\"caption\" color=\"text.secondary\">\n                      {(step.conversion_from_prev * 100).toFixed(1)}%\n                    </Typography>\n                  )}\n                </Box>\n              </Box>\n            ))}\n          </Box>\n\n          {/* Recharts horizontal bar chart */}\n          <ResponsiveContainer\n            width=\"100%\"\n            height={Math.max(200, steps.length * 56)}\n          >\n            <BarChart\n              layout=\"vertical\"\n              data={steps.map((s) => ({ name: s.name, users: s.users }))}\n              margin={{ top: 4, right: 40, left: 120, bottom: 4 }}\n            >\n              <CartesianGrid strokeDasharray=\"3 3\" horizontal={false} />\n              <XAxis type=\"number\" />\n              <YAxis\n                type=\"category\"\n                dataKey=\"name\"\n                width={110}\n                tick={{ fontSize: 12 }}\n              />\n              <Tooltip\n                formatter={(value) => [\n                  Number(value).toLocaleString(\"en-US\"),\n                  \"Users\",\n                ]}\n              />\n              <Bar dataKey=\"users\" radius={[0, 4, 4, 0]}>\n                {steps.map((step, i) => (\n                  <Cell\n                    key={step.name}\n                    fill={BAR_COLOR}\n                    fillOpacity={1 - i * (0.15 / Math.max(steps.length - 1, 1))}\n                  />\n                ))}\n              </Bar>\n            </BarChart>\n          </ResponsiveContainer>\n        </Box>\n      )}\n    </Box>\n  );\n}\n","numLines":170,"startLine":1,"totalLines":170}}}
