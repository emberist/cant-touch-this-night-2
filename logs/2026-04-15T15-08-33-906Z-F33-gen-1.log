──────────────────────────────────────────────────────────\n52\t\n53\tinterface EventCardProps {\n54\t  event: EventRow;\n55\t}\n56\t\n57\tfunction EventCard({ event }: EventCardProps): React.JSX.Element {\n58\t  return (\n59\t    <Paper variant=\"outlined\" sx={{ p: 1.5 }} data-testid=\"event-card\">\n60\t      <Box\n61\t        sx={{\n62\t          display: \"flex\",\n63\t          flexWrap: \"wrap\",\n64\t          alignItems: \"center\",\n65\t          gap: 1,\n66\t          mb: 0.5,\n67\t        }}\n68\t      >\n69\t        <Chip\n70\t          label={event.event_name}\n71\t          size=\"small\"\n72\t          color={eventChipColor(event.event_name)}\n73\t        />\n74\t        <IdentityChip resolved_id={event.resolved_id} />\n75\t        <Typography\n76\t          variant=\"caption\"\n77\t          color=\"text.secondary\"\n78\t          sx={{ ml: \"auto\" }}\n79\t        >\n80\t          {formatRelativeTime(event.timestamp)}\n81\t        </Typography>\n82\t      </Box>\n83\t      <JsonChip properties={event.properties} />\n84\t    </Paper>\n85\t  );\n86\t}\n87\t\n88\t// ─── LiveFeed ─────────────────────────────────────────────────────────────────\n89\t\n90\texport function LiveFeed(): React.JSX.Element {\n91\t  const { events, paused, connectionStatus, togglePause, clearEvents } =\n92\t    useLiveFeed();\n93\t\n94\t  return (\n95\t    <Box sx={{ display: \"flex\", flexDirection: \"column\", height: \"100%\" }}>\n96\t      {/* Toolbar */}\n97\t      <Box\n98\t        sx={{\n99\t          display: \"flex\",\n100\t          alignItems: \"center\",\n101\t          gap: 1,\n102\t          mb: 1,\n103\t          flexWrap: \"wrap\",\n104\t        }}\n105\t      >\n106\t        {/* Status dot */}\n107\t        <Box\n108\t          sx={{\n109\t            width: 8,\n110\t            height: 8,\n111\t            borderRadius: \"50%\",\n112\t            flexShrink: 0,\n113\t            bgcolor:\n114\t              connectionStatus === \"live\" ? \"success.main\" : \"error.main\",\n115\t          }}\n116\t          aria-hidden=\"true\"\n117\t        />\n118\t        <Typography variant=\"body2\" sx={{ fontWeight: 500 }}>\n119\t          {connectionStatus === \"live\" ? \"Live\" : \"Disconnected\"}\n120\t        </Typography>\n121\t\n122\t        <Box sx={{ ml: \"auto\", display: \"flex\", gap: 1 }}>\n123\t          <Button size=\"small\" variant=\"outlined\" onClick={togglePause}>\n124\t            {paused ? \"Resume\" : \"Pause\"}\n125\t          </Button>\n126\t          <Button size=\"small\" variant=\"outlined\" onClick={clearEvents}>\n127\t            Clear\n128\t          </Button>\n129\t        </Box>\n130\t      </Box>\n131\t\n132\t      <Divider sx={{ mb: 1 }} />\n133\t\n134\t      {/* Event list */}\n135\t      {events.length === 0 ? (\n136\t        <Typography variant=\"body2\" color=\"text.secondary\">\n137\t          No events yet\n138\t        </Typography>\n139\t      ) : (\n140\t        <Stack spacing={1} sx={{ overflowY: \"auto\", flex: 1 }}>\n141\t          {events.map((event) => (\n142\t            <EventCard key={event.event_id} event={event} />\n143\t          ))}\n144\t        </Stack>\n145\t      )}\n146\t    </Box>\n147\t  );\n148\t}\n149\t"}]},"parent_tool_use_id":null,"session_id":"eb1717ec-5d87-4414-9ed1-88e4656c8afb","uuid":"edf04f9d-9830-4599-8009-08467248b6e4","timestamp":"2026-04-15T19:39:38.805Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/test/LiveFeed.tsx","content":"\"use client\";\n\nimport Box from \"@mui/material/Box\";\nimport Button from \"@mui/material/Button\";\nimport Chip from \"@mui/material/Chip\";\nimport Divider from \"@mui/material/Divider\";\nimport Paper from \"@mui/material/Paper\";\nimport Stack from \"@mui/material/Stack\";\nimport Typography from \"@mui/material/Typography\";\nimport { IdentityChip } from \"@/components/ui/IdentityChip\";\nimport { JsonChip } from \"@/components/ui/JsonChip\";\nimport type { EventRow } from \"@/lib/identity\";\nimport { useLiveFeed } from \"./useLiveFeed\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction formatRelativeTime(timestamp: string): string {\n  const diff = Date.now() - new Date(timestamp).getTime();\n  if (diff < 1000) return \"just now\";\n  if (diff < 60_000) return `${Math.floor(diff / 1000)}s ago`;\n  if (diff < 3_600_000) return `${Math.floor(diff / 60_000)}m ago`;\n  return `${Math.floor(diff / 3_600_000)}h ago`;\n}\n\n// Maps event names to MUI Chip color variants\nconst EVENT_CHIP_COLORS: Record<\n  string,\n  \"default\" | \"primary\" | \"secondary\" | \"success\" | \"warning\" | \"info\" | \"error\"\n> = {\n  \"Page Viewed\": \"default\",\n  \"Button Clicked\": \"primary\",\n  \"Signup Completed\": \"success\",\n  \"Purchase Completed\": \"warning\",\n  \"Subscription Renewed\": \"info\",\n  \"Support Ticket Opened\": \"error\",\n};\n\nfunction eventChipColor(\n  eventName: string,\n):\n  | \"default\"\n  | \"primary\"\n  | \"secondary\"\n  | \"success\"\n  | \"warning\"\n  | \"info\"\n  | \"error\" {\n  return EVENT_CHIP_COLORS[eventName] ?? \"secondary\";\n}\n\n// ─── EventCard ────────────────────────────────────────────────────────────────\n\ninterface EventCardProps {\n  event: EventRow;\n}\n\nfunction EventCard({ event }: EventCardProps): React.JSX.Element {\n  return (\n    <Paper variant=\"outlined\" sx={{ p: 1.5 }} data-testid=\"event-card\">\n      <Box\n        sx={{\n          display: \"flex\",\n          flexWrap: \"wrap\",\n          alignItems: \"center\",\n          gap: 1,\n          mb: 0.5,\n        }}\n      >\n        <Chip\n          label={event.event_name}\n          size=\"small\"\n          color={eventChipColor(event.event_name)}\n        />\n        <IdentityChip resolved_id={event.resolved_id} />\n        <Typography\n          variant=\"caption\"\n          color=\"text.secondary\"\n          sx={{ ml: \"auto\" }}\n        >\n          {formatRelativeTime(event.timestamp)}\n        </Typography>\n      </Box>\n      <JsonChip properties={event.properties} />\n    </Paper>\n  );\n}\n\n// ─── LiveFeed ─────────────────────────────────────────────────────────────────\n\nexport function LiveFeed(): React.JSX.Element {\n  const { events, paused, connectionStatus, togglePause, clearEvents } =\n    useLiveFeed();\n\n  return (\n    <Box sx={{ display: \"flex\", flexDirection: \"column\", height: \"100%\" }}>\n      {/* Toolbar */}\n      <Box\n        sx={{\n          display: \"flex\",\n          alignItems: \"center\",\n          gap: 1,\n          mb: 1,\n          flexWrap: \"wrap\",\n        }}\n      >\n        {/* Status dot */}\n        <Box\n          sx={{\n            width: 8,\n            height: 8,\n            borderRadius: \"50%\",\n            flexShrink: 0,\n            bgcolor:\n              connectionStatus === \"live\" ? \"success.main\" : \"error.main\",\n          }}\n          aria-hidden=\"true\"\n        />\n        <Typography variant=\"body2\" sx={{ fontWeight: 500 }}>\n          {connectionStatus === \"live\" ? \"Live\" : \"Disconnected\"}\n        </Typography>\n\n        <Box sx={{ ml: \"auto\", display: \"flex\", gap: 1 }}>\n          <Button size=\"small\" variant=\"outlined\" onClick={togglePause}>\n            {paused ? \"Resume\" : \"Pause\"}\n          </Button>\n          <Button size=\"small\" variant=\"outlined\" onClick={clearEvents}>\n            Clear\n          </Button>\n        </Box>\n      </Box>\n\n      <Divider sx={{ mb: 1 }} />\n\n      {/* Event list */}\n      {events.length === 0 ? (\n        <Typography variant=\"body2\" color=\"text.secondary\">\n          No events yet\n        </Typography>\n      ) : (\n        <Stack spacing={1} sx={{ overflowY: \"auto\", flex: 1 }}>\n          {events.map((event) => (\n            <EventCard key={event.event_id} event={event} />\n          ))}\n        </Stack>\n      )}\n    </Box>\n  );\n}\n","numLines":149,"startLine":1,"totalLines":149}}}
