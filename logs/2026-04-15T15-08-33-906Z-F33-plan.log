{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BWCprNgc9WqTLcVF2JBpyG","type":"tool_result","content":"1\timport { expect, test } from \"@playwright/test\";\n2\t\n3\t/**\n4\t * Integration tests for the F24 Funnels page.\n5\t *\n6\t * Pre-conditions: Next.js dev or production server running at BASE_URL\n7\t * (default http://localhost:3000). Override with BASE_URL env variable.\n8\t */\n9\t\n10\tconst BASE_URL = process.env.BASE_URL ?? \"http://localhost:3000\";\n11\t\n12\ttest.describe(\"Funnels page (/funnels)\", () => {\n13\t  test(\"page heading shows 'Funnels'\", async ({ page }) => {\n14\t    await page.goto(`${BASE_URL}/funnels`);\n15\t    const heading = page.getByRole(\"heading\", { name: \"Funnels\" });\n16\t    await expect(heading).toBeVisible();\n17\t  });\n18\t\n19\t  test(\"step-builder container is visible\", async ({ page }) => {\n20\t    await page.goto(`${BASE_URL}/funnels`);\n21\t    const stepBuilder = page.getByTestId(\"step-builder\");\n22\t    await expect(stepBuilder).toBeVisible();\n23\t  });\n24\t\n25\t  test(\"funnel-date-range container is visible\", async ({ page }) => {\n26\t    await page.goto(`${BASE_URL}/funnels`);\n27\t    const dateRange = page.getByTestId(\"funnel-date-range\");\n28\t    await expect(dateRange).toBeVisible();\n29\t  });\n30\t\n31\t  test(\"funnel-chart container is visible\", async ({ page }) => {\n32\t    await page.goto(`${BASE_URL}/funnels`);\n33\t    const chart = page.getByTestId(\"funnel-chart\");\n34\t    await expect(chart).toBeVisible();\n35\t  });\n36\t\n37\t  test(\"step-builder renders exactly 2 comboboxes by default\", async ({\n38\t    page,\n39\t  }) => {\n40\t    await page.goto(`${BASE_URL}/funnels`);\n41\t    const stepBuilder = page.getByTestId(\"step-builder\");\n42\t    const combos = stepBuilder.getByRole(\"combobox\");\n43\t    await expect(combos).toHaveCount(2);\n44\t  });\n45\t\n46\t  test(\"Add Step button is visible and not disabled\", async ({ page }) => {\n47\t    await page.goto(`${BASE_URL}/funnels`);\n48\t    const addBtn = page.getByRole(\"button\", { name: /add step/i });\n49\t    await expect(addBtn).toBeVisible();\n50\t    await expect(addBtn).toBeEnabled();\n51\t  });\n52\t\n53\t  test(\"clicking Add Step adds a third combobox\", async ({ page }) => {\n54\t    await page.goto(`${BASE_URL}/funnels`);\n55\t    const addBtn = page.getByRole(\"button\", { name: /add step/i });\n56\t    await addBtn.click();\n57\t    const stepBuilder = page.getByTestId(\"step-builder\");\n58\t    const combos = stepBuilder.getByRole(\"combobox\");\n59\t    await expect(combos).toHaveCount(3);\n60\t  });\n61\t\n62\t  test(\"Run Funnel button is visible\", async ({ page }) => {\n63\t    await page.goto(`${BASE_URL}/funnels`);\n64\t    const runBtn = page.getByRole(\"button\", { name: /run funnel/i });\n65\t    await expect(runBtn).toBeVisible();\n66\t  });\n67\t});\n68\t"}]},"parent_tool_use_id":null,"session_id":"ef46994f-5887-4002-b236-0383bee9bd2b","uuid":"b3447837-c693-4fa9-80f7-407ded07e1c4","timestamp":"2026-04-15T19:37:44.719Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/playwright_tests/funnels.spec.ts","content":"import { expect, test } from \"@playwright/test\";\n\n/**\n * Integration tests for the F24 Funnels page.\n *\n * Pre-conditions: Next.js dev or production server running at BASE_URL\n * (default http://localhost:3000). Override with BASE_URL env variable.\n */\n\nconst BASE_URL = process.env.BASE_URL ?? \"http://localhost:3000\";\n\ntest.describe(\"Funnels page (/funnels)\", () => {\n  test(\"page heading shows 'Funnels'\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/funnels`);\n    const heading = page.getByRole(\"heading\", { name: \"Funnels\" });\n    await expect(heading).toBeVisible();\n  });\n\n  test(\"step-builder container is visible\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/funnels`);\n    const stepBuilder = page.getByTestId(\"step-builder\");\n    await expect(stepBuilder).toBeVisible();\n  });\n\n  test(\"funnel-date-range container is visible\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/funnels`);\n    const dateRange = page.getByTestId(\"funnel-date-range\");\n    await expect(dateRange).toBeVisible();\n  });\n\n  test(\"funnel-chart container is visible\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/funnels`);\n    const chart = page.getByTestId(\"funnel-chart\");\n    await expect(chart).toBeVisible();\n  });\n\n  test(\"step-builder renders exactly 2 comboboxes by default\", async ({\n    page,\n  }) => {\n    await page.goto(`${BASE_URL}/funnels`);\n    const stepBuilder = page.getByTestId(\"step-builder\");\n    const combos = stepBuilder.getByRole(\"combobox\");\n    await expect(combos).toHaveCount(2);\n  });\n\n  test(\"Add Step button is visible and not disabled\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/funnels`);\n    const addBtn = page.getByRole(\"button\", { name: /add step/i });\n    await expect(addBtn).toBeVisible();\n    await expect(addBtn).toBeEnabled();\n  });\n\n  test(\"clicking Add Step adds a third combobox\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/funnels`);\n    const addBtn = page.getByRole(\"button\", { name: /add step/i });\n    await addBtn.click();\n    const stepBuilder = page.getByTestId(\"step-builder\");\n    const combos = stepBuilder.getByRole(\"combobox\");\n    await expect(combos).toHaveCount(3);\n  });\n\n  test(\"Run Funnel button is visible\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/funnels`);\n    const runBtn = page.getByRole(\"button\", { name: /run funnel/i });\n    await expect(runBtn).toBeVisible();\n  });\n});\n","numLines":68,"startLine":1,"totalLines":68}}}
