{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015pzdK8ujuWMvASyz4jAZoF","type":"tool_result","content":"1\timport { expect, test } from \"@playwright/test\";\n2\t\n3\t/**\n4\t * E2e tests for F31 Bulk Generator page at /generate.\n5\t *\n6\t * Pre-conditions: Next.js server running at BASE_URL\n7\t * (default http://localhost:3000). Override with BASE_URL env variable.\n8\t *\n9\t * Covers the \"integration gap\" HTTP checks from F31-plan.md:\n10\t *   - GET /generate contains \"Generate\"\n11\t *   - GET /generate contains \"Realistic\"\n12\t *   - GET /generate contains \"Total events\"\n13\t */\n14\t\n15\tconst BASE_URL = process.env.BASE_URL ?? \"http://localhost:3000\";\n16\t\n17\ttest.describe(\"Generate page (/generate)\", () => {\n18\t  test(\"page renders with 'Generate' heading\", async ({ page }) => {\n19\t    await page.goto(`${BASE_URL}/generate`);\n20\t    await expect(\n21\t      page.getByRole(\"heading\", { name: /generate/i }),\n22\t    ).toBeVisible();\n23\t  });\n24\t\n25\t  test(\"'Realistic' preset button is visible\", async ({ page }) => {\n26\t    await page.goto(`${BASE_URL}/generate`);\n27\t    await expect(page.getByText(/realistic/i)).toBeVisible();\n28\t  });\n29\t\n30\t  test(\"'Total events' field label is visible\", async ({ page }) => {\n31\t    await page.goto(`${BASE_URL}/generate`);\n32\t    await expect(page.getByText(/total events/i)).toBeVisible();\n33\t  });\n34\t\n35\t  test(\"preset buttons for all three templates are present\", async ({\n36\t    page,\n37\t  }) => {\n38\t    await page.goto(`${BASE_URL}/generate`);\n39\t    await expect(page.getByText(/realistic/i)).toBeVisible();\n40\t    await expect(page.getByText(/high.?volume/i)).toBeVisible();\n41\t    await expect(page.getByText(/stress.?test/i)).toBeVisible();\n42\t  });\n43\t\n44\t  test(\"Generate submit button is present and enabled\", async ({ page }) => {\n45\t    await page.goto(`${BASE_URL}/generate`);\n46\t    const btn = page.getByRole(\"button\", { name: /^generate$/i });\n47\t    await expect(btn).toBeVisible();\n48\t    await expect(btn).toBeEnabled();\n49\t  });\n50\t\n51\t  test(\"progress panel is hidden on initial load\", async ({ page }) => {\n52\t    await page.goto(`${BASE_URL}/generate`);\n53\t    await expect(page.getByTestId(\"progress-panel\")).not.toBeVisible();\n54\t  });\n55\t});\n56\t"}]},"parent_tool_use_id":null,"session_id":"ef46994f-5887-4002-b236-0383bee9bd2b","uuid":"09a62408-c389-4589-a11a-206df178cca0","timestamp":"2026-04-15T19:37:46.700Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/playwright_tests/generate.spec.ts","content":"import { expect, test } from \"@playwright/test\";\n\n/**\n * E2e tests for F31 Bulk Generator page at /generate.\n *\n * Pre-conditions: Next.js server running at BASE_URL\n * (default http://localhost:3000). Override with BASE_URL env variable.\n *\n * Covers the \"integration gap\" HTTP checks from F31-plan.md:\n *   - GET /generate contains \"Generate\"\n *   - GET /generate contains \"Realistic\"\n *   - GET /generate contains \"Total events\"\n */\n\nconst BASE_URL = process.env.BASE_URL ?? \"http://localhost:3000\";\n\ntest.describe(\"Generate page (/generate)\", () => {\n  test(\"page renders with 'Generate' heading\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/generate`);\n    await expect(\n      page.getByRole(\"heading\", { name: /generate/i }),\n    ).toBeVisible();\n  });\n\n  test(\"'Realistic' preset button is visible\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/generate`);\n    await expect(page.getByText(/realistic/i)).toBeVisible();\n  });\n\n  test(\"'Total events' field label is visible\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/generate`);\n    await expect(page.getByText(/total events/i)).toBeVisible();\n  });\n\n  test(\"preset buttons for all three templates are present\", async ({\n    page,\n  }) => {\n    await page.goto(`${BASE_URL}/generate`);\n    await expect(page.getByText(/realistic/i)).toBeVisible();\n    await expect(page.getByText(/high.?volume/i)).toBeVisible();\n    await expect(page.getByText(/stress.?test/i)).toBeVisible();\n  });\n\n  test(\"Generate submit button is present and enabled\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/generate`);\n    const btn = page.getByRole(\"button\", { name: /^generate$/i });\n    await expect(btn).toBeVisible();\n    await expect(btn).toBeEnabled();\n  });\n\n  test(\"progress panel is hidden on initial load\", async ({ page }) => {\n    await page.goto(`${BASE_URL}/generate`);\n    await expect(page.getByTestId(\"progress-panel\")).not.toBeVisible();\n  });\n});\n","numLines":56,"startLine":1,"totalLines":56}}}
