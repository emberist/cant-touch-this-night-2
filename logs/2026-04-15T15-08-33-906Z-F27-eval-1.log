{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XoG6brLZSKm4FP2GjG41Mw","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport Box from \"@mui/material/Box\";\n4\timport Button from \"@mui/material/Button\";\n5\timport Stack from \"@mui/material/Stack\";\n6\timport TextField from \"@mui/material/TextField\";\n7\timport Typography from \"@mui/material/Typography\";\n8\timport { useState } from \"react\";\n9\timport type {\n10\t  EventPayload,\n11\t  SendResult,\n12\t} from \"@/components/test/useEventSender\";\n13\t\n14\t// ─── Types ────────────────────────────────────────────────────────────────────\n15\t\n16\tinterface CustomEventFormProps {\n17\t  sendEvent: (payload: EventPayload) => Promise<SendResult>;\n18\t}\n19\t\n20\t// ─── Component ────────────────────────────────────────────────────────────────\n21\t\n22\texport function CustomEventForm({\n23\t  sendEvent,\n24\t}: CustomEventFormProps): React.JSX.Element {\n25\t  const [open, setOpen] = useState(false);\n26\t\n27\t  // Form field state\n28\t  const [eventName, setEventName] = useState(\"\");\n29\t  const [deviceId, setDeviceId] = useState(\"\");\n30\t  const [userId, setUserId] = useState(\"\");\n31\t  const [timestamp, setTimestamp] = useState(\"\");\n32\t  const [propertiesRaw, setPropertiesRaw] = useState(\"\");\n33\t  const [propertiesError, setPropertiesError] = useState(false);\n34\t\n35\t  // Submit feedback\n36\t  const [loading, setLoading] = useState(false);\n37\t  const [feedback, setFeedback] = useState<{\n38\t    type: \"success\" | \"error\";\n39\t    message: string;\n40\t  } | null>(null);\n41\t\n42\t  function handlePropertiesChange(raw: string): void {\n43\t    setPropertiesRaw(raw);\n44\t    if (raw.trim() === \"\") {\n45\t      setPropertiesError(false);\n46\t      return;\n47\t    }\n48\t    try {\n49\t      JSON.parse(raw);\n50\t      setPropertiesError(false);\n51\t    } catch {\n52\t      setPropertiesError(true);\n53\t    }\n54\t  }\n55\t\n56\t  async function handleSubmit(e: React.FormEvent): Promise<void> {\n57\t    e.preventDefault();\n58\t    if (!eventName.trim() || propertiesError) return;\n59\t\n60\t    const payload: EventPayload = { event_name: eventName.trim() };\n61\t    if (deviceId.trim()) payload.device_id = deviceId.trim();\n62\t    if (userId.trim()) payload.user_id = userId.trim();\n63\t    if (timestamp.trim()) payload.timestamp = timestamp.trim();\n64\t    if (propertiesRaw.trim()) {\n65\t      try {\n66\t        payload.properties = JSON.parse(propertiesRaw) as Record<\n67\t          string,\n68\t          unknown\n69\t        >;\n70\t      } catch {\n71\t        setPropertiesError(true);\n72\t        return;\n73\t      }\n74\t    }\n75\t\n76\t    setLoading(true);\n77\t    setFeedback(null);\n78\t    const result = await sendEvent(payload);\n79\t    setLoading(false);\n80\t    setFeedback(\n81\t      result.success\n82\t        ? { type: \"success\", message: \"Sent\" }\n83\t        : { type: \"error\", message: result.error ?? \"Error\" },\n84\t    );\n85\t  }\n86\t\n87\t  return (\n88\t    <Box data-testid=\"custom-event-form\">\n89\t      <Button\n90\t        variant=\"outlined\"\n91\t        size=\"small\"\n92\t        onClick={() => setOpen((v) => !v)}\n93\t        fullWidth\n94\t      >\n95\t        Custom Event\n96\t      </Button>\n97\t\n98\t      {open && (\n99\t        <Box\n100\t          component=\"form\"\n101\t          onSubmit={(e) => void handleSubmit(e)}\n102\t          sx={{ mt: 1 }}\n103\t        >\n104\t          <Stack spacing={1}>\n105\t            <TextField\n106\t              label=\"Event Name\"\n107\t              value={eventName}\n108\t              onChange={(e) => setEventName(e.target.value)}\n109\t              size=\"small\"\n110\t              required\n111\t              fullWidth\n112\t            />\n113\t            <TextField\n114\t              label=\"Device ID\"\n115\t              value={deviceId}\n116\t              onChange={(e) => setDeviceId(e.target.value)}\n117\t              size=\"small\"\n118\t              fullWidth\n119\t            />\n120\t            <TextField\n121\t              label=\"User ID\"\n122\t              value={userId}\n123\t              onChange={(e) => setUserId(e.target.value)}\n124\t              size=\"small\"\n125\t              fullWidth\n126\t            />\n127\t            <TextField\n128\t              label=\"Timestamp\"\n129\t              type=\"datetime-local\"\n130\t              value={timestamp}\n131\t              onChange={(e) => setTimestamp(e.target.value)}\n132\t              size=\"small\"\n133\t              fullWidth\n134\t              slotProps={{ inputLabel: { shrink: true } }}\n135\t            />\n136\t            <TextField\n137\t              label=\"Properties\"\n138\t              value={propertiesRaw}\n139\t              onChange={(e) => handlePropertiesChange(e.target.value)}\n140\t              size=\"small\"\n141\t              multiline\n142\t              rows={3}\n143\t              fullWidth\n144\t              error={propertiesError}\n145\t              helperText={propertiesError ? \"Invalid JSON\" : undefined}\n146\t              placeholder='{\"key\": \"value\"}'\n147\t              slotProps={{ htmlInput: { style: { fontFamily: \"monospace\" } } }}\n148\t            />\n149\t\n150\t            <Button\n151\t              type=\"submit\"\n152\t              variant=\"contained\"\n153\t              size=\"small\"\n154\t              disabled={!eventName.trim() || propertiesError || loading}\n155\t              fullWidth\n156\t            >\n157\t              Send\n158\t            </Button>\n159\t\n160\t            {feedback != null && (\n161\t              <Typography\n162\t                variant=\"caption\"\n163\t                color={\n164\t                  feedback.type === \"success\" ? \"success.main\" : \"error.main\"\n165\t                }\n166\t              >\n167\t                {feedback.type === \"success\"\n168\t                  ? \"Sent\"\n169\t                  : `Error: ${feedback.message}`}\n170\t              </Typography>\n171\t            )}\n172\t          </Stack>\n173\t        </Box>\n174\t      )}\n175\t    </Box>\n176\t  );\n177\t}\n178\t"}]},"parent_tool_use_id":"toolu_01T7jNxLs6gWhDRp4pWq9aHS","session_id":"64f77740-6e45-45b6-8c03-7f0c13981bf2","uuid":"cc2663e3-41fc-48b8-abe3-f5a9009de3e2","timestamp":"2026-04-15T17:59:47.248Z"}
