{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NDtg83k5crXosVEMmoaHix","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport Box from \"@mui/material/Box\";\n4\timport Button from \"@mui/material/Button\";\n5\timport Stack from \"@mui/material/Stack\";\n6\timport Typography from \"@mui/material/Typography\";\n7\timport { useState } from \"react\";\n8\timport type { EventPayload } from \"@/components/test/useEventSender\";\n9\timport { generateId, useEventSender } from \"@/components/test/useEventSender\";\n10\t\n11\t// ─── Types ────────────────────────────────────────────────────────────────────\n12\t\n13\tinterface ButtonFeedback {\n14\t  type: \"success\" | \"error\";\n15\t  message: string;\n16\t}\n17\t\n18\t// ─── Quick-fire button config ─────────────────────────────────────────────────\n19\t\n20\tconst TEST_USER_ID = \"test@example.com\";\n21\t\n22\t// ─── Component ────────────────────────────────────────────────────────────────\n23\t\n24\texport function QuickFireButtons(): React.JSX.Element {\n25\t  const { sendEvent, lastDeviceId } = useEventSender();\n26\t  const [feedback, setFeedback] = useState<\n27\t    Record<string, ButtonFeedback | null>\n28\t  >({});\n29\t  const [loadingButton, setLoadingButton] = useState<string | null>(null);\n30\t\n31\t  async function fire(\n32\t    id: string,\n33\t    getPayload: () => EventPayload,\n34\t  ): Promise<void> {\n35\t    setLoadingButton(id);\n36\t    setFeedback((prev) => ({ ...prev, [id]: null }));\n37\t    const result = await sendEvent(getPayload());\n38\t    setLoadingButton(null);\n39\t    setFeedback((prev) => ({\n40\t      ...prev,\n41\t      [id]: result.success\n42\t        ? { type: \"success\", message: \"Sent\" }\n43\t        : { type: \"error\", message: result.error ?? \"Error\" },\n44\t    }));\n45\t  }\n46\t\n47\t  const buttons: Array<{\n48\t    id: string;\n49\t    label: string;\n50\t    getPayload: () => EventPayload;\n51\t  }> = [\n52\t    {\n53\t      id: \"anon-page-view\",\n54\t      label: \"Anonymous Page View\",\n55\t      getPayload: () => ({\n56\t        event_name: \"Page Viewed\",\n57\t        device_id: generateId(),\n58\t        properties: { page: \"/home\" },\n59\t      }),\n60\t    },\n61\t    {\n62\t      id: \"button-click\",\n63\t      label: \"Button Click\",\n64\t      getPayload: () => ({\n65\t        event_name: \"Button Clicked\",\n66\t        device_id: lastDeviceId ?? generateId(),\n67\t        properties: { button_name: \"Get Started\" },\n68\t      }),\n69\t    },\n70\t    {\n71\t      id: \"identify-user\",\n72\t      label: \"Identify User\",\n73\t      getPayload: () => ({\n74\t        event_name: \"Identify\",\n75\t        device_id: lastDeviceId ?? generateId(),\n76\t        user_id: TEST_USER_ID,\n77\t      }),\n78\t    },\n79\t    {\n80\t      id: \"purchase\",\n81\t      label: \"Purchase\",\n82\t      getPayload: () => ({\n83\t        event_name: \"Purchase Completed\",\n84\t        user_id: TEST_USER_ID,\n85\t        properties: { amount: 49.99, currency: \"USD\" },\n86\t      }),\n87\t    },\n88\t    {\n89\t      id: \"signup\",\n90\t      label: \"Signup\",\n91\t      getPayload: () => ({\n92\t        event_name: \"Signup Completed\",\n93\t        device_id: generateId(),\n94\t        user_id: `user-${generateId()}@example.com`,\n95\t      }),\n96\t    },\n97\t  ];\n98\t\n99\t  return (\n100\t    <Box data-testid=\"quick-fire-buttons\">\n101\t      <Stack spacing={1}>\n102\t        {buttons.map(({ id, label, getPayload }) => (\n103\t          <Box key={id}>\n104\t            <Button\n105\t              variant=\"outlined\"\n106\t              size=\"small\"\n107\t              disabled={loadingButton === id}\n108\t              onClick={() => void fire(id, getPayload)}\n109\t              fullWidth\n110\t            >\n111\t              {label}\n112\t            </Button>\n113\t            {feedback[id] != null && (\n114\t              <Typography\n115\t                variant=\"caption\"\n116\t                color={\n117\t                  feedback[id]?.type === \"success\"\n118\t                    ? \"success.main\"\n119\t                    : \"error.main\"\n120\t                }\n121\t                sx={{ display: \"block\", mt: 0.25 }}\n122\t              >\n123\t                {feedback[id]?.type === \"success\"\n124\t                  ? \"Sent\"\n125\t                  : `Error: ${feedback[id]?.message}`}\n126\t              </Typography>\n127\t            )}\n128\t          </Box>\n129\t        ))}\n130\t      </Stack>\n131\t    </Box>\n132\t  );\n133\t}\n134\t"}]},"parent_tool_use_id":"toolu_01T7jNxLs6gWhDRp4pWq9aHS","session_id":"64f77740-6e45-45b6-8c03-7f0c13981bf2","uuid":"c447b109-3adb-432e-8c04-f93c4073f1a4","timestamp":"2026-04-15T17:59:46.810Z"}
