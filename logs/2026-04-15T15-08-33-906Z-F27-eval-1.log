{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DUg2DU8iZwxifSUn91z2Xi","type":"tool_result","content":"1\t\"use client\";\n2\t\n3\timport { useCallback, useState } from \"react\";\n4\t\n5\t// ─── Types ────────────────────────────────────────────────────────────────────\n6\t\n7\texport interface EventPayload {\n8\t  event_name: string;\n9\t  device_id?: string;\n10\t  user_id?: string;\n11\t  timestamp?: string;\n12\t  properties?: Record<string, unknown>;\n13\t}\n14\t\n15\texport interface SendResult {\n16\t  success: boolean;\n17\t  error?: string;\n18\t}\n19\t\n20\texport interface SeedResult {\n21\t  success: boolean;\n22\t  eventCount?: number;\n23\t  error?: string;\n24\t}\n25\t\n26\texport interface UseEventSenderResult {\n27\t  lastDeviceId: string | null;\n28\t  sendEvent: (payload: EventPayload) => Promise<SendResult>;\n29\t  sendSeed: () => Promise<SeedResult>;\n30\t  loading: boolean;\n31\t}\n32\t\n33\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n34\t\n35\texport function generateId(): string {\n36\t  return Math.random().toString(36).slice(2, 10);\n37\t}\n38\t\n39\t// ─── Hook ─────────────────────────────────────────────────────────────────────\n40\t\n41\texport function useEventSender(): UseEventSenderResult {\n42\t  const [lastDeviceId, setLastDeviceId] = useState<string | null>(null);\n43\t  const [loading, setLoading] = useState(false);\n44\t\n45\t  const sendEvent = useCallback(\n46\t    async (payload: EventPayload): Promise<SendResult> => {\n47\t      setLoading(true);\n48\t      try {\n49\t        const res = await fetch(\"/api/events\", {\n50\t          method: \"POST\",\n51\t          headers: { \"Content-Type\": \"application/json\" },\n52\t          body: JSON.stringify(payload),\n53\t        });\n54\t\n55\t        if (!res.ok) {\n56\t          const data = (await res.json()) as { error?: string };\n57\t          return {\n58\t            success: false,\n59\t            error: data.error ?? `HTTP ${res.status}`,\n60\t          };\n61\t        }\n62\t\n63\t        if (payload.device_id) {\n64\t          setLastDeviceId(payload.device_id);\n65\t        }\n66\t\n67\t        return { success: true };\n68\t      } catch (err) {\n69\t        return {\n70\t          success: false,\n71\t          error: err instanceof Error ? err.message : \"Unknown error\",\n72\t        };\n73\t      } finally {\n74\t        setLoading(false);\n75\t      }\n76\t    },\n77\t    [],\n78\t  );\n79\t\n80\t  const sendSeed = useCallback(async (): Promise<SeedResult> => {\n81\t    setLoading(true);\n82\t    try {\n83\t      const res = await fetch(\"/api/seed\", { method: \"POST\" });\n84\t\n85\t      if (!res.ok) {\n86\t        const data = (await res.json()) as { error?: string };\n87\t        return {\n88\t          success: false,\n89\t          error: data.error ?? `HTTP ${res.status}`,\n90\t        };\n91\t      }\n92\t\n93\t      const statusRes = await fetch(\"/api/seed/status\");\n94\t      const statusData = (await statusRes.json()) as {\n95\t        event_count?: number;\n96\t        user_count?: number;\n97\t      };\n98\t\n99\t      return { success: true, eventCount: statusData.event_count };\n100\t    } catch (err) {\n101\t      return {\n102\t        success: false,\n103\t        error: err instanceof Error ? err.message : \"Unknown error\",\n104\t      };\n105\t    } finally {\n106\t      setLoading(false);\n107\t    }\n108\t  }, []);\n109\t\n110\t  return { lastDeviceId, sendEvent, sendSeed, loading };\n111\t}\n112\t"}]},"parent_tool_use_id":"toolu_01T7jNxLs6gWhDRp4pWq9aHS","session_id":"64f77740-6e45-45b6-8c03-7f0c13981bf2","uuid":"7b40532c-ff66-44f2-a3de-05fe235d250a","timestamp":"2026-04-15T17:59:46.679Z"}
