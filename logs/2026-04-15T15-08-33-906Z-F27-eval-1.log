{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EAQyXLNg4FExaWfiYT5Lp1","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport {\n3\t  cleanup,\n4\t  fireEvent,\n5\t  render,\n6\t  screen,\n7\t  waitFor,\n8\t} from \"@testing-library/react\";\n9\timport { afterEach, describe, expect, it, vi } from \"vitest\";\n10\timport { CustomEventForm } from \"@/components/test/CustomEventForm\";\n11\timport type {\n12\t  EventPayload,\n13\t  SendResult,\n14\t} from \"@/components/test/useEventSender\";\n15\t\n16\t// ─── Setup ────────────────────────────────────────────────────────────────────\n17\t\n18\tafterEach(() => {\n19\t  cleanup();\n20\t  vi.clearAllMocks();\n21\t});\n22\t\n23\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n24\t\n25\tfunction openForm() {\n26\t  const toggle = screen.getByRole(\"button\", { name: /custom event/i });\n27\t  fireEvent.click(toggle);\n28\t}\n29\t\n30\t// ─── Tests ────────────────────────────────────────────────────────────────────\n31\t\n32\tdescribe(\"CustomEventForm\", () => {\n33\t  describe(\"container\", () => {\n34\t    it(\"renders data-testid='custom-event-form' container\", () => {\n35\t      render(<CustomEventForm sendEvent={vi.fn()} />);\n36\t      expect(screen.getByTestId(\"custom-event-form\")).toBeTruthy();\n37\t    });\n38\t  });\n39\t\n40\t  describe(\"collapsible\", () => {\n41\t    it(\"form fields are not visible initially (collapsed)\", () => {\n42\t      render(<CustomEventForm sendEvent={vi.fn()} />);\n43\t      expect(\n44\t        screen.queryByRole(\"textbox\", { name: /event.?name/i }),\n45\t      ).toBeNull();\n46\t    });\n47\t\n48\t    it(\"form fields become visible after toggling open\", () => {\n49\t      render(<CustomEventForm sendEvent={vi.fn()} />);\n50\t      openForm();\n51\t      expect(\n52\t        screen.getByRole(\"textbox\", { name: /event.?name/i }),\n53\t      ).toBeTruthy();\n54\t    });\n55\t\n56\t    it(\"form fields are hidden again after toggling closed\", () => {\n57\t      render(<CustomEventForm sendEvent={vi.fn()} />);\n58\t      openForm();\n59\t      const toggle = screen.getByRole(\"button\", { name: /custom event/i });\n60\t      fireEvent.click(toggle);\n61\t      expect(\n62\t        screen.queryByRole(\"textbox\", { name: /event.?name/i }),\n63\t      ).toBeNull();\n64\t    });\n65\t  });\n66\t\n67\t  describe(\"submit button state\", () => {\n68\t    it(\"submit button is disabled when event_name is empty\", () => {\n69\t      render(<CustomEventForm sendEvent={vi.fn()} />);\n70\t      openForm();\n71\t      const submitBtn = screen.getByRole(\"button\", { name: /^send$/i });\n72\t      expect(submitBtn).toHaveProperty(\"disabled\", true);\n73\t    });\n74\t\n75\t    it(\"submit button is enabled when event_name has a value\", () => {\n76\t      render(<CustomEventForm sendEvent={vi.fn()} />);\n77\t      openForm();\n78\t      const input = screen.getByRole(\"textbox\", { name: /event.?name/i });\n79\t      fireEvent.change(input, { target: { value: \"Page Viewed\" } });\n80\t      const submitBtn = screen.getByRole(\"button\", { name: /^send$/i });\n81\t      expect(submitBtn).toHaveProperty(\"disabled\", false);\n82\t    });\n83\t  });\n84\t\n85\t  describe(\"form submission\", () => {\n86\t    it(\"calls sendEvent with event_name when submitted\", async () => {\n87\t      const mockSendEvent = vi\n88\t        .fn<(payload: EventPayload) => Promise<SendResult>>()\n89\t        .mockResolvedValue({ success: true });\n90\t      render(<CustomEventForm sendEvent={mockSendEvent} />);\n91\t      openForm();\n92\t\n93\t      fireEvent.change(screen.getByRole(\"textbox\", { name: /event.?name/i }), {\n94\t        target: { value: \"Page Viewed\" },\n95\t      });\n96\t      fireEvent.click(screen.getByRole(\"button\", { name: /^send$/i }));\n97\t\n98\t      await waitFor(() => expect(mockSendEvent).toHaveBeenCalledTimes(1));\n99\t      expect(\n100\t        (mockSendEvent.mock.calls[0] as [EventPayload])[0].event_name,\n101\t      ).toBe(\"Page Viewed\");\n102\t    });\n103\t\n104\t    it(\"includes device_id in payload when filled\", async () => {\n105\t      const mockSendEvent = vi\n106\t        .fn<(payload: EventPayload) => Promise<SendResult>>()\n107\t        .mockResolvedValue({ success: true });\n108\t      render(<CustomEventForm sendEvent={mockSendEvent} />);\n109\t      openForm();\n110\t\n111\t      fireEvent.change(screen.getByRole(\"textbox\", { name: /event.?name/i }), {\n112\t        target: { value: \"Page Viewed\" },\n113\t      });\n114\t      fireEvent.change(screen.getByRole(\"textbox\", { name: /device.?id/i }), {\n115\t        target: { value: \"dev-xyz\" },\n116\t      });\n117\t      fireEvent.click(screen.getByRole(\"button\", { name: /^send$/i }));\n118\t\n119\t      await waitFor(() => expect(mockSendEvent).toHaveBeenCalledTimes(1));\n120\t      expect((mockSendEvent.mock.calls[0] as [EventPayload])[0].device_id).toBe(\n121\t        \"dev-xyz\",\n122\t      );\n123\t    });\n124\t\n125\t    it(\"includes user_id in payload when filled\", async () => {\n126\t      const mockSendEvent = vi\n127\t        .fn<(payload: EventPayload) => Promise<SendResult>>()\n128\t        .mockResolvedValue({ success: true });\n129\t      render(<CustomEventForm sendEvent={mockSendEvent} />);\n130\t      openForm();\n131\t\n132\t      fireEvent.change(screen.getByRole(\"textbox\", { name: /event.?name/i }), {\n133\t        target: { value: \"Purchase Completed\" },\n134\t      });\n135\t      fireEvent.change(screen.getByRole(\"textbox\", { name: /user.?id/i }), {\n136\t        target: { value: \"user@test.com\" },\n137\t      });\n138\t      fireEvent.click(screen.getByRole(\"button\", { name: /^send$/i }));\n139\t\n140\t      await waitFor(() => expect(mockSendEvent).toHaveBeenCalledTimes(1));\n141\t      expect((mockSendEvent.mock.calls[0] as [EventPayload])[0].user_id).toBe(\n142\t        \"user@test.com\",\n143\t      );\n144\t    });\n145\t\n146\t    it(\"includes parsed JSON properties in payload when filled with valid JSON\", async () => {\n147\t      const mockSendEvent = vi\n148\t        .fn<(payload: EventPayload) => Promise<SendResult>>()\n149\t        .mockResolvedValue({ success: true });\n150\t      render(<CustomEventForm sendEvent={mockSendEvent} />);\n151\t      openForm();\n152\t\n153\t      fireEvent.change(screen.getByRole(\"textbox\", { name: /event.?name/i }), {\n154\t        target: { value: \"Purchase Completed\" },\n155\t      });\n156\t      // Properties field is a textarea\n157\t      const propsField = screen.getByRole(\"textbox\", { name: /properties/i });\n158\t      fireEvent.change(propsField, {\n159\t        target: { value: '{\"amount\": 49.99, \"currency\": \"USD\"}' },\n160\t      });\n161\t      fireEvent.click(screen.getByRole(\"button\", { name: /^send$/i }));\n162\t\n163\t      await waitFor(() => expect(mockSendEvent).toHaveBeenCalledTimes(1));\n164\t      expect(\n165\t        (mockSendEvent.mock.calls[0] as [EventPayload])[0].properties,\n166\t      ).toEqual({ amount: 49.99, currency: \"USD\" });\n167\t    });\n168\t\n169\t    it(\"shows validation error for invalid JSON in properties field\", () => {\n170\t      render(<CustomEventForm sendEvent={vi.fn()} />);\n171\t      openForm();\n172\t\n173\t      fireEvent.change(screen.getByRole(\"textbox\", { name: /event.?name/i }), {\n174\t        target: { value: \"Page Viewed\" },\n175\t      });\n176\t      const propsField = screen.getByRole(\"textbox\", { name: /properties/i });\n177\t      fireEvent.change(propsField, { target: { value: \"{invalid json}\" } });\n178\t\n179\t      // Multiple DOM nodes may contain the helper text — check at least one exists\n180\t      expect(screen.queryAllByText(/invalid json/i).length).toBeGreaterThan(0);\n181\t    });\n182\t  });\n183\t\n184\t  describe(\"feedback\", () => {\n185\t    it(\"displays success feedback after a successful send\", async () => {\n186\t      const mockSendEvent = vi.fn().mockResolvedValue({ success: true });\n187\t      render(<CustomEventForm sendEvent={mockSendEvent} />);\n188\t      openForm();\n189\t\n190\t      fireEvent.change(screen.getByRole(\"textbox\", { name: /event.?name/i }), {\n191\t        target: { value: \"Page Viewed\" },\n192\t      });\n193\t      fireEvent.click(screen.getByRole(\"button\", { name: /^send$/i }));\n194\t\n195\t      await waitFor(() => {\n196\t        expect(screen.queryByText(/sent|success/i)).toBeTruthy();\n197\t      });\n198\t    });\n199\t\n200\t    it(\"displays error feedback when send fails\", async () => {\n201\t      const mockSendEvent = vi\n202\t        .fn()\n203\t        .mockResolvedValue({ success: false, error: \"Server error\" });\n204\t      render(<CustomEventForm sendEvent={mockSendEvent} />);\n205\t      openForm();\n206\t\n207\t      fireEvent.change(screen.getByRole(\"textbox\", { name: /event.?name/i }), {\n208\t        target: { value: \"Page Viewed\" },\n209\t      });\n210\t      fireEvent.click(screen.getByRole(\"button\", { name: /^send$/i }));\n211\t\n212\t      await waitFor(() => {\n213\t        expect(screen.queryByText(/error|failed/i)).toBeTruthy();\n214\t      });\n215\t    });\n216\t  });\n217\t});\n218\t"}]},"parent_tool_use_id":"toolu_01T7jNxLs6gWhDRp4pWq9aHS","session_id":"64f77740-6e45-45b6-8c03-7f0c13981bf2","uuid":"5f2160d7-4fec-4282-bc4d-aadfabce3742","timestamp":"2026-04-15T17:59:48.329Z"}
