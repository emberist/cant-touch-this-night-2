{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JiFCpCSAoJMp9PrXB3pTt9","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport { act, renderHook, waitFor } from \"@testing-library/react\";\n3\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n4\timport { useEventSender } from \"@/components/test/useEventSender\";\n5\t\n6\t// ─── Setup ────────────────────────────────────────────────────────────────────\n7\t\n8\tconst mockFetch = vi.fn();\n9\t\n10\tbeforeEach(() => {\n11\t  vi.stubGlobal(\"fetch\", mockFetch);\n12\t});\n13\t\n14\tafterEach(() => {\n15\t  vi.clearAllMocks();\n16\t  vi.unstubAllGlobals();\n17\t});\n18\t\n19\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n20\t\n21\tfunction makeOkResponse(body: unknown = {}) {\n22\t  return Promise.resolve({\n23\t    ok: true,\n24\t    status: 201,\n25\t    json: () => Promise.resolve(body),\n26\t  });\n27\t}\n28\t\n29\tfunction makeErrorResponse(\n30\t  status: number,\n31\t  body: unknown = { error: \"Something went wrong\" },\n32\t) {\n33\t  return Promise.resolve({\n34\t    ok: false,\n35\t    status,\n36\t    json: () => Promise.resolve(body),\n37\t  });\n38\t}\n39\t\n40\t// ─── Tests ────────────────────────────────────────────────────────────────────\n41\t\n42\tdescribe(\"useEventSender\", () => {\n43\t  describe(\"initial state\", () => {\n44\t    it(\"starts with lastDeviceId null\", () => {\n45\t      const { result } = renderHook(() => useEventSender());\n46\t      expect(result.current.lastDeviceId).toBeNull();\n47\t    });\n48\t\n49\t    it(\"starts with loading false\", () => {\n50\t      const { result } = renderHook(() => useEventSender());\n51\t      expect(result.current.loading).toBe(false);\n52\t    });\n53\t  });\n54\t\n55\t  describe(\"sendEvent\", () => {\n56\t    it(\"calls fetch with POST /api/events and correct JSON body\", async () => {\n57\t      mockFetch.mockReturnValue(makeOkResponse());\n58\t      const { result } = renderHook(() => useEventSender());\n59\t\n60\t      await act(async () => {\n61\t        await result.current.sendEvent({\n62\t          event_name: \"Page Viewed\",\n63\t          device_id: \"dev-1\",\n64\t        });\n65\t      });\n66\t\n67\t      expect(mockFetch).toHaveBeenCalledTimes(1);\n68\t      const [url, init] = mockFetch.mock.calls[0] as [string, RequestInit];\n69\t      expect(url).toBe(\"/api/events\");\n70\t      expect(init.method).toBe(\"POST\");\n71\t      expect((init.headers as Record<string, string>)[\"Content-Type\"]).toBe(\n72\t        \"application/json\",\n73\t      );\n74\t\n75\t      const body = JSON.parse(init.body as string) as Record<string, unknown>;\n76\t      expect(body.event_name).toBe(\"Page Viewed\");\n77\t      expect(body.device_id).toBe(\"dev-1\");\n78\t    });\n79\t\n80\t    it(\"sends full payload including user_id, timestamp, and properties\", async () => {\n81\t      mockFetch.mockReturnValue(makeOkResponse());\n82\t      const { result } = renderHook(() => useEventSender());\n83\t\n84\t      await act(async () => {\n85\t        await result.current.sendEvent({\n86\t          event_name: \"Purchase Completed\",\n87\t          device_id: \"dev-1\",\n88\t          user_id: \"user@example.com\",\n89\t          timestamp: \"2026-04-15T12:00:00.000Z\",\n90\t          properties: { amount: 49.99, currency: \"USD\" },\n91\t        });\n92\t      });\n93\t\n94\t      const body = JSON.parse(\n95\t        (mockFetch.mock.calls[0] as [string, RequestInit])[1].body as string,\n96\t      ) as Record<string, unknown>;\n97\t      expect(body.user_id).toBe(\"user@example.com\");\n98\t      expect(body.timestamp).toBe(\"2026-04-15T12:00:00.000Z\");\n99\t      expect(body.properties).toEqual({ amount: 49.99, currency: \"USD\" });\n100\t    });\n101\t\n102\t    it(\"returns success: true on 201 response\", async () => {\n103\t      mockFetch.mockReturnValue(makeOkResponse());\n104\t      const { result } = renderHook(() => useEventSender());\n105\t\n106\t      let sendResult!: { success: boolean };\n107\t      await act(async () => {\n108\t        sendResult = await result.current.sendEvent({\n109\t          event_name: \"Page Viewed\",\n110\t          device_id: \"dev-1\",\n111\t        });\n112\t      });\n113\t\n114\t      expect(sendResult.success).toBe(true);\n115\t    });\n116\t\n117\t    it(\"returns success: false and error message on 400 response\", async () => {\n118\t      mockFetch.mockReturnValue(\n119\t        makeErrorResponse(400, { error: \"event_name required\" }),\n120\t      );\n121\t      const { result } = renderHook(() => useEventSender());\n122\t\n123\t      let sendResult!: { success: boolean; error?: string };\n124\t      await act(async () => {\n125\t        sendResult = await result.current.sendEvent({ event_name: \"\" });\n126\t      });\n127\t\n128\t      expect(sendResult.success).toBe(false);\n129\t      expect(sendResult.error).toBeTruthy();\n130\t    });\n131\t\n132\t    it(\"returns success: false and error message on 409 response\", async () => {\n133\t      mockFetch.mockReturnValue(makeErrorResponse(409, { error: \"Conflict\" }));\n134\t      const { result } = renderHook(() => useEventSender());\n135\t\n136\t      let sendResult!: { success: boolean; error?: string };\n137\t      await act(async () => {\n138\t        sendResult = await result.current.sendEvent({\n139\t          event_name: \"Page Viewed\",\n140\t          device_id: \"dev-1\",\n141\t          user_id: \"user-2\",\n142\t        });\n143\t      });\n144\t\n145\t      expect(sendResult.success).toBe(false);\n146\t      expect(sendResult.error).toBeTruthy();\n147\t    });\n148\t\n149\t    it(\"returns success: false and error message on 500 response\", async () => {\n150\t      mockFetch.mockReturnValue(\n151\t        makeErrorResponse(500, { error: \"Internal server error\" }),\n152\t      );\n153\t      const { result } = renderHook(() => useEventSender());\n154\t\n155\t      let sendResult!: { success: boolean; error?: string };\n156\t      await act(async () => {\n157\t        sendResult = await result.current.sendEvent({\n158\t          event_name: \"Page Viewed\",\n159\t          device_id: \"dev-1\",\n160\t        });\n161\t      });\n162\t\n163\t      expect(sendResult.success).toBe(false);\n164\t      expect(sendResult.error).toBeTruthy();\n165\t    });\n166\t  });\n167\t\n168\t  describe(\"lastDeviceId tracking\", () => {\n169\t    it(\"updates lastDeviceId after sending an event with device_id (anonymous page view)\", async () => {\n170\t      mockFetch.mockReturnValue(makeOkResponse());\n171\t      const { result } = renderHook(() => useEventSender());\n172\t\n173\t      expect(result.current.lastDeviceId).toBeNull();\n174\t\n175\t      await act(async () => {\n176\t        await result.current.sendEvent({\n177\t          event_name: \"Page Viewed\",\n178\t          device_id: \"dev-123\",\n179\t        });\n180\t      });\n181\t\n182\t      expect(result.current.lastDeviceId).toBe(\"dev-123\");\n183\t    });\n184\t\n185\t    it(\"does not update lastDeviceId when device_id is absent from payload\", async () => {\n186\t      mockFetch.mockReturnValue(makeOkResponse());\n187\t      const { result } = renderHook(() => useEventSender());\n188\t\n189\t      await act(async () => {\n190\t        await result.current.sendEvent({\n191\t          event_name: \"Purchase Completed\",\n192\t          user_id: \"user@example.com\",\n193\t        });\n194\t      });\n195\t\n196\t      expect(result.current.lastDeviceId).toBeNull();\n197\t    });\n198\t\n199\t    it(\"updates lastDeviceId to the most recent device_id sent\", async () => {\n200\t      mockFetch.mockReturnValue(makeOkResponse());\n201\t      const { result } = renderHook(() => useEventSender());\n202\t\n203\t      await act(async () => {\n204\t        await result.current.sendEvent({\n205\t          event_name: \"Page Viewed\",\n206\t          device_id: \"dev-1\",\n207\t        });\n208\t      });\n209\t      expect(result.current.lastDeviceId).toBe(\"dev-1\");\n210\t\n211\t      await act(async () => {\n212\t        await result.current.sendEvent({\n213\t          event_name: \"Page Viewed\",\n214\t          device_id: \"dev-2\",\n215\t        });\n216\t      });\n217\t      expect(result.current.lastDeviceId).toBe(\"dev-2\");\n218\t    });\n219\t  });\n220\t\n221\t  describe(\"sendSeed\", () => {\n222\t    it(\"calls POST /api/seed\", async () => {\n223\t      mockFetch.mockReturnValueOnce(makeOkResponse({})).mockReturnValueOnce(\n224\t        Promise.resolve({\n225\t          ok: true,\n226\t          status: 200,\n227\t          json: () => Promise.resolve({ event_count: 12000, user_count: 70 }),\n228\t        }),\n229\t      );\n230\t      const { result } = renderHook(() => useEventSender());\n231\t\n232\t      await act(async () => {\n233\t        await result.current.sendSeed();\n234\t      });\n235\t\n236\t      const seedCall = mockFetch.mock.calls[0] as [string, RequestInit];\n237\t      expect(seedCall[0]).toBe(\"/api/seed\");\n238\t      expect(seedCall[1].method).toBe(\"POST\");\n239\t    });\n240\t\n241\t    it(\"returns success: true and eventCount on success\", async () => {\n242\t      mockFetch.mockReturnValueOnce(makeOkResponse({})).mockReturnValueOnce(\n243\t        Promise.resolve({\n244\t          ok: true,\n245\t          status: 200,\n246\t          json: () => Promise.resolve({ event_count: 12000, user_count: 70 }),\n247\t        }),\n248\t      );\n249\t      const { result } = renderHook(() => useEventSender());\n250\t\n251\t      let seedResult!: { success: boolean; eventCount?: number };\n252\t      await act(async () => {\n253\t        seedResult = await result.current.sendSeed();\n254\t      });\n255\t\n256\t      expect(seedResult.success).toBe(true);\n257\t      expect(seedResult.eventCount).toBe(12000);\n258\t    });\n259\t\n260\t    it(\"returns success: false and error message when /api/seed returns an error\", async () => {\n261\t      mockFetch.mockReturnValue(\n262\t        makeErrorResponse(500, { error: \"Seed failed\" }),\n263\t      );\n264\t      const { result } = renderHook(() => useEventSender());\n265\t\n266\t      let seedResult!: { success: boolean; error?: string };\n267\t      await act(async () => {\n268\t        seedResult = await result.current.sendSeed();\n269\t      });\n270\t\n271\t      expect(seedResult.success).toBe(false);\n272\t      expect(seedResult.error).toBeTruthy();\n273\t    });\n274\t\n275\t    it(\"returns success: false when fetch throws (network error)\", async () => {\n276\t      mockFetch.mockReturnValue(Promise.reject(new Error(\"Network error\")));\n277\t      const { result } = renderHook(() => useEventSender());\n278\t\n279\t      let seedResult!: { success: boolean; error?: string };\n280\t      await act(async () => {\n281\t        seedResult = await result.current.sendSeed();\n282\t      });\n283\t\n284\t      expect(seedResult.success).toBe(false);\n285\t      expect(seedResult.error).toBeTruthy();\n286\t    });\n287\t  });\n288\t\n289\t  describe(\"loading state\", () => {\n290\t    it(\"is false before any request\", () => {\n291\t      const { result } = renderHook(() => useEventSender());\n292\t      expect(result.current.loading).toBe(false);\n293\t    });\n294\t\n295\t    it(\"is true during an in-flight sendEvent, false after completion\", async () => {\n296\t      let resolveRequest!: (v: unknown) => void;\n297\t      mockFetch.mockReturnValueOnce(\n298\t        new Promise((resolve) => {\n299\t          resolveRequest = resolve;\n300\t        }),\n301\t      );\n302\t\n303\t      const { result } = renderHook(() => useEventSender());\n304\t\n305\t      act(() => {\n306\t        void result.current.sendEvent({\n307\t          event_name: \"Page Viewed\",\n308\t          device_id: \"dev-1\",\n309\t        });\n310\t      });\n311\t\n312\t      await waitFor(() => expect(result.current.loading).toBe(true));\n313\t\n314\t      act(() => {\n315\t        resolveRequest({\n316\t          ok: true,\n317\t          status: 201,\n318\t          json: () => Promise.resolve({}),\n319\t        });\n320\t      });\n321\t\n322\t      await waitFor(() => expect(result.current.loading).toBe(false));\n323\t    });\n324\t\n325\t    it(\"is true during an in-flight sendSeed, false after completion\", async () => {\n326\t      let resolveRequest!: (v: unknown) => void;\n327\t      mockFetch.mockReturnValueOnce(\n328\t        new Promise((resolve) => {\n329\t          resolveRequest = resolve;\n330\t        }),\n331\t      );\n332\t\n333\t      const { result } = renderHook(() => useEventSender());\n334\t\n335\t      act(() => {\n336\t        void result.current.sendSeed();\n337\t      });\n338\t\n339\t      await waitFor(() => expect(result.current.loading).toBe(true));\n340\t\n341\t      act(() => {\n342\t        resolveRequest({\n343\t          ok: true,\n344\t          status: 200,\n345\t          json: () => Promise.resolve({}),\n346\t        });\n347\t      });\n348\t\n349\t      // After seed POST resolves, sendSeed then fetches /api/seed/status — mock that too\n350\t      mockFetch.mockReturnValueOnce(\n351\t        Promise.resolve({\n352\t          ok: true,\n353\t          status: 200,\n354\t          json: () => Promise.resolve({ event_count: 0, user_count: 0 }),\n355\t        }),\n356\t      );\n357\t\n358\t      await waitFor(() => expect(result.current.loading).toBe(false));\n359\t    });\n360\t  });\n361\t});\n362\t"}]},"parent_tool_use_id":"toolu_01T7jNxLs6gWhDRp4pWq9aHS","session_id":"64f77740-6e45-45b6-8c03-7f0c13981bf2","uuid":"8cbcb887-a5ee-44c6-9815-4496627669cc","timestamp":"2026-04-15T17:59:48.246Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FdGjTjN9VB8p6kso5vD9oJ","type":"tool_result","content":"1\t// @vitest-environment jsdom\n2\timport {\n3\t  cleanup,\n4\t  fireEvent,\n5\t  render,\n6\t  screen,\n7\t  waitFor,\n8\t} from \"@testing-library/react\";\n9\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n10\timport { QuickFireButtons } from \"@/components/test/QuickFireButtons\";\n11\t\n12\t// ─── Setup ────────────────────────────────────────────────────────────────────\n13\t\n14\tconst mockFetch = vi.fn();\n15\t\n16\tbeforeEach(() => {\n17\t  vi.stubGlobal(\"fetch\", mockFetch);\n18\t  mockFetch.mockResolvedValue({\n19\t    ok: true,\n20\t    status: 201,\n21\t    json: () => Promise.resolve({}),\n22\t  });\n23\t});\n24\t\n25\tafterEach(() => {\n26\t  cleanup();\n27\t  vi.clearAllMocks();\n28\t  vi.unstubAllGlobals();\n29\t});\n30\t\n31\t// ─── Tests ────────────────────────────────────────────────────────────────────\n32\t\n33\tdescribe(\"QuickFireButtons\", () => {\n34\t  describe(\"container\", () => {\n35\t    it(\"renders data-testid='quick-fire-buttons' container\", () => {\n36\t      render(<QuickFireButtons />);\n37\t      expect(screen.getByTestId(\"quick-fire-buttons\")).toBeTruthy();\n38\t    });\n39\t  });\n40\t\n41\t  describe(\"buttons rendered\", () => {\n42\t    it(\"renders all 5 quick-fire buttons\", () => {\n43\t      render(<QuickFireButtons />);\n44\t      expect(\n45\t        screen.getByRole(\"button\", { name: /anonymous page view/i }),\n46\t      ).toBeTruthy();\n47\t      expect(\n48\t        screen.getByRole(\"button\", { name: /button click/i }),\n49\t      ).toBeTruthy();\n50\t      expect(\n51\t        screen.getByRole(\"button\", { name: /identify user/i }),\n52\t      ).toBeTruthy();\n53\t      expect(screen.getByRole(\"button\", { name: /purchase/i })).toBeTruthy();\n54\t      expect(screen.getByRole(\"button\", { name: /signup/i })).toBeTruthy();\n55\t    });\n56\t  });\n57\t\n58\t  describe(\"Anonymous Page View button\", () => {\n59\t    it(\"sends event_name 'Page Viewed', a device_id, and page '/home'\", async () => {\n60\t      render(<QuickFireButtons />);\n61\t      fireEvent.click(\n62\t        screen.getByRole(\"button\", { name: /anonymous page view/i }),\n63\t      );\n64\t\n65\t      await waitFor(() =>\n66\t        expect(mockFetch).toHaveBeenCalledWith(\n67\t          \"/api/events\",\n68\t          expect.anything(),\n69\t        ),\n70\t      );\n71\t\n72\t      const body = JSON.parse(\n73\t        (mockFetch.mock.calls[0] as [string, RequestInit])[1].body as string,\n74\t      ) as Record<string, unknown>;\n75\t      expect(body.event_name).toBe(\"Page Viewed\");\n76\t      expect(body.device_id).toBeTruthy();\n77\t      expect(body.user_id).toBeUndefined();\n78\t      expect((body.properties as Record<string, unknown>)?.page).toBe(\"/home\");\n79\t    });\n80\t  });\n81\t\n82\t  describe(\"Button Click button\", () => {\n83\t    it(\"sends event_name 'Button Clicked' with the same device_id as the last Anonymous Page View\", async () => {\n84\t      render(<QuickFireButtons />);\n85\t\n86\t      // Step 1: fire Anonymous Page View to set lastDeviceId\n87\t      fireEvent.click(\n88\t        screen.getByRole(\"button\", { name: /anonymous page view/i }),\n89\t      );\n90\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(1));\n91\t\n92\t      const firstBody = JSON.parse(\n93\t        (mockFetch.mock.calls[0] as [string, RequestInit])[1].body as string,\n94\t      ) as Record<string, unknown>;\n95\t      const firstDeviceId = firstBody.device_id as string;\n96\t      expect(firstDeviceId).toBeTruthy();\n97\t\n98\t      // Step 2: fire Button Click — should use the same device_id\n99\t      fireEvent.click(screen.getByRole(\"button\", { name: /button click/i }));\n100\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(2));\n101\t\n102\t      const secondBody = JSON.parse(\n103\t        (mockFetch.mock.calls[1] as [string, RequestInit])[1].body as string,\n104\t      ) as Record<string, unknown>;\n105\t      expect(secondBody.event_name).toBe(\"Button Clicked\");\n106\t      expect(secondBody.device_id).toBe(firstDeviceId);\n107\t    });\n108\t  });\n109\t\n110\t  describe(\"Identify User button\", () => {\n111\t    it(\"sends the last anonymous device_id and user_id 'test@example.com'\", async () => {\n112\t      render(<QuickFireButtons />);\n113\t\n114\t      // Set lastDeviceId via Anonymous Page View\n115\t      fireEvent.click(\n116\t        screen.getByRole(\"button\", { name: /anonymous page view/i }),\n117\t      );\n118\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(1));\n119\t\n120\t      const firstBody = JSON.parse(\n121\t        (mockFetch.mock.calls[0] as [string, RequestInit])[1].body as string,\n122\t      ) as Record<string, unknown>;\n123\t      const firstDeviceId = firstBody.device_id as string;\n124\t\n125\t      // Identify User\n126\t      fireEvent.click(screen.getByRole(\"button\", { name: /identify user/i }));\n127\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(2));\n128\t\n129\t      const identifyBody = JSON.parse(\n130\t        (mockFetch.mock.calls[1] as [string, RequestInit])[1].body as string,\n131\t      ) as Record<string, unknown>;\n132\t      expect(identifyBody.device_id).toBe(firstDeviceId);\n133\t      expect(identifyBody.user_id).toBe(\"test@example.com\");\n134\t    });\n135\t  });\n136\t\n137\t  describe(\"Purchase button\", () => {\n138\t    it(\"sends event_name 'Purchase Completed' with user_id and amount/currency\", async () => {\n139\t      render(<QuickFireButtons />);\n140\t      fireEvent.click(screen.getByRole(\"button\", { name: /purchase/i }));\n141\t\n142\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(1));\n143\t\n144\t      const body = JSON.parse(\n145\t        (mockFetch.mock.calls[0] as [string, RequestInit])[1].body as string,\n146\t      ) as Record<string, unknown>;\n147\t      expect(body.event_name).toBe(\"Purchase Completed\");\n148\t      expect(body.user_id).toBe(\"test@example.com\");\n149\t\n150\t      const props = body.properties as Record<string, unknown>;\n151\t      expect(props.amount).toBe(49.99);\n152\t      expect(props.currency).toBe(\"USD\");\n153\t    });\n154\t  });\n155\t\n156\t  describe(\"Signup button\", () => {\n157\t    it(\"sends event_name 'Signup Completed' with a new random device_id and user_id\", async () => {\n158\t      render(<QuickFireButtons />);\n159\t      fireEvent.click(screen.getByRole(\"button\", { name: /signup/i }));\n160\t\n161\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(1));\n162\t\n163\t      const body = JSON.parse(\n164\t        (mockFetch.mock.calls[0] as [string, RequestInit])[1].body as string,\n165\t      ) as Record<string, unknown>;\n166\t      expect(body.event_name).toBe(\"Signup Completed\");\n167\t      expect(body.device_id).toBeTruthy();\n168\t      expect(body.user_id).toBeTruthy();\n169\t    });\n170\t\n171\t    it(\"generates a different device_id and user_id each time\", async () => {\n172\t      render(<QuickFireButtons />);\n173\t\n174\t      fireEvent.click(screen.getByRole(\"button\", { name: /signup/i }));\n175\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(1));\n176\t\n177\t      fireEvent.click(screen.getByRole(\"button\", { name: /signup/i }));\n178\t      await waitFor(() => expect(mockFetch).toHaveBeenCalledTimes(2));\n179\t\n180\t      const body1 = JSON.parse(\n181\t        (mockFetch.mock.calls[0] as [string, RequestInit])[1].body as string,\n182\t      ) as Record<string, unknown>;\n183\t      const body2 = JSON.parse(\n184\t        (mockFetch.mock.calls[1] as [string, RequestInit])[1].body as string,\n185\t      ) as Record<string, unknown>;\n186\t\n187\t      expect(body1.device_id).not.toBe(body2.device_id);\n188\t      expect(body1.user_id).not.toBe(body2.user_id);\n189\t    });\n190\t  });\n191\t\n192\t  describe(\"feedback\", () => {\n193\t    it(\"displays success feedback after a successful send\", async () => {\n194\t      render(<QuickFireButtons />);\n195\t      fireEvent.click(\n196\t        screen.getByRole(\"button\", { name: /anonymous page view/i }),\n197\t      );\n198\t\n199\t      await waitFor(() => {\n200\t        const text = screen.queryByText(/sent|success/i);\n201\t        expect(text).toBeTruthy();\n202\t      });\n203\t    });\n204\t\n205\t    it(\"displays error feedback when the send fails\", async () => {\n206\t      mockFetch.mockResolvedValue({\n207\t        ok: false,\n208\t        status: 500,\n209\t        json: () => Promise.resolve({ error: \"Server error\" }),\n210\t      });\n211\t\n212\t      render(<QuickFireButtons />);\n213\t      fireEvent.click(\n214\t        screen.getByRole(\"button\", { name: /anonymous page view/i }),\n215\t      );\n216\t\n217\t      await waitFor(() => {\n218\t        const text = screen.queryByText(/error|failed/i);\n219\t        expect(text).toBeTruthy();\n220\t      });\n221\t    });\n222\t  });\n223\t});\n224\t"}]},"parent_tool_use_id":"toolu_01T7jNxLs6gWhDRp4pWq9aHS","session_id":"64f77740-6e45-45b6-8c03-7f0c13981bf2","uuid":"13e362c7-0d36-49fa-9cd9-364973b4ac05","timestamp":"2026-04-15T17:59:48.108Z"}
