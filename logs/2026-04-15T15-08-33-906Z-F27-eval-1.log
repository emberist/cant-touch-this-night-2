\t            : `Error: ${result.error ?? \"Failed\"}`}\n56\t        </Typography>\n57\t      )}\n58\t    </Box>\n59\t  );\n60\t}\n61\t"}]},"parent_tool_use_id":"toolu_01T7jNxLs6gWhDRp4pWq9aHS","session_id":"64f77740-6e45-45b6-8c03-7f0c13981bf2","uuid":"3e2b58b5-6001-465a-9aae-70cbce2dc6db","timestamp":"2026-04-15T17:59:47.466Z"}
