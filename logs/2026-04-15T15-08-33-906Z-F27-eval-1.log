ev-1\",\n207\t        });\n208\t      });\n209\t      expect(result.current.lastDeviceId).toBe(\"dev-1\");\n210\t\n211\t      await act(async () => {\n212\t        await result.current.sendEvent({\n213\t          event_name: \"Page Viewed\",\n214\t          device_id: \"dev-2\",\n215\t        });\n216\t      });\n217\t      expect(result.current.lastDeviceId).toBe(\"dev-2\");\n218\t    });\n219\t  });\n220\t\n221\t  describe(\"sendSeed\", () => {\n222\t    it(\"calls POST /api/seed\", async () => {\n223\t      mockFetch.mockReturnValueOnce(makeOkResponse({})).mockReturnValueOnce(\n224\t        Promise.resolve({\n225\t          ok: true,\n226\t          status: 200,\n227\t          json: () => Promise.resolve({ event_count: 12000, user_count: 70 }),\n228\t        }),\n229\t      );\n230\t      const { result } = renderHook(() => useEventSender());\n231\t\n232\t      await act(async () => {\n233\t        await result.current.sendSeed();\n234\t      });\n235\t\n236\t      const seedCall = mockFetch.mock.calls[0] as [string, RequestInit];\n237\t      expect(seedCall[0]).toBe(\"/api/seed\");\n238\t      expect(seedCall[1].method).toBe(\"POST\");\n239\t    });\n240\t\n241\t    it(\"returns success: true and eventCount on success\", async () => {\n242\t      mockFetch.mockReturnValueOnce(makeOkResponse({})).mockReturnValueOnce(\n243\t        Promise.resolve({\n244\t          ok: true,\n245\t          status: 200,\n246\t          json: () => Promise.resolve({ event_count: 12000, user_count: 70 }),\n247\t        }),\n248\t      );\n249\t      const { result } = renderHook(() => useEventSender());\n250\t\n251\t      let seedResult!: { success: boolean; eventCount?: number };\n252\t      await act(async () => {\n253\t        seedResult = await result.current.sendSeed();\n254\t      });\n255\t\n256\t      expect(seedResult.success).toBe(true);\n257\t      expect(seedResult.eventCount).toBe(12000);\n258\t    });\n259\t\n260\t    it(\"returns success: false and error message when