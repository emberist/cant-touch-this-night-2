ading).toBe(true));\n313\t\n314\t      act(() => {\n315\t        resolveRequest({\n316\t          ok: true,\n317\t          status: 201,\n318\t          json: () => Promise.resolve({}),\n319\t        });\n320\t      });\n321\t\n322\t      await waitFor(() => expect(result.current.loading).toBe(false));\n323\t    });\n324\t\n325\t    it(\"is true during an in-flight sendSeed, false after completion\", async () => {\n326\t      let resolveRequest!: (v: unknown) => void;\n327\t      mockFetch.mockReturnValueOnce(\n328\t        new Promise((resolve) => {\n329\t          resolveRequest = resolve;\n330\t        }),\n331\t      );\n332\t\n333\t      const { result } = renderHook(() => useEventSender());\n334\t\n335\t      act(() => {\n336\t        void result.current.sendSeed();\n337\t      });\n338\t\n339\t      await waitFor(() => expect(result.current.loading).toBe(true));\n340\t\n341\t      act(() => {\n342\t        resolveRequest({\n343\t          ok: true,\n344\t          status: 200,\n345\t          json: () => Promise.resolve({}),\n346\t        });\n347\t      });\n348\t\n349\t      // After seed POST resolves, sendSeed then fetches /api/seed/status — mock that too\n350\t      mockFetch.mockReturnValueOnce(\n351\t        Promise.resolve({\n352\t          ok: true,\n353\t          status: 200,\n354\t          json: () => Promise.resolve({ event_count: 0, user_count: 0 }),\n355\t        }),\n356\t      );\n357\t\n358\t      await waitFor(() => expect(result.current.loading).toBe(false));\n359\t    });\n360\t  });\n361\t});\n362\t"}]},"parent_tool_use_id":null,"session_id":"64f77740-6e45-45b6-8c03-7f0c13981bf2","uuid":"b187027e-34cb-4a90-85f0-e9fd519b051c","timestamp":"2026-04-15T18:00:01.693Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/components/test/__tests__/useEventSender.test.ts","content":"// @vitest-environment jsdom\nimport { act, renderHook, waitFor } from \"@testing-library/react\";\nim