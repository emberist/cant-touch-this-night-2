4\t      const body = await res.json();\n125\t      expect(body).toHaveProperty(\"error\");\n126\t    });\n127\t\n128\t    it(\"returns 400 when start is missing\", async () => {\n129\t      const res = await POST(\n130\t        makeRequest({\n131\t          steps: [\"Page Viewed\", \"Signup Completed\"],\n132\t          end: \"2026-04-15\",\n133\t        }),\n134\t      );\n135\t\n136\t      expect(res.status).toBe(400);\n137\t      const body = await res.json();\n138\t      expect(body).toHaveProperty(\"error\");\n139\t    });\n140\t\n141\t    it(\"returns 400 when end is missing\", async () => {\n142\t      const res = await POST(\n143\t        makeRequest({\n144\t          steps: [\"Page Viewed\", \"Signup Completed\"],\n145\t          start: \"2026-04-01\",\n146\t        }),\n147\t      );\n148\t\n149\t      expect(res.status).toBe(400);\n150\t      const body = await res.json();\n151\t      expect(body).toHaveProperty(\"error\");\n152\t    });\n153\t  });\n154\t\n155\t  describe(\"success — 200\", () => {\n156\t    it(\"returns 200 with steps array in response body\", async () => {\n157\t      const res = await POST(makeRequest(validBody));\n158\t\n159\t      expect(res.status).toBe(200);\n160\t      const body = await res.json();\n161\t      expect(body).toHaveProperty(\"steps\");\n162\t      expect(Array.isArray(body.steps)).toBe(true);\n163\t    });\n164\t\n165\t    it(\"forwards parsed params correctly to queryFunnel\", async () => {\n166\t      await POST(makeRequest(validBody));\n167\t\n168\t      expect(mockQueryFunnel).toHaveBeenCalledWith({\n169\t        steps: [\"Page Viewed\", \"Signup Completed\"],\n170\t        start: \"2026-04-01\",\n171\t        end: \"2026-04-15\",\n172\t      });\n173\t    });\n174\t  });\n175\t\n176\t  describe(\"error handling — 500\", () => {\n177\t    it(\"returns 500 when queryFunnel throws\", async () => {\n178\t      mockQueryFunnel.mockRejectedValue(\n179\t        new Error(\"ClickHouse connection failed\"),\n180\t    