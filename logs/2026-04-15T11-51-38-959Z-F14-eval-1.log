{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UZyjg39yW4riCD34jwAMys","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// ─── Mock setup ────────────────────────────────────────────────────────────────\n4\t\n5\tconst { mockGetUserProfile } = vi.hoisted(() => ({\n6\t  mockGetUserProfile: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/users\", () => ({\n10\t  getUserProfile: mockGetUserProfile,\n11\t}));\n12\t\n13\timport { GET } from \"@/app/api/users/[id]/route\";\n14\t\n15\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n16\t\n17\ttype TestContext = { params: Promise<{ id: string }> };\n18\t\n19\tfunction makeRequest(id: string): [Request, TestContext] {\n20\t  return [\n21\t    new Request(`http://localhost/api/users/${encodeURIComponent(id)}`),\n22\t    { params: Promise.resolve({ id }) },\n23\t  ];\n24\t}\n25\t\n26\tconst sampleProfile = {\n27\t  resolved_id: \"user@test.com\",\n28\t  first_seen: \"2026-04-01T00:00:00.000Z\",\n29\t  last_seen: \"2026-04-15T00:00:00.000Z\",\n30\t  identity_cluster: {\n31\t    user_ids: [\"user@test.com\"],\n32\t    device_ids: [\"dev-1\"],\n33\t  },\n34\t  events: [],\n35\t};\n36\t\n37\t// ─── Tests ────────────────────────────────────────────────────────────────────\n38\t\n39\tbeforeEach(() => {\n40\t  mockGetUserProfile.mockResolvedValue(sampleProfile);\n41\t});\n42\t\n43\tafterEach(() => {\n44\t  vi.clearAllMocks();\n45\t});\n46\t\n47\tdescribe(\"GET /api/users/[id]\", () => {\n48\t  describe(\"success — 200\", () => {\n49\t    it(\"returns 200 with full profile when user exists\", async () => {\n50\t      const [req, ctx] = makeRequest(\"user@test.com\");\n51\t      const res = await GET(req, ctx);\n52\t\n53\t      expect(res.status).toBe(200);\n54\t      const body = await res.json();\n55\t      expect(body).toMatchObject({\n56\t        resolved_id: \"user@test.com\",\n57\t        first_seen: expect.any(String),\n58\t        last_seen: expect.any(String),\n59\t        identity_cluster: expect.objectContaining({\n60\t          user_ids: expect.any(Array),\n61\t          device_ids: expect.any(Array),\n62\t        }),\n63\t        events: expect.any(Array),\n64\t      });\n65\t    });\n66\t\n67\t    it(\"passes the id to getUserProfile\", async () => {\n68\t      const [req, ctx] = makeRequest(\"user@test.com\");\n69\t      await GET(req, ctx);\n70\t\n71\t      expect(mockGetUserProfile).toHaveBeenCalledWith(\"user@test.com\");\n72\t    });\n73\t  });\n74\t\n75\t  describe(\"not found — 404\", () => {\n76\t    it(\"returns 404 with error when user not found\", async () => {\n77\t      mockGetUserProfile.mockResolvedValue(null);\n78\t\n79\t      const [req, ctx] = makeRequest(\"nonexistent@test.com\");\n80\t      const res = await GET(req, ctx);\n81\t\n82\t      expect(res.status).toBe(404);\n83\t      const body = await res.json();\n84\t      expect(body).toHaveProperty(\"error\");\n85\t      expect(typeof body.error).toBe(\"string\");\n86\t    });\n87\t  });\n88\t\n89\t  describe(\"error handling — 500\", () => {\n90\t    it(\"returns 500 when getUserProfile throws\", async () => {\n91\t      mockGetUserProfile.mockRejectedValue(\n92\t        new Error(\"ClickHouse connection failed\"),\n93\t      );\n94\t\n95\t      const [req, ctx] = makeRequest(\"user@test.com\");\n96\t      const res = await GET(req, ctx);\n97\t\n98\t      expect(res.status).toBe(500);\n99\t      const body = await res.json();\n100\t      expect(body).toHaveProperty(\"error\");\n101\t    });\n102\t  });\n103\t});\n104\t"}]},"parent_tool_use_id":null,"session_id":"1e8f2076-f971-4e3e-a332-70fda55cefab","uuid":"8f90b3fd-68e5-4319-aca4-a736dae80aa1","timestamp":"2026-04-15T14:20:22.273Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/users/[id]/__tests__/route.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// ─── Mock setup ────────────────────────────────────────────────────────────────\n\nconst { mockGetUserProfile } = vi.hoisted(() => ({\n  mockGetUserProfile: vi.fn(),\n}));\n\nvi.mock(\"@/lib/users\", () => ({\n  getUserProfile: mockGetUserProfile,\n}));\n\nimport { GET } from \"@/app/api/users/[id]/route\";\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\ntype TestContext = { params: Promise<{ id: string }> };\n\nfunction makeRequest(id: string): [Request, TestContext] {\n  return [\n    new Request(`http://localhost/api/users/${encodeURIComponent(id)}`),\n    { params: Promise.resolve({ id }) },\n  ];\n}\n\nconst sampleProfile = {\n  resolved_id: \"user@test.com\",\n  first_seen: \"2026-04-01T00:00:00.000Z\",\n  last_seen: \"2026-04-15T00:00:00.000Z\",\n  identity_cluster: {\n    user_ids: [\"user@test.com\"],\n    device_ids: [\"dev-1\"],\n  },\n  events: [],\n};\n\n// ─── Tests ────────────────────────────────────────────────────────────────────\n\nbeforeEach(() => {\n  mockGetUserProfile.mockResolvedValue(sampleProfile);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\ndescribe(\"GET /api/users/[id]\", () => {\n  describe(\"success — 200\", () => {\n    it(\"returns 200 with full profile when user exists\", async () => {\n      const [req, ctx] = makeRequest(\"user@test.com\");\n      const res = await GET(req, ctx);\n\n      expect(res.status).toBe(200);\n      const body = await res.json();\n      expect(body).toMatchObject({\n        resolved_id: \"user@test.com\",\n        first_seen: expect.any(String),\n        last_seen: expect.any(String),\n        identity_cluster: expect.objectContaining({\n          user_ids: expect.any(Array),\n          device_ids: expect.any(Array),\n        }),\n        events: expect.any(Array),\n      });\n    });\n\n    it(\"passes the id to getUserProfile\", async () => {\n      const [req, ctx] = makeRequest(\"user@test.com\");\n      await GET(req, ctx);\n\n      expect(mockGetUserProfile).toHaveBeenCalledWith(\"user@test.com\");\n    });\n  });\n\n  describe(\"not found — 404\", () => {\n    it(\"returns 404 with error when user not found\", async () => {\n      mockGetUserProfile.mockResolvedValue(null);\n\n      const [req, ctx] = makeRequest(\"nonexistent@test.com\");\n      const res = await GET(req, ctx);\n\n      expect(res.status).toBe(404);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n      expect(typeof body.error).toBe(\"string\");\n    });\n  });\n\n  describe(\"error handling — 500\", () => {\n    it(\"returns 500 when getUserProfile throws\", async () => {\n      mockGetUserProfile.mockRejectedValue(\n        new Error(\"ClickHouse connection failed\"),\n      );\n\n      const [req, ctx] = makeRequest(\"user@test.com\");\n      const res = await GET(req, ctx);\n\n      expect(res.status).toBe(500);\n      const body = await res.json();\n      expect(body).toHaveProperty(\"error\");\n    });\n  });\n});\n","numLines":104,"startLine":1,"totalLines":104}}}
