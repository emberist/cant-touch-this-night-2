n118\t    mockQueryReturns([]);\n119\t\n120\t    const result = await searchUsers({});\n121\t\n122\t    expect(result.users).toEqual([]);\n123\t    expect(result.next_cursor).toBeNull();\n124\t  });\n125\t});\n126\t\n127\t// ─── getUserProfile ────────────────────────────────────────────────────────────\n128\t\n129\tdescribe(\"getUserProfile\", () => {\n130\t  it(\"returns profile with resolved_id, first_seen, last_seen, identity_cluster, events\", async () => {\n131\t    mockQuery\n132\t      .mockResolvedValueOnce({\n133\t        json: vi.fn().mockResolvedValue([\n134\t          {\n135\t            event_count: 5,\n136\t            first_seen: \"2026-04-01T00:00:00.000Z\",\n137\t            last_seen: \"2026-04-15T00:00:00.000Z\",\n138\t          },\n139\t        ]),\n140\t      })\n141\t      .mockResolvedValueOnce({\n142\t        json: vi\n143\t          .fn()\n144\t          .mockResolvedValue([\n145\t            { user_id: \"user@test.com\", device_id: \"dev-1\" },\n146\t          ]),\n147\t      })\n148\t      .mockResolvedValueOnce({\n149\t        json: vi.fn().mockResolvedValue([sampleEvent]),\n150\t      });\n151\t\n152\t    const result = await getUserProfile(\"user@test.com\");\n153\t\n154\t    expect(result).not.toBeNull();\n155\t    expect(result?.resolved_id).toBe(\"user@test.com\");\n156\t    expect(result?.first_seen).toBe(\"2026-04-01T00:00:00.000Z\");\n157\t    expect(result?.last_seen).toBe(\"2026-04-15T00:00:00.000Z\");\n158\t    expect(result?.identity_cluster).toBeDefined();\n159\t    expect(result?.events).toEqual([sampleEvent]);\n160\t  });\n161\t\n162\t  it(\"identity_cluster includes all associated user_ids and device_ids\", async () => {\n163\t    mockQuery\n164\t      .mockResolvedValueOnce({\n165\t        json: vi.fn().mockResolvedValue([\n166\t          {\n167\t            event_count: 3,\n168\t            first_seen: \"2026-04-01T00:00:00.000Z\",\n169\t            last_seen: \"2026-04-15T00:00:00.000Z\",\n170\t          },\n171\t     