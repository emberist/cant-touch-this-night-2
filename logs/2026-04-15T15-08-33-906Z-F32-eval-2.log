{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018XK4iPWZrv5pozSJfPS87r","type":"tool_result","content":"1\timport { existsSync, readFileSync } from \"node:fs\";\n2\timport path from \"node:path\";\n3\timport { defaultExclude, defineConfig } from \"vitest/config\";\n4\t\n5\t/**\n6\t * Parse a .env file and return key/value pairs.\n7\t * Skips blank lines and comments. Keys already present in process.env are\n8\t * excluded so that explicit environment variables always take precedence.\n9\t */\n10\tfunction loadEnvFile(filePath: string): Record<string, string> {\n11\t  if (!existsSync(filePath)) return {};\n12\t  const result: Record<string, string> = {};\n13\t  for (const line of readFileSync(filePath, \"utf8\").split(\"\\n\")) {\n14\t    const trimmed = line.trim();\n15\t    if (!trimmed || trimmed.startsWith(\"#\")) continue;\n16\t    const eq = trimmed.indexOf(\"=\");\n17\t    if (eq === -1) continue;\n18\t    const key = trimmed.slice(0, eq).trim();\n19\t    if (key in process.env) continue; // explicit env wins\n20\t    result[key] = trimmed.slice(eq + 1);\n21\t  }\n22\t  return result;\n23\t}\n24\t\n25\texport default defineConfig({\n26\t  test: {\n27\t    environment: \"node\",\n28\t    exclude: [...defaultExclude, \"playwright_tests/**/*.spec.ts\"],\n29\t    env: loadEnvFile(path.resolve(\".env.local\")),\n30\t    // Integration tests share the minipanel_test ClickHouse database; running\n31\t    // files in parallel causes afterEach truncates in one file to destroy data\n32\t    // mid-test in another file. Sequential execution avoids this interference.\n33\t    fileParallelism: false,\n34\t  },\n35\t  resolve: {\n36\t    alias: { \"@\": path.resolve(__dirname, \"src\") },\n37\t  },\n38\t});\n39\t"}]},"parent_tool_use_id":null,"session_id":"3ff4dcef-c30a-45f6-b856-25d94c9a4a9b","uuid":"5d5804ee-0a12-42ab-b020-45e8b6767887","timestamp":"2026-04-15T19:35:31.075Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/vitest.config.ts","content":"import { existsSync, readFileSync } from \"node:fs\";\nimport path from \"node:path\";\nimport { defaultExclude, defineConfig } from \"vitest/config\";\n\n/**\n * Parse a .env file and return key/value pairs.\n * Skips blank lines and comments. Keys already present in process.env are\n * excluded so that explicit environment variables always take precedence.\n */\nfunction loadEnvFile(filePath: string): Record<string, string> {\n  if (!existsSync(filePath)) return {};\n  const result: Record<string, string> = {};\n  for (const line of readFileSync(filePath, \"utf8\").split(\"\\n\")) {\n    const trimmed = line.trim();\n    if (!trimmed || trimmed.startsWith(\"#\")) continue;\n    const eq = trimmed.indexOf(\"=\");\n    if (eq === -1) continue;\n    const key = trimmed.slice(0, eq).trim();\n    if (key in process.env) continue; // explicit env wins\n    result[key] = trimmed.slice(eq + 1);\n  }\n  return result;\n}\n\nexport default defineConfig({\n  test: {\n    environment: \"node\",\n    exclude: [...defaultExclude, \"playwright_tests/**/*.spec.ts\"],\n    env: loadEnvFile(path.resolve(\".env.local\")),\n    // Integration tests share the minipanel_test ClickHouse database; running\n    // files in parallel causes afterEach truncates in one file to destroy data\n    // mid-test in another file. Sequential execution avoids this interference.\n    fileParallelism: false,\n  },\n  resolve: {\n    alias: { \"@\": path.resolve(__dirname, \"src\") },\n  },\n});\n","numLines":39,"startLine":1,"totalLines":39}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jn9bcxYBY1WBjDLNKBmyo1","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\t\n3\t// ─── Helpers ─────────────────────────────────────────────────────────────────\n4\t\n5\t/**\n6\t * Converts an ISO 8601 UTC timestamp to the ClickHouse DateTime64 format.\n7\t * ClickHouse JSONEachRow rejects the \"T\" separator and \"Z\" suffix; it requires\n8\t * \"YYYY-MM-DD HH:MM:SS.mmm\" with a space separator and no timezone suffix.\n9\t */\n10\tfunction toClickHouseTs(iso: string): string {\n11\t  return iso.replace(\"T\", \" \").replace(/Z$/, \"\");\n12\t}\n13\t\n14\t// ─── Types ────────────────────────────────────────────────────────────────────\n15\t\n16\texport interface EventInput {\n17\t  event_name: string;\n18\t  device_id?: string;\n19\t  user_id?: string;\n20\t  timestamp?: string;\n21\t  properties?: Record<string, unknown>;\n22\t}\n23\t\n24\texport interface EventRow {\n25\t  event_id: string;\n26\t  event_name: string;\n27\t  timestamp: string;\n28\t  device_id: string | null;\n29\t  user_id: string | null;\n30\t  properties: string;\n31\t  ingested_at: string;\n32\t  resolved_id: string;\n33\t}\n34\t\n35\texport interface QueryEventsOptions {\n36\t  event_name?: string;\n37\t  resolved_id?: string;\n38\t  /** ISO timestamp cursor — return events strictly before this time */\n39\t  before?: string;\n40\t  limit?: number;\n41\t}\n42\t\n43\t// ─── Error ────────────────────────────────────────────────────────────────────\n44\t\n45\texport class IdentityConflictError extends Error {\n46\t  readonly status = 409 as const;\n47\t\n48\t  constructor(\n49\t    device_id: string,\n50\t    existing_user_id: string,\n51\t    new_user_id: string,\n52\t  ) {\n53\t    super(\n54\t      `Device \"${device_id}\" is already mapped to user \"${existing_user_id}\". Cannot remap to \"${new_user_id}\".`,\n55\t    );\n56\t    this.name = \"IdentityConflictError\";\n57\t    // Maintain correct prototype chain in transpiled environments\n58\t    Object.setPrototypeOf(this, new.target.prototype);\n59\t  }\n60\t}\n61\t\n62\t// ─── Type alias for the ClickHouse client ─────────────────────────────────────\n63\t\n64\ttype ClickHouseClientLike = typeof clickhouse;\n65\t\n66\t// ─── validateEvent ────────────────────────────────────────────────────────────\n67\t\n68\t/**\n69\t * Validates a raw event input object. Throws an Error if invalid.\n70\t * After this call returns, callers may safely treat the input as EventInput.\n71\t */\n72\texport function validateEvent(input: unknown): asserts input is EventInput {\n73\t  if (typeof input !== \"object\" || input === null) {\n74\t    throw new Error(\"Event must be a non-null object.\");\n75\t  }\n76\t  const evt = input as Record<string, unknown>;\n77\t\n78\t  if (typeof evt.event_name !== \"string\" || evt.event_name.trim() === \"\") {\n79\t    throw new Error(\"event_name is required and must be a non-empty string.\");\n80\t  }\n81\t\n82\t  if (!evt.device_id && !evt.user_id) {\n83\t    throw new Error(\"At least one of device_id or user_id must be present.\");\n84\t  }\n85\t}\n86\t\n87\t// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n88\t\n89\t/**\n90\t * Checks identity_mappings FINAL for an existing device → user mapping and:\n91\t * - Inserts a new mapping if none exists.\n92\t * - No-ops if the same mapping already exists (idempotent).\n93\t * - Throws IdentityConflictError (status 409) if the device is mapped to a\n94\t *   different user.\n95\t */\n96\texport async function resolveIdentityMapping(\n97\t  device_id: string,\n98\t  user_id: string,\n99\t  client: ClickHouseClientLike = clickhouse,\n100\t): Promise<void> {\n101\t  const result = await client.query({\n102\t    query:\n103\t      \"SELECT user_id FROM identity_mappings FINAL WHERE device_id = {device_id:String} LIMIT 1\",\n104\t    query_params: { device_id },\n105\t    format: \"JSONEachRow\",\n106\t  });\n107\t\n108\t  const rows = await result.json<{ user_id: string }>();\n109\t\n110\t  if (rows.length === 0) {\n111\t    // No existing mapping — insert\n112\t    await client.insert({\n113\t      table: \"identity_mappings\",\n114\t      values: [{ device_id, user_id }],\n115\t      format: \"JSONEachRow\",\n116\t    });\n117\t    return;\n118\t  }\n119\t\n120\t  const existingUserId = rows[0].user_id;\n121\t\n122\t  if (existingUserId === user_id) {\n123\t    // Same mapping — no-op (idempotent)\n124\t    return;\n125\t  }\n126\t\n127\t  // Different user — conflict\n128\t  throw new IdentityConflictError(device_id, existingUserId, user_id);\n129\t}\n130\t\n131\t// ─── insertEvent ──────────────────────────────────────────────────────────────\n132\t\n133\t/**\n134\t * Validates, timestamps, and inserts a single event. If both device_id and\n135\t * user_id are provided, also writes (or verifies) the identity mapping.\n136\t *\n137\t * Throws IdentityConflictError (status 409) if the device_id is already\n138\t * associated with a different user_id.\n139\t */\n140\texport async function insertEvent(\n141\t  input: unknown,\n142\t  client: ClickHouseClientLike = clickhouse,\n143\t): Promise<EventRow> {\n144\t  validateEvent(input);\n145\t\n146\t  const timestamp = input.timestamp ?? new Date().toISOString();\n147\t  const properties = input.properties ? JSON.stringify(input.properties) : \"{}\";\n148\t  const event_id = crypto.randomUUID();\n149\t  const ingested_at = new Date().toISOString();\n150\t\n151\t  await client.insert({\n152\t    table: \"events\",\n153\t    values: [\n154\t      {\n155\t        event_id,\n156\t        event_name: input.event_name,\n157\t        timestamp: toClickHouseTs(timestamp),\n158\t        device_id: input.device_id ?? null,\n159\t        user_id: input.user_id ?? null,\n160\t        properties,\n161\t      },\n162\t    ],\n163\t    format: \"JSONEachRow\",\n164\t  });\n165\t\n166\t  if (input.device_id && input.user_id) {\n167\t    await resolveIdentityMapping(input.device_id, input.user_id, client);\n168\t  }\n169\t\n170\t  const resolved_id = input.user_id ?? input.device_id ?? \"\";\n171\t\n172\t  return {\n173\t    event_id,\n174\t    event_name: input.event_name,\n175\t    timestamp,\n176\t    device_id: input.device_id ?? null,\n177\t    user_id: input.user_id ?? null,\n178\t    properties,\n179\t    ingested_at,\n180\t    resolved_id,\n181\t  };\n182\t}\n183\t\n184\t// ─── queryEventsWithResolvedId ────────────────────────────────────────────────\n185\t\n186\t/**\n187\t * Returns events joined with identity_mappings FINAL, with resolved_id\n188\t * computed as coalesce(e.user_id, m.user_id, e.device_id).\n189\t *\n190\t * Optional filters: event_name, resolved_id, before (cursor), limit (max 200).\n191\t */\n192\texport async function queryEventsWithResolvedId(\n193\t  options: QueryEventsOptions = {},\n194\t  client: ClickHouseClientLike = clickhouse,\n195\t): Promise<EventRow[]> {\n196\t  const { event_name, resolved_id, before, limit = 50 } = options;\n197\t\n198\t  const conditions: string[] = [];\n199\t  const params: Record<string, string | number> = {\n200\t    limit: Math.min(limit, 200),\n201\t  };\n202\t\n203\t  if (event_name) {\n204\t    conditions.push(\"e.event_name = {event_name:String}\");\n205\t    params.event_name = event_name;\n206\t  }\n207\t\n208\t  if (before) {\n209\t    conditions.push(\"e.timestamp < {before:String}\");\n210\t    params.before = before;\n211\t  }\n212\t\n213\t  if (resolved_id) {\n214\t    conditions.push(\n215\t      \"coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\",\n216\t    );\n217\t    params.resolved_id = resolved_id;\n218\t  }\n219\t\n220\t  const where =\n221\t    conditions.length > 0 ? `WHERE ${conditions.join(\" AND \")}` : \"\";\n222\t\n223\t  const result = await client.query({\n224\t    query: `\n225\t      SELECT\n226\t        e.event_id,\n227\t        e.event_name,\n228\t        e.timestamp,\n229\t        e.device_id,\n230\t        e.user_id,\n231\t        e.properties,\n232\t        e.ingested_at,\n233\t        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id\n234\t      FROM events e\n235\t      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n236\t        ON e.device_id = m.device_id\n237\t      ${where}\n238\t      ORDER BY e.timestamp DESC, e.event_id DESC\n239\t      LIMIT {limit:UInt64}\n240\t    `,\n241\t    query_params: params,\n242\t    format: \"JSONEachRow\",\n243\t  });\n244\t\n245\t  return result.json<EventRow>();\n246\t}\n247\t\n248\t// ─── getEventsByResolvedId ────────────────────────────────────────────────────\n249\t\n250\t/**\n251\t * Convenience wrapper: returns all events (up to 200) attributed to a given\n252\t * resolved identity (user_id or device_id).\n253\t */\n254\texport async function getEventsByResolvedId(\n255\t  resolved_id: string,\n256\t  client: ClickHouseClientLike = clickhouse,\n257\t): Promise<EventRow[]> {\n258\t  return queryEventsWithResolvedId({ resolved_id, limit: 200 }, client);\n259\t}\n260\t"}]},"parent_tool_use_id":null,"session_id":"3ff4dcef-c30a-45f6-b856-25d94c9a4a9b","uuid":"f68c18ac-84cd-43e9-b90a-034ff921a426","timestamp":"2026-04-15T19:35:31.076Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/identity.ts","content":"import { clickhouse } from \"@/lib/clickhouse\";\n\n// ─── Helpers ─────────────────────────────────────────────────────────────────\n\n/**\n * Converts an ISO 8601 UTC timestamp to the ClickHouse DateTime64 format.\n * ClickHouse JSONEachRow rejects the \"T\" separator and \"Z\" suffix; it requires\n * \"YYYY-MM-DD HH:MM:SS.mmm\" with a space separator and no timezone suffix.\n */\nfunction toClickHouseTs(iso: string): string {\n  return iso.replace(\"T\", \" \").replace(/Z$/, \"\");\n}\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface EventInput {\n  event_name: string;\n  device_id?: string;\n  user_id?: string;\n  timestamp?: string;\n  properties?: Record<string, unknown>;\n}\n\nexport interface EventRow {\n  event_id: string;\n  event_name: string;\n  timestamp: string;\n  device_id: string | null;\n  user_id: string | null;\n  properties: string;\n  ingested_at: string;\n  resolved_id: string;\n}\n\nexport interface QueryEventsOptions {\n  event_name?: string;\n  resolved_id?: string;\n  /** ISO timestamp cursor — return events strictly before this time */\n  before?: string;\n  limit?: number;\n}\n\n// ─── Error ────────────────────────────────────────────────────────────────────\n\nexport class IdentityConflictError extends Error {\n  readonly status = 409 as const;\n\n  constructor(\n    device_id: string,\n    existing_user_id: string,\n    new_user_id: string,\n  ) {\n    super(\n      `Device \"${device_id}\" is already mapped to user \"${existing_user_id}\". Cannot remap to \"${new_user_id}\".`,\n    );\n    this.name = \"IdentityConflictError\";\n    // Maintain correct prototype chain in transpiled environments\n    Object.setPrototypeOf(this, new.target.prototype);\n  }\n}\n\n// ─── Type alias for the ClickHouse client ─────────────────────────────────────\n\ntype ClickHouseClientLike = typeof clickhouse;\n\n// ─── validateEvent ────────────────────────────────────────────────────────────\n\n/**\n * Validates a raw event input object. Throws an Error if invalid.\n * After this call returns, callers may safely treat the input as EventInput.\n */\nexport function validateEvent(input: unknown): asserts input is EventInput {\n  if (typeof input !== \"object\" || input === null) {\n    throw new Error(\"Event must be a non-null object.\");\n  }\n  const evt = input as Record<string, unknown>;\n\n  if (typeof evt.event_name !== \"string\" || evt.event_name.trim() === \"\") {\n    throw new Error(\"event_name is required and must be a non-empty string.\");\n  }\n\n  if (!evt.device_id && !evt.user_id) {\n    throw new Error(\"At least one of device_id or user_id must be present.\");\n  }\n}\n\n// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n\n/**\n * Checks identity_mappings FINAL for an existing device → user mapping and:\n * - Inserts a new mapping if none exists.\n * - No-ops if the same mapping already exists (idempotent).\n * - Throws IdentityConflictError (status 409) if the device is mapped to a\n *   different user.\n */\nexport async function resolveIdentityMapping(\n  device_id: string,\n  user_id: string,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<void> {\n  const result = await client.query({\n    query:\n      \"SELECT user_id FROM identity_mappings FINAL WHERE device_id = {device_id:String} LIMIT 1\",\n    query_params: { device_id },\n    format: \"JSONEachRow\",\n  });\n\n  const rows = await result.json<{ user_id: string }>();\n\n  if (rows.length === 0) {\n    // No existing mapping — insert\n    await client.insert({\n      table: \"identity_mappings\",\n      values: [{ device_id, user_id }],\n      format: \"JSONEachRow\",\n    });\n    return;\n  }\n\n  const existingUserId = rows[0].user_id;\n\n  if (existingUserId === user_id) {\n    // Same mapping — no-op (idempotent)\n    return;\n  }\n\n  // Different user — conflict\n  throw new IdentityConflictError(device_id, existingUserId, user_id);\n}\n\n// ─── insertEvent ──────────────────────────────────────────────────────────────\n\n/**\n * Validates, timestamps, and inserts a single event. If both device_id and\n * user_id are provided, also writes (or verifies) the identity mapping.\n *\n * Throws IdentityConflictError (status 409) if the device_id is already\n * associated with a different user_id.\n */\nexport async function insertEvent(\n  input: unknown,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<EventRow> {\n  validateEvent(input);\n\n  const timestamp = input.timestamp ?? new Date().toISOString();\n  const properties = input.properties ? JSON.stringify(input.properties) : \"{}\";\n  const event_id = crypto.randomUUID();\n  const ingested_at = new Date().toISOString();\n\n  await client.insert({\n    table: \"events\",\n    values: [\n      {\n        event_id,\n        event_name: input.event_name,\n        timestamp: toClickHouseTs(timestamp),\n        device_id: input.device_id ?? null,\n        user_id: input.user_id ?? null,\n        properties,\n      },\n    ],\n    format: \"JSONEachRow\",\n  });\n\n  if (input.device_id && input.user_id) {\n    await resolveIdentityMapping(input.device_id, input.user_id, client);\n  }\n\n  const resolved_id = input.user_id ?? input.device_id ?? \"\";\n\n  return {\n    event_id,\n    event_name: input.event_name,\n    timestamp,\n    device_id: input.device_id ?? null,\n    user_id: input.user_id ?? null,\n    properties,\n    ingested_at,\n    resolved_id,\n  };\n}\n\n// ─── queryEventsWithResolvedId ────────────────────────────────────────────────\n\n/**\n * Returns events joined with identity_mappings FINAL, with resolved_id\n * computed as coalesce(e.user_id, m.user_id, e.device_id).\n *\n * Optional filters: event_name, resolved_id, before (cursor), limit (max 200).\n */\nexport async function queryEventsWithResolvedId(\n  options: QueryEventsOptions = {},\n  client: ClickHouseClientLike = clickhouse,\n): Promise<EventRow[]> {\n  const { event_name, resolved_id, before, limit = 50 } = options;\n\n  const conditions: string[] = [];\n  const params: Record<string, string | number> = {\n    limit: Math.min(limit, 200),\n  };\n\n  if (event_name) {\n    conditions.push(\"e.event_name = {event_name:String}\");\n    params.event_name = event_name;\n  }\n\n  if (before) {\n    conditions.push(\"e.timestamp < {before:String}\");\n    params.before = before;\n  }\n\n  if (resolved_id) {\n    conditions.push(\n      \"coalesce(e.user_id, m.user_id, e.device_id) = {resolved_id:String}\",\n    );\n    params.resolved_id = resolved_id;\n  }\n\n  const where =\n    conditions.length > 0 ? `WHERE ${conditions.join(\" AND \")}` : \"\";\n\n  const result = await client.query({\n    query: `\n      SELECT\n        e.event_id,\n        e.event_name,\n        e.timestamp,\n        e.device_id,\n        e.user_id,\n        e.properties,\n        e.ingested_at,\n        coalesce(e.user_id, m.user_id, e.device_id) AS resolved_id\n      FROM events e\n      LEFT JOIN (SELECT device_id, user_id FROM identity_mappings FINAL) m\n        ON e.device_id = m.device_id\n      ${where}\n      ORDER BY e.timestamp DESC, e.event_id DESC\n      LIMIT {limit:UInt64}\n    `,\n    query_params: params,\n    format: \"JSONEachRow\",\n  });\n\n  return result.json<EventRow>();\n}\n\n// ─── getEventsByResolvedId ────────────────────────────────────────────────────\n\n/**\n * Convenience wrapper: returns all events (up to 200) attributed to a given\n * resolved identity (user_id or device_id).\n */\nexport async function getEventsByResolvedId(\n  resolved_id: string,\n  client: ClickHouseClientLike = clickhouse,\n): Promise<EventRow[]> {\n  return queryEventsWithResolvedId({ resolved_id, limit: 200 }, client);\n}\n","numLines":260,"startLine":1,"totalLines":260}}}
