{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017toB6mJ6ta3LsKzJyM7LYB","type":"tool_result","content":"1\t/**\n2\t * Integration tests for identity resolution (BR-101).\n3\t * Requires a running ClickHouse server at localhost:8123 (or CLICKHOUSE_URL).\n4\t * Uses a dedicated `minipanel_test` database — never touches `minipanel`.\n5\t *\n6\t * Run with: pnpm test (requires ./clickhouse server -- --path=.clickhouse)\n7\t */\n8\t\n9\timport { createClient } from \"@clickhouse/client\";\n10\timport { afterAll, afterEach, beforeAll, describe, expect, it } from \"vitest\";\n11\timport {\n12\t  getEventsByResolvedId,\n13\t  IdentityConflictError,\n14\t  insertEvent,\n15\t  queryEventsWithResolvedId,\n16\t} from \"@/lib/identity\";\n17\t\n18\tconst CLICKHOUSE_URL = process.env.CLICKHOUSE_URL ?? \"http://localhost:8123\";\n19\tconst TEST_DB = \"minipanel_test\";\n20\t\n21\tasync function isClickHouseReachable(): Promise<boolean> {\n22\t  try {\n23\t    const res = await fetch(`${CLICKHOUSE_URL}/ping`, {\n24\t      signal: AbortSignal.timeout(2000),\n25\t    });\n26\t    return res.ok;\n27\t  } catch {\n28\t    return false;\n29\t  }\n30\t}\n31\t\n32\t// Test-scoped client — always uses minipanel_test\n33\tconst testClient = createClient({\n34\t  url: CLICKHOUSE_URL,\n35\t  database: TEST_DB,\n36\t  password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n37\t});\n38\t\n39\tdescribe.skipIf(!(await isClickHouseReachable()))(\n40\t  \"identity integration — real ClickHouse (minipanel_test)\",\n41\t  () => {\n42\t    beforeAll(async () => {\n43\t      // Create test database and tables (idempotent)\n44\t      const adminClient = createClient({\n45\t        url: CLICKHOUSE_URL,\n46\t        password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n47\t      });\n48\t\n49\t      await adminClient.command({\n50\t        query: `CREATE DATABASE IF NOT EXISTS ${TEST_DB}`,\n51\t      });\n52\t\n53\t      await adminClient.command({\n54\t        query: `\n55\t          CREATE TABLE IF NOT EXISTS ${TEST_DB}.events\n56\t          (\n57\t            event_id    UUID                     DEFAULT generateUUIDv4(),\n58\t            event_name  LowCardinality(String),\n59\t            timestamp   DateTime64(3, 'UTC'),\n60\t            device_id   Nullable(String),\n61\t            user_id     Nullable(String),\n62\t            properties  String,\n63\t            ingested_at DateTime64(3, 'UTC')     DEFAULT now64()\n64\t          )\n65\t          ENGINE = MergeTree()\n66\t          ORDER BY (timestamp, event_id)\n67\t          PARTITION BY toYYYYMM(timestamp)\n68\t        `,\n69\t      });\n70\t\n71\t      await adminClient.command({\n72\t        query: `\n73\t          CREATE TABLE IF NOT EXISTS ${TEST_DB}.identity_mappings\n74\t          (\n75\t            device_id  String,\n76\t            user_id    String,\n77\t            created_at DateTime64(3, 'UTC') DEFAULT now64()\n78\t          )\n79\t          ENGINE = ReplacingMergeTree(created_at)\n80\t          ORDER BY (device_id)\n81\t        `,\n82\t      });\n83\t\n84\t      await adminClient.close();\n85\t    });\n86\t\n87\t    afterAll(async () => {\n88\t      await testClient.close();\n89\t    });\n90\t\n91\t    afterEach(async () => {\n92\t      // Truncate after every test to keep isolation\n93\t      await testClient.command({ query: \"TRUNCATE TABLE events\" });\n94\t      await testClient.command({ query: \"TRUNCATE TABLE identity_mappings\" });\n95\t    });\n96\t\n97\t    // ── BR-101 Scenario 1 ─────────────────────────────────────────────────────\n98\t    it(\"BR-101 S1: anonymous event followed by identify event → all events attributed to user (retroactive merge)\", async () => {\n99\t      // Anonymous event (device only)\n100\t      await insertEvent(\n101\t        { event_name: \"Page Viewed\", device_id: \"dev-s1\" },\n102\t        testClient,\n103\t      );\n104\t\n105\t      // Identify event (links device to user)\n106\t      await insertEvent(\n107\t        {\n108\t          event_name: \"Signup Completed\",\n109\t          device_id: \"dev-s1\",\n110\t          user_id: \"user-s1@test.com\",\n111\t        },\n112\t        testClient,\n113\t      );\n114\t\n115\t      // Query by user's resolved_id — should return BOTH events\n116\t      const events = await queryEventsWithResolvedId(\n117\t        { resolved_id: \"user-s1@test.com\", limit: 50 },\n118\t        testClient,\n119\t      );\n120\t\n121\t      expect(events.length).toBe(2);\n122\t      expect(events.every((e) => e.resolved_id === \"user-s1@test.com\")).toBe(\n123\t        true,\n124\t      );\n125\t    });\n126\t\n127\t    // ── BR-101 Scenario 2 ─────────────────────────────────────────────────────\n128\t    it(\"BR-101 S2: two devices linked to same user → events from both devices returned\", async () => {\n129\t      await insertEvent(\n130\t        {\n131\t          event_name: \"Page Viewed\",\n132\t          device_id: \"dev-s2a\",\n133\t          user_id: \"user-s2@test.com\",\n134\t        },\n135\t        testClient,\n136\t      );\n137\t\n138\t      await insertEvent(\n139\t        {\n140\t          event_name: \"Button Clicked\",\n141\t          device_id: \"dev-s2b\",\n142\t          user_id: \"user-s2@test.com\",\n143\t        },\n144\t        testClient,\n145\t      );\n146\t\n147\t      const events = await getEventsByResolvedId(\n148\t        \"user-s2@test.com\",\n149\t        testClient,\n150\t      );\n151\t\n152\t      expect(events.length).toBe(2);\n153\t      const deviceIds = events.map((e) => e.device_id);\n154\t      expect(deviceIds).toContain(\"dev-s2a\");\n155\t      expect(deviceIds).toContain(\"dev-s2b\");\n156\t    });\n157\t\n158\t    // ── BR-101 Scenario 3 ─────────────────────────────────────────────────────\n159\t    it(\"BR-101 S3: device mapped to two different users → second mapping throws IdentityConflictError (409)\", async () => {\n160\t      // First mapping\n161\t      await insertEvent(\n162\t        {\n163\t          event_name: \"Signup Completed\",\n164\t          device_id: \"dev-s3\",\n165\t          user_id: \"user-s3a@test.com\",\n166\t        },\n167\t        testClient,\n168\t      );\n169\t\n170\t      // Second mapping to a different user — must reject\n171\t      await expect(\n172\t        insertEvent(\n173\t          {\n174\t            event_name: \"Purchase Completed\",\n175\t            device_id: \"dev-s3\",\n176\t            user_id: \"user-s3b@test.com\",\n177\t          },\n178\t          testClient,\n179\t        ),\n180\t      ).rejects.toThrow(IdentityConflictError);\n181\t    });\n182\t\n183\t    it(\"BR-101 S3: IdentityConflictError has status 409\", async () => {\n184\t      await insertEvent(\n185\t        {\n186\t          event_name: \"Signup Completed\",\n187\t          device_id: \"dev-s3x\",\n188\t          user_id: \"user-s3x-a@test.com\",\n189\t        },\n190\t        testClient,\n191\t      );\n192\t\n193\t      try {\n194\t        await insertEvent(\n195\t          {\n196\t            event_name: \"Page Viewed\",\n197\t            device_id: \"dev-s3x\",\n198\t            user_id: \"user-s3x-b@test.com\",\n199\t          },\n200\t          testClient,\n201\t        );\n202\t        expect.fail(\"should have thrown\");\n203\t      } catch (err) {\n204\t        expect(err).toBeInstanceOf(IdentityConflictError);\n205\t        expect((err as IdentityConflictError).status).toBe(409);\n206\t      }\n207\t    });\n208\t\n209\t    // ── BR-101 Scenario 4 ─────────────────────────────────────────────────────\n210\t    it(\"BR-101 S4: same device + same user sent twice → second call succeeds (idempotent)\", async () => {\n211\t      await insertEvent(\n212\t        {\n213\t          event_name: \"Signup Completed\",\n214\t          device_id: \"dev-s4\",\n215\t          user_id: \"user-s4@test.com\",\n216\t        },\n217\t        testClient,\n218\t      );\n219\t\n220\t      // Identical mapping — must not throw\n221\t      await expect(\n222\t        insertEvent(\n223\t          {\n224\t            event_name: \"Page Viewed\",\n225\t            device_id: \"dev-s4\",\n226\t            user_id: \"user-s4@test.com\",\n227\t          },\n228\t          testClient,\n229\t        ),\n230\t      ).resolves.not.toThrow();\n231\t\n232\t      // Both events inserted\n233\t      const events = await getEventsByResolvedId(\n234\t        \"user-s4@test.com\",\n235\t        testClient,\n236\t      );\n237\t      expect(events.length).toBe(2);\n238\t    });\n239\t  },\n240\t);\n241\t"}]},"parent_tool_use_id":null,"session_id":"3ff4dcef-c30a-45f6-b856-25d94c9a4a9b","uuid":"23a218f6-1c4c-4aad-b1bf-46e44e5f5cf3","timestamp":"2026-04-15T19:35:23.236Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/identity.integration.test.ts","content":"/**\n * Integration tests for identity resolution (BR-101).\n * Requires a running ClickHouse server at localhost:8123 (or CLICKHOUSE_URL).\n * Uses a dedicated `minipanel_test` database — never touches `minipanel`.\n *\n * Run with: pnpm test (requires ./clickhouse server -- --path=.clickhouse)\n */\n\nimport { createClient } from \"@clickhouse/client\";\nimport { afterAll, afterEach, beforeAll, describe, expect, it } from \"vitest\";\nimport {\n  getEventsByResolvedId,\n  IdentityConflictError,\n  insertEvent,\n  queryEventsWithResolvedId,\n} from \"@/lib/identity\";\n\nconst CLICKHOUSE_URL = process.env.CLICKHOUSE_URL ?? \"http://localhost:8123\";\nconst TEST_DB = \"minipanel_test\";\n\nasync function isClickHouseReachable(): Promise<boolean> {\n  try {\n    const res = await fetch(`${CLICKHOUSE_URL}/ping`, {\n      signal: AbortSignal.timeout(2000),\n    });\n    return res.ok;\n  } catch {\n    return false;\n  }\n}\n\n// Test-scoped client — always uses minipanel_test\nconst testClient = createClient({\n  url: CLICKHOUSE_URL,\n  database: TEST_DB,\n  password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n});\n\ndescribe.skipIf(!(await isClickHouseReachable()))(\n  \"identity integration — real ClickHouse (minipanel_test)\",\n  () => {\n    beforeAll(async () => {\n      // Create test database and tables (idempotent)\n      const adminClient = createClient({\n        url: CLICKHOUSE_URL,\n        password: process.env.CLICKHOUSE_PASSWORD ?? \"password\",\n      });\n\n      await adminClient.command({\n        query: `CREATE DATABASE IF NOT EXISTS ${TEST_DB}`,\n      });\n\n      await adminClient.command({\n        query: `\n          CREATE TABLE IF NOT EXISTS ${TEST_DB}.events\n          (\n            event_id    UUID                     DEFAULT generateUUIDv4(),\n            event_name  LowCardinality(String),\n            timestamp   DateTime64(3, 'UTC'),\n            device_id   Nullable(String),\n            user_id     Nullable(String),\n            properties  String,\n            ingested_at DateTime64(3, 'UTC')     DEFAULT now64()\n          )\n          ENGINE = MergeTree()\n          ORDER BY (timestamp, event_id)\n          PARTITION BY toYYYYMM(timestamp)\n        `,\n      });\n\n      await adminClient.command({\n        query: `\n          CREATE TABLE IF NOT EXISTS ${TEST_DB}.identity_mappings\n          (\n            device_id  String,\n            user_id    String,\n            created_at DateTime64(3, 'UTC') DEFAULT now64()\n          )\n          ENGINE = ReplacingMergeTree(created_at)\n          ORDER BY (device_id)\n        `,\n      });\n\n      await adminClient.close();\n    });\n\n    afterAll(async () => {\n      await testClient.close();\n    });\n\n    afterEach(async () => {\n      // Truncate after every test to keep isolation\n      await testClient.command({ query: \"TRUNCATE TABLE events\" });\n      await testClient.command({ query: \"TRUNCATE TABLE identity_mappings\" });\n    });\n\n    // ── BR-101 Scenario 1 ─────────────────────────────────────────────────────\n    it(\"BR-101 S1: anonymous event followed by identify event → all events attributed to user (retroactive merge)\", async () => {\n      // Anonymous event (device only)\n      await insertEvent(\n        { event_name: \"Page Viewed\", device_id: \"dev-s1\" },\n        testClient,\n      );\n\n      // Identify event (links device to user)\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s1\",\n          user_id: \"user-s1@test.com\",\n        },\n        testClient,\n      );\n\n      // Query by user's resolved_id — should return BOTH events\n      const events = await queryEventsWithResolvedId(\n        { resolved_id: \"user-s1@test.com\", limit: 50 },\n        testClient,\n      );\n\n      expect(events.length).toBe(2);\n      expect(events.every((e) => e.resolved_id === \"user-s1@test.com\")).toBe(\n        true,\n      );\n    });\n\n    // ── BR-101 Scenario 2 ─────────────────────────────────────────────────────\n    it(\"BR-101 S2: two devices linked to same user → events from both devices returned\", async () => {\n      await insertEvent(\n        {\n          event_name: \"Page Viewed\",\n          device_id: \"dev-s2a\",\n          user_id: \"user-s2@test.com\",\n        },\n        testClient,\n      );\n\n      await insertEvent(\n        {\n          event_name: \"Button Clicked\",\n          device_id: \"dev-s2b\",\n          user_id: \"user-s2@test.com\",\n        },\n        testClient,\n      );\n\n      const events = await getEventsByResolvedId(\n        \"user-s2@test.com\",\n        testClient,\n      );\n\n      expect(events.length).toBe(2);\n      const deviceIds = events.map((e) => e.device_id);\n      expect(deviceIds).toContain(\"dev-s2a\");\n      expect(deviceIds).toContain(\"dev-s2b\");\n    });\n\n    // ── BR-101 Scenario 3 ─────────────────────────────────────────────────────\n    it(\"BR-101 S3: device mapped to two different users → second mapping throws IdentityConflictError (409)\", async () => {\n      // First mapping\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s3\",\n          user_id: \"user-s3a@test.com\",\n        },\n        testClient,\n      );\n\n      // Second mapping to a different user — must reject\n      await expect(\n        insertEvent(\n          {\n            event_name: \"Purchase Completed\",\n            device_id: \"dev-s3\",\n            user_id: \"user-s3b@test.com\",\n          },\n          testClient,\n        ),\n      ).rejects.toThrow(IdentityConflictError);\n    });\n\n    it(\"BR-101 S3: IdentityConflictError has status 409\", async () => {\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s3x\",\n          user_id: \"user-s3x-a@test.com\",\n        },\n        testClient,\n      );\n\n      try {\n        await insertEvent(\n          {\n            event_name: \"Page Viewed\",\n            device_id: \"dev-s3x\",\n            user_id: \"user-s3x-b@test.com\",\n          },\n          testClient,\n        );\n        expect.fail(\"should have thrown\");\n      } catch (err) {\n        expect(err).toBeInstanceOf(IdentityConflictError);\n        expect((err as IdentityConflictError).status).toBe(409);\n      }\n    });\n\n    // ── BR-101 Scenario 4 ─────────────────────────────────────────────────────\n    it(\"BR-101 S4: same device + same user sent twice → second call succeeds (idempotent)\", async () => {\n      await insertEvent(\n        {\n          event_name: \"Signup Completed\",\n          device_id: \"dev-s4\",\n          user_id: \"user-s4@test.com\",\n        },\n        testClient,\n      );\n\n      // Identical mapping — must not throw\n      await expect(\n        insertEvent(\n          {\n            event_name: \"Page Viewed\",\n            device_id: \"dev-s4\",\n            user_id: \"user-s4@test.com\",\n          },\n          testClient,\n        ),\n      ).resolves.not.toThrow();\n\n      // Both events inserted\n      const events = await getEventsByResolvedId(\n        \"user-s4@test.com\",\n        testClient,\n      );\n      expect(events.length).toBe(2);\n    });\n  },\n);\n","numLines":241,"startLine":1,"totalLines":241}}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_016ktjEBJFhSvEphDSwFwExK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01JKMKEzrm17v7ksSR5nwych","name":"Read","input":{"file_path":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/identity.test.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":23985,"cache_read_input_tokens":11914,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":23985},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3ff4dcef-c30a-45f6-b856-25d94c9a4a9b","uuid":"1afefd91-9f00-492f-8f9a-c5e0796f92d4"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JKMKEzrm17v7ksSR5nwych","type":"tool_result","content":"1\timport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n2\t\n3\t// Hoist mock refs so vi.mock factory can reference them\n4\tconst { mockQuery, mockInsert } = vi.hoisted(() => ({\n5\t  mockQuery: vi.fn(),\n6\t  mockInsert: vi.fn(),\n7\t}));\n8\t\n9\tvi.mock(\"@/lib/clickhouse\", () => ({\n10\t  clickhouse: {\n11\t    query: mockQuery,\n12\t    insert: mockInsert,\n13\t  },\n14\t}));\n15\t\n16\timport {\n17\t  IdentityConflictError,\n18\t  insertEvent,\n19\t  resolveIdentityMapping,\n20\t  validateEvent,\n21\t} from \"@/lib/identity\";\n22\t\n23\t// Helper: set up mockQuery to return a given rows array\n24\tfunction mockQueryReturns(rows: unknown[]) {\n25\t  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n26\t}\n27\t\n28\tbeforeEach(() => {\n29\t  // Default: no existing identity mapping, inserts succeed\n30\t  mockQueryReturns([]);\n31\t  mockInsert.mockResolvedValue(undefined);\n32\t});\n33\t\n34\tafterEach(() => {\n35\t  vi.clearAllMocks();\n36\t});\n37\t\n38\t// ─── validateEvent ────────────────────────────────────────────────────────────\n39\t\n40\tdescribe(\"validateEvent\", () => {\n41\t  it(\"rejects when both device_id and user_id are missing\", () => {\n42\t    expect(() => validateEvent({ event_name: \"Page Viewed\" })).toThrow();\n43\t  });\n44\t\n45\t  it(\"rejects when event_name is missing\", () => {\n46\t    expect(() => validateEvent({ device_id: \"dev-1\" })).toThrow();\n47\t  });\n48\t\n49\t  it(\"rejects when event_name is empty string\", () => {\n50\t    expect(() =>\n51\t      validateEvent({ event_name: \"\", device_id: \"dev-1\" }),\n52\t    ).toThrow();\n53\t  });\n54\t\n55\t  it(\"rejects when event_name is whitespace only\", () => {\n56\t    expect(() =>\n57\t      validateEvent({ event_name: \"  \", device_id: \"dev-1\" }),\n58\t    ).toThrow();\n59\t  });\n60\t\n61\t  it(\"accepts event with only device_id\", () => {\n62\t    expect(() =>\n63\t      validateEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n64\t    ).not.toThrow();\n65\t  });\n66\t\n67\t  it(\"accepts event with only user_id\", () => {\n68\t    expect(() =>\n69\t      validateEvent({ event_name: \"Page Viewed\", user_id: \"user@test.com\" }),\n70\t    ).not.toThrow();\n71\t  });\n72\t\n73\t  it(\"accepts event with both device_id and user_id\", () => {\n74\t    expect(() =>\n75\t      validateEvent({\n76\t        event_name: \"Signup Completed\",\n77\t        device_id: \"dev-1\",\n78\t        user_id: \"user@test.com\",\n79\t      }),\n80\t    ).not.toThrow();\n81\t  });\n82\t});\n83\t\n84\t// ─── insertEvent ──────────────────────────────────────────────────────────────\n85\t\n86\tdescribe(\"insertEvent\", () => {\n87\t  it(\"defaults timestamp to current time when not provided\", async () => {\n88\t    const before = Date.now();\n89\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n90\t    const after = Date.now();\n91\t\n92\t    const insertCall = mockInsert.mock.calls[0][0];\n93\t    // INSERT uses ClickHouse format (\"YYYY-MM-DD HH:MM:SS.mmm\"); re-add the T+Z\n94\t    // suffix to parse as UTC for comparison with Date.now() (always UTC).\n95\t    const chTs = insertCall.values[0].timestamp as string;\n96\t    const insertedTs = new Date(`${chTs.replace(\" \", \"T\")}Z`).getTime();\n97\t    expect(insertedTs).toBeGreaterThanOrEqual(before);\n98\t    expect(insertedTs).toBeLessThanOrEqual(after);\n99\t  });\n100\t\n101\t  it(\"preserves caller-provided timestamp\", async () => {\n102\t    const ts = \"2026-01-15T10:30:00.000Z\";\n103\t    await insertEvent({\n104\t      event_name: \"Page Viewed\",\n105\t      device_id: \"dev-1\",\n106\t      timestamp: ts,\n107\t    });\n108\t\n109\t    const insertCall = mockInsert.mock.calls[0][0];\n110\t    // insertEvent converts to ClickHouse format before inserting\n111\t    expect(insertCall.values[0].timestamp).toBe(\"2026-01-15 10:30:00.000\");\n112\t  });\n113\t\n114\t  it(\"inserts event into the events table\", async () => {\n115\t    await insertEvent({\n116\t      event_name: \"Purchase Completed\",\n117\t      user_id: \"user@test.com\",\n118\t      properties: { amount: 49.99 },\n119\t    });\n120\t\n121\t    expect(mockInsert).toHaveBeenCalledWith(\n122\t      expect.objectContaining({ table: \"events\" }),\n123\t    );\n124\t  });\n125\t\n126\t  it(\"stores event_name correctly in the inserted row\", async () => {\n127\t    await insertEvent({ event_name: \"Button Clicked\", device_id: \"dev-2\" });\n128\t\n129\t    const insertCall = mockInsert.mock.calls[0][0];\n130\t    expect(insertCall.values[0].event_name).toBe(\"Button Clicked\");\n131\t  });\n132\t\n133\t  it(\"serialises properties as a JSON string\", async () => {\n134\t    await insertEvent({\n135\t      event_name: \"Page Viewed\",\n136\t      device_id: \"dev-1\",\n137\t      properties: { page: \"/home\", count: 3 },\n138\t    });\n139\t\n140\t    const insertCall = mockInsert.mock.calls[0][0];\n141\t    expect(insertCall.values[0].properties).toBe(\n142\t      JSON.stringify({ page: \"/home\", count: 3 }),\n143\t    );\n144\t  });\n145\t\n146\t  it(\"defaults properties to '{}' when not provided\", async () => {\n147\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n148\t\n149\t    const insertCall = mockInsert.mock.calls[0][0];\n150\t    expect(insertCall.values[0].properties).toBe(\"{}\");\n151\t  });\n152\t\n153\t  it(\"calls resolveIdentityMapping (queries mappings) when both device_id and user_id are present\", async () => {\n154\t    await insertEvent({\n155\t      event_name: \"Signup Completed\",\n156\t      device_id: \"dev-1\",\n157\t      user_id: \"user@test.com\",\n158\t    });\n159\t\n160\t    // resolveIdentityMapping does a SELECT on identity_mappings\n161\t    expect(mockQuery).toHaveBeenCalled();\n162\t  });\n163\t\n164\t  it(\"does NOT call resolveIdentityMapping when only device_id is present\", async () => {\n165\t    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n166\t\n167\t    expect(mockQuery).not.toHaveBeenCalled();\n168\t  });\n169\t\n170\t  it(\"does NOT call resolveIdentityMapping when only user_id is present\", async () => {\n171\t    await insertEvent({\n172\t      event_name: \"Purchase Completed\",\n173\t      user_id: \"user@test.com\",\n174\t    });\n175\t\n176\t    expect(mockQuery).not.toHaveBeenCalled();\n177\t  });\n178\t\n179\t  it(\"returns an EventRow with resolved_id set to user_id when user_id is present\", async () => {\n180\t    const result = await insertEvent({\n181\t      event_name: \"Purchase Completed\",\n182\t      device_id: \"dev-1\",\n183\t      user_id: \"user@test.com\",\n184\t    });\n185\t\n186\t    expect(result.resolved_id).toBe(\"user@test.com\");\n187\t  });\n188\t\n189\t  it(\"returns an EventRow with resolved_id set to device_id when only device_id is present\", async () => {\n190\t    const result = await insertEvent({\n191\t      event_name: \"Page Viewed\",\n192\t      device_id: \"dev-1\",\n193\t    });\n194\t\n195\t    expect(result.resolved_id).toBe(\"dev-1\");\n196\t  });\n197\t});\n198\t\n199\t// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n200\t\n201\tdescribe(\"resolveIdentityMapping\", () => {\n202\t  it(\"inserts a new mapping when no existing mapping is found\", async () => {\n203\t    mockQueryReturns([]); // no existing mapping\n204\t\n205\t    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n206\t\n207\t    expect(mockInsert).toHaveBeenCalledWith(\n208\t      expect.objectContaining({\n209\t        table: \"identity_mappings\",\n210\t        values: [{ device_id: \"dev-1\", user_id: \"user@test.com\" }],\n211\t      }),\n212\t    );\n213\t  });\n214\t\n215\t  it(\"is a no-op when existing mapping has the same user_id\", async () => {\n216\t    mockQueryReturns([{ user_id: \"user@test.com\" }]); // same user already mapped\n217\t\n218\t    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n219\t\n220\t    expect(mockInsert).not.toHaveBeenCalled();\n221\t  });\n222\t\n223\t  it(\"throws IdentityConflictError when existing mapping has a different user_id\", async () => {\n224\t    mockQueryReturns([{ user_id: \"other@test.com\" }]); // different user already mapped\n225\t\n226\t    await expect(\n227\t      resolveIdentityMapping(\"dev-1\", \"user@test.com\"),\n228\t    ).rejects.toThrow(IdentityConflictError);\n229\t  });\n230\t\n231\t  it(\"IdentityConflictError has status 409\", async () => {\n232\t    mockQueryReturns([{ user_id: \"other@test.com\" }]);\n233\t\n234\t    try {\n235\t      await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n236\t      expect.fail(\"should have thrown\");\n237\t    } catch (err) {\n238\t      expect(err).toBeInstanceOf(IdentityConflictError);\n239\t      expect((err as IdentityConflictError).status).toBe(409);\n240\t    }\n241\t  });\n242\t});\n243\t"}]},"parent_tool_use_id":null,"session_id":"3ff4dcef-c30a-45f6-b856-25d94c9a4a9b","uuid":"7c925872-dfc6-498d-ad21-1909224ab32f","timestamp":"2026-04-15T19:35:23.729Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/__tests__/identity.test.ts","content":"import { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\n// Hoist mock refs so vi.mock factory can reference them\nconst { mockQuery, mockInsert } = vi.hoisted(() => ({\n  mockQuery: vi.fn(),\n  mockInsert: vi.fn(),\n}));\n\nvi.mock(\"@/lib/clickhouse\", () => ({\n  clickhouse: {\n    query: mockQuery,\n    insert: mockInsert,\n  },\n}));\n\nimport {\n  IdentityConflictError,\n  insertEvent,\n  resolveIdentityMapping,\n  validateEvent,\n} from \"@/lib/identity\";\n\n// Helper: set up mockQuery to return a given rows array\nfunction mockQueryReturns(rows: unknown[]) {\n  mockQuery.mockResolvedValue({ json: vi.fn().mockResolvedValue(rows) });\n}\n\nbeforeEach(() => {\n  // Default: no existing identity mapping, inserts succeed\n  mockQueryReturns([]);\n  mockInsert.mockResolvedValue(undefined);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\n// ─── validateEvent ────────────────────────────────────────────────────────────\n\ndescribe(\"validateEvent\", () => {\n  it(\"rejects when both device_id and user_id are missing\", () => {\n    expect(() => validateEvent({ event_name: \"Page Viewed\" })).toThrow();\n  });\n\n  it(\"rejects when event_name is missing\", () => {\n    expect(() => validateEvent({ device_id: \"dev-1\" })).toThrow();\n  });\n\n  it(\"rejects when event_name is empty string\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"\", device_id: \"dev-1\" }),\n    ).toThrow();\n  });\n\n  it(\"rejects when event_name is whitespace only\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"  \", device_id: \"dev-1\" }),\n    ).toThrow();\n  });\n\n  it(\"accepts event with only device_id\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" }),\n    ).not.toThrow();\n  });\n\n  it(\"accepts event with only user_id\", () => {\n    expect(() =>\n      validateEvent({ event_name: \"Page Viewed\", user_id: \"user@test.com\" }),\n    ).not.toThrow();\n  });\n\n  it(\"accepts event with both device_id and user_id\", () => {\n    expect(() =>\n      validateEvent({\n        event_name: \"Signup Completed\",\n        device_id: \"dev-1\",\n        user_id: \"user@test.com\",\n      }),\n    ).not.toThrow();\n  });\n});\n\n// ─── insertEvent ──────────────────────────────────────────────────────────────\n\ndescribe(\"insertEvent\", () => {\n  it(\"defaults timestamp to current time when not provided\", async () => {\n    const before = Date.now();\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n    const after = Date.now();\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    // INSERT uses ClickHouse format (\"YYYY-MM-DD HH:MM:SS.mmm\"); re-add the T+Z\n    // suffix to parse as UTC for comparison with Date.now() (always UTC).\n    const chTs = insertCall.values[0].timestamp as string;\n    const insertedTs = new Date(`${chTs.replace(\" \", \"T\")}Z`).getTime();\n    expect(insertedTs).toBeGreaterThanOrEqual(before);\n    expect(insertedTs).toBeLessThanOrEqual(after);\n  });\n\n  it(\"preserves caller-provided timestamp\", async () => {\n    const ts = \"2026-01-15T10:30:00.000Z\";\n    await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n      timestamp: ts,\n    });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    // insertEvent converts to ClickHouse format before inserting\n    expect(insertCall.values[0].timestamp).toBe(\"2026-01-15 10:30:00.000\");\n  });\n\n  it(\"inserts event into the events table\", async () => {\n    await insertEvent({\n      event_name: \"Purchase Completed\",\n      user_id: \"user@test.com\",\n      properties: { amount: 49.99 },\n    });\n\n    expect(mockInsert).toHaveBeenCalledWith(\n      expect.objectContaining({ table: \"events\" }),\n    );\n  });\n\n  it(\"stores event_name correctly in the inserted row\", async () => {\n    await insertEvent({ event_name: \"Button Clicked\", device_id: \"dev-2\" });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].event_name).toBe(\"Button Clicked\");\n  });\n\n  it(\"serialises properties as a JSON string\", async () => {\n    await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n      properties: { page: \"/home\", count: 3 },\n    });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].properties).toBe(\n      JSON.stringify({ page: \"/home\", count: 3 }),\n    );\n  });\n\n  it(\"defaults properties to '{}' when not provided\", async () => {\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n\n    const insertCall = mockInsert.mock.calls[0][0];\n    expect(insertCall.values[0].properties).toBe(\"{}\");\n  });\n\n  it(\"calls resolveIdentityMapping (queries mappings) when both device_id and user_id are present\", async () => {\n    await insertEvent({\n      event_name: \"Signup Completed\",\n      device_id: \"dev-1\",\n      user_id: \"user@test.com\",\n    });\n\n    // resolveIdentityMapping does a SELECT on identity_mappings\n    expect(mockQuery).toHaveBeenCalled();\n  });\n\n  it(\"does NOT call resolveIdentityMapping when only device_id is present\", async () => {\n    await insertEvent({ event_name: \"Page Viewed\", device_id: \"dev-1\" });\n\n    expect(mockQuery).not.toHaveBeenCalled();\n  });\n\n  it(\"does NOT call resolveIdentityMapping when only user_id is present\", async () => {\n    await insertEvent({\n      event_name: \"Purchase Completed\",\n      user_id: \"user@test.com\",\n    });\n\n    expect(mockQuery).not.toHaveBeenCalled();\n  });\n\n  it(\"returns an EventRow with resolved_id set to user_id when user_id is present\", async () => {\n    const result = await insertEvent({\n      event_name: \"Purchase Completed\",\n      device_id: \"dev-1\",\n      user_id: \"user@test.com\",\n    });\n\n    expect(result.resolved_id).toBe(\"user@test.com\");\n  });\n\n  it(\"returns an EventRow with resolved_id set to device_id when only device_id is present\", async () => {\n    const result = await insertEvent({\n      event_name: \"Page Viewed\",\n      device_id: \"dev-1\",\n    });\n\n    expect(result.resolved_id).toBe(\"dev-1\");\n  });\n});\n\n// ─── resolveIdentityMapping ───────────────────────────────────────────────────\n\ndescribe(\"resolveIdentityMapping\", () => {\n  it(\"inserts a new mapping when no existing mapping is found\", async () => {\n    mockQueryReturns([]); // no existing mapping\n\n    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n\n    expect(mockInsert).toHaveBeenCalledWith(\n      expect.objectContaining({\n        table: \"identity_mappings\",\n        values: [{ device_id: \"dev-1\", user_id: \"user@test.com\" }],\n      }),\n    );\n  });\n\n  it(\"is a no-op when existing mapping has the same user_id\", async () => {\n    mockQueryReturns([{ user_id: \"user@test.com\" }]); // same user already mapped\n\n    await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n\n    expect(mockInsert).not.toHaveBeenCalled();\n  });\n\n  it(\"throws IdentityConflictError when existing mapping has a different user_id\", async () => {\n    mockQueryReturns([{ user_id: \"other@test.com\" }]); // different user already mapped\n\n    await expect(\n      resolveIdentityMapping(\"dev-1\", \"user@test.com\"),\n    ).rejects.toThrow(IdentityConflictError);\n  });\n\n  it(\"IdentityConflictError has status 409\", async () => {\n    mockQueryReturns([{ user_id: \"other@test.com\" }]);\n\n    try {\n      await resolveIdentityMapping(\"dev-1\", \"user@test.com\");\n      expect.fail(\"should have thrown\");\n    } catch (err) {\n      expect(err).toBeInstanceOf(IdentityConflictError);\n      expect((err as IdentityConflictError).status).toBe(409);\n    }\n  });\n});\n","numLines":243,"startLine":1,"totalLines":243}}}
