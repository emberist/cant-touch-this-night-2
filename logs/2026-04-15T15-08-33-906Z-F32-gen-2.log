{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UFGWR3BnCCeNCBZaPcMTTR","type":"tool_result","content":"1\t/**\n2\t * Integration tests for POST /api/events\n3\t *\n4\t * These tests require:\n5\t *   - A running dev server at http://localhost:3000\n6\t *   - A running ClickHouse instance at http://localhost:8123\n7\t *\n8\t * Run with:\n9\t *   pnpm dev &    # starts ClickHouse + Next.js via concurrently\n10\t *   pnpm test\n11\t */\n12\t\n13\timport { afterAll, beforeAll, describe, expect, it } from \"vitest\";\n14\t\n15\tconst BASE_URL = \"http://localhost:3000\";\n16\tconst ENDPOINT = `${BASE_URL}/api/events`;\n17\t\n18\t/** Returns true if the dev server is reachable. */\n19\tasync function isServerAvailable(): Promise<boolean> {\n20\t  try {\n21\t    const res = await fetch(BASE_URL, {\n22\t      method: \"HEAD\",\n23\t      signal: AbortSignal.timeout(2000),\n24\t    });\n25\t    // Any HTTP response (even 404/500) means the server is up\n26\t    return res.status < 600;\n27\t  } catch {\n28\t    return false;\n29\t  }\n30\t}\n31\t\n32\tlet serverAvailable = false;\n33\t\n34\tbeforeAll(async () => {\n35\t  serverAvailable = await isServerAvailable();\n36\t  if (!serverAvailable) {\n37\t    console.warn(\n38\t      \"[integration] Dev server not available at http://localhost:3000 — skipping integration tests.\",\n39\t    );\n40\t  }"}]},"parent_tool_use_id":null,"session_id":"29f5e167-8f6c-43c0-81d3-b3219e5fab16","uuid":"f5b15311-d7d5-455e-937f-01abaa8cfd27","timestamp":"2026-04-15T19:20:35.381Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/events/__tests__/route.integration.test.ts","content":"/**\n * Integration tests for POST /api/events\n *\n * These tests require:\n *   - A running dev server at http://localhost:3000\n *   - A running ClickHouse instance at http://localhost:8123\n *\n * Run with:\n *   pnpm dev &    # starts ClickHouse + Next.js via concurrently\n *   pnpm test\n */\n\nimport { afterAll, beforeAll, describe, expect, it } from \"vitest\";\n\nconst BASE_URL = \"http://localhost:3000\";\nconst ENDPOINT = `${BASE_URL}/api/events`;\n\n/** Returns true if the dev server is reachable. */\nasync function isServerAvailable(): Promise<boolean> {\n  try {\n    const res = await fetch(BASE_URL, {\n      method: \"HEAD\",\n      signal: AbortSignal.timeout(2000),\n    });\n    // Any HTTP response (even 404/500) means the server is up\n    return res.status < 600;\n  } catch {\n    return false;\n  }\n}\n\nlet serverAvailable = false;\n\nbeforeAll(async () => {\n  serverAvailable = await isServerAvailable();\n  if (!serverAvailable) {\n    console.warn(\n      \"[integration] Dev server not available at http://localhost:3000 — skipping integration tests.\",\n    );\n  }","numLines":40,"startLine":1,"totalLines":114}}}
