{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0126E2KewSMaM1rMwJ5CbpPu","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\t\n3\t// ─── Types ────────────────────────────────────────────────────────────────────\n4\t\n5\texport type UserType = \"fully-resolved\" | \"multi-device\" | \"anonymous\";\n6\t\n7\texport interface GeneratedUser {\n8\t  type: UserType;\n9\t  userId: string | null;\n10\t  deviceIds: string[];\n11\t}\n12\t\n13\texport interface GeneratedEvent {\n14\t  event_name: string;\n15\t  timestamp: string;\n16\t  device_id: string | null;\n17\t  user_id: string | null;\n18\t  properties: string;\n19\t}\n20\t\n21\texport interface IdentityMapping {\n22\t  device_id: string;\n23\t  user_id: string;\n24\t}\n25\t\n26\texport interface SeedResult {\n27\t  events: number;\n28\t  users: number;\n29\t}\n30\t\n31\ttype ClickHouseClientLike = typeof clickhouse;\n32\t\n33\t// ─── PRNG ─────────────────────────────────────────────────────────────────────\n34\t\n35\t/**\n36\t * mulberry32 — fast seeded PRNG that returns values in [0, 1).\n37\t * Provides reproducible distributions when given the same seed.\n38\t */\n39\texport function mulberry32(seed: number): () => number {\n40\t  let s = seed;\n41\t  return (): number => {\n42\t    s |= 0;\n43\t    s = (s + 0x6d2b79f5) | 0;\n44\t    let t = Math.imul(s ^ (s >>> 15), s | 1);\n45\t    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);\n46\t    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n47\t  };\n48\t}\n49\t\n50\t// ─── Constants ────────────────────────────────────────────────────────────────\n51\t\n52\tconst DEFAULT_SEED = 42;\n53\tconst TARGET_EVENTS = 12_000;\n54\t\n55\tconst EVENT_NAMES = [\n56\t  \"Page Viewed\",\n57\t  \"Button Clicked\",\n58\t  \"Signup Completed\",\n59\t  \"Purchase Completed\",\n60\t  \"Subscription Renewed\",\n61\t  \"Support Ticket Opened\",\n62\t] as const;\n63\t\n64\ttype EventName = (typeof EVENT_NAMES)[number];\n65\t\n66\t// Page Viewed targets ~40%; remaining 60% split across 5 other event types\n67\tconst EVENT_WEIGHTS = [0.4, 0.15, 0.12, 0.13, 0.12, 0.08];\n68\t\n69\tconst PAGES = [\n70\t  \"/home\",\n71\t  \"/pricing\",\n72\t  \"/features\",\n73\t  \"/about\",\n74\t  \"/signup\",\n75\t  \"/login\",\n76\t  \"/dashboard\",\n77\t];\n78\tconst PLANS = [\"free\", \"starter\", \"pro\", \"enterprise\"];\n79\tconst CURRENCIES = [\"USD\", \"EUR\", \"GBP\", \"BTC\"];\n80\tconst SOURCES = [\"organic\", \"paid\", \"referral\", \"email\", \"social\"];\n81\tconst BUTTON_NAMES = [\n82\t  \"Get Started\",\n83\t  \"Sign Up\",\n84\t  \"Learn More\",\n85\t  \"Buy Now\",\n86\t  \"Upgrade\",\n87\t  \"Try Free\",\n88\t];\n89\t\n90\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n91\t\n92\tfunction pickFrom<T>(arr: readonly T[], rand: () => number): T {\n93\t  return arr[Math.floor(rand() * arr.length)];\n94\t}\n95\t\n96\tfunction buildCumulative(weights: readonly number[]): number[] {\n97\t  const cum: number[] = [];\n98\t  let total = 0;\n99\t  for (const w of weights) {\n100\t    total += w;\n101\t    cum.push(total);\n102\t  }\n103\t  return cum;\n104\t}\n105\t\n106\tfunction weightedIndex(cumulative: number[], rand: () => number): number {\n107\t  const r = rand() * cumulative[cumulative.length - 1];\n108\t  for (let i = 0; i < cumulative.length; i++) {\n109\t    if (r <= cumulative[i]) return i;\n110\t  }\n111\t  return cumulative.length - 1;\n112\t}\n113\t\n114\t// ─── Property generation ──────────────────────────────────────────────────────\n115\t\n116\tfunction generateProperties(\n117\t  eventName: EventName,\n118\t  rand: () => number,\n119\t): Record<string, unknown> {\n120\t  switch (eventName) {\n121\t    case \"Page Viewed\":\n122\t      return { page: pickFrom(PAGES, rand) };\n123\t    case \"Button Clicked\":\n124\t      return { button_name: pickFrom(BUTTON_NAMES, rand) };\n125\t    case \"Signup Completed\":\n126\t      return {\n127\t        plan: pickFrom(PLANS, rand),\n128\t        source: pickFrom(SOURCES, rand),\n129\t      };\n130\t    case \"Purchase Completed\":\n131\t      return {\n132\t        amount: Math.round(rand() * 500 * 100) / 100,\n133\t        currency: pickFrom(CURRENCIES, rand),\n134\t        plan: pickFrom(PLANS, rand),\n135\t      };\n136\t    case \"Subscription Renewed\":\n137\t      return {\n138\t        amount: Math.round(rand() * 500 * 100) / 100,\n139\t        currency: pickFrom(CURRENCIES, rand),\n140\t        plan: pickFrom(PLANS, rand),\n141\t      };\n142\t    case \"Support Ticket Opened\":\n143\t      return {\n144\t        ticket_count: Math.floor(rand() * 10) + 1,\n145\t        source: pickFrom(SOURCES, rand),\n146\t      };\n147\t    default: {\n148\t      const _exhaustive: never = eventName;\n149\t      void _exhaustive;\n150\t      return {};\n151\t    }\n152\t  }\n153\t}\n154\t\n155\t// ─── User generation ──────────────────────────────────────────────────────────\n156\t\n157\t/**\n158\t * Generates 70 seed users:\n159\t * - 50 fully-resolved (1 device + 1 user_id)\n160\t * - 10 multi-device (2–3 devices + 1 user_id)\n161\t * - 10 anonymous-only (1 device, no user_id)\n162\t */\n163\texport function generateUsers(seed: number = DEFAULT_SEED): GeneratedUser[] {\n164\t  const rand = mulberry32(seed);\n165\t  const users: GeneratedUser[] = [];\n166\t\n167\t  // 50 fully-resolved users\n168\t  for (let i = 0; i < 50; i++) {\n169\t    users.push({\n170\t      type: \"fully-resolved\",\n171\t      userId: `user-${String(i).padStart(4, \"0\")}@example.com`,\n172\t      deviceIds: [`device-${String(i).padStart(4, \"0\")}`],\n173\t    });\n174\t  }\n175\t\n176\t  // 10 multi-device users (2–3 devices each, determined by PRNG)\n177\t  for (let i = 0; i < 10; i++) {\n178\t    const deviceCount = rand() < 0.5 ? 2 : 3;\n179\t    const deviceIds: string[] = [];\n180\t    for (let d = 0; d < deviceCount; d++) {\n181\t      deviceIds.push(`device-multi-${i}-${d}`);\n182\t    }\n183\t    users.push({\n184\t      type: \"multi-device\",\n185\t      userId: `multi-user-${i}@example.com`,\n186\t      deviceIds,\n187\t    });\n188\t  }\n189\t\n190\t  // 10 anonymous-only users\n191\t  for (let i = 0; i < 10; i++) {\n192\t    users.push({\n193\t      type: \"anonymous\",\n194\t      userId: null,\n195\t      deviceIds: [`anon-device-${i}`],\n196\t    });\n197\t  }\n198\t\n199\t  return users;\n200\t}\n201\t\n202\t// ─── Identity mapping builder ─────────────────────────────────────────────────\n203\t\n204\t/**\n205\t * Returns one IdentityMapping row per device for every non-anonymous user.\n206\t */\n207\texport function buildIdentityMappings(\n208\t  users: GeneratedUser[],\n209\t): IdentityMapping[] {\n210\t  const mappings: IdentityMapping[] = [];\n211\t  for (const user of users) {\n212\t    if (user.userId === null) continue;\n213\t    for (const deviceId of user.deviceIds) {\n214\t      mappings.push({ device_id: deviceId, user_id: user.userId });\n215\t    }\n216\t  }\n217\t  return mappings;\n218\t}\n219\t\n220\t// ─── Event generation ─────────────────────────────────────────────────────────\n221\t\n222\t/**\n223\t * Generates TARGET_EVENTS events distributed across the given date range.\n224\t *\n225\t * User activity follows a power-law (Zipf-like) distribution so that a few\n226\t * users are highly active and most are occasional. Event types are sampled\n227\t * according to EVENT_WEIGHTS, targeting ~40% \"Page Viewed\".\n228\t */\n229\texport function generateEvents(\n230\t  users: GeneratedUser[],\n231\t  startDate: Date,\n232\t  endDate: Date,\n233\t  seed: number = DEFAULT_SEED + 1,\n234\t): GeneratedEvent[] {\n235\t  const rand = mulberry32(seed);\n236\t\n237\t  // Power-law activity weights: weight_i ∝ 1 / (rank+1)^1.5\n238\t  const userWeights = users.map((_, i) => 1 / (i + 1) ** 1.5);\n239\t  const userCumulative = buildCumulative(userWeights);\n240\t  const eventCumulative = buildCumulative(EVENT_WEIGHTS);\n241\t\n242\t  const startMs = startDate.getTime();\n243\t  const rangeMs = endDate.getTime() - startMs;\n244\t\n245\t  const events: GeneratedEvent[] = [];\n246\t\n247\t  for (let i = 0; i < TARGET_EVENTS; i++) {\n248\t    const user = users[weightedIndex(userCumulative, rand)];\n249\t    const eventName = EVENT_NAMES[weightedIndex(eventCumulative, rand)];\n250\t\n251\t    const deviceId = pickFrom(user.deviceIds, rand);\n252\t    const tsMs = startMs + Math.floor(rand() * rangeMs);\n253\t    const timestamp = new Date(tsMs).toISOString();\n254\t    const properties = JSON.stringify(generateProperties(eventName, rand));\n255\t\n256\t    events.push({\n257\t      event_name: eventName,\n258\t      timestamp,\n259\t      device_id: deviceId,\n260\t      user_id: user.userId,\n261\t      properties,\n262\t    });\n263\t  }\n264\t\n265\t  return events;\n266\t}\n267\t\n268\t// ─── seedData ─────────────────────────────────────────────────────────────────\n269\t\n270\t/**\n271\t * Clears existing data and populates ClickHouse with realistic sample data.\n272\t *\n273\t * Truncates `events` and `identity_mappings`, then bulk-inserts\n274\t * ~12,000 events and the corresponding identity mappings for the\n275\t * 60 non-anonymous seed users.\n276\t */\n277\texport async function seedData(\n278\t  client: ClickHouseClientLike = clickhouse,\n279\t): Promise<SeedResult> {\n280\t  await client.command({ query: \"TRUNCATE TABLE events\" });\n281\t  await client.command({ query: \"TRUNCATE TABLE identity_mappings\" });\n282\t\n283\t  const users = generateUsers();\n284\t  const endDate = new Date();\n285\t  const startDate = new Date(endDate.getTime() - 30 * 24 * 60 * 60 * 1000);\n286\t  const events = generateEvents(users, startDate, endDate);\n287\t  const mappings = buildIdentityMappings(users);\n288\t\n289\t  await client.insert({\n290\t    table: \"events\",\n291\t    values: events.map((e) => ({\n292\t      ...e,\n293\t      // ClickHouse JSONEachRow rejects ISO 8601 \"T\"/\"Z\" for DateTime64;\n294\t      // requires \"YYYY-MM-DD HH:MM:SS.mmm\" (space separator, no Z).\n295\t      timestamp: e.timestamp.replace(\"T\", \" \").replace(\"Z\", \"\"),\n296\t    })),\n297\t    format: \"JSONEachRow\",\n298\t  });\n299\t\n300\t  await client.insert({\n301\t    table: \"identity_mappings\",\n302\t    values: mappings,\n303\t    format: \"JSONEachRow\",\n304\t  });\n305\t\n306\t  return {\n307\t    events: events.length,\n308\t    users: users.filter((u) => u.userId !== null).length,\n309\t  };\n310\t}\n311\t"}]},"parent_tool_use_id":null,"session_id":"6d542617-c6aa-4344-aa60-030d9b2a541c","uuid":"e0c890fe-e00c-400b-95f9-3e92762a60f4","timestamp":"2026-04-15T18:37:21.749Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/seed.ts","content":"import { clickhouse } from \"@/lib/clickhouse\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport type UserType = \"fully-resolved\" | \"multi-device\" | \"anonymous\";\n\nexport interface GeneratedUser {\n  type: UserType;\n  userId: string | null;\n  deviceIds: string[];\n}\n\nexport interface GeneratedEvent {\n  event_name: string;\n  timestamp: string;\n  device_id: string | null;\n  user_id: string | null;\n  properties: string;\n}\n\nexport interface IdentityMapping {\n  device_id: string;\n  user_id: string;\n}\n\nexport interface SeedResult {\n  events: number;\n  users: number;\n}\n\ntype ClickHouseClientLike = typeof clickhouse;\n\n// ─── PRNG ─────────────────────────────────────────────────────────────────────\n\n/**\n * mulberry32 — fast seeded PRNG that returns values in [0, 1).\n * Provides reproducible distributions when given the same seed.\n */\nexport function mulberry32(seed: number): () => number {\n  let s = seed;\n  return (): number => {\n    s |= 0;\n    s = (s + 0x6d2b79f5) | 0;\n    let t = Math.imul(s ^ (s >>> 15), s | 1);\n    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);\n    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n  };\n}\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst DEFAULT_SEED = 42;\nconst TARGET_EVENTS = 12_000;\n\nconst EVENT_NAMES = [\n  \"Page Viewed\",\n  \"Button Clicked\",\n  \"Signup Completed\",\n  \"Purchase Completed\",\n  \"Subscription Renewed\",\n  \"Support Ticket Opened\",\n] as const;\n\ntype EventName = (typeof EVENT_NAMES)[number];\n\n// Page Viewed targets ~40%; remaining 60% split across 5 other event types\nconst EVENT_WEIGHTS = [0.4, 0.15, 0.12, 0.13, 0.12, 0.08];\n\nconst PAGES = [\n  \"/home\",\n  \"/pricing\",\n  \"/features\",\n  \"/about\",\n  \"/signup\",\n  \"/login\",\n  \"/dashboard\",\n];\nconst PLANS = [\"free\", \"starter\", \"pro\", \"enterprise\"];\nconst CURRENCIES = [\"USD\", \"EUR\", \"GBP\", \"BTC\"];\nconst SOURCES = [\"organic\", \"paid\", \"referral\", \"email\", \"social\"];\nconst BUTTON_NAMES = [\n  \"Get Started\",\n  \"Sign Up\",\n  \"Learn More\",\n  \"Buy Now\",\n  \"Upgrade\",\n  \"Try Free\",\n];\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction pickFrom<T>(arr: readonly T[], rand: () => number): T {\n  return arr[Math.floor(rand() * arr.length)];\n}\n\nfunction buildCumulative(weights: readonly number[]): number[] {\n  const cum: number[] = [];\n  let total = 0;\n  for (const w of weights) {\n    total += w;\n    cum.push(total);\n  }\n  return cum;\n}\n\nfunction weightedIndex(cumulative: number[], rand: () => number): number {\n  const r = rand() * cumulative[cumulative.length - 1];\n  for (let i = 0; i < cumulative.length; i++) {\n    if (r <= cumulative[i]) return i;\n  }\n  return cumulative.length - 1;\n}\n\n// ─── Property generation ──────────────────────────────────────────────────────\n\nfunction generateProperties(\n  eventName: EventName,\n  rand: () => number,\n): Record<string, unknown> {\n  switch (eventName) {\n    case \"Page Viewed\":\n      return { page: pickFrom(PAGES, rand) };\n    case \"Button Clicked\":\n      return { button_name: pickFrom(BUTTON_NAMES, rand) };\n    case \"Signup Completed\":\n      return {\n        plan: pickFrom(PLANS, rand),\n        source: pickFrom(SOURCES, rand),\n      };\n    case \"Purchase Completed\":\n      return {\n        amount: Math.round(rand() * 500 * 100) / 100,\n        currency: pickFrom(CURRENCIES, rand),\n        plan: pickFrom(PLANS, rand),\n      };\n    case \"Subscription Renewed\":\n      return {\n        amount: Math.round(rand() * 500 * 100) / 100,\n        currency: pickFrom(CURRENCIES, rand),\n        plan: pickFrom(PLANS, rand),\n      };\n    case \"Support Ticket Opened\":\n      return {\n        ticket_count: Math.floor(rand() * 10) + 1,\n        source: pickFrom(SOURCES, rand),\n      };\n    default: {\n      const _exhaustive: never = eventName;\n      void _exhaustive;\n      return {};\n    }\n  }\n}\n\n// ─── User generation ──────────────────────────────────────────────────────────\n\n/**\n * Generates 70 seed users:\n * - 50 fully-resolved (1 device + 1 user_id)\n * - 10 multi-device (2–3 devices + 1 user_id)\n * - 10 anonymous-only (1 device, no user_id)\n */\nexport function generateUsers(seed: number = DEFAULT_SEED): GeneratedUser[] {\n  const rand = mulberry32(seed);\n  const users: GeneratedUser[] = [];\n\n  // 50 fully-resolved users\n  for (let i = 0; i < 50; i++) {\n    users.push({\n      type: \"fully-resolved\",\n      userId: `user-${String(i).padStart(4, \"0\")}@example.com`,\n      deviceIds: [`device-${String(i).padStart(4, \"0\")}`],\n    });\n  }\n\n  // 10 multi-device users (2–3 devices each, determined by PRNG)\n  for (let i = 0; i < 10; i++) {\n    const deviceCount = rand() < 0.5 ? 2 : 3;\n    const deviceIds: string[] = [];\n    for (let d = 0; d < deviceCount; d++) {\n      deviceIds.push(`device-multi-${i}-${d}`);\n    }\n    users.push({\n      type: \"multi-device\",\n      userId: `multi-user-${i}@example.com`,\n      deviceIds,\n    });\n  }\n\n  // 10 anonymous-only users\n  for (let i = 0; i < 10; i++) {\n    users.push({\n      type: \"anonymous\",\n      userId: null,\n      deviceIds: [`anon-device-${i}`],\n    });\n  }\n\n  return users;\n}\n\n// ─── Identity mapping builder ─────────────────────────────────────────────────\n\n/**\n * Returns one IdentityMapping row per device for every non-anonymous user.\n */\nexport function buildIdentityMappings(\n  users: GeneratedUser[],\n): IdentityMapping[] {\n  const mappings: IdentityMapping[] = [];\n  for (const user of users) {\n    if (user.userId === null) continue;\n    for (const deviceId of user.deviceIds) {\n      mappings.push({ device_id: deviceId, user_id: user.userId });\n    }\n  }\n  return mappings;\n}\n\n// ─── Event generation ─────────────────────────────────────────────────────────\n\n/**\n * Generates TARGET_EVENTS events distributed across the given date range.\n *\n * User activity follows a power-law (Zipf-like) distribution so that a few\n * users are highly active and most are occasional. Event types are sampled\n * according to EVENT_WEIGHTS, targeting ~40% \"Page Viewed\".\n */\nexport function generateEvents(\n  users: GeneratedUser[],\n  startDate: Date,\n  endDate: Date,\n  seed: number = DEFAULT_SEED + 1,\n): GeneratedEvent[] {\n  const rand = mulberry32(seed);\n\n  // Power-law activity weights: weight_i ∝ 1 / (rank+1)^1.5\n  const userWeights = users.map((_, i) => 1 / (i + 1) ** 1.5);\n  const userCumulative = buildCumulative(userWeights);\n  const eventCumulative = buildCumulative(EVENT_WEIGHTS);\n\n  const startMs = startDate.getTime();\n  const rangeMs = endDate.getTime() - startMs;\n\n  const events: GeneratedEvent[] = [];\n\n  for (let i = 0; i < TARGET_EVENTS; i++) {\n    const user = users[weightedIndex(userCumulative, rand)];\n    const eventName = EVENT_NAMES[weightedIndex(eventCumulative, rand)];\n\n    const deviceId = pickFrom(user.deviceIds, rand);\n    const tsMs = startMs + Math.floor(rand() * rangeMs);\n    const timestamp = new Date(tsMs).toISOString();\n    const properties = JSON.stringify(generateProperties(eventName, rand));\n\n    events.push({\n      event_name: eventName,\n      timestamp,\n      device_id: deviceId,\n      user_id: user.userId,\n      properties,\n    });\n  }\n\n  return events;\n}\n\n// ─── seedData ─────────────────────────────────────────────────────────────────\n\n/**\n * Clears existing data and populates ClickHouse with realistic sample data.\n *\n * Truncates `events` and `identity_mappings`, then bulk-inserts\n * ~12,000 events and the corresponding identity mappings for the\n * 60 non-anonymous seed users.\n */\nexport async function seedData(\n  client: ClickHouseClientLike = clickhouse,\n): Promise<SeedResult> {\n  await client.command({ query: \"TRUNCATE TABLE events\" });\n  await client.command({ query: \"TRUNCATE TABLE identity_mappings\" });\n\n  const users = generateUsers();\n  const endDate = new Date();\n  const startDate = new Date(endDate.getTime() - 30 * 24 * 60 * 60 * 1000);\n  const events = generateEvents(users, startDate, endDate);\n  const mappings = buildIdentityMappings(users);\n\n  await client.insert({\n    table: \"events\",\n    values: events.map((e) => ({\n      ...e,\n      // ClickHouse JSONEachRow rejects ISO 8601 \"T\"/\"Z\" for DateTime64;\n      // requires \"YYYY-MM-DD HH:MM:SS.mmm\" (space separator, no Z).\n      timestamp: e.timestamp.replace(\"T\", \" \").replace(\"Z\", \"\"),\n    })),\n    format: \"JSONEachRow\",\n  });\n\n  await client.insert({\n    table: \"identity_mappings\",\n    values: mappings,\n    format: \"JSONEachRow\",\n  });\n\n  return {\n    events: events.length,\n    users: users.filter((u) => u.userId !== null).length,\n  };\n}\n","numLines":311,"startLine":1,"totalLines":311}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GtpP4gwGVRenHaPyobveHE","type":"tool_result","content":"1\timport { clickhouse } from \"@/lib/clickhouse\";\n2\timport {\n3\t  buildIdentityMappings,\n4\t  type GeneratedEvent,\n5\t  type GeneratedUser,\n6\t  type IdentityMapping,\n7\t  mulberry32,\n8\t} from \"@/lib/seed\";\n9\t\n10\t// ─── Types ────────────────────────────────────────────────────────────────────\n11\t\n12\texport type JobStatus =\n13\t  | \"queued\"\n14\t  | \"running\"\n15\t  | \"complete\"\n16\t  | \"failed\"\n17\t  | \"cancelled\";\n18\t\n19\texport type NumericVariance = \"low\" | \"medium\" | \"high\";\n20\t\n21\texport interface EventTypeWeight {\n22\t  name: string;\n23\t  weight: number;\n24\t}\n25\t\n26\texport interface JobConfig {\n27\t  total: number;\n28\t  users: number;\n29\t  start: string;\n30\t  end: string;\n31\t  event_types: EventTypeWeight[];\n32\t  identity_resolution: boolean;\n33\t  anonymous_ratio: number;\n34\t  numeric_variance: NumericVariance;\n35\t}\n36\t\n37\texport interface JobConfigInput {\n38\t  total?: number;\n39\t  users?: number;\n40\t  start?: string;\n41\t  end?: string;\n42\t  event_types?: EventTypeWeight[];\n43\t  identity_resolution?: boolean;\n44\t  anonymous_ratio?: number;\n45\t  numeric_variance?: string;\n46\t}\n47\t\n48\texport interface JobState {\n49\t  job_id: string;\n50\t  status: JobStatus;\n51\t  inserted: number;\n52\t  total: number;\n53\t  throughput: number;\n54\t  eta_seconds: number;\n55\t  elapsed_ms: number;\n56\t  error?: string;\n57\t  config: JobConfig;\n58\t  cancelled: boolean;\n59\t  created_at: number;\n60\t}\n61\t\n62\t// ─── Constants ────────────────────────────────────────────────────────────────\n63\t\n64\tconst BATCH_SIZE = 10_000;\n65\t\n66\tconst DEFAULT_EVENT_TYPES: EventTypeWeight[] = [\n67\t  { name: \"Page Viewed\", weight: 0.4 },\n68\t  { name: \"Button Clicked\", weight: 0.15 },\n69\t  { name: \"Signup Completed\", weight: 0.12 },\n70\t  { name: \"Purchase Completed\", weight: 0.13 },\n71\t  { name: \"Subscription Renewed\", weight: 0.12 },\n72\t  { name: \"Support Ticket Opened\", weight: 0.08 },\n73\t];\n74\t\n75\tconst PAGES = [\n76\t  \"/home\",\n77\t  \"/pricing\",\n78\t  \"/features\",\n79\t  \"/about\",\n80\t  \"/signup\",\n81\t  \"/login\",\n82\t  \"/dashboard\",\n83\t];\n84\tconst PLANS = [\"free\", \"starter\", \"pro\", \"enterprise\"];\n85\tconst CURRENCIES = [\"USD\", \"EUR\", \"GBP\", \"BTC\"];\n86\tconst SOURCES = [\"organic\", \"paid\", \"referral\", \"email\", \"social\"];\n87\tconst BUTTON_NAMES = [\n88\t  \"Get Started\",\n89\t  \"Sign Up\",\n90\t  \"Learn More\",\n91\t  \"Buy Now\",\n92\t  \"Upgrade\",\n93\t  \"Try Free\",\n94\t];\n95\t\n96\t// ─── In-memory job store ──────────────────────────────────────────────────────\n97\t\n98\tconst jobs = new Map<string, JobState>();\n99\t\n100\t// ─── Helpers ──────────────────────────────────────────────────────────────────\n101\t\n102\tfunction pickFrom<T>(arr: readonly T[], rand: () => number): T {\n103\t  return arr[Math.floor(rand() * arr.length)];\n104\t}\n105\t\n106\tfunction buildCumulative(weights: readonly number[]): number[] {\n107\t  const cum: number[] = [];\n108\t  let total = 0;\n109\t  for (const w of weights) {\n110\t    total += w;\n111\t    cum.push(total);\n112\t  }\n113\t  return cum;\n114\t}\n115\t\n116\tfunction weightedIndex(cumulative: number[], rand: () => number): number {\n117\t  const r = rand() * cumulative[cumulative.length - 1];\n118\t  for (let i = 0; i < cumulative.length; i++) {\n119\t    if (r <= cumulative[i]) return i;\n120\t  }\n121\t  return cumulative.length - 1;\n122\t}\n123\t\n124\tfunction getVarianceMultiplier(variance: NumericVariance): number {\n125\t  switch (variance) {\n126\t    case \"low\":\n127\t      return 0.2;\n128\t    case \"medium\":\n129\t      return 1.0;\n130\t    case \"high\":\n131\t      return 3.0;\n132\t  }\n133\t}\n134\t\n135\tfunction generateProperties(\n136\t  eventName: string,\n137\t  rand: () => number,\n138\t  variance: NumericVariance,\n139\t): Record<string, unknown> {\n140\t  const vm = getVarianceMultiplier(variance);\n141\t  switch (eventName) {\n142\t    case \"Page Viewed\":\n143\t      return { page: pickFrom(PAGES, rand) };\n144\t    case \"Button Clicked\":\n145\t      return { button_name: pickFrom(BUTTON_NAMES, rand) };\n146\t    case \"Signup Completed\":\n147\t      return {\n148\t        plan: pickFrom(PLANS, rand),\n149\t        source: pickFrom(SOURCES, rand),\n150\t      };\n151\t    case \"Purchase Completed\":\n152\t      return {\n153\t        amount: Math.round(rand() * 500 * vm * 100) / 100,\n154\t        currency: pickFrom(CURRENCIES, rand),\n155\t        plan: pickFrom(PLANS, rand),\n156\t      };\n157\t    case \"Subscription Renewed\":\n158\t      return {\n159\t        amount: Math.round(rand() * 500 * vm * 100) / 100,\n160\t        currency: pickFrom(CURRENCIES, rand),\n161\t        plan: pickFrom(PLANS, rand),\n162\t      };\n163\t    case \"Support Ticket Opened\":\n164\t      return {\n165\t        ticket_count: Math.floor(rand() * 10 * vm) + 1,\n166\t        source: pickFrom(SOURCES, rand),\n167\t      };\n168\t    default:\n169\t      return {};\n170\t  }\n171\t}\n172\t\n173\t/** Converts an ISO 8601 timestamp to the ClickHouse DateTime64 format. */\n174\tfunction toClickHouseTs(iso: string): string {\n175\t  return iso.replace(\"T\", \" \").replace(\"Z\", \"\");\n176\t}\n177\t\n178\t// ─── Config application and validation ───────────────────────────────────────\n179\t\n180\tfunction applyDefaults(input: JobConfigInput): JobConfig {\n181\t  const now = new Date();\n182\t  const thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);\n183\t\n184\t  const total = input.total ?? 10_000;\n185\t  const users = input.users ?? 100;\n186\t  const start = input.start ?? thirtyDaysAgo.toISOString().slice(0, 10);\n187\t  const end = input.end ?? now.toISOString().slice(0, 10);\n188\t  const event_types =\n189\t    input.event_types && input.event_types.length > 0\n190\t      ? input.event_types\n191\t      : DEFAULT_EVENT_TYPES;\n192\t  const identity_resolution = input.identity_resolution ?? true;\n193\t  const anonymous_ratio = input.anonymous_ratio ?? 30;\n194\t  const numeric_variance: NumericVariance =\n195\t    input.numeric_variance === \"low\" ||\n196\t    input.numeric_variance === \"high\" ||\n197\t    input.numeric_variance === \"medium\"\n198\t      ? input.numeric_variance\n199\t      : \"medium\";\n200\t\n201\t  return {\n202\t    total,\n203\t    users,\n204\t    start,\n205\t    end,\n206\t    event_types,\n207\t    identity_resolution,\n208\t    anonymous_ratio,\n209\t    numeric_variance,\n210\t  };\n211\t}\n212\t\n213\tfunction validateConfig(config: JobConfig): void {\n214\t  if (!Number.isInteger(config.total) || config.total < 1) {\n215\t    throw new Error(\"total must be an integer >= 1.\");\n216\t  }\n217\t  if (config.total > 1_000_000) {\n218\t    throw new Error(\"total must be <= 1,000,000.\");\n219\t  }\n220\t  if (!Number.isInteger(config.users) || config.users < 1) {\n221\t    throw new Error(\"users must be an integer >= 1.\");\n222\t  }\n223\t  const startMs = new Date(config.start).getTime();\n224\t  const endMs = new Date(config.end).getTime();\n225\t  if (Number.isNaN(startMs)) {\n226\t    throw new Error(\"start must be a valid date string.\");\n227\t  }\n228\t  if (Number.isNaN(endMs)) {\n229\t    throw new Error(\"end must be a valid date string.\");\n230\t  }\n231\t  if (endMs <= startMs) {\n232\t    throw new Error(\"end must be after start.\");\n233\t  }\n234\t}\n235\t\n236\t// ─── User pool builder ────────────────────────────────────────────────────────\n237\t\n238\tfunction buildUserPool(config: JobConfig, rand: () => number): GeneratedUser[] {\n239\t  const users: GeneratedUser[] = [];\n240\t\n241\t  const anonCount = config.identity_resolution\n242\t    ? Math.round(config.users * (config.anonymous_ratio / 100))\n243\t    : config.users;\n244\t  const resolvedCount = config.users - anonCount;\n245\t\n246\t  for (let i = 0; i < resolvedCount; i++) {\n247\t    users.push({\n248\t      type: \"fully-resolved\",\n249\t      userId: `gen-user-${i}@example.com`,\n250\t      deviceIds: [`gen-device-${i}`],\n251\t    });\n252\t  }\n253\t\n254\t  for (let i = 0; i < anonCount; i++) {\n255\t    users.push({\n256\t      type: \"anonymous\",\n257\t      userId: null,\n258\t      deviceIds: [`gen-anon-${i}`],\n259\t    });\n260\t  }\n261\t\n262\t  // Shuffle so anonymous users aren't always last (affects power-law weighting)\n263\t  for (let i = users.length - 1; i > 0; i--) {\n264\t    const j = Math.floor(rand() * (i + 1));\n265\t    [users[i], users[j]] = [users[j], users[i]];\n266\t  }\n267\t\n268\t  return users;\n269\t}\n270\t\n271\t// ─── Batch event generation ───────────────────────────────────────────────────\n272\t\n273\texport function generateBatchEvents(\n274\t  config: JobConfig,\n275\t  users: GeneratedUser[],\n276\t  startDate: Date,\n277\t  endDate: Date,\n278\t  rand: () => number,\n279\t  batchSize: number,\n280\t): GeneratedEvent[] {\n281\t  const eventCumulative = buildCumulative(\n282\t    config.event_types.map((et) => et.weight),\n283\t  );\n284\t  const userWeights = users.map((_, i) => 1 / (i + 1) ** 1.5);\n285\t  const userCumulative = buildCumulative(userWeights);\n286\t\n287\t  const startMs = startDate.getTime();\n288\t  const rangeMs = endDate.getTime() - startMs;\n289\t\n290\t  const events: GeneratedEvent[] = [];\n291\t\n292\t  for (let i = 0; i < batchSize; i++) {\n293\t    const user = users[weightedIndex(userCumulative, rand)];\n294\t    const eventTypeIdx = weightedIndex(eventCumulative, rand);\n295\t    const eventName = config.event_types[eventTypeIdx].name;\n296\t\n297\t    const deviceId = pickFrom(user.deviceIds, rand);\n298\t    const tsMs = startMs + Math.floor(rand() * rangeMs);\n299\t    const timestamp = new Date(tsMs).toISOString();\n300\t    const properties = JSON.stringify(\n301\t      generateProperties(eventName, rand, config.numeric_variance),\n302\t    );\n303\t\n304\t    events.push({\n305\t      event_name: eventName,\n306\t      timestamp,\n307\t      device_id: deviceId,\n308\t      user_id: user.userId,\n309\t      properties,\n310\t    });\n311\t  }\n312\t\n313\t  return events;\n314\t}\n315\t\n316\t// ─── Generation loop ──────────────────────────────────────────────────────────\n317\t\n318\tasync function runGenerationLoop(job_id: string): Promise<void> {\n319\t  const job = jobs.get(job_id);\n320\t  if (!job) return;\n321\t\n322\t  job.status = \"running\";\n323\t  const startTime = Date.now();\n324\t\n325\t  const { config } = job;\n326\t  const startDate = new Date(config.start);\n327\t  const endDate = new Date(config.end);\n328\t\n329\t  // Use a deterministic seed derived from the job_id's first chars\n330\t  const seed =\n331\t    job_id\n332\t      .replace(/-/g, \"\")\n333\t      .slice(0, 8)\n334\t      .split(\"\")\n335\t      .reduce((acc, c) => acc + c.charCodeAt(0), 0) | 0;\n336\t  const rand = mulberry32(seed);\n337\t\n338\t  const userPool = buildUserPool(config, rand);\n339\t\n340\t  let offset = 0;\n341\t\n342\t  while (offset < config.total) {\n343\t    if (job.cancelled) {\n344\t      job.status = \"cancelled\";\n345\t      job.elapsed_ms = Date.now() - startTime;\n346\t      return;\n347\t    }\n348\t\n349\t    const batchSize = Math.min(BATCH_SIZE, config.total - offset);\n350\t    const events = generateBatchEvents(\n351\t      config,\n352\t      userPool,\n353\t      startDate,\n354\t      endDate,\n355\t      rand,\n356\t      batchSize,\n357\t    );\n358\t\n359\t    await clickhouse.insert({\n360\t      table: \"events\",\n361\t      values: events.map((e) => ({\n362\t        ...e,\n363\t        timestamp: toClickHouseTs(e.timestamp),\n364\t      })),\n365\t      format: \"JSONEachRow\",\n366\t    });\n367\t\n368\t    offset += batchSize;\n369\t    job.inserted = offset;\n370\t\n371\t    const elapsed = Date.now() - startTime;\n372\t    job.elapsed_ms = elapsed;\n373\t    job.throughput = elapsed > 0 ? Math.round((offset / elapsed) * 1000) : 0;\n374\t    const remaining = config.total - offset;\n375\t    job.eta_seconds =\n376\t      job.throughput > 0 ? Math.round(remaining / job.throughput) : 0;\n377\t  }\n378\t\n379\t  // Insert identity mappings after all event batches are complete\n380\t  if (!job.cancelled) {\n381\t    const mappings: IdentityMapping[] = buildIdentityMappings(userPool);\n382\t    if (mappings.length > 0) {\n383\t      await clickhouse.insert({\n384\t        table: \"identity_mappings\",\n385\t        values: mappings,\n386\t        format: \"JSONEachRow\",\n387\t      });\n388\t    }\n389\t\n390\t    job.elapsed_ms = Date.now() - startTime;\n391\t    job.throughput =\n392\t      job.elapsed_ms > 0\n393\t        ? Math.round((config.total / job.elapsed_ms) * 1000)\n394\t        : 0;\n395\t    job.eta_seconds = 0;\n396\t    job.status = \"complete\";\n397\t  }\n398\t}\n399\t\n400\t// ─── Public API ───────────────────────────────────────────────────────────────\n401\t\n402\t/**\n403\t * Validates config, creates a job in the in-memory store, kicks off the async\n404\t * generation loop (fire-and-forget), and returns the job_id synchronously.\n405\t *\n406\t * Throws synchronously if the config is invalid.\n407\t */\n408\texport function startGenerationJob(input: JobConfigInput): string {\n409\t  const config = applyDefaults(input);\n410\t  validateConfig(config);\n411\t\n412\t  const job_id = crypto.randomUUID();\n413\t  const job: JobState = {\n414\t    job_id,\n415\t    status: \"queued\",\n416\t    inserted: 0,\n417\t    total: config.total,\n418\t    throughput: 0,\n419\t    eta_seconds: 0,\n420\t    elapsed_ms: 0,\n421\t    config,\n422\t    cancelled: false,\n423\t    created_at: Date.now(),\n424\t  };\n425\t  jobs.set(job_id, job);\n426\t\n427\t  runGenerationLoop(job_id).catch((err: unknown) => {\n428\t    const j = jobs.get(job_id);\n429\t    if (j && j.status !== \"cancelled\") {\n430\t      j.status = \"failed\";\n431\t      j.error = err instanceof Error ? err.message : String(err);\n432\t    }\n433\t  });\n434\t\n435\t  return job_id;\n436\t}\n437\t\n438\t/** Returns the current JobState for the given job_id, or undefined if not found. */\n439\texport function getJob(id: string): JobState | undefined {\n440\t  return jobs.get(id);\n441\t}\n442\t\n443\t/**\n444\t * Sets the cancellation flag on a job. The generation loop checks this flag\n445\t * between batches and will stop after the current batch completes.\n446\t *\n447\t * Returns true if the job was found, false otherwise.\n448\t */\n449\texport function cancelJob(id: string): boolean {\n450\t  const job = jobs.get(id);\n451\t  if (!job) return false;\n452\t  job.cancelled = true;\n453\t  return true;\n454\t}\n455\t\n456\t/** Returns all jobs in the in-memory store. */\n457\texport function listJobs(): JobState[] {\n458\t  return [...jobs.values()];\n459\t}\n460\t\n461\t// ─── Testing helpers ──────────────────────────────────────────────────────────\n462\t\n463\t/** Clears all jobs from the in-memory store. For use in unit tests only. */\n464\texport function _clearJobs(): void {\n465\t  jobs.clear();\n466\t}\n467\t"}]},"parent_tool_use_id":null,"session_id":"6d542617-c6aa-4344-aa60-030d9b2a541c","uuid":"82cdc021-5e92-40b2-83ca-1f60b88a2419","timestamp":"2026-04-15T18:37:21.861Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/lib/generator.ts","content":"import { clickhouse } from \"@/lib/clickhouse\";\nimport {\n  buildIdentityMappings,\n  type GeneratedEvent,\n  type GeneratedUser,\n  type IdentityMapping,\n  mulberry32,\n} from \"@/lib/seed\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport type JobStatus =\n  | \"queued\"\n  | \"running\"\n  | \"complete\"\n  | \"failed\"\n  | \"cancelled\";\n\nexport type NumericVariance = \"low\" | \"medium\" | \"high\";\n\nexport interface EventTypeWeight {\n  name: string;\n  weight: number;\n}\n\nexport interface JobConfig {\n  total: number;\n  users: number;\n  start: string;\n  end: string;\n  event_types: EventTypeWeight[];\n  identity_resolution: boolean;\n  anonymous_ratio: number;\n  numeric_variance: NumericVariance;\n}\n\nexport interface JobConfigInput {\n  total?: number;\n  users?: number;\n  start?: string;\n  end?: string;\n  event_types?: EventTypeWeight[];\n  identity_resolution?: boolean;\n  anonymous_ratio?: number;\n  numeric_variance?: string;\n}\n\nexport interface JobState {\n  job_id: string;\n  status: JobStatus;\n  inserted: number;\n  total: number;\n  throughput: number;\n  eta_seconds: number;\n  elapsed_ms: number;\n  error?: string;\n  config: JobConfig;\n  cancelled: boolean;\n  created_at: number;\n}\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst BATCH_SIZE = 10_000;\n\nconst DEFAULT_EVENT_TYPES: EventTypeWeight[] = [\n  { name: \"Page Viewed\", weight: 0.4 },\n  { name: \"Button Clicked\", weight: 0.15 },\n  { name: \"Signup Completed\", weight: 0.12 },\n  { name: \"Purchase Completed\", weight: 0.13 },\n  { name: \"Subscription Renewed\", weight: 0.12 },\n  { name: \"Support Ticket Opened\", weight: 0.08 },\n];\n\nconst PAGES = [\n  \"/home\",\n  \"/pricing\",\n  \"/features\",\n  \"/about\",\n  \"/signup\",\n  \"/login\",\n  \"/dashboard\",\n];\nconst PLANS = [\"free\", \"starter\", \"pro\", \"enterprise\"];\nconst CURRENCIES = [\"USD\", \"EUR\", \"GBP\", \"BTC\"];\nconst SOURCES = [\"organic\", \"paid\", \"referral\", \"email\", \"social\"];\nconst BUTTON_NAMES = [\n  \"Get Started\",\n  \"Sign Up\",\n  \"Learn More\",\n  \"Buy Now\",\n  \"Upgrade\",\n  \"Try Free\",\n];\n\n// ─── In-memory job store ──────────────────────────────────────────────────────\n\nconst jobs = new Map<string, JobState>();\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction pickFrom<T>(arr: readonly T[], rand: () => number): T {\n  return arr[Math.floor(rand() * arr.length)];\n}\n\nfunction buildCumulative(weights: readonly number[]): number[] {\n  const cum: number[] = [];\n  let total = 0;\n  for (const w of weights) {\n    total += w;\n    cum.push(total);\n  }\n  return cum;\n}\n\nfunction weightedIndex(cumulative: number[], rand: () => number): number {\n  const r = rand() * cumulative[cumulative.length - 1];\n  for (let i = 0; i < cumulative.length; i++) {\n    if (r <= cumulative[i]) return i;\n  }\n  return cumulative.length - 1;\n}\n\nfunction getVarianceMultiplier(variance: NumericVariance): number {\n  switch (variance) {\n    case \"low\":\n      return 0.2;\n    case \"medium\":\n      return 1.0;\n    case \"high\":\n      return 3.0;\n  }\n}\n\nfunction generateProperties(\n  eventName: string,\n  rand: () => number,\n  variance: NumericVariance,\n): Record<string, unknown> {\n  const vm = getVarianceMultiplier(variance);\n  switch (eventName) {\n    case \"Page Viewed\":\n      return { page: pickFrom(PAGES, rand) };\n    case \"Button Clicked\":\n      return { button_name: pickFrom(BUTTON_NAMES, rand) };\n    case \"Signup Completed\":\n      return {\n        plan: pickFrom(PLANS, rand),\n        source: pickFrom(SOURCES, rand),\n      };\n    case \"Purchase Completed\":\n      return {\n        amount: Math.round(rand() * 500 * vm * 100) / 100,\n        currency: pickFrom(CURRENCIES, rand),\n        plan: pickFrom(PLANS, rand),\n      };\n    case \"Subscription Renewed\":\n      return {\n        amount: Math.round(rand() * 500 * vm * 100) / 100,\n        currency: pickFrom(CURRENCIES, rand),\n        plan: pickFrom(PLANS, rand),\n      };\n    case \"Support Ticket Opened\":\n      return {\n        ticket_count: Math.floor(rand() * 10 * vm) + 1,\n        source: pickFrom(SOURCES, rand),\n      };\n    default:\n      return {};\n  }\n}\n\n/** Converts an ISO 8601 timestamp to the ClickHouse DateTime64 format. */\nfunction toClickHouseTs(iso: string): string {\n  return iso.replace(\"T\", \" \").replace(\"Z\", \"\");\n}\n\n// ─── Config application and validation ───────────────────────────────────────\n\nfunction applyDefaults(input: JobConfigInput): JobConfig {\n  const now = new Date();\n  const thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);\n\n  const total = input.total ?? 10_000;\n  const users = input.users ?? 100;\n  const start = input.start ?? thirtyDaysAgo.toISOString().slice(0, 10);\n  const end = input.end ?? now.toISOString().slice(0, 10);\n  const event_types =\n    input.event_types && input.event_types.length > 0\n      ? input.event_types\n      : DEFAULT_EVENT_TYPES;\n  const identity_resolution = input.identity_resolution ?? true;\n  const anonymous_ratio = input.anonymous_ratio ?? 30;\n  const numeric_variance: NumericVariance =\n    input.numeric_variance === \"low\" ||\n    input.numeric_variance === \"high\" ||\n    input.numeric_variance === \"medium\"\n      ? input.numeric_variance\n      : \"medium\";\n\n  return {\n    total,\n    users,\n    start,\n    end,\n    event_types,\n    identity_resolution,\n    anonymous_ratio,\n    numeric_variance,\n  };\n}\n\nfunction validateConfig(config: JobConfig): void {\n  if (!Number.isInteger(config.total) || config.total < 1) {\n    throw new Error(\"total must be an integer >= 1.\");\n  }\n  if (config.total > 1_000_000) {\n    throw new Error(\"total must be <= 1,000,000.\");\n  }\n  if (!Number.isInteger(config.users) || config.users < 1) {\n    throw new Error(\"users must be an integer >= 1.\");\n  }\n  const startMs = new Date(config.start).getTime();\n  const endMs = new Date(config.end).getTime();\n  if (Number.isNaN(startMs)) {\n    throw new Error(\"start must be a valid date string.\");\n  }\n  if (Number.isNaN(endMs)) {\n    throw new Error(\"end must be a valid date string.\");\n  }\n  if (endMs <= startMs) {\n    throw new Error(\"end must be after start.\");\n  }\n}\n\n// ─── User pool builder ────────────────────────────────────────────────────────\n\nfunction buildUserPool(config: JobConfig, rand: () => number): GeneratedUser[] {\n  const users: GeneratedUser[] = [];\n\n  const anonCount = config.identity_resolution\n    ? Math.round(config.users * (config.anonymous_ratio / 100))\n    : config.users;\n  const resolvedCount = config.users - anonCount;\n\n  for (let i = 0; i < resolvedCount; i++) {\n    users.push({\n      type: \"fully-resolved\",\n      userId: `gen-user-${i}@example.com`,\n      deviceIds: [`gen-device-${i}`],\n    });\n  }\n\n  for (let i = 0; i < anonCount; i++) {\n    users.push({\n      type: \"anonymous\",\n      userId: null,\n      deviceIds: [`gen-anon-${i}`],\n    });\n  }\n\n  // Shuffle so anonymous users aren't always last (affects power-law weighting)\n  for (let i = users.length - 1; i > 0; i--) {\n    const j = Math.floor(rand() * (i + 1));\n    [users[i], users[j]] = [users[j], users[i]];\n  }\n\n  return users;\n}\n\n// ─── Batch event generation ───────────────────────────────────────────────────\n\nexport function generateBatchEvents(\n  config: JobConfig,\n  users: GeneratedUser[],\n  startDate: Date,\n  endDate: Date,\n  rand: () => number,\n  batchSize: number,\n): GeneratedEvent[] {\n  const eventCumulative = buildCumulative(\n    config.event_types.map((et) => et.weight),\n  );\n  const userWeights = users.map((_, i) => 1 / (i + 1) ** 1.5);\n  const userCumulative = buildCumulative(userWeights);\n\n  const startMs = startDate.getTime();\n  const rangeMs = endDate.getTime() - startMs;\n\n  const events: GeneratedEvent[] = [];\n\n  for (let i = 0; i < batchSize; i++) {\n    const user = users[weightedIndex(userCumulative, rand)];\n    const eventTypeIdx = weightedIndex(eventCumulative, rand);\n    const eventName = config.event_types[eventTypeIdx].name;\n\n    const deviceId = pickFrom(user.deviceIds, rand);\n    const tsMs = startMs + Math.floor(rand() * rangeMs);\n    const timestamp = new Date(tsMs).toISOString();\n    const properties = JSON.stringify(\n      generateProperties(eventName, rand, config.numeric_variance),\n    );\n\n    events.push({\n      event_name: eventName,\n      timestamp,\n      device_id: deviceId,\n      user_id: user.userId,\n      properties,\n    });\n  }\n\n  return events;\n}\n\n// ─── Generation loop ──────────────────────────────────────────────────────────\n\nasync function runGenerationLoop(job_id: string): Promise<void> {\n  const job = jobs.get(job_id);\n  if (!job) return;\n\n  job.status = \"running\";\n  const startTime = Date.now();\n\n  const { config } = job;\n  const startDate = new Date(config.start);\n  const endDate = new Date(config.end);\n\n  // Use a deterministic seed derived from the job_id's first chars\n  const seed =\n    job_id\n      .replace(/-/g, \"\")\n      .slice(0, 8)\n      .split(\"\")\n      .reduce((acc, c) => acc + c.charCodeAt(0), 0) | 0;\n  const rand = mulberry32(seed);\n\n  const userPool = buildUserPool(config, rand);\n\n  let offset = 0;\n\n  while (offset < config.total) {\n    if (job.cancelled) {\n      job.status = \"cancelled\";\n      job.elapsed_ms = Date.now() - startTime;\n      return;\n    }\n\n    const batchSize = Math.min(BATCH_SIZE, config.total - offset);\n    const events = generateBatchEvents(\n      config,\n      userPool,\n      startDate,\n      endDate,\n      rand,\n      batchSize,\n    );\n\n    await clickhouse.insert({\n      table: \"events\",\n      values: events.map((e) => ({\n        ...e,\n        timestamp: toClickHouseTs(e.timestamp),\n      })),\n      format: \"JSONEachRow\",\n    });\n\n    offset += batchSize;\n    job.inserted = offset;\n\n    const elapsed = Date.now() - startTime;\n    job.elapsed_ms = elapsed;\n    job.throughput = elapsed > 0 ? Math.round((offset / elapsed) * 1000) : 0;\n    const remaining = config.total - offset;\n    job.eta_seconds =\n      job.throughput > 0 ? Math.round(remaining / job.throughput) : 0;\n  }\n\n  // Insert identity mappings after all event batches are complete\n  if (!job.cancelled) {\n    const mappings: IdentityMapping[] = buildIdentityMappings(userPool);\n    if (mappings.length > 0) {\n      await clickhouse.insert({\n        table: \"identity_mappings\",\n        values: mappings,\n        format: \"JSONEachRow\",\n      });\n    }\n\n    job.elapsed_ms = Date.now() - startTime;\n    job.throughput =\n      job.elapsed_ms > 0\n        ? Math.round((config.total / job.elapsed_ms) * 1000)\n        : 0;\n    job.eta_seconds = 0;\n    job.status = \"complete\";\n  }\n}\n\n// ─── Public API ───────────────────────────────────────────────────────────────\n\n/**\n * Validates config, creates a job in the in-memory store, kicks off the async\n * generation loop (fire-and-forget), and returns the job_id synchronously.\n *\n * Throws synchronously if the config is invalid.\n */\nexport function startGenerationJob(input: JobConfigInput): string {\n  const config = applyDefaults(input);\n  validateConfig(config);\n\n  const job_id = crypto.randomUUID();\n  const job: JobState = {\n    job_id,\n    status: \"queued\",\n    inserted: 0,\n    total: config.total,\n    throughput: 0,\n    eta_seconds: 0,\n    elapsed_ms: 0,\n    config,\n    cancelled: false,\n    created_at: Date.now(),\n  };\n  jobs.set(job_id, job);\n\n  runGenerationLoop(job_id).catch((err: unknown) => {\n    const j = jobs.get(job_id);\n    if (j && j.status !== \"cancelled\") {\n      j.status = \"failed\";\n      j.error = err instanceof Error ? err.message : String(err);\n    }\n  });\n\n  return job_id;\n}\n\n/** Returns the current JobState for the given job_id, or undefined if not found. */\nexport function getJob(id: string): JobState | undefined {\n  return jobs.get(id);\n}\n\n/**\n * Sets the cancellation flag on a job. The generation loop checks this flag\n * between batches and will stop after the current batch completes.\n *\n * Returns true if the job was found, false otherwise.\n */\nexport function cancelJob(id: string): boolean {\n  const job = jobs.get(id);\n  if (!job) return false;\n  job.cancelled = true;\n  return true;\n}\n\n/** Returns all jobs in the in-memory store. */\nexport function listJobs(): JobState[] {\n  return [...jobs.values()];\n}\n\n// ─── Testing helpers ──────────────────────────────────────────────────────────\n\n/** Clears all jobs from the in-memory store. For use in unit tests only. */\nexport function _clearJobs(): void {\n  jobs.clear();\n}\n","numLines":467,"startLine":1,"totalLines":467}}}
