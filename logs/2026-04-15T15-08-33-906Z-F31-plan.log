{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018uTZKdbRHqT8pXfuD172B4","type":"tool_result","content":"1\timport { getJob } from \"@/lib/generator\";\n2\t\n3\tconst TERMINAL_STATUSES = new Set([\"complete\", \"failed\", \"cancelled\"]);\n4\t\n5\texport async function GET(\n6\t  _request: Request,\n7\t  { params }: { params: Promise<{ job_id: string }> },\n8\t): Promise<Response> {\n9\t  const { job_id } = await params;\n10\t\n11\t  const job = getJob(job_id);\n12\t  if (!job) {\n13\t    return Response.json({ error: \"Job not found.\" }, { status: 404 });\n14\t  }\n15\t\n16\t  const encoder = new TextEncoder();\n17\t\n18\t  const stream = new ReadableStream({\n19\t    start(controller) {\n20\t      // Flush headers immediately with a keep-alive comment\n21\t      controller.enqueue(encoder.encode(\":\\n\\n\"));\n22\t\n23\t      const intervalId = setInterval(() => {\n24\t        const current = getJob(job_id);\n25\t        if (!current) {\n26\t          clearInterval(intervalId);\n27\t          controller.close();\n28\t          return;\n29\t        }\n30\t\n31\t        const payload =\n32\t          current.status === \"complete\"\n33\t            ? {\n34\t                status: current.status,\n35\t                inserted: current.inserted,\n36\t                total: current.total,\n37\t                elapsed_ms: current.elapsed_ms,\n38\t              }\n39\t            : {\n40\t                status: current.status,\n41\t                inserted: current.inserted,\n42\t                total: current.total,\n43\t                throughput: current.throughput,\n44\t                eta_seconds: current.eta_seconds,\n45\t              };\n46\t\n47\t        controller.enqueue(\n48\t          encoder.encode(`data: ${JSON.stringify(payload)}\\n\\n`),\n49\t        );\n50\t\n51\t        if (TERMINAL_STATUSES.has(current.status)) {\n52\t          clearInterval(intervalId);\n53\t          controller.close();\n54\t        }\n55\t      }, 500);\n56\t    },\n57\t  });\n58\t\n59\t  return new Response(stream, {\n60\t    headers: {\n61\t      \"Content-Type\": \"text/event-stream\",\n62\t      \"Cache-Control\": \"no-cache\",\n63\t      Connection: \"keep-alive\",\n64\t    },\n65\t  });\n66\t}\n67\t"}]},"parent_tool_use_id":null,"session_id":"6d542617-c6aa-4344-aa60-030d9b2a541c","uuid":"720a11f1-add4-4330-b91e-6ef073a6d756","timestamp":"2026-04-15T18:37:17.213Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/riccardocaranfil/bitrefill/minipanel-blank-night-2/src/app/api/generate/[job_id]/status/route.ts","content":"import { getJob } from \"@/lib/generator\";\n\nconst TERMINAL_STATUSES = new Set([\"complete\", \"failed\", \"cancelled\"]);\n\nexport async function GET(\n  _request: Request,\n  { params }: { params: Promise<{ job_id: string }> },\n): Promise<Response> {\n  const { job_id } = await params;\n\n  const job = getJob(job_id);\n  if (!job) {\n    return Response.json({ error: \"Job not found.\" }, { status: 404 });\n  }\n\n  const encoder = new TextEncoder();\n\n  const stream = new ReadableStream({\n    start(controller) {\n      // Flush headers immediately with a keep-alive comment\n      controller.enqueue(encoder.encode(\":\\n\\n\"));\n\n      const intervalId = setInterval(() => {\n        const current = getJob(job_id);\n        if (!current) {\n          clearInterval(intervalId);\n          controller.close();\n          return;\n        }\n\n        const payload =\n          current.status === \"complete\"\n            ? {\n                status: current.status,\n                inserted: current.inserted,\n                total: current.total,\n                elapsed_ms: current.elapsed_ms,\n              }\n            : {\n                status: current.status,\n                inserted: current.inserted,\n                total: current.total,\n                throughput: current.throughput,\n                eta_seconds: current.eta_seconds,\n              };\n\n        controller.enqueue(\n          encoder.encode(`data: ${JSON.stringify(payload)}\\n\\n`),\n        );\n\n        if (TERMINAL_STATUSES.has(current.status)) {\n          clearInterval(intervalId);\n          controller.close();\n        }\n      }, 500);\n    },\n  });\n\n  return new Response(stream, {\n    headers: {\n      \"Content-Type\": \"text/event-stream\",\n      \"Cache-Control\": \"no-cache\",\n      Connection: \"keep-alive\",\n    },\n  });\n}\n","numLines":67,"startLine":1,"totalLines":67}}}
