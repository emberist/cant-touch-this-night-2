t with how other integration tests in the project handle it.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":410,"cache_read_input_tokens":74979,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":410},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5cdf2567-bc16-4e11-a5aa-ef963123e5bc","uuid":"2091ee4b-e8be-4465-bdc3-190f46127710"}
